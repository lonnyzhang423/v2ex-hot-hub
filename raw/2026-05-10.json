[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10780, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2299, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 149298, "username": "inas", "url": "https://www.v2ex.com/u/inas", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/9a4a2922ece4d7a1724761c9b585aac8?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/9a4a2922ece4d7a1724761c9b585aac8?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/9a4a2922ece4d7a1724761c9b585aac8?s=73&d=retro", "created": 1448868749, "last_modified": 1712535771, "pro": 0}, "last_reply_by": "kakarotto726", "last_touched": 1778346899, "title": "大家有计划什么时候退休吗？", "url": "https://www.v2ex.com/t/1211326", "created": 1778287559, "deleted": 0, "content": "计划 45 岁攒够 100 万回老家开始退休生活，现在还差 130 万", "content_rendered": "计划 45 岁攒够 100 万回老家开始退休生活，现在还差 130 万", "last_modified": 1778294449, "replies": 156, "id": 1211326}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23247, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3664, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 646576, "username": "JShen", "url": "https://www.v2ex.com/u/JShen", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/74d6dff540e6ac840e99075d1bc571dd?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/74d6dff540e6ac840e99075d1bc571dd?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/74d6dff540e6ac840e99075d1bc571dd?s=73&d=retro", "created": 1693555994, "last_modified": 1761889509, "pro": 0}, "last_reply_by": "Rwing", "last_touched": 1778345617, "title": "兄弟们你们加薪最低的比例是多少，有没有像我一样的小丑", "url": "https://www.v2ex.com/t/1211380", "created": 1778295432, "deleted": 0, "content": "绩优，加薪 4%", "content_rendered": "<p>绩优，加薪 4%</p>\n", "last_modified": 1778304643, "replies": 114, "id": 1211380}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23247, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3664, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 750245, "username": "cslingjun", "url": "https://www.v2ex.com/u/cslingjun", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/3631613f71035e42b6f12e36cd9c61b0?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/3631613f71035e42b6f12e36cd9c61b0?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/3631613f71035e42b6f12e36cd9c61b0?s=73&d=retro", "created": 1748339923, "last_modified": 1748339923, "pro": 0}, "last_reply_by": "stella", "last_touched": 1778346177, "title": "26 岁， 3 次考公失败、0 工作经验，现在年轻人的处境确实不容易", "url": "https://www.v2ex.com/t/1211458", "created": 1778307795, "deleted": 0, "content": "说下我外甥吧，00 年的。\r\n\r\n当年高考复读了两年，最后上了本科线。那时候年轻也比较叛逆，不太听家里人的建议，执意跑得远远的，去了新疆那边读了个二本，学的是网络相关专业。\r\n\r\n24 年毕业回来后，应该也是知道现在行情不好，就开始考公了。毕竟还有个应届生身份，好像大四的时候就已经开始考了。\r\n\r\n结果这一考，就考了 3 次。今年还是没上岸。\r\n\r\n今年成绩出来后，本来五一都计划好来我这边玩的，后来也取消了。我都不敢想象他现在压力有多大。\r\n\r\n现在也 26 岁了，还是 0 工作经验。相当于这么多年一直都在读书，后面又花了两年时间考公。专业估计也差不多荒废了，毕竟只是个普通二本。\r\n\r\n他们老家是小镇上的，家里条件在镇上应该算中上吧。父母已经在市里买了房，不过还在镇上工作。他爸好像还是 67 年的，记得他爸 50 岁的时候就说想抱孙子了，那时候他确实也还小。\r\n\r\n结果这一晃，他爸也快 60 了。\r\n\r\n所以有时候我也会突然庆幸自己，毕竟没有生活在这个时代。早了 10 多年毕业，还赶上了互联网的末班车。\r\n\r\n真的是：\r\n\r\n时代的一粒沙，落在个人身上，就是一座山。", "content_rendered": "<p>说下我外甥吧，00 年的。</p>\n<p>当年高考复读了两年，最后上了本科线。那时候年轻也比较叛逆，不太听家里人的建议，执意跑得远远的，去了新疆那边读了个二本，学的是网络相关专业。</p>\n<p>24 年毕业回来后，应该也是知道现在行情不好，就开始考公了。毕竟还有个应届生身份，好像大四的时候就已经开始考了。</p>\n<p>结果这一考，就考了 3 次。今年还是没上岸。</p>\n<p>今年成绩出来后，本来五一都计划好来我这边玩的，后来也取消了。我都不敢想象他现在压力有多大。</p>\n<p>现在也 26 岁了，还是 0 工作经验。相当于这么多年一直都在读书，后面又花了两年时间考公。专业估计也差不多荒废了，毕竟只是个普通二本。</p>\n<p>他们老家是小镇上的，家里条件在镇上应该算中上吧。父母已经在市里买了房，不过还在镇上工作。他爸好像还是 67 年的，记得他爸 50 岁的时候就说想抱孙子了，那时候他确实也还小。</p>\n<p>结果这一晃，他爸也快 60 了。</p>\n<p>所以有时候我也会突然庆幸自己，毕竟没有生活在这个时代。早了 10 多年毕业，还赶上了互联网的末班车。</p>\n<p>真的是：</p>\n<p>时代的一粒沙，落在个人身上，就是一座山。</p>\n", "last_modified": 1778307795, "replies": 112, "id": 1211458}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/5229/2e0c/1192_large.png?m=1768188365", "name": "stock", "avatar_normal": "https://cdn.v2ex.com/navatar/5229/2e0c/1192_normal.png?m=1768188365", "title": "股票", "url": "https://www.v2ex.com/go/stock", "topics": 50, "footer": "", "header": "📈 股票投资交流节点\r\n- 本节点仅供讨论与经验分享，不构成任何投资建议。\r\n- 市场有风险，投资需谨慎。\r\n- 欢迎理性交流、独立思考，愿我们在长期学习中，稳步走向财富自由。", "title_alternative": "股票", "avatar_mini": "https://cdn.v2ex.com/navatar/5229/2e0c/1192_mini.png?m=1768188365", "stars": 85, "founder_id": 266787, "aliases": [], "root": false, "id": 1192, "parent_node_name": null}, "member": {"id": 439711, "username": "cmdOptionKana", "url": "https://www.v2ex.com/u/cmdOptionKana", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/07c9/d6c7/439711_mini.png?m=1774663400", "avatar_normal": "https://cdn.v2ex.com/avatar/07c9/d6c7/439711_normal.png?m=1774663400", "avatar_large": "https://cdn.v2ex.com/avatar/07c9/d6c7/439711_large.png?m=1774663400", "created": 1567591320, "last_modified": 1774663400, "pro": 0}, "last_reply_by": "han0101", "last_touched": 1778347801, "title": "无法接受自己的错误", "url": "https://www.v2ex.com/t/1211383", "created": 1778295822, "deleted": 0, "content": "最近看到一个出版社改错别字的视频，非常有趣。\r\n最有趣的地方在于人们（包括我自己）发现自己错了的时候的反应。\r\n\r\n先看错别字，以下词语里有错别字：\r\n\r\n披萨 \r\n被弄懵了 \r\n不知所踪 \r\n睡眼朦胧 \r\n山青水秀 \r\n\r\n\r\n修改后，以下用字正确：\r\n\r\n比萨\r\n被弄蒙了\r\n不知所终\r\n睡眼蒙眬\r\n山清水秀\r\n\r\n\r\n这个视频不得了，弹幕一大堆问号，评论区争论了几千条，其中很多人无法承认错误，能看出来他们的情绪与抵抗。\r\n其实这种现象在炒股论坛也很常见，例如雪球，可以看到很多人不肯承认错误、不肯接受事实。\r\n字写错了，问题不大，但投资的认知错了，是真的会亏钱。因此这种现象是非常值得重视的，学会修正自己的认知，百利而无一害。\r\n\r\n而想要修正自己的认知，第一步也是最难的一步，就是要愿意。这说来简单，但多数人意识不到这个问题，意识到了也一千一万个不愿意。想找理由找借口让自己逃离，不去面对错误，是非常容易的，很多人也是这样做的，而且会说 “我不是，我没有，从未发生过，不知道你在说什么！”", "content_rendered": "最近看到一个出版社改错别字的视频，非常有趣。<br />最有趣的地方在于人们（包括我自己）发现自己错了的时候的反应。<br /><br />先看错别字，以下词语里有错别字：<br /><br />披萨 <br />被弄懵了 <br />不知所踪 <br />睡眼朦胧 <br />山青水秀 <br /><br /><br />修改后，以下用字正确：<br /><br />比萨<br />被弄蒙了<br />不知所终<br />睡眼蒙眬<br />山清水秀<br /><br /><br />这个视频不得了，弹幕一大堆问号，评论区争论了几千条，其中很多人无法承认错误，能看出来他们的情绪与抵抗。<br />其实这种现象在炒股论坛也很常见，例如雪球，可以看到很多人不肯承认错误、不肯接受事实。<br />字写错了，问题不大，但投资的认知错了，是真的会亏钱。因此这种现象是非常值得重视的，学会修正自己的认知，百利而无一害。<br /><br />而想要修正自己的认知，第一步也是最难的一步，就是要愿意。这说来简单，但多数人意识不到这个问题，意识到了也一千一万个不愿意。想找理由找借口让自己逃离，不去面对错误，是非常容易的，很多人也是这样做的，而且会说 “我不是，我没有，从未发生过，不知道你在说什么！”", "last_modified": 1778295822, "replies": 90, "id": 1211383}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23247, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3664, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 640012, "username": "dreamdragon", "url": "https://www.v2ex.com/u/dreamdragon", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/48dc37b4c556122223933138ca1c9e78?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/48dc37b4c556122223933138ca1c9e78?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/48dc37b4c556122223933138ca1c9e78?s=73&d=retro", "created": 1690250077, "last_modified": 1690250077, "pro": 0}, "last_reply_by": "leena", "last_touched": 1778345038, "title": "五一期间认识的一个初中老师退休工资一个月 9000+，想去当老师了", "url": "https://www.v2ex.com/t/1211440", "created": 1778305530, "deleted": 0, "content": "", "content_rendered": "", "last_modified": 1778305530, "replies": 80, "id": 1211440}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_large.png?m=1630576706", "name": "invest", "avatar_normal": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_normal.png?m=1630576706", "title": "投资", "url": "https://www.v2ex.com/go/invest", "topics": 3508, "footer": "", "header": "Can you make money with money?", "title_alternative": "Invest", "avatar_mini": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_mini.png?m=1630576706", "stars": 4375, "founder_id": 0, "aliases": [], "root": false, "id": 171, "parent_node_name": "money"}, "member": {"id": 363963, "username": "shilianmlxg", "url": "https://www.v2ex.com/u/shilianmlxg", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/05ba/0783/363963_mini.png?m=1715864297", "avatar_normal": "https://cdn.v2ex.com/avatar/05ba/0783/363963_normal.png?m=1715864297", "avatar_large": "https://cdn.v2ex.com/avatar/05ba/0783/363963_large.png?m=1715864297", "avatar_xlarge": "https://cdn.v2ex.com/avatar/05ba/0783/363963_xlarge.png?m=1715864297", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/05ba/0783/363963_xxlarge.png?m=1715864297", "created": 1542527006, "last_modified": 1715864297, "pro": 0}, "last_reply_by": "Greatshu", "last_touched": 1778343048, "title": "老哥们同意这段话吗?在一个家族中第一个接触金融、股票、基金、债券、期货的人，看似是不务正业，实则是为整个家族完成了一场认知的提升", "url": "https://www.v2ex.com/t/1211422", "created": 1778300703, "deleted": 0, "content": "![]( https://i.imgur.com/EUVllDX.jpeg) \r\n\r\n原文：\r\n在一个家族中第一个接触金融、股票、基金、债券、期货的人，看似是不务正业，实则是为整个家族完成了一场认知的提升，\r\n这个不是赌博，更不是投机，而是选择成为资本流动的参与者，而非旁观者。\r\n劳动能让你存活，只有资本才能让你自由。\r\n可悲的是，很多人经常恐惧资本的风险，却坦然接受了通货膨胀和货币贬值以及意外事故和大病返贫的更大风险，多少人宁愿承受确定性的贫穷，也不敢面对不确定性的可能的财富。\r\n如果你是家族中第一个敢吃螃蟹的人，那么你的孤独和试探实则是整个家族财务史上的转折点，是打破传统致富模式的尝试。\r\n你建立的不只是一笔投资，而是一种心理遗传，是对复利的理解，是对风险的度量。\r\n这条路的价值不在于你第一个账户的数字是多少，而在于从此以后家族后代面对财富时眼里多了一种选择。", "content_rendered": "<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/EUVllDX.jpeg\"/> </p>\n<p>原文：\n在一个家族中第一个接触金融、股票、基金、债券、期货的人，看似是不务正业，实则是为整个家族完成了一场认知的提升，\n这个不是赌博，更不是投机，而是选择成为资本流动的参与者，而非旁观者。\n劳动能让你存活，只有资本才能让你自由。\n可悲的是，很多人经常恐惧资本的风险，却坦然接受了通货膨胀和货币贬值以及意外事故和大病返贫的更大风险，多少人宁愿承受确定性的贫穷，也不敢面对不确定性的可能的财富。\n如果你是家族中第一个敢吃螃蟹的人，那么你的孤独和试探实则是整个家族财务史上的转折点，是打破传统致富模式的尝试。\n你建立的不只是一笔投资，而是一种心理遗传，是对复利的理解，是对风险的度量。\n这条路的价值不在于你第一个账户的数字是多少，而在于从此以后家族后代面对财富时眼里多了一种选择。</p>\n", "last_modified": 1778300703, "replies": 74, "id": 1211422}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_large.png?m=1630576706", "name": "invest", "avatar_normal": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_normal.png?m=1630576706", "title": "投资", "url": "https://www.v2ex.com/go/invest", "topics": 3508, "footer": "", "header": "Can you make money with money?", "title_alternative": "Invest", "avatar_mini": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_mini.png?m=1630576706", "stars": 4375, "founder_id": 0, "aliases": [], "root": false, "id": 171, "parent_node_name": "money"}, "member": {"id": 328870, "username": "sddi", "url": "https://www.v2ex.com/u/sddi", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/99fa0ef155b8e3d9a8e44a3e1d277af7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/99fa0ef155b8e3d9a8e44a3e1d277af7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/99fa0ef155b8e3d9a8e44a3e1d277af7?s=73&d=retro", "created": 1531452288, "last_modified": 1749435404, "pro": 0}, "last_reply_by": "zhouyin", "last_touched": 1778333742, "title": "这几天的美股，是不是让大家萌发了不上班的念头", "url": "https://www.v2ex.com/t/1211355", "created": 1778291630, "deleted": 0, "content": "这阵子，美股一顿涨，多少 v 友有不上班的念头了，确实跟之前 v 友说的似的，每次美股下跌就是给你加仓、定投的机会呀。v 友诚不欺我，感谢感谢。", "content_rendered": "这阵子，美股一顿涨，多少 v 友有不上班的念头了，确实跟之前 v 友说的似的，每次美股下跌就是给你加仓、定投的机会呀。v 友诚不欺我，感谢感谢。", "last_modified": 1778291630, "replies": 69, "id": 1211355}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23247, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3664, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 433128, "username": "adjz057", "url": "https://www.v2ex.com/u/adjz057", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/1c5dad436e0a8a0058fff9d87181caf7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/1c5dad436e0a8a0058fff9d87181caf7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/1c5dad436e0a8a0058fff9d87181caf7?s=73&d=retro", "created": 1564542065, "last_modified": 1638514887, "pro": 0}, "last_reply_by": "lovelyxiaod", "last_touched": 1778319062, "title": "老东家不发工资，投诉了社保局，要不要去签字", "url": "https://www.v2ex.com/t/1211350", "created": 1778291183, "deleted": 0, "content": "之前的公司欠薪。投诉了社保、公积金。一审二审都打完，现在在走强制执行了。今天公积金中心打电话让我过去补缴公积金，公司已经把公积金补了。社保局之前打电话说不配合，让我过去签字移交稽核科，一直拖着没去。公积金我确定要去，但是社保局不知道去不去啊，五个月的社保，最低基数，让豆包算了一下，大概要补 2000+，退休后每个月能多拿 70-80 。大哥们出出主意啊！！", "content_rendered": "之前的公司欠薪。投诉了社保、公积金。一审二审都打完，现在在走强制执行了。今天公积金中心打电话让我过去补缴公积金，公司已经把公积金补了。社保局之前打电话说不配合，让我过去签字移交稽核科，一直拖着没去。公积金我确定要去，但是社保局不知道去不去啊，五个月的社保，最低基数，让豆包算了一下，大概要补 2000+，退休后每个月能多拿 70-80 。大哥们出出主意啊！！", "last_modified": 1778294605, "replies": 51, "id": 1211350}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/735b/90b4/67_large.png?m=1706750053", "name": "taste", "avatar_normal": "https://cdn.v2ex.com/navatar/735b/90b4/67_normal.png?m=1706750053", "title": "美酒与美食", "url": "https://www.v2ex.com/go/taste", "topics": 861, "footer": "", "header": "关于那些好喝和好吃的", "title_alternative": "Taste", "avatar_mini": "https://cdn.v2ex.com/navatar/735b/90b4/67_mini.png?m=1706750053", "stars": 831, "founder_id": 0, "aliases": [], "root": false, "id": 67, "parent_node_name": "life"}, "member": {"id": 725786, "username": "shalou8023", "url": "https://www.v2ex.com/u/shalou8023", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/fd03f18aa753b50562ab5f3ebb750b70?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/fd03f18aa753b50562ab5f3ebb750b70?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/fd03f18aa753b50562ab5f3ebb750b70?s=73&d=retro", "created": 1734423198, "last_modified": 1777278278, "pro": 0}, "last_reply_by": "koor", "last_touched": 1778343259, "title": "钟薛高破产清算了，我都没吃过一根钟薛高。。", "url": "htt