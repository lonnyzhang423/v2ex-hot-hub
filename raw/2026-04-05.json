38/1_xxlarge.png?m=1775264653", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/c4ca/4238/1_xxxlarge.png?m=1775264653", "created": 1272203146, "last_modified": 1775264653, "pro": 1775324663}, "last_reply_by": "cskeleton", "last_touched": 1775294176, "title": "使用本地模型 Gemma4 来驱动 OpenClaw", "url": "https://www.v2ex.com/t/1203472", "created": 1775264732, "deleted": 0, "content": "替换下面指令中的 model ID 为你本地 Ollama 里启动的版本。\r\n\r\n```\r\nopenclaw onboard --non-interactive \\\r\n  --auth-choice custom-api-key \\\r\n  --custom-base-url \"http://127.0.0.1:11434/v1\" \\\r\n  --custom-model-id \"gemma4:31b-it-q4_K_M\" \\\r\n  --custom-api-key \"ollama\" \\\r\n  --secret-input-mode plaintext \\\r\n  --custom-compatibility openai \\\r\n  --accept-risk\r\n```", "content_rendered": "<p>替换下面指令中的 model ID 为你本地 Ollama 里启动的版本。</p>\n<pre><code>openclaw onboard --non-interactive \\\n  --auth-choice custom-api-key \\\n  --custom-base-url \"http://127.0.0.1:11434/v1\" \\\n  --custom-model-id \"gemma4:31b-it-q4_K_M\" \\\n  --custom-api-key \"ollama\" \\\n  --secret-input-mode plaintext \\\n  --custom-compatibility openai \\\n  --accept-risk\n</code></pre>\n", "last_modified": 1775264732, "replies": 23, "id": 1203472}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c8ed/21db/722_large.png?m=1751736797", "name": "localllm", "avatar_normal": "https://cdn.v2ex.com/navatar/c8ed/21db/722_normal.png?m=1751736797", "title": "Local LLM", "url": "https://www.v2ex.com/go/localllm", "topics": 246, "footer": "", "header": "这个节点讨论在本地电脑或者局域网里运行 LLM（大语言模型）的技术细节", "title_alternative": "Local LLM", "avatar_mini": "https://cdn.v2ex.com/navatar/c8ed/21db/722_mini.png?m=1751736797", "stars": 271, "founder_id": 0, "aliases": [], "root": false, "id": 722, "parent_node_name": "geek"}, "member": {"id": 784404, "username": "workbest", "url": "https://www.v2ex.com/u/workbest", "website": "https://workbest.xyz", "twitter": null, "psn": null, "github": null, "btc": null, "location": "workbest", "tagline": "", "bio": "https://workbest.xyz", "avatar_mini": "https://cdn.v2ex.com/avatar/3f0d/63a0/784404_mini.png?m=1772172632", "avatar_normal": "https://cdn.v2ex.com/avatar/3f0d/63a0/784404_normal.png?m=1772172632", "avatar_large": "https://cdn.v2ex.com/avatar/3f0d/63a0/784404_large.png?m=1772172632", "avatar_xlarge": "https://cdn.v2ex.com/avatar/3f0d/63a0/784404_xlarge.png?m=1772172632", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/3f0d/63a0/784404_xxlarge.png?m=1772172632", "created": 1768480897, "last_modified": 1772172632, "pro": 0}, "last_reply_by": "laminux29", "last_touched": 1775319455, "title": "2 年以后的硬件和本地大模型", "url": "https://www.v2ex.com/t/1203495", "created": 1775274247, "deleted": 0, "content": "今年内存是大概率不会降价了\r\n\r\n随着价格的刺激和产能的提升，以及对本地大模型的需求，2 年以后 256G 内存能否得到普及？\r\n\r\n256G 内存，加上本地模型的发展，应该可以在本地运行一些非常不错的 coding 模型了", "content_rendered": "<p>今年内存是大概率不会降价了</p>\n<p>随着价格的刺激和产能的提升，以及对本地大模型的需求，2 年以后 256G 内存能否得到普及？</p>\n<p>256G 内存，加上本地模型的发展，应该可以在本地运行一些非常不错的 coding 模型了</p>\n", "last_modified": 1775274247, "replies": 19, "id": 1203495}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9226/2bf9/941_large.png?m=1475387237", "name": "rime", "avatar_normal": "https://cdn.v2ex.com/navatar/9226/2bf9/941_normal.png?m=1475387237", "title": "中州韻", "url": "https://www.v2ex.com/go/rime", "topics": 147, "footer": "", "header": "聪明的输入法懂我心意", "title_alternative": "RIME", "avatar_mini": "https://cdn.v2ex.com/navatar/9226/2bf9/941_mini.png?m=1475387237", "stars": 145, "founder_id": 0, "aliases": [], "root": false, "id": 941, "parent_node_name": "ime"}, "member": {"id": 717268, "username": "DearFox", "url": "https://www.v2ex.com/u/DearFox", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/f8df6c11f09cfe84cba114f98f24da53?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/f8df6c11f09cfe84cba114f98f24da53?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/f8df6c11f09cfe84cba114f98f24da53?s=73&d=retro", "created": 1730037069, "last_modified": 1774343424, "pro": 0}, "last_reply_by": "onlyxet7", "last_touched": 1775322851, "title": "是不是折腾输入法的尽头都是回归原生输入法?", "url": "https://www.v2ex.com/t/1203545", "created": 1775299058, "deleted": 0, "content": "去年折腾 rime 输入法,给电脑,手机,家人的,都弄 rime,刚开始还兴致勃勃,有时间就同步一下词库啥的,现在半年没动过,看见用的输入法方案更新,都懒的下载,总是感觉麻烦.还不如用自带的啥都不管", "content_rendered": "<p>去年折腾 rime 输入法,给电脑,手机,家人的,都弄 rime,刚开始还兴致勃勃,有时间就同步一下词库啥的,现在半年没动过,看见用的输入法方案更新,都懒的下载,总是感觉麻烦.还不如用自带的啥都不管</p>\n", "last_modified": 1775299058, "replies": 18, "id": 1203545}]