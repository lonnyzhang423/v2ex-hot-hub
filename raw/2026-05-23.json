[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71180, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9686, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 683966, "username": "haonanaaaaaa", "url": "https://www.v2ex.com/u/haonanaaaaaa", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/8417/ab2f/683966_mini.png?m=1779440936", "avatar_normal": "https://cdn.v2ex.com/avatar/8417/ab2f/683966_normal.png?m=1779440936", "avatar_large": "https://cdn.v2ex.com/avatar/8417/ab2f/683966_large.png?m=1779440936", "avatar_xlarge": "https://cdn.v2ex.com/avatar/8417/ab2f/683966_xlarge.png?m=1779440936", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/8417/ab2f/683966_xxlarge.png?m=1779440936", "created": 1712478620, "last_modified": 1779440936, "pro": 0}, "last_reply_by": "sunzhuo", "last_touched": 1779475974, "title": "大家都用的什么代理软件", "url": "https://www.v2ex.com/t/1214608", "created": 1779415358, "deleted": 0, "content": "我自己的情况：\r\n\r\n1. Windows 、Ubuntu 、macOS 电脑都是用的[clash verge]( https://github.com/clash-verge-rev/clash-verge-rev)：存在不稳定，占用资源多的问题，切轻量模式经常连接不上\r\n2. iOS 端：shadowrocket ，常开也挺耗电，不过作者挺良心的，对比 surge 简直一个天一个地\r\n3. 旁路由 istoreOS：一直用的 openclash ，也存在偶尔不稳定，偶尔需要重启一下，不知道是软件问题还是硬件问题\r\n\r\n现在想换掉 clash-verge-rev ，感觉最好是没有 ui 的，占用资源少的。现在反正配置很多时候都是 AI 写了，感觉 UI 没那么重要了。", "content_rendered": "<p>我自己的情况：</p>\n<ol>\n<li>Windows 、Ubuntu 、macOS 电脑都是用的<a href=\"https://github.com/clash-verge-rev/clash-verge-rev\" rel=\"nofollow\">clash verge</a>：存在不稳定，占用资源多的问题，切轻量模式经常连接不上</li>\n<li>iOS 端：shadowrocket ，常开也挺耗电，不过作者挺良心的，对比 surge 简直一个天一个地</li>\n<li>旁路由 istoreOS：一直用的 openclash ，也存在偶尔不稳定，偶尔需要重启一下，不知道是软件问题还是硬件问题</li>\n</ol>\n<p>现在想换掉 clash-verge-rev ，感觉最好是没有 ui 的，占用资源少的。现在反正配置很多时候都是 AI 写了，感觉 UI 没那么重要了。</p>\n", "last_modified": 1779415376, "replies": 169, "id": 1214608}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23405, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3677, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 665901, "username": "Amazing10086", "url": "https://www.v2ex.com/u/Amazing10086", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_mini.png?m=1779419604", "avatar_normal": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_normal.png?m=1779419604", "avatar_large": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_large.png?m=1779419604", "avatar_xlarge": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_xlarge.png?m=1779419604", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_xxlarge.png?m=1779419604", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/61b1/37b6/665901_xxxlarge.png?m=1779419604", "created": 1701842661, "last_modified": 1779419604, "pro": 0}, "last_reply_by": "Librola", "last_touched": 1779475129, "title": "腾讯文档裁员这么猛真的假的？", "url": "https://www.v2ex.com/t/1214594", "created": 1779414180, "deleted": 0, "content": "取消北京办公地点，全员沟通 7.18 离职。无商量余地，孕妇也不例外。法务已经准备好。其余深圳同学投奔 wb 怀抱", "content_rendered": "取消北京办公地点，全员沟通 7.18 离职。无商量余地，孕妇也不例外。法务已经准备好。其余深圳同学投奔 wb 怀抱", "last_modified": 1779414180, "replies": 111, "id": 1214594}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/301a/d0e3/834_large.png?m=1584400459", "name": "xiaomi", "avatar_normal": "https://cdn.v2ex.com/navatar/301a/d0e3/834_normal.png?m=1584400459", "title": "小米", "url": "https://www.v2ex.com/go/xiaomi", "topics": 1333, "footer": "", "header": "关于小米公司出品的各种智能硬件的使用讨论", "title_alternative": "Xiaomi", "avatar_mini": "https://cdn.v2ex.com/navatar/301a/d0e3/834_mini.png?m=1584400459", "stars": 486, "founder_id": 0, "aliases": [], "root": false, "id": 834, "parent_node_name": "android"}, "member": {"id": 371687, "username": "Rainwater", "url": "https://www.v2ex.com/u/Rainwater", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_mini.png?m=1758931373", "avatar_normal": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_normal.png?m=1758931373", "avatar_large": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_large.png?m=1758931373", "avatar_xlarge": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_xlarge.png?m=1758931373", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_xxlarge.png?m=1758931373", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/2db7/e5ee/371687_xxxlarge.png?m=1758931373", "created": 1545273210, "last_modified": 1758931373, "pro": 0}, "last_reply_by": "SenLief", "last_touched": 1779474778, "title": "怎么没人讨论昨晚小米的 YU7 GT", "url": "https://www.v2ex.com/t/1214634", "created": 1779418291, "deleted": 0, "content": "偷偷订了一辆顶配\r\n ![]( https://i.imgur.com/Y2VO4ZD.jpeg)", "content_rendered": "<p>偷偷订了一辆顶配\n<img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/Y2VO4ZD.jpeg\"/></p>\n", "last_modified": 1779418291, "replies": 97, "id": 1214634}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_large.png?m=1643940920", "name": "ev", "avatar_normal": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_normal.png?m=1643940920", "title": "电动汽车", "url": "https://www.v2ex.com/go/ev", "topics": 444, "footer": "", "header": "", "title_alternative": "EV", "avatar_mini": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_mini.png?m=1643940920", "stars": 453, "founder_id": 0, "aliases": [], "root": false, "id": 1034, "parent_node_name": "tech"}, "member": {"id": 613846, "username": "he123", "url": "https://www.v2ex.com/u/he123", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/eea48c3dabb885b92a5422490430ad23?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/eea48c3dabb885b92a5422490430ad23?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/eea48c3dabb885b92a5422490430ad23?s=73&d=retro", "created": 1676267023, "last_modified": 1676267023, "pro": 0}, "last_reply_by": "SenLief", "last_touched": 1779488627, "title": "蔚来换电讨论", "url": "https://www.v2ex.com/t/1214689", "created": 1779429198, "deleted": 0, "content": "最近在买电车，了解到蔚来换电以及最近的锁电门事件。\r\n理性分析下，蔚来换电是不是非常有优势的赛道，也是比较好的选择，虽然 baas 每个月会有对应的换电费用，也就是永续贷。\r\n电车最有价值，风险最大的就是电池，通过 bass 买入，把这部分风险交给蔚来公司，不需要担心电池老化，锁电等恶心人操作，同时出远门时可以申请 100 度电池，跑个 400 公里也没啥大问题。\r\n有点想入手蔚来 es6 ，虽然是 400v 平台。", "content_rendered": "<p>最近在买电车，了解到蔚来换电以及最近的锁电门事件。\n理性分析下，蔚来换电是不是非常有优势的赛道，也是比较好的选择，虽然 baas 每个月会有对应的换电费用，也就是永续贷。\n电车最有价值，风险最大的就是电池，通过 bass 买入，把这部分风险交给蔚来公司，不需要担心电池老化，锁电等恶心人操作，同时出远门时可以申请 100 度电池，跑个 400 公里也没啥大问题。\n有点想入手蔚来 es6 ，虽然是 400v 平台。</p>\n", "last_modified": 1779431937, "replies": 91, "id": 1214689}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10894, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini":