[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10468, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2241, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 457056, "username": "Colderer", "url": "https://www.v2ex.com/u/Colderer", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/317b/fb2e/457056_mini.png?m=1745463014", "avatar_normal": "https://cdn.v2ex.com/avatar/317b/fb2e/457056_normal.png?m=1745463014", "avatar_large": "https://cdn.v2ex.com/avatar/317b/fb2e/457056_large.png?m=1745463014", "avatar_xlarge": "https://cdn.v2ex.com/avatar/317b/fb2e/457056_xlarge.png?m=1745463014", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/317b/fb2e/457056_xxlarge.png?m=1745463014", "created": 1575343798, "last_modified": 1745463014, "pro": 0}, "last_reply_by": "svaeric", "last_touched": 1775057656, "title": "龟男又来发帖了，帮帮我", "url": "https://www.v2ex.com/t/1202731", "created": 1775011514, "deleted": 0, "content": "背景：男-大龄专科前端程序员，女-全职主妇，结婚 6 年，孩子幼儿园中班\r\n\r\n感兴趣的可以先看之前的帖子 https://v2ex.com/t/1010029\r\n\r\n最近几年每到春节都会发生冲突，今年返程前一天又因为我妈跟别人聊天的一句话生气了，让我妈给她道歉，我想着的事最后一天了，咱装孬就跟她道歉，道歉完还找小事情发脾气，最后又是闹得鸡犬不宁。\r\n\r\n上周几个早上因为我拖鞋摆放的位置，脏衣服没放到洗衣机，发过几次火；上周四早上她在给孩子扎头发就随便聊天说在家减肥遇到瓶颈了，下身瘦不下去，想去健身房找教练锻炼；我就跟她很平静的说现在形势不好，我也随时可能失业，跟其他稳定家庭的比不了，要想想以后，没有明说钱要省着点花；然后她又发火了，说她干什么我都不支持，发火就动手，动手我也还手，她叫孩子把我们打架的视频录下来，然后发给双方父母；\r\n\r\n周末她堂哥过来问问因为什么原因闹得矛盾，讲开之后就没问题了，晚上也给她道歉了；\r\n昨晚下班回家，她打包好行李也给孩子请假了，让他哥来接她们回娘家了。\r\n\r\n现在准备离婚，我想尽可能减少损失，孩子尽可能争取到抚养权，没买房，她卡里现金大约 70w ，主要是结婚时收的礼金，孩子出生收的礼金，还有我从 22 年 4 月开始每月转账 1w 给她存的，我爸自 25 年初每月转账 2000 到她微信作为老人没带孩子的补偿；我卡里没钱，全在股票账户，共 230w 左右，彩礼+工资+之前的裁员补偿+股票收益 100w ；\r\n\r\n怎么做资产转移能保证我的利益最大化？是否需要请律师咨询？", "content_rendered": "<p>背景：男-大龄专科前端程序员，女-全职主妇，结婚 6 年，孩子幼儿园中班</p>\n<p>感兴趣的可以先看之前的帖子 <a href=\"https://v2ex.com/t/1010029\" rel=\"nofollow\">https://v2ex.com/t/1010029</a></p>\n<p>最近几年每到春节都会发生冲突，今年返程前一天又因为我妈跟别人聊天的一句话生气了，让我妈给她道歉，我想着的事最后一天了，咱装孬就跟她道歉，道歉完还找小事情发脾气，最后又是闹得鸡犬不宁。</p>\n<p>上周几个早上因为我拖鞋摆放的位置，脏衣服没放到洗衣机，发过几次火；上周四早上她在给孩子扎头发就随便聊天说在家减肥遇到瓶颈了，下身瘦不下去，想去健身房找教练锻炼；我就跟她很平静的说现在形势不好，我也随时可能失业，跟其他稳定家庭的比不了，要想想以后，没有明说钱要省着点花；然后她又发火了，说她干什么我都不支持，发火就动手，动手我也还手，她叫孩子把我们打架的视频录下来，然后发给双方父母；</p>\n<p>周末她堂哥过来问问因为什么原因闹得矛盾，讲开之后就没问题了，晚上也给她道歉了；\n昨晚下班回家，她打包好行李也给孩子请假了，让他哥来接她们回娘家了。</p>\n<p>现在准备离婚，我想尽可能减少损失，孩子尽可能争取到抚养权，没买房，她卡里现金大约 70w ，主要是结婚时收的礼金，孩子出生收的礼金，还有我从 22 年 4 月开始每月转账 1w 给她存的，我爸自 25 年初每月转账 2000 到她微信作为老人没带孩子的补偿；我卡里没钱，全在股票账户，共 230w 左右，彩礼+工资+之前的裁员补偿+股票收益 100w ；</p>\n<p>怎么做资产转移能保证我的利益最大化？是否需要请律师咨询？</p>\n", "last_modified": 1775011514, "replies": 209, "id": 1202731}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/38af/8613/176_large.png?m=1644885960", "name": "car", "avatar_normal": "https://cdn.v2ex.com/navatar/38af/8613/176_normal.png?m=1644885960", "title": "汽车", "url": "https://www.v2ex.com/go/car", "topics": 3188, "footer": "", "header": "关于买车、开车及汽车文化的技术讨论", "title_alternative": "Car", "avatar_mini": "https://cdn.v2ex.com/navatar/38af/8613/176_mini.png?m=1644885960", "stars": 2257, "founder_id": 0, "aliases": [], "root": false, "id": 176, "parent_node_name": "life"}, "member": {"id": 368936, "username": "iamxueyichen", "url": "https://www.v2ex.com/u/iamxueyichen", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/c2a918887dcc9e3706a297b207450641?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/c2a918887dcc9e3706a297b207450641?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/c2a918887dcc9e3706a297b207450641?s=73&d=retro", "created": 1544206393, "last_modified": 1668823904, "pro": 0}, "last_reply_by": "kkwa56188", "last_touched": 1775063363, "title": "想问下大家是如何判断车的安全性", "url": "https://www.v2ex.com/t/1202685", "created": 1775006925, "deleted": 0, "content": "本人有新能源指标只能买纯电，因为家有小宝宝所以对安全性看的比较重要。\r\n\r\n想问下大家选车的时候，如何判断车的安全性。\r\n\r\n自己做了一些功课，比如看一些 NCAP 测试，看一些拆车的主要部件的材质，车的主动性安全，被动性安全，电池包的安全等等\r\n\r\n希望大家理性讨论，也希望大家给出一些有实际参考价值的建议和方法，谢谢", "content_rendered": "<p>本人有新能源指标只能买纯电，因为家有小宝宝所以对安全性看的比较重要。</p>\n<p>想问下大家选车的时候，如何判断车的安全性。</p>\n<p>自己做了一些功课，比如看一些 NCAP 测试，看一些拆车的主要部件的材质，车的主动性安全，被动性安全，电池包的安全等等</p>\n<p>希望大家理性讨论，也希望大家给出一些有实际参考价值的建议和方法，谢谢</p>\n", "last_modified": 1775006925, "replies": 164, "id": 1202685}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1fc2/1400/864_large.png?m=1760740512", "name": "promotions", "avatar_normal": "https://cdn.v2ex.com/navatar/1fc2/1400/864_normal.png?m=1760740512", "title": "推广", "url": "https://www.v2ex.com/go/promotions", "topics": 10925, "footer": "", "header": "来自厂商的推广活动类主题，会被归类到这个节点。希望有情怀的产商们在发布推广内容时，主动选择发布到本节点下。点击 <a href=\"/help/node\">这里</a> 阅读 V2EX 的节点使用指南。", "title_alternative": "Promotions", "avatar_mini": "https://cdn.v2ex.com/navatar/1fc2/1400/864_mini.png?m=1760740512", "stars": 1159, "founder_id": 0, "aliases": [], "root": false, "id": 864, "parent_node_name": ""}, "member": {"id": 1696, "username": "tomkyr", "url": "https://www.v2ex.com/u/tomkyr", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_mini.png?m=1767248112", "avatar_normal": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_normal.png?m=1767248112", "avatar_large": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_large.png?m=1767248112", "avatar_xlarge": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_xlarge.png?m=1767248112", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_xxlarge.png?m=1767248112", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/5cf2/1ce3/1696_xxxlarge.png?m=1767248112", "created": 1284104113, "last_modified": 1767248112, "pro": 0}, "last_reply_by": "henry99a", "last_touched": 1775059187, "title": "43 岁了，欠债几千个 w，辛苦半年开发的世界第一款真正足球 RPG 游戏，结果只有 5 个心愿单。真心求教怎么才能 steam 涨心愿单啊？", "url": "https://www.v2ex.com/t/1202694", "created": 1775007690, "deleted": 0, "content": "43 岁了。曾经一个小目标身价。因为被骗，全都赔光了。还倒欠三千个 w 。什么都不会就想着从头开发游戏吧。\r\n结果游戏市场已经不是以前我刚开始做的时候了。想起来自己喜欢的“太阁立志传”\r\n致敬太阁，高了个足球的 RPG 。Football Ambition ， 中文名 “足球立志传”\r\n结果一周了才五个心愿单。\r\n自己也不太会推广。什么外国的社区也不知道怎么用。回想起好多年前注册的 V2EX 。\r\n看着空空如也的 steam 后台，真的想问问大家：这种老游戏，现在没有人玩了吗？\r\n这是我的全部心血 —— 《足球立志传》（ FootballAmbition ）：\r\n致敬《太阁立志传》的硬核足球社会模拟：\r\n800+ 独立传记人物：他们不是背景板！会复仇、会贪污、会结婚，甚至会抱团排挤你。\r\n10 大职业人生：不只是踢球！你可以当球员、教练、甚至当经纪人、暗黑操盘手。\r\n权力与金钱的博弈：从小餐馆打工仔到控制转会市场，甚至买下 FIFA 主席，控制世界杯。\r\n真正的亿万富翁生活：征服 400+ 顶级俱乐部，迎娶名媛、明星，建立你的足球帝国。\r\n超高自由度：你可以是拯救弱旅的圣人，也可以是只手遮天的足坛恶霸。\r\n内含 30+ 建筑、1000+ 策略卡片、20+ 独立小游戏...\r\n\r\n好像不能传图片啊。那就不传。求靠谱的地方推荐。", "content_rendered": "<p>43 岁了。曾经一个小目标身价。因为被骗，全都赔光了。还倒欠三千个 w 。什么都不会就想着从头开发游戏吧。\n结果游戏市场已经不是以前我刚开始做的时候了。想起来自己喜欢的“太阁立志传”\n致敬太阁，高了个足球的 RPG 。Football Ambition ， 中文名 “足球立志传”\n结果一周了才五个心愿单。\n自己也不太会推广。什么外国的社区也不知道怎么用。回想起好多年前注册的 V2EX 。\n看着空空如也的 steam 后台，真的想问问大家：这种老游戏，现在没有人玩了吗？\n这是我的全部心血 —— 《足球立志传》（ FootballAmbition ）：\n致敬《太阁立志传》的硬核足球社会模拟：\n800+ 独立传记人物：他们不是背景板！会复仇、会贪污、会结婚，甚至会抱团排挤你。\n10 大职业人生：不只是踢球！你可以当球员、教练、甚至当经纪人、暗黑操盘手。\n权力与金钱的博弈：从小餐馆打工仔到控制转会市场，甚至买下 FIFA 主席，控制世界杯。\n真正的亿万富翁生活：征服 400+ 顶级俱乐部，迎娶名媛、明星，建立你的足球帝国。\n超高自由度：你可以是拯救弱旅的圣人，也可以是只手遮天的足坛恶霸。\n内含 30+ 建筑、1000+ 策略卡片、20+ 独立小游戏...</p>\n<p>好像不能传图片啊。那就不传。求靠谱的地方推荐。</p>\n", "last_modified": 1775008583, "replies": 139, "id": 1202694}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10468, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2241, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 183787, "username": "base", "url": "https://www.v2ex.com/u/base", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_mini.png?m=1747383590", "avatar_normal": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_normal.png?m=1747383590", "avatar_large": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_large.png?m=1747383590", "avatar_xlarge": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_xlarge.png?m=1747383590", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_xxlarge.png?m=1747383590", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/bebb/13fc/183787_xxxlarge.png?m=1747383590", "created": 1469526196, "last_modified": 1747383590, "pro": 0}, "last_reply_by": "kita", "last_touched": 1774637117, "title": "医院的商业化是不是过头了？", "url": "https://www.v2ex.com/t/1202702", "created": 1775009648, "deleted": 0, "content": "前几天去某省级公立三甲医院，发现洗手间里的纸，也需要扫码使用了，越来越智能，也越来越冷冰冰了。\r\n\r\n知道在医院借（租）个轮椅需要几步吗？\r\n\r\n+ wx 扫码\r\n+ 授权登录\r\n+ 支付押金\r\n+ 打开蓝牙\r\n+ 允许“附近的设备”权限\r\n+ 解锁\r\n+ 而且一定要记住这个小程序的名字，不然过了几天押金都不知道去哪里退。\r\n\r\n丝毫没考虑到老年人。\r\n\r\n还有在医院药房买药没有袋子怎么办？请扫码登录施舍给你一个，不够用请付费购买。\r\n\r\n下一步可以考虑把候诊室和药房的椅子也换成按摩椅，扫码付费使用了。", "content_rendered": "<p>前几天去某省级公立三甲医院，发现洗手间里的纸，也需要扫码使用了，越来越智能，也越来越冷冰冰了。</p>\n<p>知道在医院借（租）个轮椅需要几步吗？</p>\n<ul>\n<li>wx 扫码</li>\n<li>授权登录</li>\n<li>支付押金</li>\n<li>打开蓝牙</li>\n<li>允许“附近的设备”权限</li>\n<li>解锁</li>\n<li>而且一定要记住这个小程序的名字，不然过了几天押金都不知道去哪里退。</li>\n</ul>\n<p>丝毫没考虑到老年人。</p>\n<p>还有在医院药房买药没有袋子怎么办？请扫码登录施舍给你一个，不够用请付费购买。</p>\n<p>下一步可以考虑把候诊室和药房的椅子也换成按摩椅，扫码付费使用了。</p>\n", "last_modified": 1775010319, "replies": 113, "id": 1202702}, {"node": {"avatar_large": "/static/img/node_default_large.png", "name": "show", "avatar_normal": "/static/img/node_default_normal.png", "title": "晒晒更健康", "url": "https://www.v2ex.com/go/show", "topics": 99, "footer": "", "header": "", "title_alternative": "Show", "avatar_mini": "/static/img/node_default_mini.png", "stars": 106, "founder_id": 0, "aliases": [], "root": false, "id": 133, "parent_node_name": ""}, "member": {"id": 301501, "username": "mastergo", "url": "https://www.v2ex.com/u/mastergo", "website": "https://t.me/weekly_books", "twitter": "", "psn": "", "github": "yaoleifly", "btc": "", "location": "新加坡", "tagline": "好好吃饭", "bio": "新手奶爸，修己安人。", "avatar_mini": "https://cdn.v2ex.com/avatar/df18/65db/301501_mini.png?m=1766926779", "avatar_normal": "https://cdn.v2ex.com/avatar/df18/65db/301501_normal.png?m=1766926779", "avatar_large": "https://cdn.v2ex.com/avatar/df18/65db/301501_large.png?m=1766926779", "created": 1521456640, "last_modified": 1766926779, "pro": 0}, "last_reply_by": "cuicuiv5", "last_touched": 1775051501, "title": "中奖了", "url": "https://www.v2ex.com/t/1202712", "created": 1775010336, "deleted": 0, "content": "我今年 5 月份中彩票了，税后 1000W ，很平静，正常的休息日去领的奖金，一个都没告诉，买了个 200W 的房，放了 300W 存定期，剩下的放在支付宝，偶尔买点基金。", "content_rendered": "<p>我今年 5 月份中彩票了，税后 1000W ，很平静，正常的休息日去领的奖金，一个都没告诉，买了个 200W 的房，放了 300W 存定期，剩下的放在支付宝，偶尔买点基金。</p>\n", "last_modified": 1775010527, "replies": 103, "id": 1202712}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10468, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2241, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 477690, "username": "HOmo00", "url": "https://www.v2ex.com/u/HOmo00", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/0b7b/f8f2/477690_mini.png?m=1680250784", "avatar_normal":