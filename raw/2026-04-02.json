=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70393, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9617, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 411532, "username": "clacf", "url": "https://www.v2ex.com/u/clacf", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/9a5af21f8dc33efc660faf5fb6b18aff?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/9a5af21f8dc33efc660faf5fb6b18aff?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/9a5af21f8dc33efc660faf5fb6b18aff?s=73&d=retro", "created": 1557638602, "last_modified": 1770350057, "pro": 0}, "last_reply_by": "kongg", "last_touched": 1775109524, "title": "感觉 ai agent 时代， windows 越来越不行了", "url": "https://www.v2ex.com/t/1203016", "created": 1775095250, "deleted": 0, "content": "agent 在 cmd 环境下，运行时候，会出现各种兼容性的报错。每次执行，都需要烧掉额外的 token 来修复兼容性问题。大家是怎么跑的？虚拟机里面执行吗？是 vmware 还是 wsl ？", "content_rendered": "<p>agent 在 cmd 环境下，运行时候，会出现各种兼容性的报错。每次执行，都需要烧掉额外的 token 来修复兼容性问题。大家是怎么跑的？虚拟机里面执行吗？是 vmware 还是 wsl ？</p>\n", "last_modified": 1775104213, "replies": 41, "id": 1203016}]