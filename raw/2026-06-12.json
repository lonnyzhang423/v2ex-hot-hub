[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/b9d4/87a3/1108_large.png?m=1634634461", "name": "web3", "avatar_normal": "https://cdn.v2ex.com/navatar/b9d4/87a3/1108_normal.png?m=1634634461", "title": "Web3", "url": "https://www.v2ex.com/go/web3", "topics": 77, "footer": "", "header": "", "title_alternative": "Web3", "avatar_mini": "https://cdn.v2ex.com/navatar/b9d4/87a3/1108_mini.png?m=1634634461", "stars": 241, "founder_id": 0, "aliases": [], "root": false, "id": 1108, "parent_node_name": "geek"}, "member": {"id": 633133, "username": "coreJK", "url": "https://www.v2ex.com/u/coreJK", "website": "qiuyucode.com", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=73&d=retro", "created": 1686220875, "last_modified": 1764296894, "pro": 0}, "last_reply_by": "coreJK", "last_touched": 1781247726, "title": "在币安通过 c2c 尝试买了点币，反诈中心又来联系了", "url": "https://www.v2ex.com/t/1219790", "created": 1781226100, "deleted": 0, "content": "如题，不知道 v 友们有没有遇到过\r\n今天刚刚尝试在币安上买了点 usdc , 通过 c2c ，支付宝交易\r\n不到一个小时左右就被问候了，问有没有加入过什么投资理财群\r\n---\r\n至于为什么说是又，之前因为流量使用 rustdesk 被联系过，后来用 rustdesk 只用 wifi 就没被联系过了", "content_rendered": "<h2>如题，不知道 v 友们有没有遇到过\n今天刚刚尝试在币安上买了点 usdc , 通过 c2c ，支付宝交易\n不到一个小时左右就被问候了，问有没有加入过什么投资理财群</h2>\n<p>至于为什么说是又，之前因为流量使用 rustdesk 被联系过，后来用 rustdesk 只用 wifi 就没被联系过了</p>\n", "last_modified": 1781226163, "replies": 101, "id": 1219790}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c16a/5320/31_large.png?m=1584298370", "name": "chongqing", "avatar_normal": "https://cdn.v2ex.com/navatar/c16a/5320/31_normal.png?m=1584298370", "title": "重庆", "url": "https://www.v2ex.com/go/chongqing", "topics": 145, "footer": "", "header": "", "title_alternative": "Chongqing", "avatar_mini": "https://cdn.v2ex.com/navatar/c16a/5320/31_mini.png?m=1584298370", "stars": 249, "founder_id": 0, "aliases": [], "root": false, "id": 31, "parent_node_name": "cn"}, "member": {"id": 239594, "username": "jacketma", "url": "https://www.v2ex.com/u/jacketma", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/a941f83ac4192740c2e1f95676ce23c5?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/a941f83ac4192740c2e1f95676ce23c5?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/a941f83ac4192740c2e1f95676ce23c5?s=73&d=retro", "created": 1499704166, "last_modified": 1770973638, "pro": 0}, "last_reply_by": "squarefong17", "last_touched": 1781247928, "title": "老铁们是怎么看待狗妈猫妈人士的？", "url": "https://www.v2ex.com/t/1219754", "created": 1781190913, "deleted": 0, "content": "互联网公司曾经流行过一段风气：允许带宠物到办公室上班。好像不爱好宠物，就是不够文明、有爱心了\r\n\r\n这点是比较反感的。咱自己不养、也不至于虐动物，别人家可爱的猫猫狗狗可爱的也撩两下，但是自己不养。主要是考虑的猫藓、狗虱子等给人带来的潜在安全威胁。\r\n\r\n打包哥这种也是太变态了，感觉遇到狗妈猫妈人士，两边人能火拼起来\r\n\r\n现在人是因为情绪空虚吗，要搞个宠物来填补，不太理解这样的人越来越多了", "content_rendered": "<p>互联网公司曾经流行过一段风气：允许带宠物到办公室上班。好像不爱好宠物，就是不够文明、有爱心了</p>\n<p>这点是比较反感的。咱自己不养、也不至于虐动物，别人家可爱的猫猫狗狗可爱的也撩两下，但是自己不养。主要是考虑的猫藓、狗虱子等给人带来的潜在安全威胁。</p>\n<p>打包哥这种也是太变态了，感觉遇到狗妈猫妈人士，两边人能火拼起来</p>\n<p>现在人是因为情绪空虚吗，要搞个宠物来填补，不太理解这样的人越来越多了</p>\n", "last_modified": 1781190913, "replies": 94, "id": 1219754}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239103, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4491, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 603255, "username": "vviolet", "url": "https://www.v2ex.com/u/vviolet", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/d7cbb528870f0ed31877a3696cfb52a5?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/d7cbb528870f0ed31877a3696cfb52a5?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/d7cbb528870f0ed31877a3696cfb52a5?s=73&d=retro", "created": 1669291506, "last_modified": 1669291506, "pro": 0}, "last_reply_by": "Azmeont", "last_touched": 1781246848, "title": "应届生不小心进了大厂咋办", "url": "https://www.v2ex.com/t/1219723", "created": 1781180348, "deleted": 0, "content": "请问不小心进入大厂的后果是什么？应届本科双非女不小心进了大厂，没啥实力很担心试用期（三个月不打折）咋办呢？现在已经在公司实习快大半年个月了，然后给的薪资是 26k 但是觉得自己做的方向很偏，基本给人打杂做 dirtywork 的。我学习成绩蛮好的，离保研就差一点点，我心理一直都想考研的，但是感觉研究生考出来就那样，生活没有方向标了。。很迷茫，我的身体一直在干着，但是我的大脑空空，而且我实习期薪资就两百一天的水平。秋招一份简历没投一次都没面试过。其实对于开出来的价格已经很满意了，但是找不到自己的价值，技术也没提升，纯 vibe coding ；周围也没同事，只有领导给任务，很孤独；平时还会被各个项目组当工具人用；我现在基本没请过假了，要不要和主管请假去毕业旅行，过半个月入职，还是卷生卷死？", "content_rendered": "<p>请问不小心进入大厂的后果是什么？应届本科双非女不小心进了大厂，没啥实力很担心试用期（三个月不打折）咋办呢？现在已经在公司实习快大半年个月了，然后给的薪资是 26k 但是觉得自己做的方向很偏，基本给人打杂做 dirtywork 的。我学习成绩蛮好的，离保研就差一点点，我心理一直都想考研的，但是感觉研究生考出来就那样，生活没有方向标了。。很迷茫，我的身体一直在干着，但是我的大脑空空，而且我实习期薪资就两百一天的水平。秋招一份简历没投一次都没面试过。其实对于开出来的价格已经很满意了，但是找不到自己的价值，技术也没提升，纯 vibe coding ；周围也没同事，只有领导给任务，很孤独；平时还会被各个项目组当工具人用；我现在基本没请过假了，要不要和主管请假去毕业旅行，过半个月入职，还是卷生卷死？</p>\n", "last_modified": 1781180454, "replies": 85, "id": 1219723}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239103, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4491, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 603675, "username": "ModiKa2022", "url": "https://www.v2ex.com/u/ModiKa2022", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/12b6/e075/603675_mini.png?m=1776999896", "avatar_normal": "https://cdn.v2ex.com/avatar/12b6/e075/603675_normal.png?m=1776999896", "avatar_large": "https://cdn.v2ex.com/avatar/12b6/e075/603675_large.png?m=1776999896", "avatar_xlarge": "https://cdn.v2ex.com/avatar/12b6/e075/603675_xlarge.png?m=1776999896", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/12b6/e075/603675_xxlarge.png?m=1776999896", "created": 1669616409, "last_modified": 1776999896, "pro": 0}, "last_reply_by": "rockddd", "last_touched": 1781248073, "title": "大家各自的房贷还剩多少? 每个月压力大吗?", "url": "https://www.v2ex.com/t/1219842", "created": 1781233994, "deleted": 0, "content": "### 缘起\r\n昨天刚提前换了一部分贷款, 农行的房贷, 通知的是 17:00 之前准备好资金, 结果是昨天半夜 11:45 扣的款, 我以为出问题了, 感觉农行的批量脚本很慢, 也许是提前还款的人多吧\r\n\r\n### 房贷的情况\r\n\r\n个人情况:\r\n\r\n- 贷款还剩 7 年\r\n- 现在每月的还款占税后收入的 7%以内了\r\n- 我还租着房子, 异地上班, 公积金可以覆盖现在的租金\r\n\r\n### 想问的问题\r\n\r\n1, 各位现在房贷占税后收入大概多少? 压力大吗?\r\n\r\n2, IT 行业感觉未来的路很迷茫, vibe coding 快半年了, 4.6 出来以后, 基本就很少手工写代码了, 年龄已经过了 35, 感觉这条路的尽头也快到了, 各位的感觉未来怎么样? \r\n\r\n\r\n### 备注\r\n\r\n- 只是想了解下现在大概的情况\r\n- 个人对未来感觉比较悲观(仅个人的想法)", "content_rendered": "<h3>缘起</h3>\n<p>昨天刚提前换了一部分贷款, 农行的房贷, 通知的是 17:00 之前准备好资金, 结果是昨天半夜 11:45 扣的款, 我以为出问题了, 感觉农行的批量脚本很慢, 也许是提前还款的人多吧</p>\n<h3>房贷的情况</h3>\n<p>个人情况:</p>\n<ul>\n<li>贷款还剩 7 年</li>\n<li>现在每月的还款占税后收入的 7%以内了</li>\n<li>我还租着房子, 异地上班, 公积金可以覆盖现在的租金</li>\n</ul>\n<h3>想问的问题</h3>\n<p>1, 各位现在房贷占税后收入大概多少? 压力大吗?</p>\n<p>2, IT 行业感觉未来的路很迷茫, vibe coding 快半年了, 4.6 出来以后, 基本就很少手工写代码了, 年龄已经过了 35, 感觉这条路的尽头也快到了, 各位的感觉未来怎么样? </p>\n<h3>备注</h3>\n<ul>\n<li>只是想了解下现在大概的情况</li>\n<li>个人对未来感觉比较悲观(仅个人的想法)</li>\n</ul>\n", "last_modified": 1781234085, "replies": 78, "id": 1219842}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71506, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9708, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 559213, "username": "tellmeworld", "url": "https://www.v2ex.com/u/tellmeworld", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/39fa93500aaf29f84cb9b6bc2c47af2d?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/39fa93500aaf29f84cb9b6bc2c47af2d?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/39fa93500aaf29f84cb9b6bc2c47af2d?s=73&d=retro", "created": 1634787326, "last_modified": 1740616627, "pro": 0}, "last_reply_by": "dushixiang", "last_touched": 1781248097, "title": "用 AI 写了个中医自诊网站，亚健康的都来测测，求喷", "url": "https://www.v2ex.com/t/1219848", "created": 1781234782, "deleted": 0, "content": "地址：www.xuanhu.cn\r\n\r\n几年的失眠看了西医只会让你吃安眠药；\r\n\r\n然后开始了解中医，觉得中医有非常可取的一面，就写了这个网站，纯爱发电；\r\n\r\n这里不争中西医孰优孰劣，谁有效用谁；\r\n\r\n求喷。", "content_rendered": "<p>地址：<a href=\"http://www.xuanhu.cn\" rel=\"nofollow\">www.xuanhu.cn</a></p>\n<p>几年的失眠看了西医只会让你吃安眠药；</p>\n<p>然后开始了解中医，觉得中医有非常可取的一面，就写了这个网站，纯爱发电；</p>\n<p>这里不争中西医孰优孰劣，谁有效用谁；</p>\n<p>求喷。</p>\n", "last_modified": 1781234782, "replies": 70, "id": 1219848}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11034, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2352, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 342008, "username": "Sercheif", "url": "https://www.v2ex.com/u/Sercheif", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6022/1a8c/342008_mini.png?m=1778718872", "avatar_normal": "https://cdn.v2ex.com/avatar/6022/1a8c/342008_normal.png?m=1778718872", "avatar_large": "https://cdn.v2ex.com/avatar/6022/1a8c/342008_large.png?m=1778718872", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6022/1a8c/342008_xlarge.png?m=1778718872", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/6022/1a8c/342008_xxlarge.png?m=1778718872", "created": 1534471632, "last_modified": 1778718872, "pro": 0}, "last_reply_by": "hellopz", "last_touched": 1781248062, "title": "时隔多周，体重总算又下来了...骑行确实比徒步要减脂", "url": "https://www.v2ex.com/t/1219789", "created": 1781225778, "deleted": 0, "content": "https://i.imgur.com/KFUeVLg.png \r\n 自行车带来的运动量确实比徒步要高，周六 7 点，3 个半钟骑了 52km （和大佬比不上），有上下坡，累的要死，由于周五晚上喝了很多啤酒，所以早上没吃东西，骑到胃痛。\r\n 周天城市道路骑行 32km 。再爬个小山（ 2 个钟）。\r\n 导致这周一周二腿痛，周三恢复，周四小跑 4km 。\r\n 这周完全正常吃，甚至吃的比之前多，没想到体重他周五的时候下来了。之前一直稳定在 64-65 之间。\r\n 上周的运动情况非常意外。\r\n  https://i.imgur.com/OS0U922.png\r\n  \r\n  上面文字输入给大模型后，大模型给得回复：\r\n   https://i.imgur.com/sHzDGit.png \r\n \r\n 减脂效果跑步>骑行>徒步。\r\n 对于我来说，跑步没办法坚持 3 、4 个钟，做不到一天到晚跑。\r\n 骑行可以短时间心率上升，时间持续长，更容易达到减脂效果。\r\n 徒步（ 16-30km ）感觉只有上山阶段消耗，大部分路段都是平稳消耗。\r\n 我感觉，骑行是减肥的“懒”办法，既能消耗，又能持久，又能坚持。", "content_rendered": "<a target=\"_blank\" href=\"https://i.imgur.com/KFUeVLg.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/KFUeVLg.png\" class=\"embedded_image\" rel=\"noreferrer\"></a><br /> 自行车带来的运动量确实比徒步要高，周六 7 点，3 个半钟骑了 52km （和大佬比不上），有上下坡，累的要死，由于周五晚上喝了很多啤酒，所以早上没吃东西，骑到胃痛。<br /> 周天城市道路骑行 32km 。再爬个小山（ 2 个钟）。<br /> 导致这周一周二腿痛，周三恢复，周四小跑 4km 。<br /> 这周完全正常吃，甚至吃的比之前多，没想到体重他周五的时候下来了。之前一直稳定在 64-65 之间。<br /> 上周的运动情况非常意外。<br />  <a target=\"_blank\" href=\"https://i.imgur.com/OS0U922.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/OS0U922.png\" class=\"embedded_image\" rel=\"noreferrer\"></a><br />  <br />  上面文字输入给大模型后，大模型给得回复：<br />   <a target=\"_blank\" href=\"https://i.imgur.com/sHzDGit.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/sHzDGit.png\" class=\"embedded_image\" rel=\"noreferrer\"></a><br /> <br /> 减脂效果跑步&gt;骑行&gt;徒步。<br /> 对于我来说，跑步没办法坚持 3 、4 个钟，做不到一天到晚跑。<br /> 骑行可以短时间心率上升，时间持续长，更容易达到减脂效果。<br /> 徒步（ 16-30km ）感觉只有上山阶段消耗，大部分路段都是平稳消耗。<br /> 我感觉，骑行是减肥的“懒”办法，既能消耗，又能持久，又能坚持。", "last_modified": 1781225778, "replies": 57, "id": 1219789}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239103, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4491, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 350395, "username": "ldlywt", "url": "https://www.v2ex.com/u/ldlywt", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/b526/fb4a/350395_mini.png?m=1743485791", "avatar_normal": "https://cdn.v2ex.com/avatar/b526/fb4a/350395_normal.png?m=1743485791", "avatar_large": "https://cdn.v2ex.com/avatar/b526/fb4a/350395_large.png?m=1743485791", "created": 1537260791, "last_modified": 1743485791, "pro": 0}, "last_reply_by": "ltux", "last_touched": 1781246239, "title": "阿里系的 app 是不是大厂中最难用的？", "url": "https://www.v2ex.com/t/1219690", "created": 1781169040, "deleted": 0, "content": "点击支付宝，闪购，经常白屏，无任何反应。\r\n还有阿里系的 app 打开经常跳到淘宝，好恶心。\r\n要不是淘宝闪购比其他家便宜很多，早就卸了。https://i.imgur.com/2rPidfQ.jpeg", "content_rendered": "点击支付宝，闪购，经常白屏，无任何反应。<br />还有阿里系的 app 打开经常跳到淘宝，好恶心。<br />要不是淘宝闪购比其他家便宜很多，早就卸了。<a target=\"_blank\" href=\"https://i.imgur.com/2rPidfQ.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/2rPidfQ.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1781169040, "replies": 56, "id": 1219690}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6ecb/dd6e/426_large.png?m=1592893106", "name": "wwdc", "avatar_normal": "https://cdn.v2ex.com/navatar/6ecb/dd6e/426_normal.png?m=1592893106", "title": "WWDC", "url": "https://www.v2ex.com/go/wwdc", "topics": 104, "footer": "", "header": "Apple Worldwide Developers Conference", "title_alternative": "WWDC", "avatar_mini": "https://cdn.v2ex.com/navatar/6ecb/dd6e/426_mini.png?m=1592893106", "stars": 91, "founder_id": 0, "aliases": [], "root": false, "id": 426, "parent_node_name": "apple"}, "member": {"id": 482248, "username": "ximaoyang", "url": "https://www.v2ex.com/u/ximaoyang", "website": "https://codeplato3721.github.io/", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "代码Plato", "bio": "怎么才能改自己的用户名啊。。。", "avatar_mini": "https://cdn.v2ex.com/avatar/c764/a00c/482248_mini.png?m=1779329638", "avatar_normal": "https://cdn.v2ex.com/avatar/c764/a00c/482248_normal.png?m=1779329638", "avatar_large": "https://cdn.v2ex.com/avatar/c764/a00c/482248_large.png?m=1779329638", "avatar_xlarge": "https://cdn.v2ex.com/avatar/c764/a00c/482248_xlarge.png?m=1779329638", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/c764/a00c/482248_xxlarge.png?m=1779329638", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/c764/a00c/482248_xxxlarge.png?m=1779329638", "created": 1586271105, "last_modified": 1779329638, "pro": 0}, "last_reply_by": "jydeng", "last_touched": 1781243329, "title": "苹果 WWDC2026 拉完了", "url": "https://www.v2ex.com/t/1219768", "created": 1781200745, "deleted": 0, "content": "谁都知道大家想听什么。但它就是遮遮掩掩。然后讲了一大堆 iOS 的功能更新。什么调透明度。\r\n终于到 Siri AI 环节，结果是所谓的自研大模型+Gemini 。说是不足之处用 Gemini 补齐。但是大家都知道估计就是自己暂时还搞不定，然后套壳 Gemini 先撑一下。现在这几家头部企业最有财力可以搞出下一个 LLM 的就是苹果了。再搞不出来苹果真的要掉队了。结果合作的还是 Gemini 。\r\n在模型圈，模型分为两类 A 家的和非 A 家的。非 A 家的模型虽然便宜一些，但是用起来的体验一言难尽，基本没法直接干活。O 家的就是又贵又一言难尽。G 家的已经算是垫底的了，只不过背靠 google 和强大的财力，可以免费给小白用，也算是占领了一块垂直分类。结果苹果最终还是靠 G 家托底。全班倒数第一和第二抱团。\r\n几年前投了大价钱搞的无人驾驶现在也基本放弃了。AI 还掉队。难怪股价大跌，美股讲究的就是个长线投资，如果这个企业开始有走下坡路的趋势了，那就是套现的最好时机了。等到真走下坡路了就不好出了。", "content_rendered": "<p>谁都知道大家想听什么。但它就是遮遮掩掩。然后讲了一大堆 iOS 的功能更新。什么调透明度。\n终于到 Siri AI 环节，结果是所谓的自研大模型+Gemini 。说是不足之处用 Gemini 补齐。但是大家都知道估计就是自己暂时还搞不定，然后套壳 Gemini 先撑一下。现在这几家头部企业最有财力可以搞出下一个 LLM 的就是苹果了。再搞不出来苹果真的要掉队了。结果合作的还是 Gemini 。\n在模型圈，模型分为两类 A 家的和非 A 家的。非 A 家的模型虽然便宜一些，但是用起来的体验一言难尽，基本没法直接干活。O 家的就是又贵又一言难尽。G 家的已经算是垫底的了，只不过背靠 google 和强大的财力，可以免费给小白用，也算是占领了一块垂直分类。结果苹果最终还是靠 G 家托底。全班倒数第一和第二抱团。\n几年前投了大价钱搞的无人驾驶现在也基本放弃了。AI 还掉队。难怪股价大跌，美股讲究的就是个长线投资，如果这个企业开始有走下坡路的趋势了，那就是套现的最好时机了。等到真走下坡路了就不好出了。</p>\n", "last_modified": 1781210768, "replies": 47, "id": 1219768}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_large.png?m=1650127314", "name": "beijing", "avatar_normal": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_normal.png?m=1650127314", "title": "北京", "url": "https://www.v2ex.com/go/beijing", "topics": 4459, "footer": "", "header": "", "title_alternative": "Beijing", "avatar_mini": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_mini.png?m=1650127314", "stars": 2393, "founder_id": 0, "aliases": [], "root": false, "id": 19, "parent_node_name": "cn"}, "member": {"id": 680145, "username": "Frank570", "url": "https://www.v2ex.com/u/Frank570", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "中中中！錢錢進我兜！！！", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/13a1/68d6/680145_mini.png?m=1744713437", "avatar_normal": "https://cdn.v2ex.com/avatar/