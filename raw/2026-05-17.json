[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/41ae/36ec/417_large.png?m=1625409262", "name": "software", "avatar_normal": "https://cdn.v2ex.com/navatar/41ae/36ec/417_normal.png?m=1625409262", "title": "软件", "url": "https://www.v2ex.com/go/software", "topics": 1062, "footer": "", "header": "关于软件使用的日常讨论", "title_alternative": "Software", "avatar_mini": "https://cdn.v2ex.com/navatar/41ae/36ec/417_mini.png?m=1625409262", "stars": 361, "founder_id": 0, "aliases": [], "root": false, "id": 417, "parent_node_name": "computer"}, "member": {"id": 216370, "username": "quicknight", "url": "https://www.v2ex.com/u/quicknight", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/e9e8b40756c084ae025bf6a5ab0aaf92?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/e9e8b40756c084ae025bf6a5ab0aaf92?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/e9e8b40756c084ae025bf6a5ab0aaf92?s=73&d=retro", "created": 1487644250, "last_modified": 1487644250, "pro": 0}, "last_reply_by": "duhbbx1119", "last_touched": 1778983176, "title": "58 元买断的软件，希望可以终生维护，为什么 58 元买的衣服，吃的快餐，没有同样的要求呢？", "url": "https://www.v2ex.com/t/1213183", "created": 1778924185, "deleted": 0, "content": "研究了一下国内独立开发的作品，看了很多用户评论得出这个疑问\r\n\r\n这是一种什么样的心理，同样价格的商品，为什么对付费软件的要求，会显著高于其它同价格的产品\r\n\r\n这种市场认知下，软件产品如何定价更合理", "content_rendered": "<p>研究了一下国内独立开发的作品，看了很多用户评论得出这个疑问</p>\n<p>这是一种什么样的心理，同样价格的商品，为什么对付费软件的要求，会显著高于其它同价格的产品</p>\n<p>这种市场认知下，软件产品如何定价更合理</p>\n", "last_modified": 1778963227, "replies": 74, "id": 1213183}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10834, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2316, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 375728, "username": "HinamiAoi", "url": "https://www.v2ex.com/u/HinamiAoi", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/f506/f2bc/375728_mini.png?m=1546831481", "avatar_normal": "https://cdn.v2ex.com/avatar/f506/f2bc/375728_normal.png?m=1546831481", "avatar_large": "https://cdn.v2ex.com/avatar/f506/f2bc/375728_large.png?m=1546831481", "created": 1546831429, "last_modified": 1546831481, "pro": 0}, "last_reply_by": "mytsing520", "last_touched": 1778970924, "title": "香港/东京/新加坡/迪拜这四个城市该怎么选呢？", "url": "https://www.v2ex.com/t/1213199", "created": 1778931727, "deleted": 0, "content": "公司想让我 relocate ，给了四个选择\r\n\r\n人力成本不变，按当地政策交税\r\n\r\n查了下，香港/新加坡 房价高，税低\r\n\r\n东京 房价稍低，税高\r\n\r\n迪拜 房价更低，税无\r\n\r\n这样看来似乎该去迪拜吗？", "content_rendered": "<p>公司想让我 relocate ，给了四个选择</p>\n<p>人力成本不变，按当地政策交税</p>\n<p>查了下，香港/新加坡 房价高，税低</p>\n<p>东京 房价稍低，税高</p>\n<p>迪拜 房价更低，税无</p>\n<p>这样看来似乎该去迪拜吗？</p>\n", "last_modified": 1778931764, "replies": 62, "id": 1213199}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71084, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9681, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 509968, "username": "289396212", "url": "https://www.v2ex.com/u/289396212", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "taglin