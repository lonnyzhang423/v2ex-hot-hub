[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/38af/8613/176_large.png?m=1644885960", "name": "car", "avatar_normal": "https://cdn.v2ex.com/navatar/38af/8613/176_normal.png?m=1644885960", "title": "汽车", "url": "https://www.v2ex.com/go/car", "topics": 3182, "footer": "", "header": "关于买车、开车及汽车文化的技术讨论", "title_alternative": "Car", "avatar_mini": "https://cdn.v2ex.com/navatar/38af/8613/176_mini.png?m=1644885960", "stars": 2256, "founder_id": 0, "aliases": [], "root": false, "id": 176, "parent_node_name": "life"}, "member": {"id": 340972, "username": "myadmin", "url": "https://www.v2ex.com/u/myadmin", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/131c/80d8/340972_mini.png?m=1769743449", "avatar_normal": "https://cdn.v2ex.com/avatar/131c/80d8/340972_normal.png?m=1769743449", "avatar_large": "https://cdn.v2ex.com/avatar/131c/80d8/340972_large.png?m=1769743449", "avatar_xlarge": "https://cdn.v2ex.com/avatar/131c/80d8/340972_xlarge.png?m=1769743449", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/131c/80d8/340972_xxlarge.png?m=1769743449", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/131c/80d8/340972_xxxlarge.png?m=1769743449", "created": 1534211727, "last_modified": 1769743449, "pro": 0}, "last_reply_by": "18k", "last_touched": 1774597313, "title": "一场家庭矛盾，到底该听谁的？", "url": "https://www.v2ex.com/t/1201490", "created": 1774574743, "deleted": 0, "content": "<h3>事件起因：</h3>\r\n特斯拉开了两年，每年都做了保养，前段时间保养 4s 店打电话说该换空调滤芯了。<br>\r\n媳妇想直接在 4s 店换，6 个滤芯总费用在 1000 以上。<br>\r\n我是感觉滤芯哪儿换都一样，淘宝买品牌的加换费用在 400 左右。<br>\r\n\r\n<h3>争吵点</h3>\r\n媳妇观点：车花了那么多钱，滤芯当然要在 4s 店，谁保养不是在 4s 店<br>\r\n我观点：滤芯是消耗品，一两年要换一次，没必要非在 4s 店<br>\r\n\r\n<h3>现在</h3>\r\n双方都在坚持自己的观点，我在想要不要听她的。<br>\r\n听她的可以避免继续争吵，但是我是真的感觉没必要。<br>\r\n想听听 v 友们的意见<br>", "content_rendered": "<h3>事件起因：</h3>\n特斯拉开了两年，每年都做了保养，前段时间保养 4s 店打电话说该换空调滤芯了。<br/>\n媳妇想直接在 4s 店换，6 个滤芯总费用在 1000 以上。<br/>\n我是感觉滤芯哪儿换都一样，淘宝买品牌的加换费用在 400 左右。<br/>\n<h3>争吵点</h3>\n媳妇观点：车花了那么多钱，滤芯当然要在 4s 店，谁保养不是在 4s 店<br/>\n我观点：滤芯是消耗品，一两年要换一次，没必要非在 4s 店<br/>\n<h3>现在</h3>\n双方都在坚持自己的观点，我在想要不要听她的。<br/>\n听她的可以避免继续争吵，但是我是真的感觉没必要。<br/>\n想听听 v 友们的意见<br/>", "last_modified": 1774580978, "replies": 200, "id": 1201490}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_large.png?m=1643940920", "name": "ev", "avatar_normal": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_normal.png?m=1643940920", "title": "电动汽车", "url": "https://www.v2ex.com/go/ev", "topics": 425, "footer": "", "header": "", "title_alternative": "EV", "avatar_mini": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_mini.png?m=1643940920", "stars": 433, "founder_id": 0, "aliases": [], "root": false, "id": 1034, "parent_node_name": "tech"}, "member": {"id": 460559, "username": "DeYiAo", "url": "https://www.v2ex.com/u/DeYiAo", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/fc217259f1e8d6a61ea8a1ae65ed8a68?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/fc217259f1e8d6a61ea8a1ae65ed8a68?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/fc217259f1e8d6a61ea8a1ae65ed8a68?s=73&d=retro", "created": 1576921381, "last_modified": 1751935516, "pro": 0}, "last_reply_by": "lonccc", "last_touched": 1774597298, "title": "智驾撞孩子的视频大家看了吗？", "url": "https://www.v2ex.com/t/1201475", "created": 1774572745, "deleted": 0, "content": "不知道是不是迄今最恶劣的智驾事故，一点没减速，直接碾过去了。抖音上视频删的很快。\r\nxiaohongshu.com/explore/69c4ffe300000000210068ec?app_platform=android&ignoreEngage=true&app_version=9.23.0&share_from_user_hidden=true&xsec_source=app_share&type=video&xsec_token=CBHDoxn6TTvJfuZAx576qODANMxas6BgUBLvP03NOjCiQ=&author_share=1&xhsshare=&shareRedId=ODtGMzg6SEE2NzUyOTgwNjY4OTo2STtA&apptime=1774570738&share_id=9e0f3d552ce949329c213bf952170580&share_channel=wechat&wechatWid=cf7d7b017603e7a21208c2cb01c82c6f&wechatOrigin=menu", "content_rendered": "<p>不知道是不是迄