tar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70065, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9582, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 176904, "username": "uni", "url": "https://www.v2ex.com/u/uni", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/dd6a4e14a4462dcc14ac5df07a8cbb63?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/dd6a4e14a4462dcc14ac5df07a8cbb63?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/dd6a4e14a4462dcc14ac5df07a8cbb63?s=73&d=retro", "created": 1465643005, "last_modified": 1714192098, "pro": 0}, "last_reply_by": "Alexandry", "last_touched": 1773608765, "title": "现在购买 ssl 证书最具性价比的方案是什么？", "url": "https://www.v2ex.com/t/1198387", "created": 1773555492, "deleted": 0, "content": "给微信小程序后端域名用的\r\n\r\n网上搜了一下，阿里云提供的都要一千多一年了，在别的地方能搜到便宜一点的都要大几百，到处都是推广和广告，我感觉这个价格有水分，咸鱼上面很多几十块一年的，不知道是否靠谱？感觉这玩意好不透明，水太深了，希望有经验的兄弟能解惑", "content_rendered": "<p>给微信小程序后端域名用的</p>\n<p>网上搜了一下，阿里云提供的都要一千多一年了，在别的地方能搜到便宜一点的都要大几百，到处都是推广和广告，我感觉这个价格有水分，咸鱼上面很多几十块一年的，不知道是否靠谱？感觉这玩意好不透明，水太深了，希望有经验的兄弟能解惑</p>\n", "last_modified": 1773555492, "replies": 25, "id": 1198387}]