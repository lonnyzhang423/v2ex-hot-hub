[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70899, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9663, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 330060, "username": "BenjaminSu", "url": "https://www.v2ex.com/u/BenjaminSu", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=73&d=retro", "created": 1531963495, "last_modified": 1531963495, "pro": 0}, "last_reply_by": "Bingchunmoli", "last_touched": 1777785074, "title": "2026 年了， Notepad++ 对比 VSCode ，优势在哪？", "url": "https://www.v2ex.com/t/1210012", "created": 1777727158, "deleted": 0, "content": "讨论如题，优势在哪？\r\n身边的同事，不少人还在用着 Notepad++,刚微信文章也在说 Notepad++有 Mac 版本了，然后想到了这个问题。\r\n\r\n用过一段时间的 Notepad ，并没有感觉有非用不可得地步。\r\n本着工作流做减法的原则，然后就卸载了，统一用 VSCode 了。\r\n\r\n在我看来，Notepad 已经是上一代的产品了。", "content_rendered": "<p>讨论如题，优势在哪？\n身边的同事，不少人还在用着 Notepad++,刚微信文章也在说 Notepad++有 Mac 版本了，然后想到了这个问题。</p>\n<p>用过一段时间的 Notepad ，并没有感觉有非用不可得地步。\n本着工作流做减法的原则，然后就卸载了，统一用 VSCode 了。</p>\n<p>在我看来，Notepad 已经是上一代的产品了。</p>\n", "last_modified": 1777727158, "replies": 82, "id": 1210012}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_large.png?m=1630576706", "name": "invest", "avatar_normal": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_normal.png?m=1630576706", "title": "投资", "url": "https://www.v2ex.com/go/invest", "topics": 3489, "footer": "", "header": "Can you make money with money?", "title_alternative": "Invest", "avatar_mini": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_mini.png?m=1630576706", "stars": 4358, "founder_id": 0, "aliases": [], "root": false, "id": 171, "parent_node_name": "money"}, "member": {"id": 614018, "username": "tokas93", "url": "https://www.v2ex.com/u/tokas93", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=73&d=retro", "created": 1676336120, "last_modified": 1676336120, "pro": 0}, "last_reply_by": "way2explore2", "last_touched": 1777785600, "title": "决定开始定投标普 500 和纳指 100 了！", "url": "https://www.v2ex.com/t/1209961", "created": 1777700620, "deleted": 0, "content": "准备的子弹是 50w ，但是一个月只定投 1w ，这样的话今年开始的话，其实只有 6 个月，所以预留了 10w ，6w 拿来定投 1w ，4w 拿来补充回撤", "content_rendered": "<p>准备的子弹是 50w ，但是一个月只定投 1w ，这样的话今年开始的话，其实只有 6 个月，所以预留了 10w ，6w 拿来定投 1w ，4w 拿来补充回撤</p>\n", "last_modified": 1777708604, "replies": 75, "id": 1209961}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_large.png?m=1754172750", "name": "android", "avatar_normal": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_normal.png?m=1754172750", "title": "Android", "url": "https://www.v2ex.com/go/android", "topics": 12841, "footer": "", "header": "来自 <a href=\"/go/google\">Google</a> 的开放源代码智能手机平台。", "title_alternative": "Android", "avatar_mini": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_mini.png?m=1754172750", "stars": 6202, "founder_id": 0, "aliases": [], "root": false, "id": 39, "parent_node_name": "hardware"}, "member": {"id": 651782, "username": "NekoBoss", "url": "https://www.v2ex.com/u/NekoBoss", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f508/e70e/651782_mini.png?m=1695986604", "avatar_normal": "https://cdn.v2ex.com/avatar/f508/e70e/651782_normal.png?m=1695986604", "avatar_large": "https://cdn.v2ex.com/avatar/f508/e70e/651782_large.png?m=1695986604", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f508/e70e/651782_xlarge.png?m=1695986604", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f508/e70e/651782_xxlarge.png?m=1695986604", "created": 1695986468, "last_modified": 1695986604, "pro": 0}, "last_reply_by": "seers", "last_touched": 1777784768, "title": "安卓的权限管理是假的，拒绝了仍然可以获取", "url": "https://www.v2ex.com/t/1210002", "created": 1777720303, "deleted": 0, "content": "123 云盘 app ，在拒绝了获取访问剪贴板之后，仍然可以读取。\r\n起因是在酷安找到一个 app 旧版本的链接，是 123 云盘的，于是就复制了链接去浏览器下载，但是现在不能直接下载，需要用账号密码登录，不记得密码，于是就去 123 云盘 app 去设置密码。\r\n然后发现 app 直接弹窗提醒刚才复制的链接。\r\n于是之后进行更完整的测试：重新下载 app ，启动之前就拒绝权限，然后把手机上唯一一个可以写入和读取的输入法 app 也给拒绝。\r\n再次测试之后，仍然可以读取复制的链接。\r\n在手机权限记录中，可以看到 123 云盘读取剪贴板-已允许，点击进去之后，发现仍然是拒绝的。\r\n系统版本是小米澎湃 os3 。\r\n反观 iOS ，iOS 默认不显示从未申请过的权限，于是我创建了快捷指令，在 app 第一次申请剪贴板时，一键跳转到系统设置对应的 app 中选择永久拒绝。\r\n\r\n再次补充一点：国产安卓中还有拒绝访问应用列表的权限,如果拒绝了该权限，那么像酷安，taptap 这些软件就不知道手机上有什么 app 了。\r\n但是，有一个例外，那就是腾讯的应用宝 app ，无论你怎么拒绝，它始终知道手机上安装的 app 。", "content_rendered": "<p>123 云盘 app ，在拒绝了获取访问剪贴板之后，仍然可以读取。\n起因是在酷安找到一个 app 旧版本的链接，是 123 云盘的，于是就复制了链接去浏览器下载，但是现在不能直接下载，需要用账号密码登录，不记得密码，于是就去 123 云盘 app 去设置密码。\n然后发现 app 直接弹窗提醒刚才复制的链接。\n于是之后进行更完整的测试：重新下载 app ，启动之前就拒绝权限，然后把手机上唯一一个可以写入和读取的输入法 app 也给拒绝。\n再次测试之后，仍然可以读取复制的链接。\n在手机权限记录中，可以看到 123 云盘读取剪贴板-已允许，点击进去之后，发现仍然是拒绝的。\n系统版本是小米澎湃 os3 。\n反观 iOS ，iOS 默认不显示从未申请过的权限，于是我创建了快捷指令，在 app 第一次申请剪贴板时，一键跳转到系统设置对应的 app 中选择永久拒绝。</p>\n<p>再次补充一点：国产安卓中还有拒绝访问应用列表的权限,如果拒绝了该权限，那么像酷安，taptap 这些软件就不知道手机上有什么 app 了。\n但是，有一个例外，那就是腾讯的应用宝 app ，无论你怎么拒绝，它始终知道手机上安装的 app 。</p>\n", "last_modified": 1777720303, "replies": 71, "id": 1210002}, {"node": {"avatar_large": 