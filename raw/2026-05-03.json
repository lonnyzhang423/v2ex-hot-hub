[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_large.png?m=1630576706", "name": "invest", "avatar_normal": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_normal.png?m=1630576706", "title": "投资", "url": "https://www.v2ex.com/go/invest", "topics": 3489, "footer": "", "header": "Can you make money with money?", "title_alternative": "Invest", "avatar_mini": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_mini.png?m=1630576706", "stars": 4358, "founder_id": 0, "aliases": [], "root": false, "id": 171, "parent_node_name": "money"}, "member": {"id": 614018, "username": "tokas93", "url": "https://www.v2ex.com/u/tokas93", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/ca59916259eef93fa45faff664b89733?s=73&d=retro", "created": 1676336120, "last_modified": 1676336120, "pro": 0}, "last_reply_by": "freekindom", "last_touched": 1777739208, "title": "决定开始定投标普 500 和纳指 100 了！", "url": "https://www.v2ex.com/t/1209961", "created": 1777700620, "deleted": 0, "content": "准备的子弹是 50w ，但是一个月只定投 1w ，这样的话今年开始的话，其实只有 6 个月，所以预留了 10w ，6w 拿来定投 1w ，4w 拿来补充回撤", "content_rendered": "<p>准备的子弹是 50w ，但是一个月只定投 1w ，这样的话今年开始的话，其实只有 6 个月，所以预留了 10w ，6w 拿来定投 1w ，4w 拿来补充回撤</p>\n", "last_modified": 1777708604, "replies": 56, "id": 1209961}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_large.png?m=1754172750", "name": "android", "avatar_normal": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_normal.png?m=1754172750", "title": "Android", "url": "https://www.v2ex.com/go/android", "topics": 12841, "footer": "", "header": "来自 <a href=\"/go/google\">Google</a> 的开放源代码智能手机平台。", "title_alternative": "Android", "avatar_mini": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_mini.png?m=1754172750", "stars": 6202, "founder_id": 0, "aliases": [], "root": false, "id": 39, "parent_node_name": "hardware"}, "member": {"id": 651782, "username": "NekoBoss", "url": "https://www.v2ex.com/u/NekoBoss", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f508/e70e/651782_mini.png?m=1695986604", "avatar_normal": "https://cdn.v2ex.com/avatar/f508/e70e/651782_normal.png?m=1695986604", "avatar_large": "https://cdn.v2ex.com/avatar/f508/e70e/651782_large.png?m=1695986604", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f508/e70e/651782_xlarge.png?m=1695986604", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f508/e70e/651782_xxlarge.png?m=1695986604", "created": 1695986468, "last_modified": 1695986604, "pro": 0}, "last_reply_by": "cgroot", "last_touched": 1777744175, "title": "安卓的权限管理是假的，拒绝了仍然可以获取", "url": "https://www.v2ex.com/t/1210002", "created": 1777720303, "deleted": 0, "content": "123 云盘 app ，在拒绝了获取访问剪贴板之后，仍然可以读取。\r\n起因是在酷安找到一个 app 旧版本的链接，是 123 云盘的，于是就复制了链接去浏览器下载，但是现在不能直接下载，需要用账号密码登录，不记得密码，于是就去 123 云盘 app 去设置密码。\r\n然后发现 app 直接弹窗提醒刚才复制的链接。\r\n于是之后进行更完整的测试：重新下载 app ，启动之前就拒绝权限，然后把手机上唯一一个可以写入和读取的输入法 app 也给拒绝。\r\n再次测试之后，仍然可以读取复制的链接。\r\n在手机权限记录中，可以看到 123 云盘读取剪贴板-已允许，点击进去之后，发现仍然是拒绝的。\r\n系统版本是小米澎湃 os3 。\r\n反观 iOS ，iOS 默认不显示从未申请过的权限，于是我创建了快捷指令，在 app 第一次申请剪贴板时，一键跳转到系统设置对应的 app 中选择永久拒绝。\r\n\r\n再次补充一点：国产安卓中还有拒绝访问应用列表的权限,如果拒绝了该权限，那么像酷安，taptap 这些软件就不知道手机上有什么 app 了。\r\n但是，有一个例外，那就是腾讯的应用宝 app ，无论你怎么拒绝，它始终知道手机上安装的 app 。", "content_rendered": "<p>123 云盘 app ，在拒绝了获取访问剪贴板之后，仍然可以读取。\n起因是在酷安找到一个 app 旧版本的链接，是 123 云盘的，于是就复制了链接去浏览器下载，但是现在不能直接下载，需要用账号密码登录，不记得密码，于是就去 123 云盘 app 去设置密码。\n然后发现 app 直接弹窗提醒刚才复制的链接。\n于是之后进行更完整的测试：重新下载 app ，启动之前就拒绝权限，然后把手机上唯一一个可以写入和读取的输入法 app 也给拒绝。\n再次测试之后，仍然可以读取复制的链接。\n在手机权限记录中，可以看到 123 云盘读取剪贴板-已允许，点击进去之后，发现仍然是拒绝的。\n系统版本是小米澎湃 os3 。\n反观 iOS ，iOS 默认不显示从未申请过的权限，于是我创建了快捷指令，在 app 第一次申请剪贴板时，一键跳转到系统设置对应的 app 中选择永久拒绝。</p>\n<p>再次补充一点：国产安卓中还有拒绝访问应用列表的权限,如果拒绝了该权限，那么像酷安，taptap 这些软件就不知道手机上有什么 app 了。\n但是，有一个例外，那就是腾讯的应用宝 app ，无论你怎么拒绝，它始终知道手机上安装的 app 。</p>\n", "last_modified": 1777720303, "replies": 53, "id": 1210002}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1fc2/1400/864_large.png?m=1775086598", "name": "promotions", "avatar_normal": "https://cdn.v2ex.com/navatar/1fc2/1400/864_normal.png?m=1775086598", "title": "推广", "url": "https://www.v2ex.com/go/promotions", "topics": 11453, "footer": "", "header": "来自厂商的推广活动类主题，会被归类到这个节点。希望有情怀的产商们在发布推广内容时，主动选择发布到本节点下。点击 <a href=\"/help/node\">这里</a> 阅读 V2EX 的节点使用指南。", "title_alternative": "Promotions", "avatar_mini": "https://cdn.v2ex.com/navatar/1fc2/1400/864_mini.png?m=1775086598", "stars": 1226, "founder_id": 0, "aliases": [], "root": false, "id": 864, "parent_node_name": ""}, "member": {"id": 676532, "username": "livib", "url": "https://www.v2ex.com/u/livib", "website": "", "twitter": "", "psn": "", "github": "byoungd", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/d586/b382/676532_mini.png?m=1775706819", "avatar_normal": "https://cdn.v2ex.com/avatar/d586/b382/676532_normal.png?m=1775706819", "avatar_large": "https://cdn.v2ex.com/avatar/d586/b382/676532_large.png?m=1775706819", "avatar_xlarge": "https://cdn.v2ex.com/avatar/d586/b382/676532_xlarge.png?m=1775706819", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/d586/b382/676532_xxlarge.png?m=1775706819", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/d586/b382/676532_xxxlarge.png?m=1775706819", "created": 1708412308, "last_modified": 1775706819, "pro": 0}, "last_reply_by": "kwistzzqq", "last_touched": 1777690359, "title": "ChatGPT Pro 低价兑换 最后的绝唱了 全网唯一 ku0.com 抽奖送一个 Pro 5x", "url": "https://www.v2ex.com/t/1209942", "created": 1777690202, "deleted": 0, "content": "市面上仅存的所有货全部扫光\r\n\r\n\r\nhttps://ku0.com 库 可信任资源库\r\n\r\n\r\nChatGPT Pro 5x / 20x （已经孤品，未上架）\r\n\r\nV 友购买返现 20 红包 \r\n\r\n最后的狂欢了 团队也准备撤了 一个时代就此落幕\r\n\r\n\r\n-----\r\n\r\n 随机楼层抽奖先送 1 个 Pro 5x 后续奖品看活动情况", "content_rendered": "市面上仅存的所有货全部扫光<br /><br /><br /><a target=\"_blank\" href=\"https://ku0.com\" rel=\"nofollow noopener\">https://ku0.com</a> 库 可信任资源库<br /><br /><br />ChatGPT Pro 5x / 20x （已经孤品，未上架）<br /><br />V 友购买返现 20 红包 <br /><br />最后的狂欢了 团队也准备撤了 一个时代就此落幕<br /><br /><br />-----<br /><br /> 随机楼层抽奖先送 1 个 Pro 5x 后续奖品看活动情况", "last_modified": 1777690596, "replies": 42, "id": 1209942}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70898, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9662, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 330060, "username": "BenjaminSu", "url": "https://www.v2ex.com/u/BenjaminSu", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/10ebee33a8890792e1fbd58e390fe4f7?s=73&d=retro", "created": 1531963495, "last_modified": 1531963495, "pro": 0}, "last_reply_by": "JFZ", "last_touched": 1777753253, "title": "2026 年了， Notepad++ 对比 VSCode ，优势在哪？", "url": "https://www.v2ex.com/t/1210012", "created": 1777727158, "deleted": 0, "content": "讨论如题，优势在哪？\r\n身边的同事，不少人还在用着 Notepad++,刚微信文章也在说 Notepad++有 Mac 版本了，然后想到了这个问题。\r\n\r\n用过一段时间的 Notepad ，并没有感觉有非用不可得地步。\r\n本着工作流做减法的原则，然后就卸载了，统一用 VSCode 了。\r\n\r\n在我看来，Notepad 已经是上一代的产品了。", "content_rendered": "<p>讨论如题，优势在哪？\n身边的同事，不少人还在用着 Notepad++,刚微信文章也在说 Notepad++有 Mac 版本了，然后想到了这个问题。</p>\n<p>用过一段时间的 Notepad ，并没有感觉有非用不可得地步。\n本着工作流做减法的原则，然后就卸载了，统一用 VSCode 了。</p>\n<p>在我看来，Notepad 已经是上一代的产品了。</p>\n", "last_modified": 1777727158, "replies": 37, "id": 1210012}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_large.png?m=1691642161", "name": "bb", "avatar_normal": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_normal.png?m=1691642161", "title": "宽带症候群", "url": "https://www.v2ex.com/go/bb", "topics": 18641, "footer": "", "header": "网速很重要。比快更快。", "title_alternative": "Broadband Symptom Complex", "avatar_mini": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_mini.png?m=1691642161", "stars": 8221, "founder_id": 0, "aliases": [], "root": false, "id": 108, "parent_node_name": "geek"}, "member": {"id": 492684, "username": "xyzzyssd", "url": "https://www.v2ex.com/u/xyzzyssd", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/901a1d65aa615f4100579efc29525813?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/901a1d65aa615f4100579efc29525813?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/901a1d65aa615f4100579efc29525813?s=73&d=retro", "created": 1591044757, "last_modified": 1591044757, "pro": 0}, "last_reply_by": "leetcode2020", "last_touched": 1777732260, "title": "如何在国内受限网络环境下使用官方 claude 或 codex 等模型？", "url": "https://www.v2ex.com/t/1209960", "created": 1777700117, "deleted": 0, "content": "单位环境不能装 vpn ，但我自己账户还是订阅了 codex 等服务。想问下有没有什么优雅的方式使用原版服务呢？我目前有两种想法：\r\n1. 海外搞个服务器，上面跑一个 CLI ，本地通过 ssh 连接\r\n2. 海外服务器上部署 CLIProxyAPI 把 codex 转成 api 然后本地 codex 修改供应商到这个 api\r\n\r\n这两种办法有尝试过吗？感觉第二个更方便但第一个更安全？大佬们有什么经验吗？", "content_rendered": "<p>单位环境不能装 vpn ，但我自己账户还是订阅了 codex 等服务。想问下有没有什么优雅的方式使用原版服务呢？我目前有两种想法：</p>\n<ol>\n<li>海外搞个服务器，上面跑一个 CLI ，本地通过 ssh 连接</li>\n<li>海外服务器上部署 CLIProxyAPI 把 codex 转成 api 然后本地 codex 修改供应商到这个 api</li>\n</ol>\n<p>这两种办法有尝试过吗？感觉第二个更方便但第一个更安全？大佬们有什么经验吗？</p>\n", "last_modified": 1777718499, "replies": 34, "id": 1209960}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/7022/2949/1290_large.png?m=1772417478", "name": "skills", "avatar_normal": "https://cdn.v2ex.com/navatar/7022/2949/1290_normal.png?m=1772417478", "title": "技术栈", "url": "https://www.v2ex.com/go/skills", "topics": 17, "footer": "以超级个体为目标，遵循客观规律、自力更生、创造影响力为核心。\r\n1. 分析这个世界的一部分  \r\n2. 用代码高效准确地描述这个世界的一部分  \r\n3. 设计一种自动化传播你的想法的机制  \r\n\r\n善意。一个对世界怀抱善意的想法才能走得足够远。", "header": "一个技能、一个经验、一个套路 | 人人都是超级个体", "title_alternative": "技术栈", "avatar_mini": "https://cdn.v2ex.com/navatar/7022/2949/1290_mini.png?m=1772417478", "stars": 14, "founder_id": 624907, "aliases": [], "root": false, "id": 1290, "parent_node_name": null}, "member": {"id": 624907, "username": "JieyueXing", "url": "https://www.v2ex.com/u/JieyueXing", "website": "jie.v2ex.pro", "twitter": "jieyuexing", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/59da/4184/624907_mini.png?m=1775884346", "avatar_normal": "https://cdn.v2ex.com/avatar/59da/4184/624907_normal.png?m=1775884346", "avatar_large": "https://cdn.v2ex.com/avatar/59da/4184/624907_large.png?m=1775884346", "avatar_xlarge": "https://cdn.v2ex.com/avatar/59da/4184/624907_xlarge.png?m=1775884346", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/59da/4184/624907_xxlarge.png?m=1775884346", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/59da/4184/624907_xxxlarge.png?m=1775884346", "created": 1681909224, "last_modified": 1775884346, "pro": 1777752767}, "last_reply_by": "amlee", "last_touched": 1777740681, "title": "AI 时代， Java 中短期的地位不降反增", "url": "https://www.v2ex.com/t/1209937", "created": 1777689421, "deleted": 0, "content": "AI 的兴起在 Java 面前只能算是一个稚童。\r\n一些人借 AI 炒热度造铲子，搞得像新兴的邪修门派功法，并借此开宗立派喊口号，一度造成了几十年的名门正派中的内外门弟子都感觉马上要被颠覆的错觉。\r\n但在真正的 AGI 到来前，AI 不会颠覆现在的传统编程语言，只会融入到传统编程语言中，这种新兴的理念会被名门正派所吸收。\r\nJava 在企业级场景下占据主导地位。现实世界的逻辑是大量 Java 基建项目与 AI 结合，在原有的商业闭环中迭代与进步，这也是 Java 8 这些年屹立不动的原因——而不是幻想着用 AI 加上一门轻量快速的编程语言，就能随时造出商业铲子、一人 OPC 改变命运。\r\n商业的本质是闭环。AI 是放大器，放大个人和已有的商业闭环的效率，而不是因为新时代造楼效率有突破，就跟随喊高口号的人流，把原有的大楼推翻，再建一个自认为创新的小屋等着别人住进来。", "content_rendered": "AI 的兴起在 Java 面前只能算是一个稚童。<br />一些人借 AI 炒热度造铲子，搞得像新兴的邪修门派功法，并借此开宗立派喊口号，一度造成了几十年的名门正派中的内外门弟子都感觉马上要被颠覆的错觉。<br />但在真正的 AGI 到来前，AI 不会颠覆现在的传统编程语言，只会融入到传统编程语言中，这种新兴的理念会被名门正派所吸收。<br />Java 在企业级场景下占据主导地位。现实世界的逻辑是大量 Java 基建项目与 AI 结合，在原有的商业闭环中迭代与进步，这也是 Java 8 这些年屹立不动的原因——而不是幻想着用 AI 加上一门轻量快速的编程语言，就能随时造出商业铲子、一人 OPC 改变命运。<br />商业的本质是闭环。AI 是放大器，放大个人和已有的商业闭环的效率，而不是因为新时代造楼效率有突破，就跟随喊高口号的人流，把原有的大楼推翻，再建一个自认为创新的小屋等着别人住进来。", "last_modified": 1777689421, "replies": 30, "id": 1209937}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3c59/dc04/21_large.png?m=1650127623", "name": "shenzhen", "avatar_normal": "https://cdn.v2ex.com/navatar/3c59/dc04/21_normal.png?m=1650127623", "title": "深圳", "url": "https://www.v2ex.com/go/shenzhen", "topics": 3523, "footer": "", "header": "", "title_alternative": "Shenzhen", "avatar_mini": "https://cdn.v2ex.com/navatar/3c59/dc04/21_mini.png?m=1650127623", "stars": 2124, "founder_id": 0, "aliases": [], "root": false, "id": 21, "parent_node_name": "cn"}, "member": {"id": 620774, "username": "beasnail", "url": "https://www.v2ex.com/u/beasnail", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=73&d=retro", "created": 1679729308, "last_modified": 1679729308, "pro": 0}, "last_reply_by": "liuzhihang", "last_touched": 1777745950, "title": "有人在推特展示深圳高中的情况...", "url": "https://www.v2ex.com/t/1210004", "created": 1777720945, "deleted": 0, "content": "老外很疑惑，为什么他们晚上还要上学\r\n\r\n😰😰😰😰😰\r\n\r\nhttps://x.com/ed_dems/status/2050423204036911109", "content_rendered": "<p>老外很疑惑，为什么他们晚上还要上学</p>\n<p>😰😰