[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11173, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2379, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 545059, "username": "rxswift", "url": "https://www.v2ex.com/u/rxswift", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_mini.png?m=1750306012", "avatar_normal": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_normal.png?m=1750306012", "avatar_large": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_large.png?m=1750306012", "avatar_xlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xlarge.png?m=1750306012", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xxlarge.png?m=1750306012", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/748a/7ef3/545059_xxxlarge.png?m=1750306012", "created": 1620724109, "last_modified": 1750306012, "pro": 0}, "last_reply_by": "unused", "last_touched": 1783125363, "title": "看《感觉女友很爱去看演唱会，不想让她去怎么办》有感，人生真正的享受是什么", "url": "https://www.v2ex.com/t/1224760", "created": 1783061557, "deleted": 0, "content": "贴一下原文：[感觉女友很爱去看演唱会，不想让她去怎么办]( https://www.v2ex.com/t/1224428#reply273)  \r\n作为我个人肯定觉得去看演唱会，费钱又费精力。不如自己呆在空调房里，打打游戏、睡睡觉、vibecoding 一下、看看电影。    \r\n但从他女朋友的角度，可能人家就是喜欢追星呢，就喜欢花大几千去看演唱会呢  \r\n各位觉得人生真正的享受是什么样的", "content_rendered": "<p>贴一下原文：<a href=\"https://www.v2ex.com/t/1224428#reply273\" rel=\"nofollow\">感觉女友很爱去看演唱会，不想让她去怎么办</a><br/>\n作为我个人肯定觉得去看演唱会，费钱又费精力。不如自己呆在空调房里，打打游戏、睡睡觉、vibecoding 一下、看看电影。<br/>\n但从他女朋友的角度，可能人家就是喜欢追星呢，就喜欢花大几千去看演唱会呢<br/>\n各位觉得人生真正的享受是什么样的</p>\n", "last_modified": 1783082198, "replies": 89, "id": 1224760}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71872, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9720, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 571634, "username": "123128xyz", "url": "https://www.v2ex.com/u/123128xyz", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/cbe9fb364138757f76e872e0ca8ee5f1?s=73&d=retro", "created": 1643703509, "last_modified": 1782739315, "pro": 0}, "last_reply_by": "aaa0009", "last_touched": 1783128008, "title": "我预判，第一波 AI 洪峰已过！", "url": "https://www.v2ex.com/t/1224778", "created": 1783065265, "deleted": 0, "content": "AI coding 趋势终于拐点了！\r\n\r\n**我预判，第一波 AI 洪峰已过。**\r\n\r\n\r\n据我观察**4 个方面**:\r\n\r\n1 、第三方价格数据(暴跌，需求减少)：\r\n\r\nGeminiPro 一年会员自动开通 CDK 包绑卡订阅 **¥12**\r\n\r\nChatGPT  [带 RT ]  [ Plus 成品号]  **¥15**\r\n\r\n2 、v 站数据（话题占比下降）：\r\n\r\n据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势\r\n\r\n3 、个人数据：\r\n\r\n短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。\r\n\r\n4 、小红书数据：\r\n\r\n前段时间->vibe coding 帖子热度极高。\r\n\r\n很多**不懂代码的人**。\r\n\r\n偶然有一个/多个想法->开通 ai 会员(短期)->生成 app （养猫\\遛狗\\逗娃..）\r\n\r\n后面在于推广维护，短期很难再有一个新想法。\r\n\r\n**看懂趋势比埋头苦干更有价值！**\r\n\r\n真的需要，**说说大家的感觉**，比如公司使用，个人观察，中转站数据？", "content_rendered": "<p>AI coding 趋势终于拐点了！</p>\n<p><strong>我预判，第一波 AI 洪峰已过。</strong></p>\n<p>据我观察<strong>4 个方面</strong>:</p>\n<p>1 、第三方价格数据(暴跌，需求减少)：</p>\n<p>GeminiPro 一年会员自动开通 CDK 包绑卡订阅 <strong>¥12</strong></p>\n<p>ChatGPT  [带 RT ]  [ Plus 成品号]  <strong>¥15</strong></p>\n<p>2 、v 站数据（话题占比下降）：</p>\n<p>据观察 V 站上月 AI 话题占比趋近 100%，当前占比也有下降趋势</p>\n<p>3 、个人数据：</p>\n<p>短期使用量，也明显下跌。不可能永远有新项目，只有初版稳定之后就不会再有暴力 token 需求。</p>\n<p>4 、小红书数据：</p>\n<p>前段时间-&gt;vibe coding 帖子热度极高。</p>\n<p>很多<strong>不懂代码的人</strong>。</p>\n<p>偶然有一个/多个想法-&gt;开通 ai 会员(短期)-&gt;生成 app （养猫\\遛狗\\逗娃..）</p>\n<p>后面在于推广维护，短期很难再有一个新想法。</p>\n<p><strong>看懂趋势比埋头苦干更有价值！</strong></p>\n<p>真的需要，<strong>说说大家的感觉</strong>，比如公司使用，个人观察，中转站数据？</p>\n", "last_modified": 1783065487, "replies": 74, "id": 1224778}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239653, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 623288, "username": "Y25tIGxpdmlk", "url": "https://www.v2ex.com/u/Y25tIGxpdmlk", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=73&d=retro", "created": 1681019214, "last_modified": 1716984949, "pro": 0}, "last_reply_by": "nsjs", "last_touched": 1783143728, "title": "暗色模式到底是怎么流行起来的？？", "url": "https://www.v2ex.com/t/1224886", "created": 1783131113, "deleted": 0, "content": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。\r\n作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。\r\n有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。\r\n\r\n夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。\r\n日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "content_rendered": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。<br />作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。<br />有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。<br /><br />夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。<br />日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "last_modified": 1783131113, "replies": 53, "id": 1224886}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239653, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 604449, "username": "gotOwt", "url": "https://www.v2ex.com/u/gotOwt", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_mini.png?m=1781573104", "avatar_normal": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_normal.png?m=1781573104", "avatar_large": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_large.png?m=1781573104", "avatar_xlarge": "https://cdn.v2ex.com/avatar/aeb0/c0ec/604449_xlarge.png?m=1781573104", "created": 1669943889, "last_modified": 1781573104, "pro": 0}, "last_reply_by": "oLUCKo", "last_touched": 1783095545, "title": "家里孩子生了，请帮忙取个名字", "url": "https://www.v2ex.com/t/1224777", "created": 1783065171, "deleted": 0, "content": "姓先不跟你们说了。\r\n麻烦帮忙取下吧。", "content_rendered": "<p>姓先不跟你们说了。\n麻烦帮忙取下吧。</p>\n", "last_modified": 1783065191, "replies": 51, "id": 1224777}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239653, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 259170, "username": "syc001", "url": "https://www.v2ex.com/u/syc001", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/beaa/cbb1/259170_mini.png?m=1783062997", "avatar_normal": "https://cdn.v2ex.com/avatar/beaa/cbb1/259170_normal.png?m=1783062997", "avatar_large": "https://cdn.v2ex.com/avatar/beaa/cbb1/259170_large.png?m=1783062997", "created": 1507791337, "last_modified": 1783062997, "pro": 0}, "last_reply_by": "defaw", "last_touched": 1783136231, "title": "因存在植入后门风险，阿里内部全面禁用 Claude Code", "url": "https://www.v2ex.com/t/1224766", "created": 1783063004, "deleted": 0, "content": "自 7 月 10 日起，阿里将全面禁止内部员工在办公环境下使用 Claude Code ，并推荐使用 Qoder 作为替代方案。\r\n这是玩不起了吗", "content_rendered": "自 7 月 10 日起，阿里将全面禁止内部员工在办公环境下使用 Claude Code ，并推荐使用 Qoder 作为替代方案。<br />这是玩不起了吗", "last_modified": 1783063004, "replies": 49, "id": 1224766}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_large.png?m=1630643913", "name": "apple", "avatar_normal": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_normal.png?m=1630643913", "title": "Apple", "url": "https://www.v2ex.com/go/apple", "topics": 30828, "footer": "", "header": "设计了 <a href=\"/go/watch\">Apple Watch</a>，<a href=\"/go/ipad\">iPad</a>，<a href=\"/go/iphone\">iPhone</a>，<a href=\"/go/imac\">iMac</a> 及 <a href=\"/go/mbp\">MacBook Pro</a> 等电子产品的美国公司。", "title_alternative": "Apple", "avatar_mini": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_mini.png?m=1630643913", "stars": 3325, "founder_id": 0, "aliases": [], "root": false, "id": 184, "parent_node_name": "hardware"}, "member": {"id": 406395, "username": "xxw1754352621", "url": "https://www.v2ex.com/u/xxw1754352621", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_mini.png?m=1773115604", "avatar_normal": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_normal.png?m=1773115604", "avatar_large": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_large.png?m=1773115604", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xlarge.png?m=1773115604", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xxlarge.png?m=1773115604", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xxxlarge.png?m=1773115604", "created": 1556249871, "last_modified": 1773115604, "pro": 0}, "last_reply_by": "msdurex", "last_touched": 1783136104, "title": "因为帮朋友代充了 ChatGPT Plus，我的 Apple ID 不干净了", "url": "https://www.v2ex.com/t/1224834", "created": 1783078610, "deleted": 0, "content": "起因是前几个月，我用我的美区 Apple Id ，帮我朋友代充了 ChatGPT Plus ，后面这个订阅过期了。\r\n\r\n后来我朋友用自己注册的美区 Apple Id 给自己的 ChatGPT 充值了。\r\n\r\n我最近由于工作需要使用 Codex ，准备自己充一波，钱扣了，然后提示什么错误，发现没有充上。\r\n\r\n点击恢复购买，提示 “你的 AppleID 购买项目关联到另一个 ChatGPT 账号。巴拉巴拉...”。\r\n\r\n后面跟我朋友联系，发现充到他的账号上了。并且是覆盖式的，他在 6 月 30 号充值的，我今天 7 月 3 号 充值的。他的 ChatGPT 账号显示 8 月 3 号过期...\r\n\r\n后来翻阅相关文档，发现是永久绑定的，天塌了！这个美区 Apple ID 是我长期使用的...以前真不知道，还有这样的操作", "content_rendered": "<p>起因是前几个月，我用我的美区 Apple Id ，帮我朋友代充了 ChatGPT Plus ，后面这个订阅过期了。</p>\n<p>后来我朋友用自己注册的美区 Apple Id 给自己的 ChatGPT 充值了。</p>\n<p>我最近由于工作需要使用 Codex ，准备自己充一波，钱扣了，然后提示什么错误，发现没有充上。</p>\n<p>点击恢复购买，提示 “你的 AppleID 购买项目关联到另一个 ChatGPT 账号。巴拉巴拉...”。</p>\n<p>后面跟我朋友联系，发现充到他的账号上了。并且是覆盖式的，他在 6 月 30 号充值的，我今天 7 月 3 号 充值的。他的 ChatGPT 账号显示 8 月 3 号过期...</p>\n<p>后来翻阅相关文档，发现是永久绑定的，天塌了！这个美区 Apple ID 是我长期使用的...以前真不知道，还有这样的操作</p>\n", "last_modified": 1783078610, "replies": 36, "id": 1224834}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71872, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9720, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 450720, "username": "twk93", "url": "https://www.v2ex.com/u/twk93", "website": "https://www.uwarp.design", "twitter": "819573105Vic", "psn": "", "github": "sherotree", "btc": "", "location": "", "tagline": "uwarp.design", "bio": "独立开发者&产品设计师，专注于打造小而美的设计工具", "avatar_mini": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_mini.png?m=1761381542", "avatar_normal": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_normal.png?m=1761381542", "avatar_large": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_large.png?m=1761381542", "avatar_xlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xlarge.png?m=1761381542", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xxlarge.png?m=1761381542", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xxxlarge.png?m=1761381542", "created": 1572683453, "last_modified": 1761381542, "pro": 1783143762}, "last_reply_by": "xing3kong", "last_touched": 1783143799, "title": "Claude 账号被封风险检测工具", "url": "https://www.v2ex.com/t/1224898", "created": 1783134549, "deleted": 0, "content": "Claude Code 的封号思路：Claude Code 会偷偷读取你电脑上的本地信息，然后用一种肉眼完全看不到的方式，悄悄给你发送给 AI 服务器的每一个请求，打上「这个人是中国用户」的隐形标记，传回 Anthropic 的服务器。昨天看到社区上 LinXiaoTao 开发了个一键检测功能，挺好用的，将这个功能集成到了 Uwarp\r\n\r\n[Fuck Claude 一键检测]( https://www.uwarp.design/fuck-clau