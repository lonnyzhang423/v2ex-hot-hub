[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239655, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 623288, "username": "Y25tIGxpdmlk", "url": "https://www.v2ex.com/u/Y25tIGxpdmlk", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/2f59b786fd9cd2ec2b95720531ebbe83?s=73&d=retro", "created": 1681019214, "last_modified": 1716984949, "pro": 0}, "last_reply_by": "Chentao1006", "last_touched": 1783152551, "title": "暗色模式到底是怎么流行起来的？？", "url": "https://www.v2ex.com/t/1224886", "created": 1783131113, "deleted": 0, "content": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。\r\n作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。\r\n有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。\r\n\r\n夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。\r\n日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "content_rendered": "RT ，现在基本上但凡 IT 数码沾点边的站点或者软件，进去默认都是夜间模式、暗色模式。<br />作为一个讨厌暗色模式的人，每次进去都要找半天日渐模式按钮在哪里，有些在右上角或者左下角直接可以切换的还好。<br />有些 TM 的直接没有切换按钮或者藏在设置页深处的，简直想打人。<br /><br />夜间模式到底好在哪里啊？护眼吗？好像没有科学依据证明啊。<br />日间模式看着多舒服啊，各种设计颜色都是原始的，夜间模式好多界面颜色啥的设计都变乱了，很丑啊。", "last_modified": 1783131113, "replies": 71, "id": 1224886}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71872, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9720, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 450720, "username": "twk93", "url": "https://www.v2ex.com/u/twk93", "website": "https://www.uwarp.design", "twitter": "819573105Vic", "psn": "", "github": "sherotree", "btc": "", "location": "", "tagline": "uwarp.design", "bio": "独立开发者&产品设计师，专注于打造小而美的设计工具", "avatar_mini": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_mini.png?m=1761381542", "avatar_normal": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_normal.png?m=1761381542", "avatar_large": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_large.png?m=1761381542", "avatar_xlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xlarge.png?m=1761381542", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xxlarge.png?m=1761381542", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/b9b4/aec4/450720_xxxlarge.png?m=1761381542", "created": 1572683453, "last_modified": 1761381542, "pro": 1783153097}, "last_reply_by": "FaustinaD", "last_touched": 1783151973, "title": "Claude 账号被封风险检测工具", "url": "https://www.v2ex.com/t/1224898", "created": 1783134549, "deleted": 0, "content": "Claude Code 的封号思路：Claude Code 会偷偷读取你电脑上的本地信息，然后用一种肉眼完全看不到的方式，悄悄给你发送给 AI 服务器的每一个请求，打上「这个人是中国用户」的隐形标记，传回 Anthropic 的服务器。昨天看到社区上 LinXiaoTao 开发了个一键检测功能，挺好用的，将这个功能集成到了 Uwarp\r\n\r\n[Fuck Claude 一键检测]( https://www.uwarp.design/fuck-claude)\r\n\r\n\r\n![]( https://i.v2ex.co/BYIWi1QN.png)", "content_rendered": "<p>Claude Code 的封号思路：Claude Code 会偷偷读取你电脑上的本地信息，然后用一种肉眼完全看不到的方式，悄悄给你发送给 AI 服务器的每一个请求，打上「这个人是中国用户」的隐形标记，传回 Anthropic 的服务器。昨天看到社区上 LinXiaoTao 开发了个一键检测功能，挺好用的，将这个功能集成到了 Uwarp</p>\n<p><a href=\"https://www.uwarp.design/fuck-claude\" rel=\"nofollow\">Fuck Claude 一键检测</a></p>\n<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.v2ex.co/BYIWi1QN.png\"/></p>\n", "last_modified": 1783134549, "replies": 47, "id": 1224898}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_large.png?m=1630643913", "name": "apple", "avatar_normal": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_normal.png?m=1630643913", "title": "Apple", "url": "https://www.v2ex.com/go/apple", "topics": 30829, "footer": "", "header": "设计了 <a href=\"/go/watch\">Apple Watch</a>，<a href=\"/go/ipad\">iPad</a>，<a href=\"/go/iphone\">iPhone</a>，<a href=\"/go/imac\">iMac</a> 及 <a href=\"/go/mbp\">MacBook Pro</a> 等电子产品的美国公司。", "title_alternative": "Apple", "avatar_mini": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_mini.png?m=1630643913", "stars": 3325, "founder_id": 0, "aliases": [], "root": false, "id": 184, "parent_node_name": "hardware"}, "member": {"id": 406395, "username": "xxw1754352621", "url": "https://www.v2ex.com/u/xxw1754352621", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_mini.png?m=1773115604", "avatar_normal": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_normal.png?m=1773115604", "avatar_large": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_large.png?m=1773115604", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xlarge.png?m=1773115604", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xxlarge.png?m=1773115604", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/f9cb/9fdb/406395_xxxlarge.png?m=1773115604", "created": 1556249871, "last_modified": 1773115604, "pro": 0}, "last_reply_by": "blockmin", "last_touched": 1783151764, "title": "因为帮朋友代充了 ChatGPT Plus，我的 Apple ID 不干净了", "url": "https://www.v2ex.com/t/1224834", "created": 1783078610, "deleted": 0, "content": "起因是前几个月，我用我的美区 Apple Id ，帮我朋友代充了 ChatGPT Plus ，后面这个订阅过期了。\r\n\r\n后来我朋友用自己注册的美区 Apple Id 给自己的 ChatGPT 充值了。\r\n\r\n我最近由于工作需要使用 Codex ，准备自己充一波，钱扣了，然后提示什么错误，发现没有充上。\r\n\r\n点击恢复购买，提示 “你的 AppleID 购买项目关联到另一个 ChatGPT 账号。巴拉巴拉...”。\r\n\r\n后面跟我朋友联系，发现充到他的账号上了。并且是覆盖式的，他在 6 月 30 号充值的，我今天 7 月 3 号 充值的。他的 ChatGPT 账号显示 8 月 3 号过期...\r\n\r\n后来翻阅相关文档，发现是永久绑定的，天塌了！这个美区 Apple ID 是我长期使用的...以前真不知道，还有这样的操作", "content_rendered": "<p>起因是前几个月，我用我的美区 Apple Id ，帮我朋友代充了 ChatGPT Plus ，后面这个订阅过期了。</p>\n<p>后来我朋友用自己注册的美区 Apple Id 给自己的 ChatGPT 充值了。</p>\n<p>我最近由于工作需要使用 Codex ，准备自己充一波，钱扣了，然后提示什么错误，发现没有充上。</p>\n<p>点击恢复购买，提示 “你的 AppleID 购买项目关联到另一个 ChatGPT 账号。巴拉巴拉...”。</p>\n<p>后面跟我朋友联系，发现充到他的账号上了。并且是覆盖式的，他在 6 月 30 号充值的，我今天 7 月 3 号 充值的。他的 ChatGPT 账号显示 8 月 3 号过期...</p>\n<p>后来翻阅相关文档，发现是永久绑定的，天塌了！这个美区 Apple ID 是我长期使用的...以前真不知道，还有这样的操作</p>\n", "last_modified": 1783078610, "replies": 39, "id": 1224834}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/735b/90b4/67_large.png?m=1706750053", "name": "taste", "avatar_normal": "https://cdn.v2ex.com/navatar/735b/90b4/67_normal.png?m=1706750053", "title": "美酒与美食", "url": "https://www.v2ex.com/go/taste", "topics": 874, "footer": "", "header": "关于那些好喝和好吃的", "title_alternative": "Taste", "avatar_mini": "https://cdn.v2ex.com/navatar/735b/90b4/67_mini.png?m=1706750053", "stars": 843, "founder_id": 0, "aliases": [], "root": false, "id": 67, "parent_node_name": "life"}, "member": {"id": 554904, "username": "11000111010", "url": "https://www.v2ex.com/u/11000111010", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/2849eb464101d4e008226d658410ce10?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/2849eb464101d4e008226d658410ce10?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/2849eb464101d4e008226d658410ce10?s=73&d=retro", "created": 1630486935, "last_modified": 1753324501, "pro": 0}, "last_reply_by": "sherryspaopao", "last_touched": 1783117468, "title": "咸粽子好吃还是甜粽子好吃？", "url": "https://www.v2ex.com/t/1224812", "created": 1783071150, "deleted": 0, "content": "本人经常吃甜粽子，感觉甜粽子好吃，但是上一个端午节 朋友从南方寄过来几个咸粽子，有叉烧肉咸蛋黄的，有腊肉的还有一个是包的鲜肉粽。感觉都能接受呢？（把币扔给我🤣）", "content_rendered": "本人经常吃甜粽子，感觉甜粽子好吃，但是上一个端午节 朋友从南方寄过来几个咸粽子，有叉烧肉咸蛋黄的，有腊肉的还有一个是包的鲜肉粽。感觉都能接受呢？（把币扔给我🤣）", "last_modified": 1783128791, "replies": 36, "id": 1224812}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11173, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2379, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 410741, "username": "loving29cn", "url": "https://www.v2ex.com/u/loving29cn", "website": "https://www.lajiaohttp.com?kwd=hyj-v2ex", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6ab4/388e/410741_mini.png?m=1782264977", "avatar_normal": "https://cdn.v2ex.com/avatar/6ab4/388e/410741_normal.png?m=1782264977", "avatar_large": "https://cdn.v2ex.com/avatar/6ab4/388e/410741_large.png?m=1782264977", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6ab4/388e/410741_xlarge.png?m=1782264977", "created": 1557396422, "last_modified": 1782264977, "pro": 0}, "last_reply_by": "copperDC", "last_touched": 1783112815, "title": "求一个好用的蓝牙耳机推荐", "url": "https://www.v2ex.com/t/1224791", "created": 1783068136, "deleted": 0, "content": "来个不要那么贵的，便宜一点的，质量还可以的，没有运动什么的需求，就平时听听歌，没有噪音，不会断连就行，续航差不多就行，我丢的就剩充电舱了，有线耳机又很容易缠绕，求一个大家用的趁手的", "content_rendered": "<p>来个不要那么贵的，便宜一点的，质量还可以的，没有运动什么的需求，就平时听听歌，没有噪音，不会断连就行，续航差不多就行，我丢的就剩充电舱了，有线耳机又很容易缠绕，求一个大家用的趁手的</p>\n", "last_modified": 1783068136, "replies": 33, "id": 1224791}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/39e4/973b/1248_large.png?m=1782710839", "name": "isv", "avatar_normal": "https://cdn.v2ex.com/navatar/39e4/973b/1248_normal.png?m=1782710839", "title": "独立开发者 👨‍💻", "url": "https://www.v2ex.com/go/isv", "topics": 68, "footer": "独立开发者节点右侧广告位为公益广告位, 免费开放给独立开发者申请", "header": "独立软件开发商(Independent Software Vendors)\r\n\r\n---\r\n\r\n这里旨在给开发者们提供一个相对聚焦的知识板块.\r\n\r\n愿每一位独立开发者都能保持初心, 都能获得一个好的结果.", "title_alternative": "独立开发者 👨‍💻", "avatar_mini": "https://cdn.v2ex.com/navatar/39e4/973b/1248_mini.png?m=1782710839", "stars": 220, "founder_id": 531733, "aliases": [], "root": false, "id": 1248, "parent_node_name": null}, "member": {"id": 660606, "username": "RmondJone", "url": "https://www.v2ex.com/u/RmondJone", "website": "https://rmondjone.github.io/", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "失业码农 家里蹲煮夫", "avatar_mini": "https://cdn.v2ex.com/avatar/1617/0aed/660606_mini.png?m=1779171096", "avatar_normal": "https://cdn.v2ex.com/avatar/1617/0aed/660606_normal.png?m=1779171096", "avatar_large": "https://cdn.v2ex.com/avatar/1617/0aed/660606_large.png?m=1779171096", "avatar_xlarge": "https://cdn.v2ex.com/avatar/1617/0aed/660606_xlarge.png?m=1779171096", "created": 1699195326, "last_modified": 1779171096, "pro": 0}, "last_reply_by": "RmondJone", "last_touched": 1783152705, "title": "问大佬们个问题， App 只要接了手机验证码就需要办理等保二级？", "url": "https://www.v2ex.com/t/1224876", "created": 1783123239, "deleted": 0, "content": "今天抖音上面刷到一个哥们，被网安叫到派出所交了 5 万的罚款，就因为他上架的 App 没有做等保。他说他只收集了用户的手机号，只有十几个用户，就被要求做等保三级，这是什么规定？有了解的老哥出来说说?查了下还挺贵的，二级是每年 2 万，三级是每年 5 万。\r\n\r\n这样搞国内市场看来真的得放弃了，还没有什么成果呢，上来就要交钱，不交钱就得吃罚款！", "content_rendered": "<p>今天抖音上面刷到一个哥们，被网安叫到派出所交了 5 万的罚款，就因为他上架的 App 没有做等保。他说他只收集了用户的手机号，只有十几个用户，就被要求做等保三级，这是什么规定？有了解的老哥出来说说?查了下还挺贵的，二级是每年 2 万，三级是每年 5 万。</p>\n<p>这样搞国内市场看来真的得放弃了，还没有什么成果呢，上来就要交钱，不交钱就得吃罚款！</p>\n", "last_modified": 1783123239, "replies": 32, "id": 1224876}, {"