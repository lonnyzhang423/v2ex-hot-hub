[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/854d/6fae/202_large.png?m=1643941191", "name": "mileage", "avatar_normal": "https://cdn.v2ex.com/navatar/854d/6fae/202_normal.png?m=1643941191", "title": "行程控", "url": "https://www.v2ex.com/go/mileage", "topics": 15, "footer": "", "header": "", "title_alternative": "Mileage", "avatar_mini": "https://cdn.v2ex.com/navatar/854d/6fae/202_mini.png?m=1643941191", "stars": 79, "founder_id": 0, "aliases": [], "root": false, "id": 202, "parent_node_name": "travel"}, "member": {"id": 318015, "username": "nododo", "url": "https://www.v2ex.com/u/nododo", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/cdaf/d8ba/318015_mini.png?m=1764112105", "avatar_normal": "https://cdn.v2ex.com/avatar/cdaf/d8ba/318015_normal.png?m=1764112105", "avatar_large": "https://cdn.v2ex.com/avatar/cdaf/d8ba/318015_large.png?m=1764112105", "created": 1527044741, "last_modified": 1764112105, "pro": 0}, "last_reply_by": "sevenday", "last_touched": 1777674197, "title": "顺风车已经变味了", "url": "https://www.v2ex.com/t/1209795", "created": 1777594959, "deleted": 0, "content": "今天忙，想给家人约个顺风车（私享）回老家。\r\n\r\n结果顺风车全被滴滴型司机占据了，还有私信加要感谢费，还有提出价格翻倍的（因为节假日？）还有防止被别的正常车主接单，接单立马取消的，之前的沟通全部作废。", "content_rendered": "今天忙，想给家人约个顺风车（私享）回老家。<br /><br />结果顺风车全被滴滴型司机占据了，还有私信加要感谢费，还有提出价格翻倍的（因为节假日？）还有防止被别的正常车主接单，接单立马取消的，之前的沟通全部作废。", "last_modified": 1777594959, "replies": 69, "id": 1209795}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/069d/3bb0/580_large.png?m=1751415489", "name": "ios", "avatar_normal": "https://cdn.v2ex.com/navatar/069d/3bb0/580_normal.png?m=1751415489", "title": "iOS", "url": "https://www.v2ex.com/go/ios", "topics": 4409, "footer": "", "header": "运行于 Apple 移动设备上的操作系统。", "title_alternative": "iOS", "avatar_mini": "https://cdn.v2ex.com/navatar/069d/3bb0/580_mini.png?m=1751415489", "stars": 1185, "founder_id": 0, "aliases": [], "root": false, "id": 580, "parent_node_name": "apple"}, "member": {"id": 197590, "username": "klii", "url": "https://www.v2ex.com/u/klii", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_mini.png?m=1777595726", "avatar_normal": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_normal.png?m=1777595726", "avatar_large": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_large.png?m=1777595726", "avatar_xlarge": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_xlarge.png?m=1777595726", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_xxlarge.png?m=1777595726", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/c00f/a9f6/197590_xxxlarge.png?m=1777595726", "created": 1477058961, "last_modified": 1777595726, "pro": 0}, "last_reply_by": "flavoury", "last_touched": 1777658908, "title": "iOS 无法收到 TG 的通知", "url": "https://www.v2ex.com/t/1209797", "created": 1777595798, "deleted": 0, "content": "> 苹果🍎用户注意：Telegram 消息推送服务疑似出现异常，部分用户可能遇到消息通知不显示、推送延迟或无法及时收到提醒的问题，建议临时打开应用内查看消息，避免遗漏重要信息\r\n\r\n已经测试了，确实收不到 TG 的推送了，\r\n\r\n\r\n加入代理列表，依旧无法收到 TG 消息，目前国内应用推送正常\r\n```\r\nDOMAIN-SUFFIX,push.apple.com,PROXY\r\nIP-CIDR,17.0.0.0/8,PROXY,no-resolve\r\n\r\n```\r\n\r\nTG 为 DC4/5\r\n美区账号\r\n肉身国内", "content_rendered": "<blockquote>\n<p>苹果🍎用户注意：Telegram 消息推送服务疑似出现异常，部分用户可能遇到消息通知不显示、推送延迟或无法及时收到提醒的问题，建议临时打开应用内查看消息，避免遗漏重要信息</p>\n</blockquote>\n<p>已经测试了，确实收不到 TG 的推送了，</p>\n<p>加入代理列表，依旧无法收到 TG 消息，目前国内应用推送正常</p>\n<pre><code>DOMAIN-SUFFIX,push.apple.com,PROXY\nIP-CIDR,17.0.0.0/8,PROXY,no-resolve\n\n</code></pre>\n<p>TG 为 DC4/5\n美区账号\n肉身国内</p>\n", "last_modified": 1777595859, "replies": 60, "id": 1209797}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70893, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9662, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 633133, "username": "coreJK", "url": "https://www.v2ex.com/u/coreJK", "website": "qiuyucode.com", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=73&d=retro", "created": 1686220875, "last_modified": 1764296894, "pro": 0}, "last_reply_by": "lostrainX", "last_touched": 1777652801, "title": "领到小米 MIMO 的额度了，大家领了多少？", "url": "https://www.v2ex.com/t/1209799", "created": 1777597909, "deleted": 0, "content": "https://i.imgur.com/aGwLOne.jpeg\n\n真“大方”\n\nhttps://i.imgur.com/0NkFuFp.jpeg", "content_rendered": "<a target=\"_blank\" href=\"https://i.imgur.com/aGwLOne.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/aGwLOne.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a><br />真“大方”<br /><br /><a target=\"_blank\" href=\"https://i.imgur.com/0NkFuFp.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/0NkFuFp.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1777597909, "replies": 56, "id": 1209799}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23182, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3663, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 61965, "username": "0987363", "url": "https://www.v2ex.com/u/0987363", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/f891/f3a2/61965_mini.png?m=1412762678", "avatar_normal": "https://cdn.v2ex.com/avatar/f891/f3a2/61965_normal.png?m=1412762678", "avatar_large": "https://cdn.v2ex.com/avatar/f891/f3a2/61965_large.png?m=1412762678", "created": 1399290000, "last_modified": 1412762678, "pro": 0}, "last_reply_by": "QS0x01", "last_touched": 1777669780, "title": "感慨下，假期第一天，被裁了", "url": "https://www.v2ex.com/t/1209838", "created": 1777617864, "deleted": 0, "content": "最近合同到期，要转签无固定期限合同时，老板不续签合同了。\r\n\r\n在公司待了 10 年，都 40 了，时间是飞快。\r\n从后端到产品，从产品到技术总监，啥都干过了，啥都经历了。\r\n\r\n感慨下，被裁的原因不是因为公司业绩不行，而是“方法”不对，没能给出完美的“PPT”。\r\n\r\n人生短短几十年不应该只有工作，家庭才是最重要的。\r\n慢慢思考下以后能做点什么有意义的事，不想再做些心里不认可，但又不得不做的事。", "content_rendered": "最近合同到期，要转签无固定期限合同时，老板不续签合同了。<br /><br />在公司待了 10 年，都 40 了，时间是飞快。<br />从后端到产品，从产品到技术总监，啥都干过了，啥都经历了。<br /><br />感慨下，被裁的原因不是因为公司业绩不行，而是“方法”不对，没能给出完美的“PPT”。<br /><br />人生短短几十年不应该只有工作，家庭才是最重要的。<br />慢慢思考下以后能做点什么有意义的事，不想再做些心里不认可，但又不得不做的事。", "last_modified": 1777617915, "replies": 41, "id": 1209838}, {"node": {"avatar_large": "/static/img/node_default_large.png", "name": "fit", "avatar_normal": "/static/img/node_default_normal.png", "title": "健康", "url": "https://www.v2ex.com/go/fit", "topics": 1725, "footer": "", "header": "这个节点的设立，是为了让大家可以分享关于健身和健康生活方式的经验。如果你有什么正在困扰自己的身体症状，请立刻寻求正规医院的帮助。", "title_alternative": "Fit", "avatar_mini": "/static/img/node_default_mini.png", "stars": 423, "founder_id": 0, "aliases": [], "root": false, "id": 700, "parent_node_name": "life"}, "member": {"id": 529619, "username": "W4J1e", "url": "https://www.v2ex.com/u/W4J1e", "website": "null.null", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "你都有那么多棒棒糖了，还要自由做什么？", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/24db/13b6/529619_mini.png?m=1777613435", "avatar_normal": "https://cdn.v2ex.com/avatar/24db/13b6/529619_normal.png?m=1777613435", "avatar_large": "https://cdn.v2ex.com/avatar/24db/13b6/529619_large.png?m=1777613435", "avatar_xlarge": "https://cdn.v2ex.com/avatar/24db/13b6/529619_xlarge.png?m=1777613435", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/24db/13b6/529619_xxlarge.png?m=1777613435", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/24db/13b6/529619_xxxlarge.png?m=1777613435", "created": 1611133855, "last_modified": 1777613435, "pro": 0}, "last_reply_by": "ycgk", "last_touched": 1777659864, "title": "恳请过来人分享面瘫治疗经验", "url": "https://www.v2ex.com/t/1209832", "created": 1777613752, "deleted": 0, "content": "我 30 岁出头，4 月 22 日感觉很不舒服，起初以为是没睡好，23 号去医院检查，被确诊。具体症状：右侧面瘫，抬额右侧无额纹，皱眉左右极不对称，右眼睑闭合不完全，右眼吹风刺激性强，右侧嘴角漏气，无法鼓气，伴有后脑勺头痛，无耳痛。核磁共振报告显示颅内未发现异常。致病原因至今不明。\r\n\r\n24 号中午去办理住院输液，输了两次后，25 号办理出院，改为服用药物。医生给我开的口服药：碳酸钙 D3 片，一天一次，一次一片；醋酸泼尼松片，一天一次，一次 8 粒，共 40mg ；复合维生素 B 片，一天三次，每次两粒；甲钴胺片，一天三次，一次一粒。阿昔洛韦片一日三次，一次两粒，共吃 7 天。泼尼松片每五天减一片，直到减完为止停止所有用药（共计四十天）。\r\n\r\n截至今天（ 5 月 1 日），我的右眼睑闭合还是不完全，但只有微小的缝了，可以往右侧咧嘴，脸颊肌肉有明显的变化，抬额时右侧额头也有了一道额纹，总之就是已经恢复了将近一半。\r\n\r\n昨天我首先去了中医院老同学（曾在那个医院任职）推荐的中医那去，医生说：针灸两周，每周四次，扎一次几分钟搞定，建议针药并用，即要吃中药。他说开住院的去针灸要便宜些，门诊扎贵一点，并且中药也贵，还建议我泼尼松最多吃两周，他质疑我一开始的剂量即每天 8 片共 40mg 太少了，应该先急用药，药程两周即可。我问他针灸是好得更快还是好得更多，他答复好得更快。\r\n\r\n后来我去了人民医院的康复科门诊，医生也说要针灸，半个月，每天一次，每次一到两个小时，也可能扎几天就好了就不扎了，但跟我说现在泼尼松吃得太多了，建议我减到 10mg 或者 20mg 。\r\n\r\n我身边的人无论医生还是曾经的病患都说要针灸，我现在非常纠结，好像每个医生的方案都有些差异，到底该相信谁。问了一大圈 AI 都说针灸非必需。用药不到一周恢复到这个水平可以不用针灸吗？", "content_rendered": "<p>我 30 岁出头，4 月 22 日感觉很不舒服，起初以为是没睡好，23 号去医院检查，被确诊。具体症状：右侧面瘫，抬额右侧无额纹，皱眉左右极不对称，右眼睑闭合不完全，右眼吹风刺激性强，右侧嘴角漏气，无法鼓气，伴有后脑勺头痛，无耳痛。核磁共振报告显示颅内未发现异常。致病原因至今不明。</p>\n<p>24 号中午去办理住院输液，输了两次后，25 号办理出院，改为服用药物。医生给我开的口服药：碳酸钙 D3 片，一天一次，一次一片；醋酸泼尼松片，一天一次，一次 8 粒，共 40mg ；复合维生素 B 片，一天三次，每次两粒；甲钴胺片，一天三次，一次一粒。阿昔洛韦片一日三次，一次两粒，共吃 7 天。泼尼松片每五天减一片，直到减完为止停止所有用药（共计四十天）。</p>\n<p>截至今天（ 5 月 1 日），我的右眼睑闭合还是不完全，但只有微小的缝了，可以往右侧咧嘴，脸颊肌肉有明显的变化，抬额时右侧额头也有了一道额纹，总之就是已经恢复了将近一半。</p>\n<p>昨天我首先去了中医院老同学（曾在那个医院任职）推荐的中医那去，医生说：针灸两周，每周四次，扎一次几分钟搞定，建议针药并用，即要吃中药。他说开住院的去针灸要便宜些，门诊扎贵一点，并且中药也贵，还建议我泼尼松最多吃两周，他质疑我一开始的剂量即每天 8 片共 40mg 太少了，应该先急用药，药程两周即可。我问他针灸是好得更快还是好得更多，他答复好得更快。</p>\n<p>后来我去了人民医院的康复科门诊，医生也说要针灸，半个月，每天一次，每次一到两个小时，也可能扎几天就好了就不扎了，但跟我说现在泼尼松吃得太多了，建议我减到 10mg 或者 20mg 。</p>\n<p>我身边的人无论医生还是曾经的病患都说要针灸，我现在非常纠结，好像每个医生的方案都有些差异，到底该相信谁。问了一大圈 AI 都说针灸非必需。用药不到一周恢复到这个水平可以不用针灸吗？</p>\n", "last_modified": 1777613752, "replies": 36, "id": 1209832}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70893, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9662, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 56780, "username": "layman3612", "url": "https://www.v2ex.com/u/layman3612", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/d46f/5c33/56780_mini.png?m=1777639569", "avatar_normal": "https://cdn.v2ex.com/avatar/d46f/5c33/56780_normal.png?m=1777639569", "avatar_large": "https://cdn.v2ex.com/avatar/d46f/5c33/56780_large.png?m=1777639569", "created": 1393306427, "last_modified": 1777639569, "pro": 0}, "last_reply_by": "frankies", "last_touched": 1777674768, "title": "chatgpt 代充这是常规操作 还是我被坑了", "url": "https://www.v2ex.com/t/1209887", "created": 1777639760, "deleted": 0, "content": "在 https://www.naifeistation.com/ （星际放映厅） 充值的 三个月的 chatgpt pro 账号代充\r\n价格是 2600+\r\n只用了一个星期就停了