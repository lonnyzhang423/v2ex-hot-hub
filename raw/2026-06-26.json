[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11135, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2374, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 672786, "username": "leeyin98", "url": "https://www.v2ex.com/u/leeyin98", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/42f0d7ba5bf99c00870e5431c1811c80?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/42f0d7ba5bf99c00870e5431c1811c80?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/42f0d7ba5bf99c00870e5431c1811c80?s=73&d=retro", "created": 1705915349, "last_modified": 1782372966, "pro": 0}, "last_reply_by": "skies457", "last_touched": 1782448133, "title": "刚办完父亲丧事难过想抱会，女友怕传染感冒耽误旅行拒绝，是我太敏感吗？", "url": "https://www.v2ex.com/t/1222857", "created": 1782379732, "deleted": 0, "content": "这事发生在 24 年 1 月底，埋在心里两年多了，在 24 年 3 月份提了分手，原因种种不全因为这事提的。\r\n\r\n**事情经过**：\r\n当时父亲离世，请假几天回老家办完所有丧事，期间不小心感冒了。\r\n\r\n回到合肥后，女友来到我住处，夜里躺在床上她拉着我手，其实这时我真的很想被抱着，于是问她：怎么不抱抱我？（大概意思，原话忘记了）\r\n\r\n她说：过几天要去日本旅游，怕感冒传染给她，耽误行程。（大概意思，原话忘记了）\r\n\r\n听完心里一下失落到极点了，背过身去不想再说话了。她可能察觉到了，然后从后面抱住我了，但也已经心生芥蒂。\r\n\r\n刚分手后的一段时间其实在知乎上提问过（现在想想那时应该是想寻求认同吧），得到第一个回答大概意思是：如果是他，他都不会让女友跟自己接触，怕传染感冒给她。\r\n\r\n看到这个回答后我把问题给删了，在想难道真的也是我自私了？\r\n\r\n此后每想起这事都先感觉她好像并不爱我，旅游比我更重要，而后又思考没有考虑会把感冒传染给她是否也是我自私呢？\r\n\r\n如果换位的话，将心比心，自己不会考虑被传染感冒耽误行程而紧紧抱住对方，相比父亲去世，旅游可以损失点手续费推迟下次再去，对方这时候非常脆弱一定很需要我。\r\n\r\n现在想把这是拉出来聊聊，就此想客观问问大家的看法，不再是寻求认同，理性讨论。", "content_rendered": "<p>这事发生在 24 年 1 月底，埋在心里两年多了，在 24 年 3 月份提了分手，原因种种不全因为这事提的。</p>\n<p><strong>事情经过</strong>：\n当时父亲离世，请假几天回老家办完所有丧事，期间不小心感冒了。</p>\n<p>回到合肥后，女友来到我住处，夜里躺在床上她拉着我手，其实这时我真的很想被抱着，于是问她：怎么不抱抱我？（大概意思，原话忘记了）</p>\n<p>她说：过几天要去日本旅游，怕感冒传染给她，耽误行程。（大概意思，原话忘记了）</p>\n<p>听完心里一下失落到极点了，背过身去不想再说话了。她可能察觉到了，然后从后面抱住我了，但也已经心生芥蒂。</p>\n<p>刚分手后的一段时间其实在知乎上提问过（现在想想那时应该是想寻求认同吧），得到第一个回答大概意思是：如果是他，他都不会让女友跟自己接触，怕传染感冒给她。</p>\n<p>看到这个回答后我把问题给删了，在想难道真的也是我自私了？</p>\n<p>此后每想起这事都先感觉她好像并不爱我，旅游比我更重要，而后又思考没有考虑会把感冒传染给她是否也是我自私呢？</p>\n<p>如果换位的话，将心比心，自己不会考虑被传染感冒耽误行程而紧紧抱住对方，相比父亲去世，旅游可以损失点手续费推迟下次再去，对方这时候非常脆弱一定很需要我。</p>\n<p>现在想把这是拉出来聊聊，就此想客观问问大家的看法，不再是寻求认同，理性讨论。</p>\n", "last_modified": 1782379732, "replies": 209, "id": 1222857}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/d3d9/4468/10_large.png?m=1630643933", "name": "mbp", "avatar_normal": "https://cdn.v2ex.com/navatar/d3d9/4468/10_normal.png?m=1630643933", "title": "MacBook Pro", "url": "https://www.v2ex.com/go/mbp", "topics": 9686, "footer": "", "header": "State-of-the-art processors. All-new graphics. Breakthrough high-speed I/O. Three very big leaps forward.", "title_alternative": "MacBook Pro", "avatar_mini": "https://cdn.v2ex.com/navatar/d3d9/4468/10_mini.png?m=1630643933", "stars": 3490, "founder_id": 0, "aliases": [], "root": false, "id": 10, "parent_node_name": "apple"}, "member": {"id": 421302, "username": "handsomezai", "url": "https://www.v2ex.com/u/handsomezai", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_mini.png?m=1778317871", "avatar_normal": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_normal.png?m=1778317871", "avatar_large": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_large.png?m=1778317871", "avatar_xlarge": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_xlarge.png?m=1778317871", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_xxlarge.png?m=1778317871", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/e016/a0f2/421302_xxxlarge.png?m=1778317871", "created": 1560396519, "last_modified": 1778317871, "pro": 0}, "last_reply_by": "cxe2v", "last_touched": 1782447815, "title": "如何看待苹果 6 月 25 日 Mac， iPad 全线涨价 20%？", "url": "https://www.v2ex.com/t/1222950", "created": 1782435167, "deleted": 0, "content": "### 观望了大半年的 MacBook Pro m5 ，返校季没等到，涨了 4500\r\n如图所示：\r\n![产品对比 1]( https://pic4.zhimg.com/100/v2-ca33dd3ced4a02b3355d3401c4ac9c4b_r.jpg \"产品对比 1\")\r\n![产品对比 2]( https://picx.zhimg.com/100/v2-2bf8d3ecd0d456df8e71b0a7a9dfe285_r.jpg \"产品对比 2\")", "content_rendered": "<h3>观望了大半年的 MacBook Pro m5 ，返校季没等到，涨了 4500</h3>\n<p>如图所示：\n<img alt=\"产品对比 1\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://pic4.zhimg.com/100/v2-ca33dd3ced4a02b3355d3401c4ac9c4b_r.jpg\" title=\"产品对比 1\"/>\n<img alt=\"产品对比 2\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://picx.zhimg.com/100/v2-2bf8d3ecd0d456df8e71b0a7a9dfe285_r.jpg\" title=\"产品对比 2\"/></p>\n", "last_modified": 1782435167, "replies": 114, "id": 1222950}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23697, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3701, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 578137, "username": "midsolo", "url": "https://www.v2ex.com/u/midsolo", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "已定居深圳的 90 后湘籍程序员，工作之余喜欢跑步、爬山、钓鱼。", "avatar_mini": "https://cdn.v2ex.com/avatar/7833/53a0/578137_mini.png?m=1769696267", "avatar_normal": "https://cdn.v2ex.com/avatar/7833/53a0/578137_normal.png?m=1769696267", "avatar_large": "https://cdn.v2ex.com/avatar/7833/53a0/578137_large.png?m=1769696267", "avatar_xlarge": "https://cdn.v2ex.com/avatar/7833/53a0/578137_xlarge.png?m=1769696267", "created": 1649829588, "last_modified": 1769696267, "pro": 0}, "last_reply_by": "nofishing", "last_touched": 1782449039, "title": "这种情况该跑路吗？", "url": "https://www.v2ex.com/t/1222967", "created": 1782438104, "deleted": 0, "content": "1. 5 月拿大礼包，面了十几家，6 月 8 号降薪入职了某厂，拿着 35 * 14 的微薄薪资，工作量大的惊人，每天都是紧急需求，入职第一天就干到了 10 点，后续每天都要 11 点才下班。\r\n2. 祖传屎山项目，用的 SpringBoot 1.5 跟内部自研微服务框架，源码 220w 行，微服务拆了 46 个，库用的还是同一个...... \r\n3. 用的 Codebuddy ，每个月 2000 额度，根本就不够用，向上反馈后，领导让我去借其他同事的号来用...... 听起来很不靠谱的样子，我就自己掏钱买了 GLM Coding Plan 跟 DeepSeek ，每天付费上班。\r\n4. 领导是从爱国厂出来的，特别喜欢开会，屁大的事要拉几十个人去开会，每天白天的时间都陪领导开会去了，只有晚上才有时间干活；他思想觉悟也高，经常跟我们讲：如果哪天觉得自己没法胜任这份工作了，就会自动离职，不给公司找麻烦...... 但是他思想觉悟都这么高了，还搞了一些亲戚朋友进来混日子，有点讽刺。\r\n5. 现在每天精神都极度紧绷，工作压力也大，领导事儿还多，就快坚持不下去了。\r\n\r\n个人情况：深圳定居，有车有房，已婚未育，夫妻收入每个月 5w ，存款有 67w ，房贷 282w 。\r\n\r\n这种情况该不该跑？", "content_rendered": "<ol>\n<li>5 月拿大礼包，面了十几家，6 月 8 号降薪入职了某厂，拿着 35 * 14 的微薄薪资，工作量大的惊人，每天都是紧急需求，入职第一天就干到了 10 点，后续每天都要 11 点才下班。</li>\n<li>祖传屎山项目，用的 SpringBoot 1.5 跟内部自研微服务框架，源码 220w 行，微服务拆了 46 个，库用的还是同一个...... </li>\n<li>用的 Codebuddy ，每个月 2000 额度，根本就不够用，向上反馈后，领导让我去借其他同事的号来用...... 听起来很不靠谱的样子，我就自己掏钱买了 GLM Coding Plan 跟 DeepSeek ，每天付费上班。</li>\n<li>领导是从爱国厂出来的，特别喜欢开会，屁大的事要拉几十个人去开会，每天白天的时间都陪领导开会去了，只有晚上才有时间干活；他思想觉悟也高，经常跟我们讲：如果哪天觉得自己没法胜任这份工作了，就会自动离职，不给公司找麻烦...... 但是他思想觉悟都这么高了，还搞了一些亲戚朋友进来混日子，有点讽刺。</li>\n<li>现在每天精神都极度紧绷，工作压力也大，领导事儿还多，就快坚持不下去了。</li>\n</ol>\n<p>个人情况：深圳定居，有车有房，已婚未育，夫妻收入每个月 5w ，存款有 67w ，房贷 282w 。</p>\n<p>这种情况该不该跑？</p>\n", "last_modified": 1782438104, "replies": 87, "id": 1222967}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/093f/65e0/59_large.png?m=1747623725", "name": "random", "avatar_normal": "https://cdn.v2ex.com/navatar/093f/65e0/59_normal.png?m=1747623725", "title": "随想", "url": "https://www.v2ex.com/go/random", "topics": 4331, "footer": "", "header": "有的时候，可以停下来找找灵感，然后再继续。", "title_alternative": "Random", "avatar_mini": "https://cdn.v2ex.com/navatar/093f/65e0/59_mini.png?m=1747623725", "stars": 1314, "founder_id": 0, "aliases": [], "root": false, "id": 59, "parent_node_name": "v2ex"}, "member": {"id": 390537, "username": "Henryable", "url": "https://www.v2ex.com/u/Henryable", "website": "https://blog.riveer.dpdns.org/", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/f893f63bba7803d3762ebed5ff773f84?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/f893f63bba7803d3762ebed5ff773f84?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/f893f63bba7803d3762ebed5ff773f84?s=73&d=retro", "created": 1552028488, "last_modified": 1552028488, "pro": 0}, "last_reply_by": "QUIOA", "last_touched": 1782448467, "title": "V 站越到后面，靠签到领取的铜币会越来越少，被迫发帖讨要铜币", "url": "https://www.v2ex.com/t/1222945", "created": 1782433496, "deleted": 0, "content": "V 站的铜币规则很有意思，每次领取的数目是随机的但有规律的，一开始平均每次有 10 几枚，连续签到 40 天左右之后，每次只能领 2 枚左右，为了获取更多的铜币，只能积极发帖，这种设计挺好的。", "content_rendered": "<p>V 站的铜币规则很有意思，每次领取的数目是随机的但有规律的，一开始平均每次有 10 几枚，连续签到 40 天左右之后，每次只能领 2 枚左右，为了获取更多的铜币，只能积极发帖，这种设计挺好的。</p>\n", "last_modified": 1782433847, "replies": 84, "id": 1222945}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11135, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2374, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 638855, "username": "mode171", "url": "https://www.v2ex.com/u/mode171", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "深圳", "tagline": "生活是一部电影； 死亡是一张照片。", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_mini.png?m=1766369444", "avatar_normal": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_normal.png?m=1766369444", "avatar_large": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_large.png?m=1766369444", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xlarge.png?m=1766369444", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxlarge.png?m=1766369444", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxxlarge.png?m=1766369444", "created": 1689515364, "last_modified": 1766369444, "pro": 0}, "last_reply_by": "MoeDisk", "last_touched": 1782448223, "title": "有没有必要在车上放“武器”防身？", "url": "https://www.v2ex.com/t/1222952", "created": 1782435868, "deleted": 0, "content": "坐网约车，听师傅们唠嗑，说以前开车在广西遇到开摩托车抱团抢劫的，因为手里没有趁手的“武器”，手机和现金被抢了。那么车上有必要放武器吗？", "content_rendered": "<p>坐网约车，听师傅们唠嗑，说以前开车在广西遇到开摩托车抱团抢劫的，因为手里没有趁手的“武器”，手机和现金被抢了。那么车上有必要放武器吗？</p>\n", "last_modified": 1782440180, "replies": 80, "id": 1222952}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c9f0/f895/8_large.png?m=1630643991", "name": "iphone", "avatar_normal": "https://cdn.v2ex.com/navatar/c9f0/f895/8_normal.png?m=1630643991", "title": "iPhone", "url": "https://www.v2ex.com/go/iphone", "topics": 13001, "footer": "这里绝不讨论如何获得 iPhone 盗版软件、iTunes 黑卡之类。", "header": "Say hello to the future.", "title_alternative": "iPhone", "avatar_mini": "https://cdn.v2ex.com/navatar/c9f0/f895/8_mini.png?m=1630643991", "stars": 3623, "founder_id": 0, "aliases": [], "root": false, "id": 8, "parent_node_name": "apple"}, "member": {"id": 538620, "username": "MagicCoder", "url": "https://www.v2ex.com/u/MagicCoder", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/c735/cd24/538620_mini.png?m=1778433299", "avatar_normal": "https://cdn.v2ex.com/avatar/c735/cd24/538620_normal.png?m=1778433299", "avatar_large": "https://cdn.v2ex.com/avatar/c735/cd24/538620_large.png?m=1778433299", 