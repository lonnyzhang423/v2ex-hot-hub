ar/51f9f89af340304c3d4fe9dbcfd91ebf?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/51f9f89af340304c3d4fe9dbcfd91ebf?s=73&d=retro", "created": 1686220875, "last_modified": 1764296894, "pro": 0}, "last_reply_by": "sillydaddy", "last_touched": 1777622171, "title": "领到小米 MIMO 的额度了，大家领了多少？", "url": "https://www.v2ex.com/t/1209799", "created": 1777597909, "deleted": 0, "content": "https://i.imgur.com/aGwLOne.jpeg\n\n真“大方”\n\nhttps://i.imgur.com/0NkFuFp.jpeg", "content_rendered": "<a target=\"_blank\" href=\"https://i.imgur.com/aGwLOne.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/aGwLOne.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a><br />真“大方”<br /><br /><a target=\"_blank\" href=\"https://i.imgur.com/0NkFuFp.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/0NkFuFp.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1777597909, "replies": 29, "id": 1209799}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10735, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2292, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 367026, "username": "weishao666", "url": "https://www.v2ex.com/u/weishao666", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/690f81902891f1bb72bbf56f0b551838?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/690f81902891f1bb72bbf56f0b551838?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/690f81902891f1bb72bbf56f0b551838?s=73&d=retro", "created": 1543592881, "last_modified": 1741865292, "pro": 0}, "last_reply_by": "legendBro", "last_touched": 1777610940, "title": "家在小县城的农村，老婆在省会的郊区，如果把我的户口迁过来是不是违背祖宗了？", "url": "https://www.v2ex.com/t/1209774", "created": 1777563939, "deleted": 0, "content": "我家是一个小农村，基本上没啥发展的那种，房子在乡里边，有几亩田地，基本上没啥征收的可能\r\n\r\n媳妇儿家是在省会的郊区，周边不少地方都征收了，传了挺久要征收了，估计后续征收的可能性确实也比较大\r\n\r\n后面小孩为了教育问题，小孩肯定是想落省会的户口了，可能落到老妈那边去？不然的话怎么操作？\r\n\r\n又考虑是不是一般娃娃户口都跟爹走？不知道家里会不会有意见？我情况还比较特殊，父亲不在了，独生子，还没开口跟家里提过，也不知道该找谁聊聊\r\n\r\n进一步的，我那户口是不是也可以迁出来？迁到老婆这边是不是违背祖宗了，一般印象会认为与入赘一样么？像我这种单亲，如果我迁出来了，百年后母上大人也不在了，房子和土地怎么办？收归集体了？\r\n\r\nV 友们有没有想法的，可否交流一下，哪怕想法不妥，就骂上两句也行", "content_rendered": "<p>我家是一个小农村，基本上没啥发展的那种，房子在乡里边，有几亩田地，基本上没啥征收的可能</p>\n<p>媳妇儿家是在省会的郊区，周边不少地方都征收了，传了挺久要征收了，估计后续征收的可能性确实也比较大</p>\n<p>后面小孩为了教育问题，小孩肯定是想落省会的户口了，可能落到老妈那边去？不然的话怎么操作？</p>\n<p>又考虑是不是一般娃娃户口都跟爹走？不知道家里会不会有意见？我情况还比较特殊，父亲不在了，独生子，还没开口跟家里提过，也不知道该找谁聊聊</p>\n<p>进一步的，我那户口是不是也可以迁出来？迁到老婆这边是不是违背祖宗了，一般印象会认为与入赘一样么？像我这种单亲，如果我迁出来了，百年后母上大人也不在了，房子和土地怎么办？收归集体了？</p>\n<p>V 友们有没有想法的，可否交流一下，哪怕想法不妥，就骂上两句也行</p>\n", "last_modified": 1777589896, "replies": 22, "id": 1209774}]