[{"node": {"avatar_large": "/static/img/node_default_large.png", "name": "eco", "avatar_normal": "/static/img/node_default_normal.png", "title": "经济", "url": "https://www.v2ex.com/go/eco", "topics": 63, "footer": "", "header": "", "title_alternative": "Economics", "avatar_mini": "/static/img/node_default_mini.png", "stars": 113, "founder_id": 0, "aliases": [], "root": false, "id": 125, "parent_node_name": ""}, "member": {"id": 3924, "username": "iloveyou", "url": "https://www.v2ex.com/u/iloveyou", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/943b/5fd1/3924_mini.png?m=1760512392", "avatar_normal": "https://cdn.v2ex.com/avatar/943b/5fd1/3924_normal.png?m=1760512392", "avatar_large": "https://cdn.v2ex.com/avatar/943b/5fd1/3924_large.png?m=1760512392", "created": 1292319835, "last_modified": 1760512392, "pro": 0}, "last_reply_by": "forisra", "last_touched": 1774950745, "title": "经济要崩溃了吗？大萧条叠加 AI 危机", "url": "https://www.v2ex.com/t/1202405", "created": 1774920591, "deleted": 0, "content": "人家美国是通胀，搞 AI 提高生产效率降通胀，就算最后大模型没成功至少英伟达吃饱了。\r\n\r\n本来国内最大问题就是债务衰退消费不振，不想着怎么调整分配制度，跑去学人家搞 AI 想靠所谓的新质生产力解决经济问题。问题 AI 是提高生产效率的，并不会让普通人增收，只会导致更多失业更多的生产过剩。\r\n\r\n也许真是天意，东大国运到头了。通缩还没解决又刚好碰上了 AI 大爆发，还飞蛾扑火般上了 AI 的贼船。", "content_rendered": "人家美国是通胀，搞 AI 提高生产效率降通胀，就算最后大模型没成功至少英伟达吃饱了。<br /><br />本来国内最大问题就是债务衰退消费不振，不想着怎么调整分配制度，跑去学人家搞 AI 想靠所谓的新质生产力解决经济问题。问题 AI 是提高生产效率的，并不会让普通人增收，只会导致更多失业更多的生产过剩。<br /><br />也许真是天意，东大国运到头了。通缩还没解决又刚好碰上了 AI 大爆发，还飞蛾扑火般上了 AI 的贼船。", "last_modified": 1774920591, "replies": 158, "id": 1202405}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1751718333", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1751718333", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 237923, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1751718333", "stars": 4475, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 319867, "username": "zhangH258", "url": "https://www.v2ex.com/u/zhangH258", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/bcfd/7403/319867_mini.png?m=1774936664", "avatar_normal": "https://cdn.v2ex.com/avatar/bcfd/7403/319867_normal.png?m=1774936664", "avatar_large": "https://cdn.v2ex.com/avatar/bcfd/7403/319867_large.png?m=1774936664", "avatar_xlarge": "https://cdn.v2ex.com/avatar/bcfd/7403/319867_xlarge.png?m=1774936664", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/bcfd/7403/319867_xxlarge.png?m=1774936664", "created": 1527826505, "last_modified": 1774936664, "pro": 0}, "last_reply_by": "zhangH258", "last_touched": 1774228905, "title": "如何投诉苏州大学？", "url": "https://www.v2ex.com/t/1202403", "created": 1774920405, "deleted": 0, "content": "临近毕业，搞了个论文查重，搞得对象本来因为工作找不到就压力爆棚，现在更加爆棚\r\n\r\n26 岁的人比我 30 岁的白头发都多，让大家这么压抑，本来生育力就低得不能再低，还给这么高压力\r\n\r\n这种学校不止一个", "content_rendered": "临近毕业，搞了个论文查重，搞得对象本来因为工作找不到就压力爆棚，现在更加爆棚<br /><br />26 岁的人比我 30 岁的白头发都多，让大家这么压抑，本来生育力就低得不能再低，还给这么高压力<br /><br />这种学校不止一个", "last_modified": 1774920405, "replies": 131, "id": 1202403}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10448, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2239, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 684334, "username": "diligentCoding", "url": "https://www.v2ex.com/u/diligentCoding", "website": null, "twitter": "", "psn": "", "github": "lizy-coding", "btc": "", "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/ce95/82dc/684334_mini.png?m=1774863898", "avatar_normal": "https://cdn.v2ex.com/avatar/ce95/82dc/684334_normal.png?m=1774863898", "avatar_large": "https://cdn.v2ex.com/avatar/ce95/82dc/684334_large.png?m=1774863898", "avatar_xlarge": "https://cdn.v2ex.com/avatar/ce95/82dc/684334_xlarge.png?m=1774863898", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/ce95/82dc/684334_xxlarge.png?m=1774863898", "created": 1712642348, "last_modified": 1774863898, "pro": 0}, "last_reply_by": "diligentCoding", "last_touched": 1774948586, "title": "对于吸血的另一半家庭，陷入了迷茫", "url": "https://www.v2ex.com/t/1202295", "created": 1774865261, "deleted": 0, "content": "首先表明观点，就是瞎聊聊没指望得到什么答案，谁来刷乌龟的全部拉黑举报，生活够烦了不接受任何无意义的网络指控\r\n\r\n## 婚姻情况\r\n人口大省，结婚对象某不知名县城\r\n结婚三年，目前老婆孕期无业，有小舅子没结婚倒也正常工作，但结合情况彩礼大概率要不回来\r\n\r\n岳父母无任何托举形式，老婆的大学是贷款上的自己还的，结婚陪嫁几床被子，甚至女方在当地办礼席还赚点我家差价，每年过年要求老婆给小舅子发红包（不知道结婚后还会要不）细节懒得吐槽，反正结婚一直以来感觉是在扶贫\r\n\r\n## 资产情况\r\n没有欠债，并且物质欲不强每个月只是在吃上花钱多，但是要准备生小孩\r\n\r\n老婆拿着一些礼金和上班一年多的工资大致 5w\r\n\r\n目前我工作第五年存款大致 40w 全在股票基金，对钱的认知就是各自打是健康状态，怀孕前基本也如此，一直以来都是梭哈炒股有亏有赚（最近亏损部分本金），买东西抠抠搜搜炒股直接梭哈（也是个病态）\r\n\r\n\r\n## 冲突\r\n日常基本开销（房租，大部分日用，出行，下馆子）我来承担，老婆最大开销是工作日自己吃饭和买点自用小物件\r\n\r\n目前孕期经常被索要生活费，当前正在争执想 2000 上涨到 3000 ，理由是为自己争取保障存点底气（也许是看到她堂姐 30 多婚姻不幸财产无法独立）；还一直讨论生孩子会得到我父母多少钱的相关话题，整体无力回应（过于敲打个人价值观）\r\n\r\n观点：贼尼玛的某不知名县城灌输的恶俗风气，底气是自己挣得，结婚是搭伙互帮互助过日子不是一味期望输血，不如直接沿街乞讨\r\n\r\n\r\n## 下一步\r\n不指望任何从岳父母处得到的托举，别再要东西就谢天谢地\r\n希望老婆也不要被自小始终灌输的亏欠教育持续影响减少内耗与资金赠与（目前为止知道的只是偶尔买日用与过节红包，数额未知）\r\n\r\n深感人与人之间的互相理解尊重并不容易，指望一群不断试探底线的 [淳朴] 村民感受善意并回报简直如同希望狼该吃素一般；婚姻状况本身没有违反原则的冲突，但是就是在不理解与被试探中消磨耐心，只是第三年已疲惫不堪", "content_rendered": "<p>首先表明观点，就是瞎聊聊没指望得到什么答案，谁来刷乌龟的全部拉黑举报，生活够烦了不接受任何无意义的网络指控</p>\n<h2>婚姻情况</h2>\n<p>人口大省，结婚对象某不知名县城\n结婚三年，目前老婆孕期无业，有小舅子没结婚倒也正常工作，但结合情况彩礼大概率要不回来</p>\n<p>岳父母无任何托举形式，老婆的大学是贷款上的自己还的，结婚陪嫁几床被子，甚至女方在当地办礼席还赚点我家差价，每年过年要求老婆给小舅子发红包（不知道结婚后还会要不）细节懒得吐槽，反正结婚一直以来感觉是在扶贫</p>\n<h2>资产情况</h2>\n<p>没有欠债，并且物质欲不强每个月只是在吃上花钱多，但是要准备生小孩</p>\n<p>老婆拿着一些礼金和上班一年多的工资大致 5w</p>\n<p>目前我工作第五年存款大致 40w 全在股票基金，对钱的认知就是各自打是健康状态，怀孕前基本也如此，一直以来都是梭哈炒股有亏有赚（最近亏损部分本金），买东西抠抠搜搜炒股直接梭哈（也是个病态）</p>\n<h2>冲突</h2>\n<p>日常基本开销（房租，大部分日用，出行，下馆子）我来承担，老婆最大开销是工作日自己吃饭和买点自用小物件</p>\n<p>目前孕期经常被索要生活费，当前正在争执想 2000 上涨到 3000 ，理由是为自己争取保障存点底气（也许是看到她堂姐 30 多婚姻不幸财产无法独立）；还一直讨论生孩子会得到我父母多少钱的相关话题，整体无力回应（过于敲打个人价值观）</p>\n<p>观点：贼尼玛的某不知名县城灌输的恶俗风气，底气是自己挣得，结婚是搭伙互帮互助过日子不是一味期望输血，不如直接沿街乞讨</p>\n<h2>下一步</h2>\n<p>不指望任何从岳父母处得到的托举，别再要东西就谢天谢地\n希望老婆也不要被自小始终灌输的亏欠教育持续影响减少内耗与资金赠与（目前为止知道的只是偶尔买日用与过节红包，数额未知）</p>\n<p>深感人与人之间的互相理解尊重并不容易，指望一群不断试探底线的 [淳朴] 村民感受善意并回报简直如同希望狼该吃素一般；婚姻状况本身没有违反原则的冲突，但是就是在不理解与被试探中消磨耐心，只是第三年已疲惫不堪</p>\n", "last_modified": 1774865261, "replies": 97, "id": 1202295}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1751718333", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1751718333", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 237923, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1751718333", "stars": 4475, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 705085, "username": "myTrip", "url": "https://www.v2ex.com/u/myTrip", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/b034856a32b8404d6826d471fe7b7659?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/b034856a32b8404d6826d471fe7b7659?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/b034856a32b8404d6826d471fe7b7659?s=73&d=retro", "created": 1723247004, "last_modified": 1742733396, "pro": 0}, "last_reply_by": "davecat", "last_touched": 1774949092, "title": "想统计一下频率， 2 天或者 3 天一次频率算高吗", "url": "https://www.v2ex.com/t/1202440", "created": 1774924219, "deleted": 0, "content": "心里总有些罪恶感", "content_rendered": "心里总有些罪恶感", "last_modified": 1774924219, "replies": 96, "id": 1202440}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10448, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2239, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 703049, "username": "deadlineChen", "url": "https://www.v2ex.com/u/deadlineChen", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/63c4/98c3/703049_mini.png?m=1727500521", "avatar_normal": "https://cdn.v2ex.com/avatar/63c4/98c3/703049_normal.png?m=1727500521", "avatar_large": "https://cdn.v2ex.com/avatar/63c4/98c3/703049_large.png?m=1727500521", "avatar_xlarge": "https://cdn.v2ex.com/avatar/63c4/98c3/703049_xlarge.png?m=1727500521", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/63c4/98c3/703049_xxlarge.png?m=1727500521", "created": 1722214510, "last_modified": 1727500521, "pro": 0}, "last_reply_by": "diligentCoding", "last_touched": 1774950006, "title": "妹妹嫁到 300 多公里外，这种距离你们还会经常来往吗？", "url": "https://www.v2ex.com/t/1202445", "created": 1774925326, "deleted": 0, "content": "想问下大家一个挺现实的问题，最近一直有点纠结。\r\n\r\n我老家是河南南阳邓州的，我妹妹嫁到了周口项城。虽然说是同省，但其实单程大概 300 公里，而且只能开车，没有高铁或者直达的大巴。\r\n\r\n上次去了一趟，单程开了 4 个小时。我们早上 7 点出发，11 点多才到，下午 2 点吃完饭就得走了，晚上 7 点才回到家。基本一整天都在路上，真正坐下来也就那么一会儿。\r\n\r\n说实话，那种感觉就是：挺赶、挺累的，来回成本也不低，更像是“完成了一次走亲戚”，而不是轻松的走动。\r\n\r\n但问题就在这儿：\r\n这是我妹妹，不去又觉得说不过去\r\n可每次去一趟，又真的挺折腾\r\n\r\n现在就有点纠结，不知道这种情况该怎么拿捏。\r\n\r\n想问问大家：\r\n像这种距离的亲戚（尤其是直系的），你们一般是怎么处理的？\r\n是固定时间去看看，还是慢慢减少频率？", "content_rendered": "<p>想问下大家一个挺现实的问题，最近一直有点纠结。</p>\n<p>我老家是河南南阳邓州的，我妹妹嫁到了周口项城。虽然说是同省，但其实单程大概 300 公里，而且只能开车，没有高铁或者直达的大巴。</p>\n<p>上次去了一趟，单程开了 4 个小时。我们早上 7 点出发，11 点多才到，下午 2 点吃完饭就得走了，晚上 7 点才回到家。基本一整天都在路上，真正坐下来也就那么一会儿。</p>\n<p>说实话，那种感觉就是：挺赶、挺累的，来回成本也不低，更像是“完成了一次走亲戚”，而不是轻松的走动。</p>\n<p>但问题就在这儿：\n这是我妹妹，不去又觉得说不过去\n可每次去一趟，又真的挺折腾</p>\n<p>现在就有点纠结，不知道这种情况该怎么拿捏。</p>\n<p>想问问大家：\n像这种距离的亲戚（尤其是直系的），你们一般是怎么处理的？\n是固定时间去看看，还是慢慢减少频率？</p>\n", "last_modified": 1774932920, "replies": 80, "id": 1202445}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_large.png?m=1754172750", "name": "android", "avatar_normal": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_normal.png?m=1754172750", "title": "Android", "url": "https://www.v2ex.com/go/android", "topics": 12813, "footer": "", "header": "来自 <a href=\"/go/google\">Google</a> 的开放源代码智能手机平台。", "title_alternative": "Android", "avatar_mini": "https://cdn.v2ex.com/navatar/d67d/8ab4/39_mini.png?m=1754172750", "stars": 6191, "founder_id": 0, "aliases": [], "root": false, "id": 39, "parent_node_name": "hardware"}, "member": {"id": 442167, "username": "ztjal", "url": "https://www.v2ex.com/u/ztjal", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/8c9d0ba22693441f5f868eb96ee1bb94?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/8c9d0ba22693441f5f868eb96ee1bb94?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/8c9d0ba22693441f5f868eb96ee1bb94?s=73&d=retro", "created": 1568908626, "last_modified": 1774876664, "pro": 0}, "last_reply_by": "hshe", "last_touched": 1774950265, "title": "刚才发现小米应用商店半夜 3 点偷偷给我装应用", "url": "https://www.v2ex.com/t/1202332", "created": 1774876925, "deleted": 0, "content": "应用名称\t\t\t\t小游戏服务\r\n\r\n应用版本\t\t\t\t1.31.2.1\r\n\r\n应用包名\t\t\t\tcom.xiaomi.minigame\r\n\r\n首次安装来源\t\t\t\t应用商店\r\n\r\n首次安装时间\t\t\t\t2026/03/09 03:09:48\r\n\r\n最后更新来源\t\t\t\t应用商店\r\n\r\n最后更新时间\t\t\t\t2026/03/09 03:09:48\r\n\r\n\r\n这东西没有图标的，不是刚才发现商店里有新版本可以