[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71996, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9727, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 305534, "username": "rizon", "url": "https://www.v2ex.com/u/rizon", "website": "https://1object.cn", "twitter": "rizon_dev", "psn": "", "github": "othorizon", "btc": "", "location": "", "tagline": "", "bio": "微信公众号： 奕象派研究社\r\n\r\nJustMark - AI 零负担 收藏夹\r\nhttps://justmark.app/\r\n\r\nNoteloom - 基于画板的 AI Agent 生产力平台\r\nhttps://noteloom.app/", "avatar_mini": "https://cdn.v2ex.com/avatar/8b75/b98f/305534_mini.png?m=1779625860", "avatar_normal": "https://cdn.v2ex.com/avatar/8b75/b98f/305534_normal.png?m=1779625860", "avatar_large": "https://cdn.v2ex.com/avatar/8b75/b98f/305534_large.png?m=1779625860", "created": 1522684419, "last_modified": 1779625860, "pro": 0}, "last_reply_by": "micean", "last_touched": 1783780192, "title": "为了省下每年几万的的费用，用 ai 做了完整的 erp", "url": "https://www.v2ex.com/t/1226505", "created": 1783698922, "deleted": 0, "content": "我们有自己的电商平台，当然也在各家电商上售卖产品。\r\n然后对接云仓时，感觉那些 erp 卖的贵，系统还老旧，去对接到自己的业务定制化的电商流程也不见得好对接，\r\n索性就自己开发了。\r\n\r\n\r\n其实最花时间的地方是需求整理，\r\n云仓的人沟通起来比想象中要难，体系复杂笨重且陈旧。\r\n做完之后现在觉得需求也就这些了。\r\n但是第一次接触电商，第一次接触云仓，对需求没有全局视角，没有经验指导，探索起来还是很痛苦的，很多数据模型也因为缺乏经验指导，后期才发现有问题又各种改。\r\n\r\n好在有 Claude code 加持，并行开发，对抗审查，浏览器模拟调用测试，\r\n就这么吭哧吭哧的，还做了得有一周的时间。\r\n\r\n自己的脑力真的是有些跟不上了，为了提高开发效率就要并行思考很多事，尤其是 ai 开始工作时，你就一刻不歇的去思考其他事情了，然后各种事情贴了一堆待办，但是前面 AI 的产出又可能产生很多预期外的变化与分支，导致又影响了你原本计划记下来要做的事。\r\n\r\n过去开发体验还是很舒服的，但这次因为赶工期，又是从 0 构建，没有很多时间去好好 review 和消化产出。\r\n\r\n于是更深刻的感受到，ai 辅助编程对脑力的消耗真的很大，你要被 ai 推着去思考，再加上因为开发节奏快，很多写出来的东西自己本身就不熟，ai 再说很多黑话或者说简略的话，根本不知道他在说啥，扔一堆让我决策的我都听不懂，还得去先研究明白他在说啥。", "content_rendered": "我们有自己的电商平台，当然也在各家电商上售卖产品。<br />然后对接云仓时，感觉那些 erp 卖的贵，系统还老旧，去对接到自己的业务定制化的电商流程也不见得好对接，<br />索性就自己开发了。<br /><br /><br />其实最花时间的地方是需求整理，<br />云仓的人沟通起来比想象中要难，体系复杂笨重且陈旧。<br />做完之后现在觉得需求也就这些了。<br />但是第一次接触电商，第一次接触云仓，对需求没有全局视角，没有经验指导，探索起来还是很痛苦的，很多数据模型也因为缺乏经验指导，后期才发现有问题又各种改。<br /><br />好在有 Claude code 加持，并行开发，对抗审查，浏览器模拟调用测试，<br />就这么吭哧吭哧的，还做了得有一周的时间。<br /><br />自己的脑力真的是有些跟不上了，为了提高开发效率就要并行思考很多事，尤其是 ai 开始工作时，你就一刻不歇的去思考其他事情了，然后各种事情贴了一堆待办，但是前面 AI 的产出又可能产生很多预期外的变化与分支，导致又影响了你原本计划记下来要做的事。<br /><br />过去开发体验还是很舒服的，但这次因为赶工期，又是从 0 构建，没有很多时间去好好 review 和消化产出。<br /><br />于是更深刻的感受到，ai 辅助编程对脑力的消耗真的很大，你要被 ai 推着去思考，再加上因为开发节奏快，很多写出来的东西自己本身就不熟，ai 再说很多黑话或者说简略的话，根本不知道他在说啥，扔一堆让我决策的我都听不懂，还得去先研究明白他在说啥。", "last_modified": 1783698922, "replies": 61, "id": 1226505}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/74bb/a227/938_large.png?m=1591791660", "name": "gts", "avatar_normal": "https://cdn.v2ex.com/navatar/74bb/a227/938_normal.png?m=1591791660", "title": "全球工单系统", "url": "https://www.v2ex.com/go/gts", "topics": 10716, "footer": "", "header": "希望这里能够为你遇到的问题找到解决方案", "title_alternative": "Global Ticket System", "avatar_mini": "https://cdn.v2ex.com/navatar/74bb/a227/938_mini.png?m=1591791660", "stars": 1929, "founder_id": 0, "aliases": [], "root": false, "id": 938, "parent_node_name": "geek"}, "member": {"id": 145915, "username": "Light3", "url": "https://www.v2ex.com/u/Light3", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/110e/3b03/145915_mini.png?m=1721197613", "avatar_normal": "https://cdn.v2ex.com/avatar/110e/3b03/145915_normal.png?m=1721197613", "avatar_large": "https://cdn.v2ex.com/avatar/110e/3b03/145915_large.png?m=1721197613", "avatar_xlarge": "https://cdn.v2ex.com/avatar/110e/3b03/145915_xlarge.png?m=1721197613", "avatar_xxlarge": "https://cdn.v2ex.com/