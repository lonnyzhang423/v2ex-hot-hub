[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11279, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2402, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 365601, "username": "szwhszw", "url": "https://www.v2ex.com/u/szwhszw", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/5df7/4c87/365601_mini.png?m=1772710396", "avatar_normal": "https://cdn.v2ex.com/avatar/5df7/4c87/365601_normal.png?m=1772710396", "avatar_large": "https://cdn.v2ex.com/avatar/5df7/4c87/365601_large.png?m=1772710396", "created": 1543136502, "last_modified": 1772710396, "pro": 0}, "last_reply_by": "BigPiggggg", "last_touched": 1784598027, "title": "失业期间打了老婆脸颊和肩膀一下，直接判离婚是不是太冤枉了", "url": "https://www.v2ex.com/t/1228502", "created": 1784517301, "deleted": 0, "content": "去年失业期间，因琐碎事情和老婆争吵，老婆说我天天在家好吃懒惰，然后我一恼火打了我老婆脸颊和肩膀一下，然后她就立即报警了，被个公安下了家暴告诫书；然后后面她立即到医院做了检查（起诉我后我看到了才知道她荡秋天晚上就急诊去了医院）\r\n\r\n现在离婚一审直接判离婚，而且抚养权也归她（整个庭审都没有聊多收小孩什么情况来判断到底谁更有利），而且抚养费也是偏高，不合理\r\n\r\n不合理原因：\r\n1 、无视小孩出生到目前，小孩的生活费、教育、医疗费、家庭生活开支基本都是我出，即使失业期间都是我出\r\n2 、无视我在频繁失业的几年间，我也在尽努力带小孩\r\n3 、无视女方工作期间，大部分育儿是我父母帮衬着再带\r\n4 、无视我不同意离婚的强烈要求\r\n\r\n我怀疑她是出轨，虽然我没有证据，但是及其不正常，原因\r\n1 、离婚她家全部一致同意，连她弟弟不在家，我打电话给她她都说支持\r\n2 、她后期每天晚上都把家中监控关掉，要不就是断网\r\n\r\n要是这样判，真不知道中国男性后面的婚姻应该怎么做了", "content_rendered": "去年失业期间，因琐碎事情和老婆争吵，老婆说我天天在家好吃懒惰，然后我一恼火打了我老婆脸颊和肩膀一下，然后她就立即报警了，被个公安下了家暴告诫书；然后后面她立即到医院做了检查（起诉我后我看到了才知道她荡秋天晚上就急诊去了医院）<br /><br />现在离婚一审直接判离婚，而且抚养权也归她（整个庭审都没有聊多收小孩什么情况来判断到底谁更有利），而且抚养费也是偏高，不合理<br /><br />不合理原因：<br />1 、无视小孩出生到目前，小孩的生活费、教育、医疗费、家庭生活开支基本都是我出，即使失业期间都是我出<br />2 、无视我在频繁失业的几年间，我也在尽努力带小孩<br />3 、无视女方工作期间，大部分育儿是我父母帮衬着再带<br />4 、无视我不同意离婚的强烈要求<br /><br />我怀疑她是出轨，虽然我没有证据，但是及其不正常，原因<br />1 、离婚她家全部一致同意，连她弟弟不在家，我打电话给她她都说支持<br />2 、她后期每天晚上都把家中监控关掉，要不就是断网<br /><br />要是这样判，真不知道中国男性后面的婚姻应该怎么做了", "last_modified": 1784517327, "replies": 364, "id": 1228502}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9f61/408e/56_large.png?m=1628212285", "name": "internet", "avatar_normal": "https://cdn.v2ex.com/navatar/9f61/408e/56_normal.png?m=1628212285", "title": "互联网", "url": "https://www.v2ex.com/go/internet", "topics": 4207, "footer": "", "header": "In Internet we trust", "title_alternative": "Internet", "avatar_mini": "https://cdn.v2ex.com/navatar/9f61/408e/56_mini.png?m=1628212285", "stars": 1203, "founder_id": 0, "aliases": [], "root": false, "id": 56, "parent_node_name": "computer"}, "member": {"id": 564433, "username": "nealHuang", "url": "https://www.v2ex.com/u/nealHuang", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/722f/696f/564433_mini.png?m=1764582033", "avatar_normal": "https://cdn.v2ex.com/avatar/722f/696f/564433_normal.png?m=1764582033", "avatar_large": "https://cdn.v2ex.com/avatar/722f/696f/564433_large.png?m=1764582033", "avatar_xlarge": "https://cdn.v2ex.com/avatar/722f/696f/564433_xlarge.png?m=1764582033", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/722f/696f/564433_xxlarge.png?m=1764582033", "created": 1638786886, "last_modified": 1764582033, "pro": 0}, "last_reply_by": "jjwjiang", "last_touched": 1784573424, "title": "卧槽， PDD 这么牛批嘛，真见鬼了", "url": "https://www.v2ex.com/t/1228477", "created": 1784513868, "deleted": 0, "content": "今天在群友转发了这样的一个聊天记录\r\n\r\n https://i.imgur.com/M6Et8QQ.jpeg \r\n \r\n \r\n 我是电脑微信看到这个图的，然后马上去手机打开 pdd 测试一下\r\n \r\n  https://i.imgur.com/IcmnLUO.jpeg", "content_rendered": "今天在群友转发了这样的一个聊天记录<br /><br /> <a target=\"_blank\" href=\"https://i.imgur.com/M6Et8QQ.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/M6Et8QQ.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a><br /> <br /> <br /> 我是电脑微信看到这个图的，然后马上去手机打开 pdd 测试一下<br /> <br />  <a target=\"_blank\" href=\"https://i.imgur.com/IcmnLUO.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/IcmnLUO.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1784517781, "replies": 117, "id": 1228477}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11279, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2402, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 546565, "username": "afkool", "url": "https://www.v2ex.com/u/afkool", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/09069d134d28763cbeccac8b2e9fff3e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/09069d134d28763cbeccac8b2e9fff3e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/09069d134d28763cbeccac8b2e9fff3e?s=73&d=retro", "created": 1622174833, "last_modified": 1776679450, "pro": 0}, "last_reply_by": "NoKey", "last_touched": 1784559115, "title": "吃瓜吧。表弟骗了 50 多万，如何对账知道他在干嘛？", "url": "https://www.v2ex.com/t/1228512", "created": 1784519299, "deleted": 0, "content": "年初的时候找家里说缺 20 万。家里给了 10 万。\r\n5 月份骗他哥说要去招标啥的，一个月给还，拿了 50 万。\r\n到期了说没钱得缓，转头给他妈说没钱。创业失败之类的。\r\n他妈心软，给他哥说这钱别找你弟要，我给你还。\r\n\r\n他哥的意思是，明显谎话连篇。\r\n1 、不可能 50 万的招标项目。\r\n2 、表弟的说法是：公司每个月亏 5 万，他亏了半年扛不住了去借的网贷给员工发工资然后倒闭\r\n他哥觉得，创业、有公司的人不会动网贷的心思，其次，宁愿欠员工也不可能欠网贷。再次，他都一个月亏 5 万了，他还继续亏是脑子有包？\r\n\r\n他妈也有点回过神来，但农村人啥都不懂，他妈打算过去查账\r\n\r\n我的想法是：\r\n1 、他说一个月亏 5 万，查每个月亏在哪里，转账转给了谁。\r\n2 、给了他 50 万，他说还网贷了，看收款是公司还是不同的个人。\r\n3 、如何查他还有没有其他的网贷？\r\n4 、如何查他房产是不是抵押了？（全家给他在准一线首付了 200 个买的房，就怕房子也保不住了）\r\n还有什么需要补充的。我也不懂这些。主要看他现在是不是已经无底洞了。（他自己说目前还欠 7 万，就怕不止）\r\n想给他爸妈列个表，让他爸妈过去他的城市一条一条过一遍、查一遍。真只欠 7 万了就已经算最好的结果了。", "content_rendered": "年初的时候找家里说缺 20 万。家里给了 10 万。<br />5 月份骗他哥说要去招标啥的，一个月给还，拿了 50 万。<br />到期了说没钱得缓，转头给他妈说没钱。创业失败之类的。<br />他妈心软，给他哥说这钱别找你弟要，我给你还。<br /><br />他哥的意思是，明显谎话连篇。<br />1 、不可能 50 万的招标项目。<br />2 、表弟的说法是：公司每个月亏 5 万，他亏了半年扛不住了去借的网贷给员工发工资然后倒闭<br />他哥觉得，创业、有公司的人不会动网贷的心思，其次，宁愿欠员工也不可能欠网贷。再次，他都一个月亏 5 万了，他还继续亏是脑子有包？<br /><br />他妈也有点回过神来，但农村人啥都不懂，他妈打算过去查账<br /><br />我的想法是：<br />1 、他说一个月亏 5 万，查每个月亏在哪里，转账转给了谁。<br />2 、给了他 50 万，他说还网贷了，看收款是公司还是不同的个人。<br />3 、如何查他还有没有其他的网贷？<br />4 、如何查他房产是不是抵押了？（全家给他在准一线首付了 200 个买的房，就怕房子也保不住了）<br />还有什么需要补充的。我也不懂这些。主要看他现在是不是已经无底洞了。（他自己说目前还欠 7 万，就怕不止）<br />想给他爸妈列个表，让他爸妈过去他的城市一条一条过一遍、查一遍。真只欠 7 万了就已经算最好的结果了。", "last_modified": 1784519422, "replies": 78, "id": 1228512}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72182, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9730, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 19231, "username": "Tsing2", "url": "https://www.v2ex.com/u/Tsing2", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/517f/62b2/19231_mini.png?m=1745375683", "avatar_normal": "https://cdn.v2ex.com/avatar/517f/62b2/19231_normal.png?m=1745375683", "avatar_large": "https://cdn.v2ex.com/avatar/517f/62b2/19231_large.png?m=1745375683", "avatar_xlarge": "https://cdn.v2ex.com/avatar/517f/62b2/19231_xlarge.png?m=1745375683", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/517f/62b2/19231_xxlarge.png?m=1745375683", "created": 1333903730, "last_modified": 1745375683, "pro": 0}, "last_reply_by": "MK47", "last_touched": 1784597946, "title": "所以说，你们对大模型是一点黏性都没有的？", "url": "https://www.v2ex.com/t/1228568", "created": 1784531495, "deleted": 0, "content": "从 DP4 ，到 GLM 5.2 ，到 K3 ，说换就换，毫无纠结，就跟渣男一样……\r\n那，做了一半的任务，是直接在新模型上继续了？", "content_rendered": "<p>从 DP4 ，到 GLM 5.2 ，到 K3 ，说换就换，毫无纠结，就跟渣男一样……\n那，做了一半的任务，是直接在新模型上继续了？</p>\n", "last_modified": 1784531495, "replies": 74, "id": 1228568}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240068, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4500, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 330382, "username": "dfadfadfadf", "url": "https://www.v2ex.com/u/dfadfadfadf", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/1f24/0b77/330382_mini.png?m=1782369242", "avatar_normal": "https://cdn.v2ex.com/avatar/1f24/0b77/330382_normal.png?m=1782369242", "avatar_large": "https://cdn.v2ex.com/avatar/1f24/0b77/330382_large.png?m=1782369242", "avatar_xlarge": "https://cdn.v2ex.com/avatar/1f24/0b77/330382_xlarge.png?m=1782369242", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/1f24/0b77/330382_xxlarge.png?m=1782369242", "created": 1532068387, "last_modified": 1782369242, "pro": 0}, "last_reply_by": "HankAviator", "last_touched": 1784597793, "title": "如何解决在境外坐车，半路被蒙头，拉去缅北的场景问题", "url": "https://www.v2ex.com/t/1228576", "created": 1784532375, "deleted": 0, "content": "我想带我爸妈去泰国玩玩。\r\n如果你已经上了车，并且还是导游带的车，半路就让你下车，把你拉到缅北。如何提前预判？好像无解啊", "content_rendered": "<p>我想带我爸妈去泰国玩玩。\n如果你已经上了车，并且还是导游带的车，半路就让你下车，把你拉到缅北。如何提前预判？好像无解啊</p>\n", "last_modified": 1784532375, "replies": 74, "id": 1228576}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23892, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3713, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 514779, "username": "Toadair", "url": "https://www.v2ex.com/u/Toadair", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "guangzhou", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_mini.png?m=1767668010", "avatar_normal": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_normal.png?m=1767668010", "avatar_large": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_large.png?m=1767668010", "avatar_xlarge": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_xlarge.png?m=1767668010", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_xxlarge.png?m=1767668010", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/dcef/8dec/514779_xxxlarge.png?m=1767668010", "created": 1603769996, "last_modified": 1767668010, "pro": 0}, "last_reply_by": "jimrok", "last_touched": 1784597511, "title": "被辞退了，准备到年底都不工作了，怎么玩呢？听听大家的建议", "url": "https://www.v2ex.com/t/1228593", "created": 1784534438, "deleted": 0, "content": "无外债", "content_rendered": "<p>无外债</p>\n", "last_modified": 1784534438, "replies": 63, "id": 1228593}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11279, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2402, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 580171, "username": "90e", "url": "https://www.v2ex.com/u/90e", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_mini.png?m=1757660160", "avatar_normal": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_normal.png?m=1757660160", "avatar_large": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_large.png?m=1757660160", "avatar_xlarge": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_xlarge.png?m=1757660160", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_xxlarge.png?m=1757660160", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/b3fb/315e/580171_xxxlarge.png?m=1757660160", "created": 1651830175, "last_modified": 1757660160, "pro": 0}, "last_reply_by": "90e", "last_touched": 1784597956, "title": "普通人对重大疾病的无力", "url": "https://www.v2ex.com/t/1228609", "created": 1784536569, "deleted": 0, "content": "1. 今年 3 月底我爸说自己越来越瘦，食欲不行，然后让我们带到社区医院去检查，然后社区医院说这个病很麻烦，要去大医院才行，\r\n\r\n2. 去了一个离家很近的三甲医院，住院几天，各种检查，最后检查出来是十二指肠肿瘤，然后又转到了华中比较靠前的 tz 大医院做手术，因为在网上搜了一下，这个肿瘤，切除后，手术愈后效果是很不错的，医生说的也是现在手术切除条件很不错，可能最多就是术后需要化疗几次，然后想着是大医院，比较放心，自己就没有太搜这些相关的内容。\r\n\r\n3. 4 月份做了手术，术后 1 个半月出院了，有些发烧，去呼吸科各种检查，发现了有远处淋巴结转移，当时虽然觉得很危险，但是想着是淋巴结，而是十二指肠肿瘤也还好，就没太关注，\r\n\r\n4. 因为之前一直瞒着我爸，说是良性肿瘤，6 月底需要开始化疗的时候，才告诉我爸他的情况，然后到肿瘤科，医生才告诉我们实际情况，说这个十二指肠肿瘤和胰腺癌是一样的，按目前情况可能就半年的样子，即使化疗情况良好，可能也就 2 年，当时根本接受不了，之前一直以为是可以治好的。\r\n\r\n5. 很近之前就有买医疗保险，以为是有这个保障的，但是没想到在真的大病面前，根本没用。\r\n\r\n6. 目前两次化疗后出现了脓毒症，可能真的不太久了。\r\n\r\n7. 今天我女朋友跟我聊天的时候说我妈给她说她连我爸要在哪儿走？她都想好了，她说一定要让他在医院走，不要让他在家里走，他怕之后我害怕", "content_rendered": "<ol>\n<li>\n<p>今年 3 月底我爸说自己越来越瘦，食欲不行，然后让我们带到社区医院去检查，然后社区医院说这个病很麻烦，要去大医院才行，</p>\n</li>\n<li>\n<p>去了一个离家很近的三甲医院，住院几天，各种检查，最后检查出来是十二指肠肿瘤，然后又转到了华中比较靠前的 tz 大医院做手术，因为在网上搜了一下，这个肿瘤，切除后，手术愈后效果是很不错的，医生说的也是现在手术切除条件很不错，可能最多就是术后需要化疗几次，然后想着是大医院，比较放心，自己就没有太搜这些相关的内容。</p>\n</li>\n<li>\n<p>4 月份做了手术，术后 1 个半月出院了，有些发烧，去呼吸科各种检查，发现了有远处淋巴结转移，当时虽然觉得很危险，但是想着是淋巴结，而是十二指肠肿瘤也还好，就没太关注，</p>\n</li>\n<li>\n<p>因为之前一直瞒着我爸，说是良性肿瘤，6 月底需要开始化疗的时候，才告诉我爸他的情况，然后到肿瘤科，医生才告诉我们实际情况，说这个十二指肠肿瘤和胰腺癌是一样的，按目前情况可能就半年的样子，即使化疗情况良好，可能也就 2 年，当时根本接受不了，之前一直以为是可以治好的。</p>\n</li>\n<li>\n<p>很近之前就有买医疗保险，以为是有这个保障的，但是没想到在真的大病面前，根本没用。</p>\n</li>\n<li>\n<p>目前两次化疗后出现了脓毒症，可能真的不太久了。</p>\n</li>\n<li>\n<p>今天我女朋友跟我聊天的时候说我妈给她说她连我爸要在哪儿走？她都想好了，她说一定要让他在医院走，不要让他在家里走，他怕之后我害怕</p>\n</li>\n</ol>\n", "last_modified": 1784536569, "replies": 59, "id": 1228609}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11279, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2402, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 336746, "username": "JohnXu20151211", "url": "https://www.v2ex.com/u/JohnXu20151211", "website": null, "twitter": "", "psn": "", "github": "xu20160924", "btc": "", "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/58b49211768add9b479f99100faba14f?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/58b49211768add9b479f99100faba14f?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/58b49211768add9b479f99100faba14f?s=73&d=retro", "created": 1532758722, "last_modified": 1783178256, "pro": 0}, "last_reply_by": "akorn", "last_touched": 1784597901, "title": "如何让对象忙起来？", "url": "https://www.v2ex.com/t/1228629", "created": 1784541292, "deleted": 0, "content": "说下背景，我们在一线城市，已婚，没有小孩。\r\n我是码农，她在外企，整体我会忙一些。她在外企相对轻松很多。\r\n我想向上走，想向优秀的人看齐，毕竟生活一线城市，多少是想创造更好的生活。再加上我这行有年龄危机和这几年不好干，我周末都会去尝试做副业和提升。因为我心里十分担忧未来。\r\n但是目前看来她对当前的生活挺满足，没有任何危机意识和未来规划，到了周末基本就是刷小视频或者玩小游戏。不过这也没问题，但是人一旦闲下来，它就得出事。就会开始胡思乱想，想的无非就是感情那些或者鸡毛蒜皮事儿。 \r\n\r\n怎么能让她忙起来呢？暂时没有要小孩的想法。她英语专业，可以做小孩的辅导。谁能来点需求？能挣钱我也跟着干。我甚至想如果是背上了百万房贷就没这些事了。", "content_rendered": "<p>说下背景，我们在一线城市，已婚，没有小孩。\n我是码农，她在外企，整体我会忙一些。她在外企相对轻松很多。\n我想向上走，想向优秀的人看齐，毕竟生活一线城市，多少是想创造更好的生活。再加上我这行有年龄危机和这几年不好干，我周末都会去尝试做副业和提升。因为我心里十分担忧未来。\n但是目前看来她对当前的生活挺满足，没有任何危机意识和未来规划，到了周末基本就是刷小视频或者玩小游戏。不过这也没问题，但是人一旦闲下来，它就得出事。就会开始胡思乱想，想的无非就是感情那些或者鸡毛蒜皮事儿。 </p>\n<p>怎么能让她忙起来呢？暂时没有要小孩的想法。她英语专业，可以做小孩的辅导。谁能来点需求？能挣钱我也跟着干。我甚至想如果是背上了百万房贷就没这些事了。</p>\n", "last_modified": 1784541292, "replies": 54, "id": 1228629}]