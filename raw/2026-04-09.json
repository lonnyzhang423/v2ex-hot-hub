[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1751718333", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1751718333", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 238073, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1751718333", "stars": 4479, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 638855, "username": "mode171", "url": "https://www.v2ex.com/u/mode171", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "深圳", "tagline": "生活是一部电影； 死亡是一张照片。", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_mini.png?m=1766369444", "avatar_normal": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_normal.png?m=1766369444", "avatar_large": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_large.png?m=1766369444", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xlarge.png?m=1766369444", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxlarge.png?m=1766369444", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxxlarge.png?m=1766369444", "created": 1689515364, "last_modified": 1766369444, "pro": 0}, "last_reply_by": "xdzhang", "last_touched": 1775722046, "title": "大家来说一个自己独特的癖好吧！", "url": "https://www.v2ex.com/t/1204499", "created": 1775699032, "deleted": 0, "content": "独特癖好，比如喜欢闻**消毒水**味儿。", "content_rendered": "<p>独特癖好，比如喜欢闻<strong>消毒水</strong>味儿。</p>\n", "last_modified": 1775699032, "replies": 136, "id": 1204499}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10540, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2247, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 376712, "username": "ufan0", "url": "https://www.v2ex.com/u/ufan0", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "wolframalpha.com", "bio": "若没有收到我的回复，定是站内通知又出了问题。", "avatar_mini": "https://cdn.v2ex.com/avatar/056f/afca/376712_mini.png?m=1761701381", "avatar_normal": "https://cdn.v2ex.com/avatar/056f/afca/376712_normal.png?m=1761701381", "avatar_large": "https://cdn.v2ex.com/avatar/056f/afca/376712_large.png?m=1761701381", "created": 1547167809, "last_modified": 1761701381, "pro": 0}, "last_reply_by": "bigLinux", "last_touched": 1775682665, "title": "通勤路上被和尚纠缠，应该如何应对？", "url": "https://www.v2ex.com/t/1204503", "created": 1775699649, "deleted": 0, "content": "如题，早上上班时，老远有个和尚过来说是化缘，让我给他买米。\r\n\r\n可是上班马上迟到，我没有时间，也一直在给他解释。\r\n\r\n对方仍然不依不饶，我提出给他转钱他不要，我说加微信等我下班，也不行，跟了我大概 150 米。\r\n即将路过一家超市门口时，他拦住我，说这里就行，直接转钱买点就可以。\r\n\r\n但是我确实没有时间了，路边很多人坐着乘凉，让他重新问下他人也不答应，非要揪着我。\r\n\r\n最后让我转钱，我没搭理，快步走开，他在我身后人群中吼了几句“你这人真的是，没救了，你这个人怎么这样啊”，感觉很不舒服。想找他理论，刚回头，他就行了一礼说“阿弥陀佛”，无法选中啊。\r\n\r\n实在是着急上班（迟到一分钟就是扣半天工资），就赶紧离开了。\r\n\r\n后续遇见这种情况应该如何处理？心里感觉很不是滋味。", "content_rendered": "<p>如题，早上上班时，老远有个和尚过来说是化缘，让我给他买米。</p>\n<p>可是上班马上迟到，我没有时间，也一直在给他解释。</p>\n<p>对方仍然不依不饶，我提出给他转钱他不要，我说加微信等我下班，也不行，跟了我大概 150 米。\n即将路过一家超市门口时，他拦住我，说这里就行，直接转钱买点就可以。</p>\n<p>但是我确实没有时间了，路边很多人坐着乘凉，让他重新问下他人也不答应，非要揪着我。</p>\n<p>最后让我转钱，我没搭理，快步走开，他在我身后人群中吼了几句“你这人真的是，没救了，你这个人怎么这样啊”，感觉很不舒服。想找他理论，刚回头，他就行了一礼说“阿弥陀佛”，无法选中啊。</p>\n<p>实在是着急上班（迟到一分钟就是扣半天工资），就赶紧离开了。</p>\n<p>后续遇见这种情况应该如何处理？心里感觉很不是滋味。</p>\n", "last_modified": 1775699649, "replies": 115, "id": 1204503}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10540, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2247, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 175311, "username": "Mogugugugu", "url": "https://www.v2ex.com/u/Mogugugugu", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/d92e/7173/175311_mini.png?m=1759030105", "avatar_normal": "https://cdn.v2ex.com/avatar/d92e/7173/175311_normal.png?m=1759030105", "avatar_large": "https://cdn.v2ex.com/avatar/d92e/7173/175311_large.png?m=1759030105", "created": 1464602567, "last_modified": 1759030105, "pro": 0}, "last_reply_by": "zerovoid", "last_touched": 1775722003, "title": "来一起讨论一下，你选择生育的理由是什么？", "url": "https://www.v2ex.com/t/1204483", "created": 1775695982, "deleted": 0, "content": "首先，个人非厌童，非丁克，娃这种生物虽然可爱，但是想到要负责培养一个“人”，对于我来说挑战性还是太高了。所以想知道你们选择生育，成为父母的理由是什么呢？是缘分到了，还是年龄到了，或者想过一种新的体验，又或者是迫于长辈的压力？\r\n\r\n\r\n本帖只讨论生育，不讨论丁克，不婚，不育。", "content_rendered": "<p>首先，个人非厌童，非丁克，娃这种生物虽然可爱，但是想到要负责培养一个“人”，对于我来说挑战性还是太高了。所以想知道你们选择生育，成为父母的理由是什么呢？是缘分到了，还是年龄到了，或者想过一种新的体验，又或者是迫于长辈的压力？</p>\n<p>本帖只讨论生育，不讨论丁克，不婚，不育。</p>\n", "last_modified": 1775714266, "replies": 112, "id": 1204483}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a87f/f679/4_large.png?m=1625264761", "name": "music", "avatar_normal": "https://cdn.v2ex.com/navatar/a87f/f679/4_normal.png?m=1625264761", "title": "音乐", "url": "https://www.v2ex.com/go/music", "topics": 1815, "footer": "", "header": "Music is an art form whose medium is sound and silence.", "title_alternative": "Music", "avatar_mini": "https://cdn.v2ex.com/navatar/a87f/f679/4_mini.png?m=1625264761", "stars": 1576, "founder_id": 0, "aliases": [], "root": false, "id": 4, "parent_node_name": "life"}, "member": {"id": 510532, "username": "missx", "url