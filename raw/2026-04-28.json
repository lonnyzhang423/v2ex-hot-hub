[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1fc2/1400/864_large.png?m=1775086598", "name": "promotions", "avatar_normal": "https://cdn.v2ex.com/navatar/1fc2/1400/864_normal.png?m=1775086598", "title": "推广", "url": "https://www.v2ex.com/go/promotions", "topics": 11387, "footer": "", "header": "来自厂商的推广活动类主题，会被归类到这个节点。希望有情怀的产商们在发布推广内容时，主动选择发布到本节点下。点击 <a href=\"/help/node\">这里</a> 阅读 V2EX 的节点使用指南。", "title_alternative": "Promotions", "avatar_mini": "https://cdn.v2ex.com/navatar/1fc2/1400/864_mini.png?m=1775086598", "stars": 1217, "founder_id": 0, "aliases": [], "root": false, "id": 864, "parent_node_name": ""}, "member": {"id": 708661, "username": "v2exgo", "url": "https://www.v2ex.com/u/v2exgo", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_mini.png?m=1774860655", "avatar_normal": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_normal.png?m=1774860655", "avatar_large": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_large.png?m=1774860655", "avatar_xlarge": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_xlarge.png?m=1774860655", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_xxlarge.png?m=1774860655", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/77fc/e6c8/708661_xxxlarge.png?m=1774860655", "created": 1725198542, "last_modified": 1774860655, "pro": 0}, "last_reply_by": "dayoujie0", "last_touched": 1777363213, "title": "Termina.Pub 中转站 可开发票，欢迎企业合作，限时开启 claude-free 渠道，回帖留 id 送 10 刀额度", "url": "https://www.v2ex.com/t/1208985", "created": 1777334753, "deleted": 0, "content": "在 V 站宣传有一段时间了，积累不了少客户，有些朋友用的不开心走了，有的朋友退款了，但是老板还在，老板又回来给 v 友发福利了\r\n\r\nclaude-free 渠道 限时开启，避免滥用，只要 5 分一刀\r\n\r\n**官网地址**\r\n\r\n[https://terminal.pub/register]( https://terminal.pub/register)\r\n\r\n\r\n* 充值 1 人民币=1 美金, 套餐可以 0.9 人民币=1 美金\r\n\r\n## 活动规则\r\n老规矩，回帖发自己 id 每个人送 10 刀，仅限前 150 位\r\n![图片]( https://i.imgur.com/0oWfkP0.png )\r\n\r\n