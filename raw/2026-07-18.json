[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11261, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2399, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 225840, "username": "zsxzy", "url": "https://www.v2ex.com/u/zsxzy", "website": "iosair.cn", "twitter": "", "psn": "", "github": "xfirefly", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_mini.png?m=1750605867", "avatar_normal": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_normal.png?m=1750605867", "avatar_large": "https://cdn.v2ex.com/avatar/6ced/5cd3/225840_large.png?m=1750605867", "created": 1492064566, "last_modified": 1750605867, "pro": 0}, "last_reply_by": "liulicaixiao", "last_touched": 1783685193, "title": "纯功利的角度, 如何为孩子选兴趣班？", "url": "https://www.v2ex.com/t/1228170", "created": 1784342900, "deleted": 0, "content": "孩子才 8 岁，报了好几个兴趣班：羽毛球、舞蹈、武术、钢琴、绘画。\r\n\r\n如果站在纯功利角度，以普通家庭、普通孩子的条件来考虑，优先选**低投入、高确定性、长期有用**的项目，\r\n\r\n应该重点深耕哪一个？有更好的项目吗", "content_rendered": "<p>孩子才 8 岁，报了好几个兴趣班：羽毛球、舞蹈、武术、钢琴、绘画。</p>\n<p>如果站在纯功利角度，以普通家庭、普通孩子的条件来考虑，优先选<strong>低投入、高确定性、长期有用</strong>的项目，</p>\n<p>应该重点深耕哪一个？有更好的项目吗</p>\n", "last_modified": 1784342900, "replies": 91, "id": 1228170}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240039, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4499, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 276277, "username": "chniccs", "url": "https://www.v2ex.com/u/chniccs", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/62031a8745e8929e0be3dd99908a97cf?s=73&d=retro", "created": 1513927680, "last_modified": 1703469299, "pro": 0}, "last_reply_by": "y1y1", "last_touched": 1784376322, "title": "假如没有厕纸了，你用什么？", "url": "https://www.v2ex.com/t/1228159", "created": 1784339422, "deleted": 0, "content": "坐标江西，小时候在乡下，那时候厕纸还是高级货，没多少人有，小伙伴出去玩，中途释放完之后，会使用竹片刮（不是擦，是刮）屁股，现在就好奇，江西竹子多所以用竹子，那其它地方的人在没厕纸的情况下都用什么？", "content_rendered": "坐标江西，小时候在乡下，那时候厕纸还是高级货，没多少人有，小伙伴出去玩，中途释放完之后，会使用竹片刮（不是擦，是刮）屁股，现在就好奇，江西竹子多所以用竹子，那其它地方的人在没厕纸的情况下都用什么？", "last_modified": 1784339422, "replies": 68, "id": 1228159}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11261, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2399, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 8373, "username": "Hyvi", "url": "https://www.v2ex.com/u/Hyvi", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/343d6ab15ce2190705252441e8083e40?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/343d6ab15ce2190705252441e8083e40?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/343d6ab15ce2190705252441e8083e40?s=73&d=retro", "created": 1304053219, "last_modified": 1304139646, "pro": 0}, "last_reply_by": "Hyvi", "last_touched": 1784374415, "title": "投资建议：自有宅基地建房出租。", "url": "https://www.v2ex.com/t/1228206", "created": 1784354819, "deleted": 0, "content": "背景是这样子的。\r\n\r\n自有宅基地在县城的一中附近大概 500 米左右，想自建楼房出租，建 5 层楼，每层楼 4 套 50 平米的两室一厅，租金大概在每套 500 块钱一个月。关于投资的成本，主要包括建楼的成本、简单装修的成本。简单空调油烟机热水器的购买、安装，以及电梯的安装。预计成本在 100 万左右。\r\n\r\n想知道值不值得投入。", "content_rendered": "<p>背景是这样子的。</p>\n<p>自有宅基地在县城的一中附近大概 500 米左右，想自建楼房出租，建 5 层楼，每层楼 4 套 50 平米的两室一厅，租金大概在每套 500 块钱一个月。关于投资的成本，主要包括建楼的成本、简单装修的成本。简单空调油烟机热水器的购买、安装，以及电梯的安装。预计成本在 100 万左右。</p>\n<p>想知道值不值得投入。</p>\n", "last_modified": 1784354819, "replies": 34, "id": 1228206}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23880, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3712, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 338820, "username": "frankkly", "url": "https://www.v2ex.com/u/frankkly", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_mini.png?m=1754288397", "avatar_normal": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_normal.png?m=1754288397", "avatar_large": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_large.png?m=1754288397", "avatar_xlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xlarge.png?m=1754288397", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xxlarge.png?m=1754288397", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/0dc0/565f/338820_xxxlarge.png?m=1754288397", "created": 1533524726, "last_modified": 1754288397, "pro": 0}, "last_reply_by": "sun1719", "last_touched": 1784378856, "title": "裁员 n+1，已签解除合同，社保和公积金还能要求公司补吗？", "url": "https://www.v2ex.com/t/1228195", "created": 1784348242, "deleted": 0, "content": "7 月 15 号下午谈的，当时也不知道咋想的，n+1 就直接签了，事后想想挺傻逼的\r\n我们的社保和公积金都是按照最低的基数交的，我在支付宝里面查到公司的公积金缴费比例是 12%，社保的基数每年都不太一样，但是也都是按照最低交的，我当时也提了社保和公积金补偿，他们说社保只能补今年 1 月到 7 月，公积金说是要跟着公司上面集团一起补了才会补，后来感觉就是忽悠人的\r\n我让豆包按照我的工资水平算了一下，6 年，公司要给我补的钱大概一共是 38w7,这其中社保 26w6,公积金 12w1,然后我自己要补社保 10w6 ，公积金 12w1\r\n目前离职证明还没拿到，解除劳动合同签了，跟人事约了周一下午继续谈一下\r\n我想问问，假如我走投诉渠道去社保局和公积金中心，这笔钱我能拿到吗，就是打到我相应的账户里，我自己也补钱，再一个投诉渠道会不会给公司造成压力，公司会不会想跟我私下补一笔钱和解（不包含 n+1 ）\r\n杭州，国企性质，老板有编制，大家有类似的处理经验吗？", "content_rendered": "7 月 15 号下午谈的，当时也不知道咋想的，n+1 就直接签了，事后想想挺傻逼的<br />我们的社保和公积金都是按照最低的基数交的，我在支付宝里面查到公司的公积金缴费比例是 12%，社保的基数每年都不太一样，但是也都是按照最低交的，我当时也提了社保和公积金补偿，他们说社保只能补今年 1 月到 7 月，公积金说是要跟着公司上面集团一起补了才会补，后来感觉就是忽悠人的<br />我让豆包按照我的工资水平算了一下，6 年，公司要给我补的钱大概一共是 38w7,这其中社保 26w6,公积金 12w1,然后我自己要补社保 10w6 ，公积金 12w1<br />目前离职证明还没拿到，解除劳动合同签了，跟人事约了周一下午继续谈一下<br />我想问问，假如我走投诉渠道去社保局和公积金中心，这笔钱我能拿到吗，就是打到我相应的账户里，我自己也补钱，再一个投诉渠道会不会给公司造成压力，公司会不会想跟我私下补一笔钱和解（不包含 n+1 ）<br />杭州，国企性质，老板有编制，大家有类似的处理经验吗？", "last_modified": 1784351751, "replies": 31, "id": 1228195}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72137, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9729, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 674000, "username": "karashoukpan", "url": "https://www.v2ex.com/u/karashoukpan", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "Everything Wins!", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/8710/5769/674000_mini.png?m=1773923502", "avatar_normal": "https://cdn.v2ex.com/avatar/8710/5769/674000_normal.png?m=1773923502", "avatar_large": "https://cdn.v2ex.com/avatar/8710/5769/674000_large.png?m=1773923502", "avatar_xlarge": "https://cdn.v2ex.com/avatar/8710/5769/674000_xlarge.png?m=1773923502", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/8710/5769/674000_xxlarge.png?m=1773923502", "created": 1706581761, "last_modified": 1773923502, "pro": 0}, "last_reply_by": "shawnsh", "last_touched": 1784376883, "title": "大家用 AI 写代码真实感受是啥？", "url": "https://www.v2ex.com/t/1228212", "created": 1784357907, "deleted": 0, "content": "先说说，会感觉比较空虚；\r\n\r\n- 因为代码写完了，但是不是我写的，我没学到东西也没发现问题。没有仔细 review 代码，大概率也不会 review\r\n\r\n心里没底；\r\n\r\n- 连调和修 bug 的时候心理没底，因为不知道写了啥东西 🤣", "content_rendered": "<p>先说说，会感觉比较空虚；</p>\n<ul>\n<li>因为代码写完了，但是不是我写的，我没学到东西也没发现问题。没有仔细 review 代码，大概率也不会 review</li>\n</ul>\n<p>心里没底；</p>\n<ul>\n<li>连调和修 bug 的时候心理没底，因为不知道写了啥东西 🤣</li>\n</ul>\n", "last_modified": 1784357907, "replies": 31, "id": 1228212}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23880, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3712, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 797202, "username": "wobuchiyu", "url": "https://www.v2ex.com/u/wobuchiyu", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "我不爱吃鱼", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_mini.png?m=1780382015", "avatar_normal": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_normal.png?m=1780382015", "avatar_large": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_large.png?m=1780382015", "avatar_xlarge": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_xlarge.png?m=1780382015", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/946a/cfbd/797202_xxlarge.png?m=1780382015", "created": 1774418682, "last_modified": 1780382015, "pro": 0}, "last_reply_by": "haiku", "last_touched": 1784377683, "title": "我发现真的只有互联网行业自己卷死自己，自己把自己的工作整没了。", "url": "https://www.v2ex.com/t/1228193", "created": 1784347542, "deleted": 0, "content": "应该只有互联网开发会出现所谓的 35 斩杀线吧，并且经验完全没有用，瞬间被 ai 替代。 像机械 电子 这种，开源好像没有计算机的多。经验多的老师傅 完全不担心失业。 但是就算你是全栈 资深  高级，  算法  在 ai 出来后，人人自危。   \r\n\r\n还有今年冒出来的 agent 开发工程师。 公司真的需要这玩意吗，造需求，就更 3 月份的龙虾一样。等 agent 开发完了。还需要那么多 agent 开发吗？最后还是自己把自己干死了。", "content_rendered": "应该只有互联网开发会出现所谓的 35 斩杀线吧，并且经验完全没有用，瞬间被 ai 替代。 像机械 电子 这种，开源好像没有计算机的多。经验多的老师傅 完全不担心失业。 但是就算你是全栈 资深  高级，  算法  在 ai 出来后，人人自危。   <br /><br />还有今年冒出来的 agent 开发工程师。 公司真的需要这玩意吗，造需求，就更 3 月份的龙虾一样。等 agent 开发完了。还需要那么多 agent 开发吗？最后还是自己把自己干死了。", "last_modified": 1784347760, "replies": 30, "id": 1228193}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4321, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3225, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 238062, "username": "johnsonhk", "url": "https://www.v2ex.com/u/johnsonhk", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/6e1df90fea4e7dfbc7e019cbb1b83356?s=73&d=retro", "created": 1498818608, "last_modified": 1498818608, "pro": 0}, "last_reply_by": "chrosing", "last_touched": 1784347698, "title": "18 号到期的重置，本来想着今天用的，结果。。。", "url": "https://www.v2ex.com/t/1228155", "created": 1784337150, "deleted": 0, "content": "今天 18 号一大早就发现重置已经没有了。。。。。。", "content_rendered": "<p>今天 18 号一大早就发现重置已经没有了。。。。。。</p>\n", "last_modified": 1784337150, "replies": 29, "id": 1228155}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4321, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3225, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 688475, "username": "bilulanlv", "url": "https://www.v2ex.com/u/bilulanlv", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/7c0f2d1c493e04ece49e15c33bbfc44e?s=73&d=retro", "created": 1714965491, "last_modified": 1714965491, "pro": 0}, "last_reply_by": "BaiLinfeng", "last_touched": 1784377683, "title": "Codex 又又又重置了", "url": "https://www.v2ex.com/t/1228183", "created": 1784345579, "deleted": 0, "content": "还好忍住没用重置卡，竟然在 18%的时候又重置了。感觉有点赚翻了。", "content_rendered": "<p>还好忍住没用重置卡，竟然在 18%的时候又重置了。感觉有点赚翻了。</p>\n", "last_modified": 1784345579, "replies": 25, "id": 1228183}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72137, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9729, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 554382, "username": "luojiedev", "url": "https://www.v2ex.com/u/luojiedev", "website": "https://blog.luojie.net/", "twitter": "luojiedev", "psn": "", "github": "luojiedev", "btc": "", "location": "", "tagline": "", "bio": "从事休闲游戏后端十多年，还在写代码。\r\n\r\n喜欢读书，过着平静的生活，养育着两个儿子。", "avatar_mini": "https://cdn.v2ex.com/avatar/83db/495c/554382_mini.png?m=1782970802", "avatar_normal": "https://cdn.v2ex.com/avatar/83db/495c/554382_normal.png?m=1782970802", "avatar_large": "https://cdn.v2ex.com/avatar/83db/495c/554382_large.png?m=1782970802", "avatar_xlarge": "https://cdn.v2ex.com/avatar/83db/495c/554382_xlarge.png?m=1782970802", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/83db/495c/554382_xxlarge.png?m=1782970802", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/83db/495c/554382_xxxlarge.png?m=1782970802", "created": 1629959189, "last_modified": 1782970802, "pro": 0}, "last_reply_by": "dif", "last_touched": 1784373295, "title": "2026，我将博客部署到了 Cloudflare（CF）", "url": "https://www.v2ex.com/t/1228199", "created": 1784350675, "deleted": 0, "content": "20 年的时候，我看别人写博客，自己也开始凑热闹，大多都是些没有啥价值的内容。当时想着，肯定要部署在国内的云服务上，于是发现成本还挺高的。要购买域名（还必须是 .com 后缀)，还要搞定备案，HTTPS 还要单独配置。\r\n\r\n并没有坚持写几篇内容，还要经常注意别让免费的证书过期了，虽然可以通过脚本来处理。但是当时自己的心智还不足以成熟到把一件事情做好。\r\n\r\n24 年的时候，我觉得自己维护服务器太麻烦了，于是将博客直接采用了 Github Pages 部署，因为再也不用担心服务器的维护问题了。\r\n\r\n反倒是在这个时候，开始坚持发布我的读书笔记，慢慢了习惯了将自己的阅读记录整理出来。\r\n\r\n虽然大多数读书笔记对于大多数人都没啥用，但是偶尔有一篇帮助到别人，就挺好的。\r\n\r\n这么多年坚持下来，也读了些书，算是没有浪费空闲的时间。\r\n\r\n今年，我突然接触了大家口中的赛博菩萨，算是开了新世界的大门。因为 Github Pages 只能部署静态页面，但是 CF 没有这个限制，可以随心自定义，并且免费的额度真的足够我们玩出好多花活了。\r\n\r\nCF 可以绑定 Github 仓库，只需要授权一下，**私有仓库代码**也能轻松部署。\r\n\r\n我已经将我几乎所有玩具都直接使用 CF 部署了，[个人主页]( https://luojie.net/)，[个人博客]( https://blog.luojie.net/)，还有专门给自己做了个[阅读管理的网站]( https://books-ledger.luojie.dev/)，以及为了不看广告，足够流畅的[家庭记账软件]( https://qjz.luojie.dev/)。\r\n\r\n若有 CF 账号，建议建议大家尝试了，好多不清楚的内容，直接可以让 AI 来协助实现，真的很方便。", "content_rendered": "<p>20 年的时候，我看别人写博客，自己也开始凑热闹，大多都是些没有啥价值的内容。当时想着，肯定要部署在国内的云服务上，于是发现成本还挺高的。要购买域名（还必须是 .com 后缀)，还要搞定备案，HTTPS 还要单独配置。</p>\n<p>并没有坚持写几篇内容，还要经常注意别让免费的证书过期了，虽然可以通过脚本来处理。但是当时自己的心智还不足以成熟到把一件事情做好。</p>\n<p>24 年的时候，我觉得自己维护服务器太麻烦了，于是将博客直接采用了 Github Pages 部署，因为再也不用担心服务器的维护问题了。</p>\n<p>反倒是在这个时候，开始坚持发布我的读书笔记，慢慢了习惯了将自己的阅读记录整理出来。</p>\n<p>虽然大多数读书笔记对于大多数人都没啥用，但是偶尔有一篇帮助到别人，就挺好的。</p>\n<p>这么多年坚持下来，也读了些书，算是没有浪费空闲的时间。</p>\n<p>今年，我突然接触了大家口中的赛博菩萨，算是开了新世界的大门。因为 Github Pages 只能部署静态页面，但是 CF 没有这个限制，可以随心自定义，并且免费的额度真的足够我们玩出好多花活了。</p>\n<p>CF 可以绑定 Github 仓库，只需要授权一下，<strong>私有仓库代码</strong>也能轻松部署。</p>\n<p>我已经将我几乎所有玩具都直接使用 CF 部署了，<a href=\"https://luojie.net/\" rel=\"nofollow\">个人主页</a>，<a href=\"https://blog.luojie.net/\" rel=\"nofollow\">个人博客</a>，还有专门给自己做了个<a href=\"https://books-ledger.luojie.dev/\" rel=\"nofollow\">阅读管理的网站</a>，以及为了不看广告，足够流畅的<a href=\"https://qjz.luojie.dev/\" rel=\"nofollow\">家庭记账软件</a>。</p>\n<p>若有 CF 账号，建议建议大家尝试了，好多不清楚的内容，直接可以让 AI 来协助实现，真的很方便。</p>\n", "last_modified": 1784350675, "replies": 24, "id": 1228199}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11261, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2399, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 664555, "username": "moudy", "url": "https://www.v2ex.com/u/moudy", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/cdb3b37880cc74e53c75c571c1c934b5?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/cdb3b37880cc74e53c75c571c1c934b5?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/cdb3b37880cc74e53c75c571c1c934b5?s=73&d=retro", "created": 1701083910, "last_modified": 1764184152, "pro": 0}, "last_reply_by": "irainsoft", "last_touched": 1784363828, "title": "二手手机面交这个流程算啥水平？", "url": "https://www.v2ex.com/t/1228150", "created": 1784324024, "deleted": 0, "content": "娃暑假参加学校夏令营，软磨硬泡求升级他的 11pm 。我随手一搜同城有个哥们出 15pro ，3000 块，上门自取。于是发消息要了地址开车过去取手机。\r\n\r\n到了地方按门铃，哥们正在做饭。进屋后，跟我一指\r\n“机器在沙发上，你自己慢慢验，没问题了喊我”\r\n然后跑厨房接着做饭去了。\r\n\r\n我花了一刻钟验好机器，打包好，喊哥们过来把钱给他。\r\n\r\n他拿着钱送我到玄关，随手把钱往门厅鞋柜上一放，说“我不送了，你回去开慢点哈”，就接着奔厨房做饭了。留下我自己穿鞋开门拿包走人。", "content_rendered": "娃暑假参加学校夏令营，软磨硬泡求升级他的 11pm 。我随手一搜同城有个哥们出 15pro ，3000 块，上门自取。于是发消息要了地址开车过去取手机。<br /><br />到了地方按门铃，哥们正在做饭。进屋后，跟我一指<br />“机器在沙发上，你自己慢慢验，没问题了喊我”<br />然后跑厨房接着做饭去了。<br /><br />我花了一刻钟验好机器，打包好，喊哥们过来把钱给他。<br /><br />他拿着钱送我到玄关，随手把钱往门厅鞋柜上一放，说“我不送了，你回去开慢点哈”，就接着奔厨房做饭了。留下我自己穿鞋开门拿包走人。", "last_modified": 1784334954, "replies": 19, "id": 1228150}]