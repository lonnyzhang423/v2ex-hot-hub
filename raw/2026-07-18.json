[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9f61/408e/56_large.png?m=1628212285", "name": "internet", "avatar_normal": "https://cdn.v2ex.com/navatar/9f61/408e/56_normal.png?m=1628212285", "title": "互联网", "url": "https://www.v2ex.com/go/internet", "topics": 4202, "footer": "", "header": "In Internet we trust", "title_alternative": "Internet", "avatar_mini": "https://cdn.v2ex.com/navatar/9f61/408e/56_mini.png?m=1628212285", "stars": 1201, "founder_id": 0, "aliases": [], "root": false, "id": 56, "parent_node_name": "computer"}, "member": {"id": 275922, "username": "dyxLike", "url": "https://www.v2ex.com/u/dyxLike", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/4bd1/ee3f/275922_mini.png?m=1784269040", "avatar_normal": "https://cdn.v2ex.com/avatar/4bd1/ee3f/275922_normal.png?m=1784269040", "avatar_large": "https://cdn.v2ex.com/avatar/4bd1/ee3f/275922_large.png?m=1784269040", "created": 1513818435, "last_modified": 1784269040, "pro": 0}, "last_reply_by": "katoyu", "last_touched": 1784326936, "title": "在 nga 看到一个帖子, 说拼多多会监控用户手机屏幕, 试了下竟然是真的", "url": "https://www.v2ex.com/t/1228005", "created": 1784269261, "deleted": 0, "content": "在手机微信里打开下面这张图片, 然后再打开拼多多首页, 就会给你推送这个手办\r\n\r\n我试了下竟然是真的, 查看图片之前首页推送没有手办, 微信里看了之后, 再打开拼多多就有了\r\n\r\n而且感觉也不像单纯的官方推流导致曝光度高, 因为看图片之前是没有给我推送的\r\n\r\n之前对于互联网个性推送的认知只有监控手机输入法, 不知道这个是通过什么实现的\r\n\r\n\r\n原贴: https://bbs.nga.cn/read.php?tid=47199959\r\n\r\n\r\n![]( https://img.nga.178.com/attachments/mon_202607/17/-7Q54-3tprZfT3cShs-13i.jpg)", "content_rendered": "<p>在手机微信里打开下面这张图片, 然后再打开拼多多首页, 就会给你推送这个手办</p>\n<p>我试了下竟然是真的, 查看图片之前首页推送没有手办, 微信里看了之后, 再打开拼多多就有了</p>\n<p>而且感觉也不像单纯的官方推流导致曝光度高, 因为看图片之前是没有给我推送的</p>\n<p>之前对于互联网个性推送的认知只有监控手机输入法, 不知道这个是通过什么实现的</p>\n<p>原贴: <a href=\"https://bbs.nga.cn/read.php?tid=47199959\" rel=\"nofollow\">https://bbs.nga.cn/read.php?tid=47199959</a></p>\n<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://img.nga.178.com/attachments/mon_202607/17/-7Q54-3tprZfT3cShs-13i.jpg\"/></p>\n", "last_modified": 1784269261, "replies": 103, "id": 1228005}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a9be/4c2a/1362_large.png?m=1783590860", "name": "stocktrading", "avatar_normal": "https://cdn.v2ex.com/navatar/a9be/4c2a/1362_normal.png?m=1783590860", "title": "炒股", "url": "https://www.v2ex.com/go/stocktrading", "topics": 2, "footer": "", "header": "", "title_alternative": "炒股", "avatar_mini": "https://cdn.v2ex.com/navatar/a9be/4c2a/1362_mini.png?m=1783590860", "stars": 2, "founder_id": 771892, "aliases": [], "root": false, "id": 1362, "parent_node_name": null}, "member": {"id": 619444, "username": "evan9527", "url": "https://www.v2ex.com/u/evan9527", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/034d/526a/619444_mini.png?m=1761963935", "avatar_normal": "https://cdn.v2ex.com/avatar/034d/526a/619444_normal.png?m=1761963935", "avatar_large": "https://cdn.v2ex.com/avatar/034d/526a/619444_large.png?m=1761963935", "avatar_xlarge": "https://cdn.v2ex.com/avatar/034d/526a/619444_xlarge.png?m=1761963935", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/034d/526a/619444_xxlarge.png?m=1761963935", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/034d/526a/619444_xxxlarge.png?m=1761963935", "created": 1679044255, "last_modified": 1761963935, "pro": 0}, "last_reply_by": "moregun", "last_touched": 1784303036, "title": "我知道已经跌的不敢打开账户了，所以连讨论的帖子都没有吗？", "url": "https://www.v2ex.com/t/1227990", "created": 1784266084, "deleted": 0, "content": "账户被腰斩了,入市依赖就一直在回本，\r\n好几次已经快回本了又马上迎来大跌。\r\n把希望寄托在一个又一个明天，\r\n明天会更好吗？\r\n其实并不会，\r\n但是如果失去希望，\r\n我真的不知道怎么才能坚持活下去。", "content_rendered": "账户被腰斩了,入市依赖就一直在回本，<br />好几次已经快回本了又马上迎来大跌。<br />把希望寄托在一个又一个明天，<br />明天会更好吗？<br />其实并不会，<br />但是如果失去希望，<br />我真的不知道怎么才能坚持活下去。", "last_modified": 1784266084, "replies": 50, "id": 1227990}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72129, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9729, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 534706, "username": "liuwk", "url": "https://www.v2ex.com/u/liuwk", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/537d8499acaf403c9f6299e193a0744d?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/537d8499acaf403c9f6299e193a0744d?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/537d8499acaf403c9f6299e193a0744d?s=73&d=retro", "created": 1614216767, "last_modified": 1784275448, "pro": 0}, "last_reply_by": "w912598204", "last_touched": 1784297506, "title": "8 年前端，已厌倦目前的每天做不完的需求，是否该离职？", "url": "https://www.v2ex.com/t/1228050", "created": 1784275457, "deleted": 0, "content": "在广州做了 8 年多的前端，目前在一个小公司，做自己产品的，10 来个人，正常发薪，加班较少，正常 6 点下班\r\n\r\n公司有 2 个前端，另一个前端兼职了项目经理，可以说是负责整个项目的负责人，除了领导外，他是统领整个项目进度的\r\n\r\n而我负责的项目多而杂，电脑 project 那个目录下，存在十几二十个项目，部分项目偶尔需要维护下，有几个长期的项目要经常迭代，基本这些项目都是我负责在做迭代升级，面对长期的这几个项目，每天坐在座位上，动都不想动，看到那些需求，若不去完成的话，又会到月底清算（绩效）\r\n\r\n题主一家老小都在广州，大的也读小学了，小的刚幼儿园，然后这几年捣鼓了个服装开工厂，不算我的工资，能覆盖生活开支，略有结余\r\n\r\n服装加工厂每天下班后，基本每天都要去帮忙，上半年经常 12-1 点才休息，早上周而复始 8 点起床上班\r\n\r\n每天这样上班、下班，自己工厂加班，循环往复，也感觉自己身心疲惫，导致我萌生了辞职的打算\r\n\r\n特来问问大家的意见", "content_rendered": "在广州做了 8 年多的前端，目前在一个小公司，做自己产品的，10 来个人，正常发薪，加班较少，正常 6 点下班<br /><br />公司有 2 个前端，另一个前端兼职了项目经理，可以说是负责整个项目的负责人，除了领导外，他是统领整个项目进度的<br /><br />而我负责的项目多而杂，电脑 project 那个目录下，存在十几二十个项目，部分项目偶尔需要维护下，有几个长期的项目要经常迭代，基本这些项目都是我负责在做迭代升级，面对长期的这几个项目，每天坐在座位上，动都不想动，看到那些需求，若不去完成的话，又会到月底清算（绩效）<br /><br />题主一家老小都在广州，大的也读小学了，小的刚幼儿园，然后这几年捣鼓了个服装开工厂，不算我的工资，能覆盖生活开支，略有结余<br /><br />服装加工厂每天下班后，基本每天都要去帮忙，上半年经常 12-1 点才休息，早上周而复始 8 点起床上班<br /><br />每天这样上班、下班，自己工厂加班，循环往复，也感觉自己身心疲惫，导致我萌生了辞职的打算<br /><br />特来问问大家的意见", "last_modified": 1784275457, "replies": 45, "id": 1228050}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3c59/dc04/21_large.png?m=1650127623", "name": "shenzhen", "avatar_normal": "https://cdn.v2ex.com/navatar/3c59/dc04/21_normal.png?m=1650127623", "title": "深圳", "url": "https://www.v2ex.com/go/shenzhen", "topics": 3572, "footer": "", "header": "", "title_alternative": "Shenzhen", "avatar_mini": "https://cdn.v2ex.com/navatar/3c59/dc04/21_mini.png?m=1650127623", "stars": 2136, "founder_id": 0, "aliases": [], "root": false, "id": 21, "parent_node_name": "cn"}, "member": {"id": 588794, "username": "davinci21s", "url": "https://www.v2ex.com/u/davinci21s", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/7a4c4bbb84322b069036d29ad8e1658e?s=73&d=retro", "created": 1658391108, "last_modified": 1695025708, "pro": 0}, "last_reply_by": "luojiedev", "last_touched": 1784349099, "title": "深圳的西瓜是镶了金边吗，这么贵", "url": "https://www.v2ex.com/t/1228103", "created": 1784289900, "deleted": 0, "content": "实体店普遍最便宜的麒麟瓜都要 5 元/斤\r\n\r\n外卖最便宜的叮咚买菜都接近 3.5/斤，但是运费要 7 元！！！\r\n\r\n无力吐槽！！\r\n\r\n坐标，深圳南山。", "content_rendered": "<p>实体店普遍最便宜的麒麟瓜都要 5 元/斤</p>\n<p>外卖最便宜的叮咚买菜都接近 3.5/斤，但是运费要 7 元！！！</p>\n<p>无力吐槽！！</p>\n<p>坐标，深圳南山。</p>\n", "last_modified": 1784289938, "replies": 41, "id": 1228103}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240029, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4499, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 111998, "username": "flyico", "url": "https://www.v2ex.com/u/flyico", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/3907/99d0/111998_mini.png?m=1735525820", "avatar_normal": "https://cdn.v2ex.com/avatar/3907/99d0/111998_normal.png?m=1735525820", "avatar_large": "https://cdn.v2ex.com/avatar/3907/99d0/111998_large.png?m=1735525820", "avatar_xlarge": "https://cdn.v2ex.com/avatar/3907/99d0/111998_xlarge.png?m=1735525820", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/3907/99d0/111998_xxlarge.png?m=1735525820", "created": 1429508703, "last_modified": 1735525820, "pro": 0}, "last_reply_by": "ajaxfunction", "last_touched": 1784344554, "title": "现在中国哪里还能看到肉眼看到银河？", "url": "https://www.v2ex.com/t/1228090", "created": 1784283671, "deleted": 0, "content": "孩子最近对星空很感兴趣，我告诉他，记得我小时候大概 90 年代初，我所在的城市夜晚还是能清晰的用肉眼看到银河的，那时候星光甚至都能照亮道路，可惜现在已经不行了，每次说到这里，他总是表现出无限的遗憾，所以，现在中国哪里还能看到银河呢？", "content_rendered": "孩子最近对星空很感兴趣，我告诉他，记得我小时候大概 90 年代初，我所在的城市夜晚还是能清晰的用肉眼看到银河的，那时候星光甚至都能照亮道路，可惜现在已经不行了，每次说到这里，他总是表现出无限的遗憾，所以，现在中国哪里还能看到银河呢？", "last_modified": 1784283671, "replies": 34, "id": 1228090}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 240029, "footer": "", "header": "<!--\r\n一个更好的世界需要