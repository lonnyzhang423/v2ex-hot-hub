cdn.v2ex.com/navatar/c74d/97b0/16_normal.png?m=1727584731", "title": "分享发现", "url": "https://www.v2ex.com/go/share", "topics": 45853, "footer": "", "header": "分享你看到的好玩的，有信息量的，欢迎从这里获取灵感。", "title_alternative": "Share", "avatar_mini": "https://cdn.v2ex.com/navatar/c74d/97b0/16_mini.png?m=1727584731", "stars": 6267, "founder_id": 0, "aliases": [], "root": false, "id": 16, "parent_node_name": "v2ex"}, "member": {"id": 4627, "username": "thinkever", "url": "https://www.v2ex.com/u/thinkever", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_mini.png?m=1754710687", "avatar_normal": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_normal.png?m=1754710687", "avatar_large": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_large.png?m=1754710687", "avatar_xlarge": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_xlarge.png?m=1754710687", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_xxlarge.png?m=1754710687", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/0d1a/9651/4627_xxxlarge.png?m=1754710687", "created": 1294039870, "last_modified": 1754710687, "pro": 0}, "last_reply_by": "mogging", "last_touched": 1775482598, "title": "士别三日刮目相看，全系切换为 edge 浏览器", "url": "https://www.v2ex.com/t/1203752", "created": 1775432986, "deleted": 0, "content": "之前的话主力浏览器一直是 pc 和 mac 端 chrome ，安卓端 Firefox nightly ，ios 端 Safari 。\r\n\r\n之前 edge 用过一段时间又屁滚尿流切换回来了，很多地方的小 bug 不舒服。\r\n\r\n但这段时间又试了一下，pc 端的流畅易用性已经超过 chrome ，尤其是 pdf 阅读体验不可替代；而安卓端更是支持了多个重度使用的插件、包括油猴脚本。并且 edge 的网页翻译比 Firefox 强。\r\n\r\n所以全系切换为 edge 浏览器了，真的好用。chrome 和 Firefox 又落伍了。", "content_rendered": "<p>之前的话主力浏览器一直是 pc 和 mac 端 chrome ，安卓端 Firefox nightly ，ios 端 Safari 。</p>\n<p>之前 edge 用过一段时间又屁滚尿流切换回来了，很多地方的小 bug 不舒服。</p>\n<p>但这段时间又试了一下，pc 端的流畅易用性已经超过 chrome ，尤其是 pdf 阅读体验不可替代；而安卓端更是支持了多个重度使用的插件、包括油猴脚本。并且 edge 的网页翻译比 Firefox 强。</p>\n<p>所以全系切换为 edge 浏览器了，真的好用。chrome 和 Firefox 又落伍了。</p>\n", "last_modified": 1775432986, "replies"