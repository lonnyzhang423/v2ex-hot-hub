[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11225, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2390, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 474521, "username": "aincvy", "url": "https://www.v2ex.com/u/aincvy", "website": "https://fantasyplayer.link/", "twitter": "", "psn": "", "github": "Aincvy", "btc": "", "location": "上海", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/89098de9956980517c8418995d52cd33?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/89098de9956980517c8418995d52cd33?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/89098de9956980517c8418995d52cd33?s=73&d=retro", "created": 1583462574, "last_modified": 1752048047, "pro": 0}, "last_reply_by": "lp7631010", "last_touched": 1783906966, "title": "钥匙忘拔，电动车被别人骑走， 有点成心魔了，另外问一下有摩托车推荐吗", "url": "https://www.v2ex.com/t/1226675", "created": 1783826772, "deleted": 0, "content": "最近失眠多， 睡眠质量差， 周五上班去的时候还迟到了， 醒来就迟到了， 然后停放电动车的地方没位置， 挪动了一下其他的车腾一个位子， 钥匙就只关电，忘记拔掉了。 \r\n\r\n在犯蠢方面，我对自己一直挺严格的，希望不要犯蠢， 然后有点成心魔了 😂    \r\n\r\nPS 报警过了， 但是没用， 就在监控摄像头下， 哎， 看来以后也不能相信摄像头。 \r\n\r\n然后吃一堑长一智嘛， 所以我想考个 D 照， 弄一个可以无钥匙启动/蓝牙钥匙解锁的摩托车。 这样就完全的避免了钥匙拔掉的问题。 \r\n\r\n看了一下 全新的 125/150cc 的踏板好像都差不多需要  13500 CNY ？  是搞一个新车呢， 还是弄一个二手的好点？\r\n\r\nCFMOTO 春风， 天鹰 TX150F ，SYM 三阳   这些算杂牌吗 ？    \r\n\r\n我估计搞新车的话， 我的预算就在 13500CNY 左右了", "content_rendered": "<p>最近失眠多， 睡眠质量差， 周五上班去的时候还迟到了， 醒来就迟到了， 然后停放电动车的地方没位置， 挪动了一下其他的车腾一个位子， 钥匙就只关电，忘记拔掉了。 </p>\n<p>在犯蠢方面，我对自己一直挺严格的，希望不要犯蠢， 然后有点成心魔了 😂    </p>\n<p>PS 报警过了， 但是没用， 就在监控摄像头下， 哎， 看来以后也不能相信摄像头。 </p>\n<p>然后吃一堑长一智嘛， 所以我想考个 D 照， 弄一个可以无钥匙启动/蓝牙钥匙解锁的摩托车。 这样就完全的避免了钥匙拔掉的问题。 </p>\n<p>看了一下 全新的 125/150cc 的踏板好像都差不多需要  13500 CNY ？  是搞一个新车呢， 还是弄一个二手的好点？</p>\n<p>CFMOTO 春风， 天鹰 TX150F ，SYM 三阳   这些算杂牌吗 ？    </p>\n<p>我估计搞新车的话， 我的预算就在 13500CNY 左右了</p>\n", "last_modified": 1783835191, "replies": 93, "id": 1226675}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11225, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2390, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 562972, "username": "importmeta", "url": "https://www.v2ex.com/u/importmeta", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/2018/6513/562972_mini.png?m=1764517099", "avatar_normal": "https://cdn.v2ex.com/avatar/2018/6513/562972_normal.png?m=1764517099", "avatar_large": "https://cdn.v2ex.com/avatar/2018/6513/562972_large.png?m=1764517099", "created": 1637669069, "last_modified": 1764517099, "pro": 0}, "last_reply_by": "PromiseResolve", "last_touched": 1783906544, "title": "奔三 感觉自己漂泊不定 怎么规划人生", "url": "https://www.v2ex.com/t/1226703", "created": 1783837279, "deleted": 0, "content": "奔三，这几年一直上班，被裁，化解抑郁症，经常家里蹲，还没谈过对象，之前写过经历。https://www.v2ex.com/t/1080820\r\n\r\n然后这 2 年自己 1 人搞了各种 AI 创业抓住风口赚了大钱（完全合规合法），大概有 1 注双色球一等奖奖金这么多，相当于赚了被裁前 40 年的工资。现在感觉像做梦一样。创业过程中，每天身心俱疲，像是被驱使着一样，没多少快乐，压力很大。干啥都是 1 个人，现在风口有点过了，不怎么赚了。\r\n\r\n之前还想过，我要有钱了一定很快乐，后来感觉也不是多快乐，还变扣了，还是会为了几块钱优惠券不开心，之前就不怎么花钱。\r\n\r\n目前在二线省会老家市中心租房子住，爹妈家里都在郊区，我不太喜欢这个城市，人多，楼房便宜的一套都有将近二百万，贵的大几百万，别墅也大几百万，上千万的很多，不可能买这种房子。\r\n\r\n爷爷这辈家里 3 代都是普通工人，没多少以后的经验能给我。\r\n\r\n不知道接下来怎么办了，年纪大了，没对象没家，对年龄有点莫名的紧迫和躁动，想换个赛道创业，想离开这个老家城市，但是不知道去哪。", "content_rendered": "<p>奔三，这几年一直上班，被裁，化解抑郁症，经常家里蹲，还没谈过对象，之前写过经历。<a href=\"https://www.v2ex.com/t/1080820\" rel=\"nofollow\">https://www.v2ex.com/t/1080820</a></p>\n<p>然后这 2 年自己 1 人搞了各种 AI 创业抓住风口赚了大钱（完全合规合法），大概有 1 注双色球一等奖奖金这么多，相当于赚了被裁前 40 年的工资。现在感觉像做梦一样。创业过程中，每天身心俱疲，像是被驱使着一样，没多少快乐，压力很大。干啥都是 1 个人，现在风口有点过了，不怎么赚了。</p>\n<p>之前还想过，我要有钱了一定很快乐，后来感觉也不是多快乐，还变扣了，还是会为了几块钱优惠券不开心，之前就不怎么花钱。</p>\n<p>目前在二线省会老家市中心租房子住，爹妈家里都在郊区，我不太喜欢这个城市，人多，楼房便宜的一套都有将近二百万，贵的大几百万，别墅也大几百万，上千万的很多，不可能买这种房子。</p>\n<p>爷爷这辈家里 3 代都是普通工人，没多少以后的经验能给我。</p>\n<p>不知道接下来怎么办了，年纪大了，没对象没家，对年龄有点莫名的紧迫和躁动，想换个赛道创业，想离开这个老家城市，但是不知道去哪。</p>\n", "last_modified": 1783837279, "replies": 57, "id": 1226703}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239867, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4496, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 758918, "username": "DeepSIeep", "url": "https://www.v2ex.com/u/DeepSIeep", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/142d/6dc1/758918_mini.png?m=1774259572", "avatar_normal": "https://cdn.v2ex.com/avatar/142d/6dc1/758918_normal.png?m=1774259572", "avatar_large": "https://cdn.v2ex.com/avatar/142d/6dc1/758918_large.png?m=1774259572", "avatar_xlarge": "https://cdn.v2ex.com/avatar/142d/6dc1/758918_xlarge.png?m=1774259572", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/142d/6dc1/758918_xxlarge.png?m=1774259572", "created": 1753236507, "last_modified": 1774259572, "pro": 0}, "last_reply_by": "jamme", "last_touched": 1783907058, "title": "老家修路，简单聊一下村里那无敌的村主任。", "url": "https://www.v2ex.com/t/1226762", "created": 1783861251, "deleted": 0, "content": "有几个很离谱的事。。。\r\n\r\n老家要修水泥路，村主任 n 年前收了一波前，说集资修路。然后收了钱到去年一直都没修。\r\n\r\n今年有集资修路，n 年前的钱去哪了？不知道，没答复，让一家出 3500 块钱（竟然都出了）。\r\n\r\n和家里人聊了一下，这种事，没人敢说，因为你说了，村里以后啥事都回针对你，让你不好过。你要忍一忍，这个路还能修到你家\r\n\r\n另外我无意中发现，之所以修这个路，是因为有一家人得式，好像村里当官了，他家门口没水泥路，这条水泥路是路过他家的（没错，没路过的地方还是没修）", "content_rendered": "有几个很离谱的事。。。<br /><br />老家要修水泥路，村主任 n 年前收了一波前，说集资修路。然后收了钱到去年一直都没修。<br /><br />今年有集资修路，n 年前的钱去哪了？不知道，没答复，让一家出 3500 块钱（竟然都出了）。<br /><br />和家里人聊了一下，这种事，没人敢说，因为你说了，村里以后啥事都回针对你，让你不好过。你要忍一忍，这个路还能修到你家<br /><br />另外我无意中发现，之所以修这个路，是因为有一家人得式，好像村里当官了，他家门口没水泥路，这条水泥路是路过他家的（没错，没路过的地方还是没修）", "last_modified": 1783861251, "replies": 42, "id": 1226762}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6353/8fe6/519_large.png?m=1595507885", "name": "ideas", "avatar_normal": "https://cdn.v2ex.com/navatar/6353/8fe6/519_normal.png?m=1595507885", "title": "奇思妙想", "url": "https://www.v2ex.com/go/ideas", "topics": 6570, "footer": "", "header": "让你的创意在这里自由流动吧。", "title_alternative": "Ideas", "avatar_mini": "https://cdn.v2ex.com/navatar/6353/8fe6/519_mini.png?m=1595507885", "stars": 3242, "founder_id": 0, "aliases": [], "root": false, "id": 519, "parent_node_name": "v2ex"}, "member": {"id": 641049, "username": "lj92458", "url": "https://www.v2ex.com/u/lj92458", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/c24da16da6aefc69f7f90223317d2ea5?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/c24da16da6aefc69f7f90223317d2ea5?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/c24da16da6aefc69f7f90223317d2ea5?s=73&d=retro", "created": 1690726240, "last_modified": 1690726240, "pro": 0}, "last_reply_by": "Danswerme", "last_touched": 1783861671, "title": "中国人的 homeLab，从 matrix 聊天服务器开始", "url": "https://www.v2ex.com/t/1226693", "created": 1783833325, "deleted": 0, "content": "今天的互联网，已经高度发达、停滞不前。要想继续发展，只剩下“家庭”这个没被开发的领域。\r\n\r\nHomeLab 在欧美流行，在中国冷淡。为什么？因为缺乏刚需、杀手级应用，国人顶多用一下 NAS 。但我认为每个家庭需要的不只是 NAS 网盘，更需要真正的服务器。因为这涉及到个人隐私、数据主权。最典型的就是聊天软件：你以为你在私聊，但它在运营商眼里享有和微博、知乎同样的风控。\r\n\r\n为了推动“家庭服务器”的发展，我打算开发一种 matrix 聊天服务器、聊天盒子。它看起来像机顶盒、安卓盒子，功率只有 5~10w ，但确有完整的 debian 系统、1~2G 内存、64G 储存空间。用户需填写自己在 cloudflare 购买的域名，然后就能自动创建 tunnel ，从而实现公网暴露。\r\n\r\n请大家说说：是应该用 cloudflare tunnel 做中继，还是像 NAS 厂商那样建设中继给客户用？\r\nmatrix 追求联邦、去中心化，如果我建设中继，那我就是中心，和 matrix 理念背道而驰。", "content_rendered": "<p>今天的互联网，已经高度发达、停滞不前。要想继续发展，只剩下“家庭”这个没被开发的领域。</p>\n<p>HomeLab 在欧美流行，在中国冷淡。为什么？因为缺乏刚需、杀手级应用，国人顶多用一下 NAS 。但我认为每个家庭需要的不只是 NAS 网盘，更需要真正的服务器。因为这涉及到个人隐私、数据主权。最典型的就是聊天软件：你以为你在私聊，但它在运营商眼里享有和微博、知乎同样的风控。</p>\n<p>为了推动“家庭服务器”的发展，我打算开发一种 matrix 聊天服务器、聊天盒子。它看起来像机顶盒、安卓盒子，功率只有 5~10w ，但确有完整的 debian 系统、1~2G 内存、64G 储存空间。用户需填写自己在 cloudflare 购买的域名，然后就能自动创建 tunnel ，从而实现公网暴露。</p>\n<p>请大家说说：是应该用 cloudflare tunnel 做中继，还是像 NAS 厂商那样建设中继给客户用？\nmatrix 追求联邦、去中心化，如果我建设中继，那我就是中心，和 matrix 理念背道而驰。</p>\n", "last_modified": 1783833325, "replies": 36, "id": 1226693}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/55b3/7c5c/649_large.png?m=1651386010", "name": "wechat", "avatar_normal": "https://cdn.v2ex.com/navatar/55b3/7c5c/649_normal.png?m=1651386010", "title": "微信", "url": "https://www.v2ex.com/go/wechat", "topics": 4440, "footer": "", "header": "关于微信及微信小程序的讨论节点", "title_alternative": "WeChat", "avatar_mini": "https://cdn.v2ex.com/navatar/55b3/7c5c/649_mini.png?m=1651386010", "stars": 823, "founder_id": 0, "aliases": [], "root": false, "id": 649, "parent_node_name": "internet"}, "member": {"id": 451955, "username": "EasonWong", "url": "https://www.v2ex.com/u/EasonWong", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "Wuhan", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/c49c/f693/451955_mini.png?m=1573270944", "avatar_normal": "https://cdn.v2ex.com/avatar/c49c/f693/451955_normal.png?m=1573270944", "avatar_large": "https://cdn.v2ex.com/avatar/c49c/f693/451955_large.png?m=1573270944", "created": 1573227727, "last_modified": 1573270944, "pro": 0}, "last_reply_by": "handwork", "last_touched": 1783871206, "title": "把微信转成 wechat 对现有业务有什么影响？", "url": "https://www.v2ex.com/t/1226684", "created": 1783830712, "deleted": 0, "content": "近期注册了个香港的手机号想把微信捆绑的手机号换过去用 wechat ，但考虑到现有的微信上有大量的业务怕换过去有影响，想问下换过去 wechat 有哪些变化，对现有功能有哪些影响？", "content_rendered": "<p>近期注册了个香港的手机号想把微信捆绑的手机号换过去用 wechat ，但考虑到现有的微信上有大量的业务怕换过去有影响，想问下换过去 wechat 有哪些变化，对现有功能有哪些影响？</p>\n", "last_modified": 1783830712, "replies": 35, "id": 1226684}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72011, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9727, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 100723, "username": "sw042", "url": "https://www.v2ex.com/u/sw042", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/4396/e9d2/100723_mini.png?m=1501612539", "avatar_normal": "https://cdn.v2ex.com/avatar/4396/e9d2/100723_normal.png?m=1501612539", "avatar_large": "https://cdn.v2ex.com/avatar/4396/e9d2/100723_large.png?m=1501612539", "created": 1425025399, "last_modified": 1501612539, "pro": 0}, "last_reply_by": "sigma65535", "last_touched": 1783906753, "title": "像 ZCode 这种一天一更新是怎么做到的？", "url": "https://www.v2ex.com/t/1226782", "created": 1783867671, "deleted": 0, "content": "如题 https://zcode.z.ai/cn/changelog\r\n现在就算有 AI 工具加码，也只提升了整个编码的开发速度，后面还有调试、测试、发版等一系列相关流程要走。如果一个人做，一天一更新感觉也比较极限，很难持续；如果多个人一起做，又如何保证大家并发开发的功能在合并时不会发生冲突？\r\n\r\n在多模块、多人协作的场景下，AI 有没有好的提效和控制熵增的方案？", "content_rendered": "<p>如题 <a href=\"https://zcode.z.ai/cn/changelog\" rel=\"nofollow\">https://zcode.z.ai/cn/changelog</a>\n现在就算有 AI 工具加码，也只提升了整个编码的开发速度，后面还有调试、测试、发版等一系列相关流程要走。如果一个人做，一天一更新感觉也比较极限，很难持续；如果多个人一起做，又如何保证大家并发开发的功能在合并时不会发生冲突？</p>\n<p>在多模块、多人协作的场景下，AI 有没有好的提效和控制熵增的方案？</p>\n", "last_modified": 1783867671, "replies": 34, "id": 1226782}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4254, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3209, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 794327, "username": "Brightt", "url": "https://www.v2ex.com/u/Brightt", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=73&d=retro", "created": 1773653592, "last_modified": 1782099148, "pro": 0}, "last_reply_by": "kneo", "last_touched": 1783012485, "title": "为什么 chatgpt 这么固执", "url": "https://www.v2ex.com/t/1226659", "created": 1783821437, "deleted": 0, "content": "我让 gpt 帮我把图片背景换成透明色，它总是用白色方格伪装成透明色\r\n\r\n我明确告诉他要真透明，不要用白色方格伪装成透明色\r\n\r\n它还是要用，气死我了\r\n\r\nhttps://i.v2ex.co/8lQ5dH56.png", "content_rendered": "我让 gpt 帮我把图片背景换成透明色，它总是用白色方格伪装成透明色<br /><br />我明确告诉他要真透明，不要用白色方格伪装成透明色<br /><br />它还是要用，气死我了<br /><br /><a target=\"_blank\" href=\"/i/8lQ5dH56.png\" rel=\"nofollow noopener\" target=\"_blank\" title=\"在新窗口打开图片 8lQ5dH56.png\"><img src=\"//i.v2ex.co/8lQ5dH56.png\" class=\"embedded_image\"></a>", "last_modified": 1783821437, "replies": 34, "id": 1226659}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72011, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9727, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 201033, "username": "swananan", "url": "https://www.v2ex.com/u/swananan", "website": "https://jt26wzz.com/", "twitter": "", "psn": "", "github": "swananan", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/2e0f/9937/201033_mini.png?m=1753754111", "avatar_normal": "https://cdn.v2ex.com/avatar/2e0f/9937/201033_normal.png?m=1753754111", "avatar_large": "https://cdn.v2ex.com/avatar/2e0f/9937/201033_large.png?m=1753754111", "created": 1478967159, "last_modified": 1753754111, "pro": 0}, "last_reply_by": "cat9life", "last_touched": 1783868801, "title": "突然发现 chatgpt 语音多了 live 功能，感觉练口语挺好的", "url": "https://www.v2ex.com/t/1226716", "created": 1783842756, "deleted": 0, "content": "以前拿 chatgpt 练口语，都是 chatgpt 一句，我语音读一句。现在用这个 live 模式，终于有点像实时真人对话了，比菲律宾人的英语课效果还要好，至少不要钱。\r\n\r\n现在唯一的难点，就是得坚持了。\r\n\r\nhttps://openai.com/zh-Hans-CN/index/introducing-gpt-live/", "content_rendered": "以前拿 chatgpt 练口语，都是 chatgpt 一句，我语音读一句。现在用这个 live 模式，终于有点像实时真人对话了，比菲律宾人的英语课效果还要好，至少不要钱。<br /><br />现在唯一的难点，就是得坚持了。<br /><br /><a target=\"_blank\" href=\"https://openai.com/zh-Hans-CN/index/introducing-gpt-live/\" rel=\"nofollow noopener\">https://openai.com/zh-Hans-CN/index/introducing-gpt-live/</a>", "last_modified": 1783842756, "replies": 34, "id": 1226716}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239867, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4496, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 102641, "username": "milkleeeeee", "url": "https://www.v2ex.com/u/milkleeeeee", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f8d0/1045/102641_mini.png?m=1641529094", "avatar_normal": "https://cdn.v2ex.com/avatar/f8d0/1045/102641_normal.png?m=1641529094", "avatar_large": "https://cdn.v2ex.com/avatar/f8d0/1045/102641_large.png?m=1641529094", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f8d0/1045/102641_xlarge.png?m=1641529094", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f8d0/1045/102641_xxlarge.png?m=1641529094", "created": 1425548795, "last_modified": 1641529094, "pro": 0}, "last_reply_by": "Tink", "last_touched": 1783907105, "title": "有哪些词让你一看到就觉得是 AI 写的？", "url": "https://www.v2ex.com/t/1226775", "created": 1783864993, "deleted": 0, "content": "我先来：边界", "content_rendered": "<p>我先来：边界</p>\n", "last_modified": 1783905820, "replies": 31, "id": 1226775}]