[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11294, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2407, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 314954, "username": "yang59324", "url": "https://www.v2ex.com/u/yang59324", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/6191/1cc1/314954_mini.png?m=1784622344", "avatar_normal": "https://cdn.v2ex.com/avatar/6191/1cc1/314954_normal.png?m=1784622344", "avatar_large": "https://cdn.v2ex.com/avatar/6191/1cc1/314954_large.png?m=1784622344", "created": 1525752343, "last_modified": 1784622344, "pro": 0}, "last_reply_by": "IamUNICODE", "last_touched": 1784705266, "title": "这事 V 友如何评价", "url": "https://www.v2ex.com/t/1228864", "created": 1784623454, "deleted": 0, "content": "事情是这样的\r\n\r\n我和媳妇早上带孩子看牙，我骑摩托带他俩到地铁站，然后我们三坐地铁去医院，看完回来路上我想着下午没啥事就不回家了，直接去公司工作，公司和家是两个不同的方向，分别的时候我摸了一下口袋找不到摩托钥匙了，但是我不记得是停车的时候没拔钥匙还是要是掉到地铁里了，于是我安顿媳妇回家下了地铁帮我确认下，如果没拔钥匙，帮我拔下来，如果钥匙没在车上，我就得赶紧联系地铁客服帮我找下。\r\n\r\n这期间我心里一直是忐忑的，努力回忆着要是到底哪去了，如果没在车上怎么办\r\n\r\n大约过了 1 个小时我估计媳妇已经出地铁了，然后电话联系她到哪了，结果她说没在我放车地铁那站下车，提前几站下车去逛商场了，我说你就不担心我没拔钥匙车被人骑走吗？她说骑走也没办法啊，我逛完街再去给你确认，理由是我现在回家也没钥匙进不家门，我直接气的血脉喷张啊，真是无语了，家里的贵重交通工具的得失在她面前都没有逛街购物重要，我在微信上给他留言了\r\n\r\n又过了大概 40 多分钟吧，我还是心里不痛快，又电话问了她一次，如果她还没回家我就准备自己回去找钥匙了，这次他从放车的那站下车了，钥匙确实没拔，庆幸的是车没丢，然后她就开始说明明是你自己忘了拔钥匙，还在微信里职责我。。。", "content_rendered": "<p>事情是这样的</p>\n<p>我和媳妇早上带孩子看牙，我骑摩托带他俩到地铁站，然后我们三坐地铁去医院，看完回来路上我想着下午没啥事就不回家了，直接去公司工作，公司和家是两个不同的方向，分别的时候我摸了一下口袋找不到摩托钥匙了，但是我不记得是停车的时候没拔钥匙还是要是掉到地铁里了，于是我安顿媳妇回家下了地铁帮我确认下，如果没拔钥匙，帮我拔下来，如果钥匙没在车上，我就得赶紧联系地铁客服帮我找下。</p>\n<p>这期间我心里一直是忐忑的，努力回忆着要是到底哪去了，如果没在车上怎么办</p>\n<p>大约过了 1 个小时我估计媳妇已经出地铁了，然后电话联系她到哪了，结果她说没在我放车地铁那站下车，提前几站下车去逛商场了，我说你就不担心我没拔钥匙车被人骑走吗？她说骑走也没办法啊，我逛完街再去给你确认，理由是我现在回家也没钥匙进不家门，我直接气的血脉喷张啊，真是无语了，家里的贵重交通工具的得失在她面前都没有逛街购物重要，我在微信上给他留言了</p>\n<p>又过了大概 40 多分钟吧，我还是心里不痛快，又电话问了她一次，如果她还没回家我就准备自己回去找钥匙了，这次他从放车的那站下车了，钥匙确实没拔，庆幸的是车没丢，然后她就开始说明明是你自己忘了拔钥匙，还在微信里职责我。。。</p>\n", "last_modified": 1784680461, "replies": 141, "id": 1228864}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3c59/dc04/21_large.png?m=1650127623", "name": "shenzhen", "avatar_normal": "https://cdn.v2ex.com/navatar/3c59/dc04/21_normal.png?m=1650127623", "title": "深圳", "url": "https://www.v2ex.com/go/shenzhen", "topics": 3577, "footer": "", "header": "", "title_alternative": "Shenzhen", "avatar_mini": "https://cdn.v2ex.com/navatar/3c59/dc04/21_mini.png?m=1650127623", "stars": 2137, "founder_id": 0, "aliases": [], "root": false, "id": 21, "parent_node_name": "cn"}, "member": {"id": 243182, "username": "SilenceLL", "url": "https://www.v2ex.com/u/SilenceLL", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "想得太多，做的太少", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/4505/454a/243182_mini.png?m=1725416416", "avatar_normal": "https://cdn.v2ex.com/avatar/4505/454a/243182_normal.png?m=1725416416", "avatar_large": "https://cdn.v2ex.com/avatar/4505/454a/243182_large.png?m=1725416416", "avatar_xlarge": "https://cdn.v2ex.com/avatar/4505/454a/243182_xlarge.png?m=1725416416", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/4505/454a/243182_xxlarge.png?m=1725416416", "created": 1500541973, "last_modified": 1725416416, "pro": 0}, "last_reply_by": "evilHa", "last_touched": 1784704940, "title": "水多了加面，面多了加水", "url": "https://www.v2ex.com/t/1228958", "created": 1784681506, "deleted": 0, "content": "![]( https://i.imgur.com/YrxDTVR.jpeg)  ![]( https://i.imgur.com/6o3Hymu.jpeg)", "content_rendered": "<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\"