 "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/d961/3cd9/563553_mini.png?m=1749532589", "avatar_normal": "https://cdn.v2ex.com/avatar/d961/3cd9/563553_normal.png?m=1749532589", "avatar_large": "https://cdn.v2ex.com/avatar/d961/3cd9/563553_large.png?m=1749532589", "avatar_xlarge": "https://cdn.v2ex.com/avatar/d961/3cd9/563553_xlarge.png?m=1749532589", "created": 1638086311, "last_modified": 1749532589, "pro": 0}, "last_reply_by": "chen8511207", "last_touched": 1782555364, "title": "你有新的速率限制重置机会～", "url": "https://www.v2ex.com/t/1223251", "created": 1782522798, "deleted": 0, "content": "刚刚打开 Codex\r\n \r\n ![]( https://i.imgur.com/5F61hwW.png)", "content_rendered": "<p>刚刚打开 Codex</p>\n<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/5F61hwW.png\"/></p>\n", "last_modified": 1782522798, "replies": 27, "id": 1223251}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71755, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9719, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 438369, "username": "Leon6868", "url": "https://www.v2ex.com/u/Leon6868", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "☑ LLM |☑ CSS | ☑ All In Web 践行者", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/14ed/48e6/438369_mini.png?m=1748955348", "avatar_normal": "https://cdn.v2ex.com/avatar/14ed/48e6/438369_normal.png?m=1748955348", "avatar_large": "https://cdn.v2ex.com/avatar/14ed/48e6/438369_large.png?m=1748955348", "created": 1566961594, "last_modified": 1748955348, "pro": 0}, "last_reply_by": "fj24911", "last_touched": 1782553657, "title": "VIBE CODING 时代，应用开发是否应该使用 ORM ？", "url": "https://www.v2ex.com/t/1223254", "created": 1782523268, "deleted": 0, "content": "我认为 ORM 是有存在价值的，原因如下：\r\n- ORM 提供了标准的数据库迁移脚手架\r\n- 能在一定程度上规避 SQL 注入攻击（不知道现在大模型写的代码是否容易出现这些漏洞）\r\n- 提供标准的数据库操作方法\r\n- 能通过 LSP 将数据库操作纳入大模型调试闭环\r\n- 高性能的操作也可以手写 SQL ，有一定的灵活性\r\n\r\n大家在开发中是否用 ORM 呢？用的都是哪些 ORM ？", "content_rendered": "<p>我认为 ORM 是有存在价值的，原因如下：</p>\n<ul>\n<li>ORM 提供了标准的数据库迁移脚手架</li>\n<li>能在一定程度上规避 SQL 注入攻击（不知道现在大模型写的代码是否容易出现这些漏洞）</li>\n<li>提供标准的数据库操作方法</li>\n<li>能通过 LSP 将数据库操作纳入大模型调试闭环</li>\n<li>高性能的操作也可以手写 SQL ，有一定的灵活性</li>\n</ul>\n<p>大家在开发中是否用 ORM 呢？用的都是哪些 ORM ？</p>\n", "last_modified": 1782523268, "replies": 26, "id": 1223254}]