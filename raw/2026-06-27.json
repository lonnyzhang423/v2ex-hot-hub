[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_large.png?m=1691642161", "name": "bb", "avatar_normal": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_normal.png?m=1691642161", "title": "宽带症候群", "url": "https://www.v2ex.com/go/bb", "topics": 18825, "footer": "", "header": "网速很重要。比快更快。", "title_alternative": "Broadband Symptom Complex", "avatar_mini": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_mini.png?m=1691642161", "stars": 8271, "founder_id": 0, "aliases": [], "root": false, "id": 108, "parent_node_name": "geek"}, "member": {"id": 555917, "username": "iswangsir", "url": "https://www.v2ex.com/u/iswangsir", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/6c2715006fd62c9e73ebb61a20240f20?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/6c2715006fd62c9e73ebb61a20240f20?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/6c2715006fd62c9e73ebb61a20240f20?s=73&d=retro", "created": 1631550259, "last_modified": 1631550259, "pro": 0}, "last_reply_by": "Busy", "last_touched": 1782538638, "title": "科学上网的疑问", "url": "https://www.v2ex.com/t/1223114", "created": 1782460146, "deleted": 0, "content": "现在的环境是爱快主路由，挂旁路由 immt+nikki 。手动指定网关和 DNS 到旁路由。nikki 是直接用的机场的配置文件，大部分情况都用的好好的，但是偶尔会抽风，比如淘宝打不开，也不是全部打不开，部分页面打不开，直接连接被重置。也发生在其他网站上。有时候挺闹心的，这貌似是 DNS 的问题。是否有更完美的方式呢，不用自己维护的。收费也 ok 。之前是用 apple tv  装 surge ，就是内存溢出死机比较难绷。", "content_rendered": "<p>现在的环境是爱快主路由，挂旁路由 immt+nikki 。手动指定网关和 DNS 到旁路由。nikki 是直接用的机场的配置文件，大部分情况都用的好好的，但是偶尔会抽风，比如淘宝打不开，也不是全部打不开，部分页面打不开，直接连接被重置。也发生在其他网站上。有时候挺闹心的，这貌似是 DNS 的问题。是否有更完美的方式呢，不用自己维护的。收费也 ok 。之前是用 apple tv  装 surge ，就是内存溢出死机比较难绷。</p>\n", "last_modified": 1782460146, "replies": 76, "id": 1223114}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11141, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2374, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 673408, "username": "freefly111", "url": "https://www.v2ex.com/u/freefly111", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/e9727b8344edd5e420a47d5f8baebef9?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/e9727b8344edd5e420a47d5f8baebef9?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/e9727b8344edd5e420a47d5f8baebef9?s=73&d=retro", "created": 1706253543, "last_modified": 1779848145, "pro": 0}, "last_reply_by": "imicksoft", "last_touched": 1782540927, "title": "曾经倾力帮我的学长，如今再也不回消息。", "url": "https://www.v2ex.com/t/1223282", "created": 1782532874, "deleted": 0, "content": "想跟大家倾诉一下心里的困惑。\r\n\r\n有一位学长，从前真心提携我，给了我很多宝贵建议，大大小小帮过我不少忙，我一直心怀感激，平时逢年过节也会送上祝福。\r\n\r\n这几年我主动给他发消息，前后发了五六条，他始终没有任何回复，也没有拉黑删除，就一直保持沉默。\r\n\r\n我忍不住反复思索：是不是我已经无法给他带去任何价值，所以他才选择慢慢冷淡、刻意疏远？\r\n\r\n我一直很珍惜这段情谊，面对这种无声的冷落，心里难免失落。\r\n\r\n想问问大家，这种不拉黑、不回话的相处状态，代表着什么？大家遇到过吗？", "content_rendered": "<p>想跟大家倾诉一下心里的困惑。</p>\n<p>有一位学长，从前真心提携我，给了我很多宝贵建议，大大小小帮过我不少忙，我一直心怀感激，平时逢年过节也会送上祝福。</p>\n<p>这几年我主动给他发消息，前后发了五六条，他始终没有任何回复，也没有拉黑删除，就一直保持沉默。</p>\n<p>我忍不住反复思索：是不是我已经无法给他带去任何价值，所以他才选择慢慢冷淡、刻意疏远？</p>\n<p>我一直很珍惜这段情谊，面对这种无声的冷落，心里难免失落。</p>\n<p>想问问大家，这种不拉黑、不回话的相处状态，代表着什么？大家遇到过吗？</p>\n", "last_modified": 1782535924, "replies": 50, "id": 1223282}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_large.png?m=1630643913", "name": "apple", "avatar_normal": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_normal.png?m=1630643913", "title": "Apple", "url": "https://www.v2ex.com/go/apple", "topics": 30781, "footer": "", "header": "设计了 <a href=\"/go/watch\">Apple Watch</a>，<a href=\"/go/ipad\">iPad</a>，<a href=\"/go/iphone\">iPhone</a>，<a href=\"/go/imac\">iMac</a> 及 <a href=\"/go/mbp\">MacBook Pro</a> 等电子产品的美国公司。", "title_alternative": "Apple", "avatar_mini": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_mini.png?m=1630643913", "stars": 3325, "founder_id": 0, "aliases": [], "root": false, "id": 184, "parent_node_name": "hardware"}, "member": {"id": 751165, "username": "helloboy9527", "url": "https://www.v2ex.com/u/helloboy9527", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/1304/f3db/751165_mini.png?m=1782461040", "avatar_normal": "https://cdn.v2ex.com/avatar/1304/f3db/751165_normal.png?m=1782461040", "avatar_large": "https://cdn.v2ex.com/avatar/1304/f3db/751165_large.png?m=1782461040", "avatar_xlarge": "https://cdn.v2ex.com/avatar/1304/f3db/751165_xlarge.png?m=1782461040", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/1304/f3db/751165_xxlarge.png?m=1782461040", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/1304/f3db/751165_xxxlarge.png?m=1782461040", "created": 1749007061, "last_modified": 1782461040, "pro": 0}, "last_reply_by": "yiranw09", "last_touched": 1782490551, "title": "apple 涨价，心态炸了，紧急补仓！", "url": "https://www.v2ex.com/t/1223129", "created": 1782461278, "deleted": 0, "content": "apple 涨价，昨天晚上看到消息，心态炸了，因为月初要买 M5max 128+2T 没买成，我媳妇有 85 折，想着等 M6 的毕竟只要等 3 个月；\r\n\r\n然后喝了口咖啡清醒了，那时候晚上八点还在公司加班，第一时间咸鱼掏附近的 M4Max 128G ，开车去苏州上海掏了 4 台，平均一台 27000 ，还买了个 M3max 128+8T 25000 ，应该能赚钱，投入了 10 万。。。PS:我其实现在还是很慌的\r\n\r\n人生第一次投资 10 万", "content_rendered": "apple 涨价，昨天晚上看到消息，心态炸了，因为月初要买 M5max 128+2T 没买成，我媳妇有 85 折，想着等 M6 的毕竟只要等 3 个月；<br /><br />然后喝了口咖啡清醒了，那时候晚上八点还在公司加班，第一时间咸鱼掏附近的 M4Max 128G ，开车去苏州上海掏了 4 台，平均一台 27000 ，还买了个 M3max 128+8T 25000 ，应该能赚钱，投入了 10 万。。。PS:我其实现在还是很慌的<br /><br />人生第一次投资 10 万", "last_modified": 1782461278, "replies": 38, "id": 1223129}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4f28/4803/1187_large.png?m=1773123999", "name": "codex", "avatar_normal": "https://cdn.v2ex.com/navatar/4f28/4803/1187_normal.png?m=1773123999", "title": "Codex", "url": "https://www.v2ex.com/go/codex", "topics": 273, "footer": "", "header": "Codex 是 OpenAI 开发的面向软件工程的人工智能系统，能够将自然语言指令转换为可执行代码，并协助完成多种编程任务。", "title_alternative": "Codex", "avatar_mini": "https://cdn.v2ex.com/navatar/4f28/4803/1187_mini.png?m=1773123999", "stars": 146, "founder_id": 559063, "aliases": [], "root": false, "id": 1187, "parent_node_name": null}, "member": {"id": 45344, "username": "hansonl", "url": "https://www.v2ex.com/u/hansonl", "website": "jarvans.com", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/ab7b1a5c43c0ea20b1a74ca2e315eaf8?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/ab7b1a5c43c0ea20b1a74ca2e315eaf8?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/ab7b1a5c43c0ea20b1a74ca2e315eaf8?s=73&d=retro", "created": 1379034681, "last_modified": 1779765751, "pro": 0}, "last_reply_by": "biubiula", "last_touched": 1782507883, "title": "gpt 写前端页面很丑怎么办？", "url": "https://www.v2ex.com/t/1223111", "created": 1782458900, "deleted": 0, "content": "有没有大佬分享一下工作流", "content_rendered": "<p>有没有大佬分享一下工作流</p>\n", "last_modified": 1782495625, "replies": 34, "id": 1223111}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/df0a/ab05/1148_large.png?m=1751736790", "name": "claude", "avatar_normal": "https://cdn.v2ex.com/navatar/df0a/ab05/1148_normal.png?m=1751736790", "title": "Claude", "url": "https://www.v2ex.com/go/claude", "topics": 659, "footer": "", "header": "", "title_alternative": "Claude", "avatar_mini": "https://cdn.v2ex.com/navatar/df0a/ab05/1148_mini.png?m=1751736790", "stars": 606, "founder_id": 0, "aliases": [], "root": false, "id": 1148, "parent_node_name": "geek"}, "member": {"id": 147230, "username": "unusualcat", "url": "https://www.v2ex.com/u/unusualcat", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/79e7ca774a4e72df3bf05c429ac7aa01?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/79e7ca774a4e72df3bf05c429ac7aa01?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/79e7ca774a4e72df3bf05c429ac7aa01?s=73&d=retro", "created": 1447568746, "last_modified": 1781405792, "pro": 0}, "last_reply_by": "stabc", "last_touched": 1782532935, "title": "Anthropic 指控阿里巴巴对 Claude 进行了大规模蒸馏攻击", "url": "https://www.v2ex.com/t/1223127", "created": 1782461101, "deleted": 0, "content": "6 月 25 号的消息，Anthropic 指控阿里巴巴开展了“迄今为止已知最大规模的蒸馏攻击”。该公司在致美国会议员的信中称，阿里巴巴创建了近 2.5 万个虚假账户，通过与 Claude 进行交互来获取能力。\r\n我靠，这是真的假的？大厂真在默默干这种事啊？", "content_rendered": "6 月 25 号的消息，Anthropic 指控阿里巴巴开展了“迄今为止已知最大规模的蒸馏攻击”。该公司在致美国会议员的信中称，阿里巴巴创建了近 2.5 万个虚假账户，通过与 Claude 进行交互来获取能力。<br />我靠，这是真的假的？大厂真在默默干这种事啊？", "last_modified": 1782461101, "replies": 33, "id": 1223127}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11141, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2374, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 649397, "username": "casey8802", "url": "https://www.v2ex.com/u/casey8802", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_mini.png?m=1747924528", "avatar_normal": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_normal.png?m=1747924528", "avatar_large": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_large.png?m=1747924528", "avatar_xlarge": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_xlarge.png?m=1747924528", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_xxlarge.png?m=1747924528", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/acf8/7f56/649397_xxxlarge.png?m=1747924528", "created": 1695171640, "last_modified": 1747924528, "pro": 0}, "last_reply_by": "likooo125802023", "last_touched": 1782480024, "title": "买房：纠结品质，还是地段", "url": "https://www.v2ex.com/t/1223109", "created": 1782458888, "deleted": 0, "content": "山东省潍坊市，三线城市，目前打算在奎文区和高新区买房。\n\n\n\n1. 市中心旁边，辰龙天玺城有回迁楼栋，但是品质差一些。\n\n2. 往东 7 公里，高新区东方名郡品质好一些，但是距离市中心远点。\n\n\n\n个人认为还是，首先看地段，地段，其次品质。(因为不太看好高新区的发展，可能发展不动了。)", "content_rendered": "<p>山东省潍坊市，三线城市，目前打算在奎文区和高新区买房。</p>\n<ol>\n<li>\n<p>市中心旁边，辰龙天玺城有回迁楼栋，但是品质差一些。</p>\n</li>\n<li>\n<p>往东 7 公里，高新区东方名郡品质好一些，但是距离市中心远点。</p>\n</li>\n</ol>\n<p>个人认为还是，首先看地段，地段，其次品质。(因为不太看好高新区的发展，可能发展不动了。)</p>\n", "last_modified": 1782458888, "replies": 32, "id": 1223109}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239469, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4497, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 274090, "username": "Danswerme", "url": "https://www.v2ex.com/u/Danswerme", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_mini.png?m=1765551963", "avatar_normal": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_normal.png?m=1765551963", "avatar_large": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_large.png?m=1765551963", "avatar_xlarge": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_xlarge.png?m=1765551963", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_xxlarge.png?m=1765551963", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/7460/e1cd/274090_xxxlarge.png?m=1765551963", "created": 1513081062, "last_modified": 1765551963, "pro": 0}, "last_reply_by": "Wyearn", "last_touched": 1782541009, "title": "有在草原长大的朋友吗？ 在国内哪里能看到类似的风景呢（图见正文）。", "url": "https://www.v2ex.com/t/1223257", "created": 1782524246, "deleted": 0, "content": "昨天在 Youtube 上看到一个去乌兰巴托旅游的视频，视频中的一些画面吸引了我。低矮的丘陵上长满了青草，接近山顶的地方散布着一片树林，山顶的云团似乎触手可及，山脚下散布着一些房子。我想象着跑到丘陵顶部，远眺整片草原，在树林下小憩。\r\n\r\n请教下，在国内哪些地方有类似的风景呢？ 此外，我之前似乎听到过草原的草场都是有主人的，不能随便进入，我想象的爬到丘陵顶部是不是不可行？\r\n\r\n![img]( https://i.v2ex.co/5CCWwl7h.png)", "content_rendered": "<p>昨天在 Youtube 上看到一个去乌兰巴托旅游的视频，视频中的一些画面吸引了我。低矮的丘陵上长满了青草，接近山顶的地方散布着一片树林，山顶的云团似乎触手可及，山脚下散布着一些房子。我想象着跑到丘陵顶部，远眺整片草原，在树林下小憩。</p>\n<p>请教下，在国内哪些地方有类似的风景呢？ 此外，我之前似乎听到过草原的草场都是有主人的，不能随便进入，我想象的爬到丘陵顶部是不是不可行？</p>\n<p><img alt=\"img\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.v2ex.co/5CCWwl7h.png\"/></p>\n", "last_modified": 1782524280, "replies": 30, "id": 1223257}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_large.png?m=1691642161", "name": "bb", "avatar_normal": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_normal.png?m=1691642161", "title": "宽带症候群", "url": "https://www.v2ex.com/go/bb", "topics": 18825, "footer": "", "header": "网速很重要。比快更快。", "title_alternative": "Broadband Symptom Complex", "avatar_mini": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_mini.png?m=1691642161", "stars": 8271, "founder_id": 0, "aliases": [], "root": false, "id": 108, "parent_node_name": "geek"}, "member": {"id": 241991, "username": "nathandoge", "url": "https://www.v2ex.com/u/nathandoge", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/cd58/dcda/241991_mini.png?m=1686789829", "avatar_normal": "https://cdn.v2ex.com/avatar/cd58/dcda/241991_normal.png?m=1686789829", "avatar_large": "https://cdn.v2ex.com/avatar/cd58/dcda/241991_large.png?m=1686789829", "avatar_xlarge": "https://cdn.v2ex.com/avatar/cd58/dcda/241991_xlarge.png?m=1686789829", "created": 1500514999, "last_modified": 1686789829, "pro": 0}, "last_reply_by": "hantconny", "last_touched": 1782540276, "title": "”“亲历，接到过国内派出所关于“翻墙”的质询。”“", "url": "https://www.v2ex.com/t/1223269", "created": 1782528554, "deleted": 0, "content": "是协议问题还是什么原因？ 晶哥目前技术能知道在当地网络用 x ？\r\n\r\n\r\n“”“失业养猫中\r\n@Lwith3cats\r\n亲历，接到过国内派出所关于“翻墙”的质询。\r\n\r\n出差去东北某地，在当地酒店住，晚上开了梯子，连的香港节点，看 X 。\r\n\r\n第二天，接到当地派出所电话，问是不是翻墙了。得知我是路过该地，长出一口气的样子，“哦那没事了，以后注意啊”\r\n\r\n我是技术盲，至今都在疑惑那次是如何“暴露”的，没有使用酒店 WiFi ，用的手机 5G 。\r\n\r\n酒店网络监控？\r\n梯子本身有问题？\r\n香港节点服务器有问题？\r\n总不能是被 X 举报了吧？！\r\nQuote\r\n李新宝\r\n@lixinbao_X\r\n·\r\n15h\r\n之前介绍一个朋友来玩 X ，他是政法系统的。\r\n\r\n结果他每一次打开 X 不出半个小时，\r\n\r\n就有专人给他打电话，“”“”", "content_rendered": "<p>是协议问题还是什么原因？ 晶哥目前技术能知道在当地网络用 x ？</p>\n<p>“”“失业养猫中\n@<a href=\"/member/Lwith3cats\">Lwith3cats</a>\n亲历，接到过国内派出所关于“翻墙”的质询。</p>\n<p>出差去东北某地，在当地酒店住，晚上开了梯子，连的香港节点，看 X 。</p>\n<p>第二天，接到当地派出所电话，问是不是翻墙了。得知我是路过该地，长出一口气的样子，“哦那没事了，以后注意啊”</p>\n<p>我是技术盲，至今都在疑惑那次是如何“暴露”的，没有使用酒店 WiFi ，用的手机 5G 。</p>\n<p>酒店网络监控？\n梯子本身有问题？\n香港节点服务器有问题？\n总不能是被 X 举报了吧？！\nQuote\n李新宝\n@<a href=\"/member/lixinbao_X\">lixinbao_X</a>\n·\n15h\n之前介绍一个朋友来玩 X ，他是政法系统的。</p>\n<p>结果他每一次打开 X 不出半个小时，</p>\n<p>就有专人给他打电话，“”“”</p>\n", "last_modified": 1782528554, "replies": 28, "id": 1223269}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c9f0/f895/8_large.png?m=1630643991", "name": "iphone", "avatar_normal": "https://cdn.v2ex.com/navatar/c9f0/f895/8_normal.png?m=1630643991", "title": "iPhone", "url": "https://www.v2ex.com/go/iphone", "topics": 13004, "footer": "这里绝不讨论如何获得 iPhone 盗版软件、iTunes 黑卡之类。", "header": "Say hello to the future.", "title_alternative": "iPhone", "avatar_mini": "https://cdn.v2ex.com/navatar/c9f0/f895/8_mini.png?m=1630643991", "stars": 3623, "founder_id": 0, "aliases": [], "root": false, "id": 8, "parent_node_name": "apple"}, "member": {"id": 482232, "username": "Retas", "url": "https://www.v2ex.com/u/Retas", "website": "", "twitter": "Femoon56", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_mini.png?m=1774590569", "avatar_normal": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_normal.png?m=1774590569", "avatar_large": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_large.png?m=1774590569", "avatar_xlarge": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_xlarge.png?m=1774590569", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_xxlarge.png?m=1774590569", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/bbc5/f715/482232_xxxlarge.png?m=1774590569", "created": 1586264972, "last_modified": 1774590569, "pro": 0}, "last_reply_by": "yolee599", "last_touched": 1782540262, "title": "PDD 百亿补贴发了个拆封 iPhone", "url": "https://www.v2ex.com/t/1223268", "created": 1782527716, "deleted": 0, "content": "昨天看到 Apple 全系涨价之后，只有 iPhone 17 系没涨，感觉等 18 大概率会涨价，然后索性就下在 PDD 上下单了 iPhone 17\r\n\r\n顺丰非常效率，今天上午就派送，然后快递员打电话让我当面签收，我当面当着快递员的面打开了快递盒，把里面包装拿出来之后，发现封条完全是拆开的（撕开不退不换那个封条），我和顺丰小哥都惊呆了，就特么离谱，顺丰小哥也表示从来没见过这种事\r\n\r\n听说过后封机，但没听说过全新拆封机，在 PDD 上买的电子产品应该也有十几个了（单价小几千）还没翻车过，今天也是开眼了，给我干无语了，直接在京东自营店下了一单\r\n\r\n还有就是店铺客服在装死，目前已经申请 PDD 介入\r\n\r\n解锁人生最扯淡的购物体验，网购这么多年，印象中没有收到过拆封的商品，顶多盒子被快递搞烂了。。。\r\n\r\n ![]( https://i.imgur.com/Adx7WgV.png)", "content_rendered": "<p>昨天看到 Apple 全系涨价之后，只有 iPhone 17 系没涨，感觉等 18 大概率会涨价，然后索性就下在 PDD 上下单了 iPhone 17</p>\n<p>顺丰非常效率，今天上午就派送，然后快递员打电话让我当面签收，我当面当着快递员的面打开了快递盒，把里面包装拿出来之后，发现封条完全是拆开的（撕开不退不换那个封条），我和顺丰小哥都惊呆了，就特么离谱，顺丰小哥也表示从来没见过这种事</p>\n<p>听说过后封机，但没听说过全新拆封机，在 PDD 上买的电子产品应该也有十几个了（单价小几千）还没翻车过，今天也是开眼了，给我干无语了，直接在京东自营店下了一单</p>\n<p>还有就是店铺客服在装死，目前已经申请 PDD 介入</p>\n<p>解锁人生最扯淡的购物体验，网购这么多年，印象中没有收到过拆封的商品，顶多盒子被快递搞烂了。。。</p>\n<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/Adx7WgV.png\"/></p>\n", "last_modified": 1782528137, "replies": 26, "id": 1223268}]