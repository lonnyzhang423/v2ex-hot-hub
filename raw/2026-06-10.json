[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/093f/65e0/59_large.png?m=1747623725", "name": "random", "avatar_normal": "https://cdn.v2ex.com/navatar/093f/65e0/59_normal.png?m=1747623725", "title": "随想", "url": "https://www.v2ex.com/go/random", "topics": 4319, "footer": "", "header": "有的时候，可以停下来找找灵感，然后再继续。", "title_alternative": "Random", "avatar_mini": "https://cdn.v2ex.com/navatar/093f/65e0/59_mini.png?m=1747623725", "stars": 1311, "founder_id": 0, "aliases": [], "root": false, "id": 59, "parent_node_name": "v2ex"}, "member": {"id": 589328, "username": "ccctttwww", "url": "https://www.v2ex.com/u/ccctttwww", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/91d8/6992/589328_mini.png?m=1778318827", "avatar_normal": "https://cdn.v2ex.com/avatar/91d8/6992/589328_normal.png?m=1778318827", "avatar_large": "https://cdn.v2ex.com/avatar/91d8/6992/589328_large.png?m=1778318827", "avatar_xlarge": "https://cdn.v2ex.com/avatar/91d8/6992/589328_xlarge.png?m=1778318827", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/91d8/6992/589328_xxlarge.png?m=1778318827", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/91d8/6992/589328_xxxlarge.png?m=1778318827", "created": 1658994387, "last_modified": 1778318827, "pro": 0}, "last_reply_by": "crossingmay", "last_touched": 1781057433, "title": "这种情况算是崇洋媚外吗", "url": "https://www.v2ex.com/t/1219079", "created": 1780988371, "deleted": 0, "content": "我身边有几位朋友，对所有国产产品都抱有极强的不信任感。\r\n\r\n手机方面只认可苹果，对国产手机从不了解、从不关注，还一味贬低吐槽；聊到汽车，如今国产车表现越来越好，可他们只认准特斯拉，直言国产车企的宣传都是虚假噱头，智能驾驶也只信任 FSD 。\r\n\r\n再说说 AI 大模型，业内公认综合实力顶尖的是 Claude ，而在 arena 排行榜中，国产模型在代码领域表现突出，除了 Claude 之外，直接包揽了榜单 2-5 名。即便数据摆在眼前，他们依旧打心底里看不起国产模型。宁愿花大价钱使用体验参差不齐的海外模型中转站，也要坚持用 Gemini 和 Claude 。\r\n\r\n在他们眼里，仿佛国外产品不论实际表现如何，就一定是好的，对国产事物的偏见根深蒂固。想问问大家，这种情况算崇洋媚外吗？", "content_rendered": "我身边有几位朋友，对所有国产产品都抱有极强的不信任感。<br /><br />手机方面只认可苹果，对国产手机从不了解、从不关注，还一味贬低吐槽；聊到汽车，如今国产车表现越来越好，可他们只认准特斯拉，直言国产车企的宣传都是虚假噱头，智能驾驶也只信任 FSD 。<br /><br />再说说 AI 大模型，业内公认综合实力顶尖的是 Claude ，而在 arena 排行榜中，国产模型在代码领域表现突出，除了 Claude 之外，直接包揽了榜单 2-5 名。即便数据摆在眼前，他们依旧打心底里看不起国产模型。宁愿花大价钱使用体验参差不齐的海外模型中转站，也要坚持用 Gemini 和 Claude 。<br /><br />在他们眼里，仿佛国外产品不论实际表现如何，就一定是好的，对国产事物的偏见根深蒂固。想问问大家，这种情况算崇洋媚外吗？", "last_modified": 1781021851, "replies": 298, "id": 1219079}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239006, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4491, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 307012, "username": "guoguobaba", "url": "https://www.v2ex.com/u/guoguobaba", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_mini.png?m=1742526918", "avatar_normal": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_normal.png?m=1742526918", "avatar_large": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_large.png?m=1742526918", "avatar_xlarge": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_xlarge.png?m=1742526918", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_xxlarge.png?m=1742526918", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/48a4/7fbb/307012_xxxlarge.png?m=1742526918", "created": 1523237980, "last_modified": 1742526918, "pro": 0}, "last_reply_by": "loryyang", "last_touched": 1781057578, "title": "教育孩子失败", "url": "https://www.v2ex.com/t/1219093", "created": 1780991002, "deleted": 0, "content": "娃执意要带智能手表去学校，她之前已经因此被处罚过一次了（记过）。\r\n我跟她讲了半天大道理，让她不要漠视规则，结果她回了我一句，你不是还翻墙吗，这不也是违法的事情吗，凭什么让我遵守这些规则呢？\r\n\r\n我没话说了。", "content_rendered": "<p>娃执意要带智能手表去学校，她之前已经因此被处罚过一次了（记过）。\n我跟她讲了半天大道理，让她不要漠视规则，结果她回了我一句，你不是还翻墙吗，这不也是违法的事情吗，凭什么让我遵守这些规则呢？</p>\n<p>我没话说了。</p>\n", "last_modified": 1780991002, "replies": 143, "id": 1219093}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11017, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2349, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 719709, "username": "Void000", "url": "https://www.v2ex.com/u/Void000", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/196ddfd2ae2fd3a8bf7cdc534ac6bbdb?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/196ddfd2ae2fd3a8bf7cdc534ac6bbdb?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/196ddfd2ae2fd3a8bf7cdc534ac6bbdb?s=73&d=retro", "created": 1731392735, "last_modified": 1757039947, "pro": 0}, "last_reply_by": "actopas", "last_touched": 1781043354, "title": "有多少钱能过上躺平的生活？", "url": "https://www.v2ex.com/t/1218982", "created": 1780973363, "deleted": 0, "content": "最近看了下日本失落的 30 年，基本大部分时间都是处于通缩状态。对比国内，情况大概率应该差不多。\r\n\r\n所以有个想法：在单身，欲望极低的情况下，手上有 100 个存银行应该够生活 50 年了吧？", "content_rendered": "<p>最近看了下日本失落的 30 年，基本大部分时间都是处于通缩状态。对比国内，情况大概率应该差不多。</p>\n<p>所以有个想法：在单身，欲望极低的情况下，手上有 100 个存银行应该够生活 50 年了吧？</p>\n", "last_modified": 1781046671, "replies": 104, "id": 1218982}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71463, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9704, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 5055, "username": "sdjl", "url": "https://www.v2ex.com/u/sdjl", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "贵州安顺", "tagline": "懂产品，擅长沟通，接外包。", "bio": "Web全栈开发，腾讯云开发，APP开发，接外包。", "avatar_mini": "https://cdn.v2ex.com/avatar/be6a/d876/5055_mini.png?m=1741067330", "avatar_normal": "https://cdn.v2ex.com/avatar/be6a/d876/5055_normal.png?m=1741067330", "avatar_large": "https://cdn.v2ex.com/avatar/be6a/d876/5055_large.png?m=1741067330", "created": 1294652197, "last_modified": 1741067330, "pro": 0}, "last_reply_by": "raysonlu", "last_touched": 1781056127, "title": "被公安请去喝茶了，刚回到家，提醒一下大家注意安全", "url": "https://www.v2ex.com/t/1219106", "created": 1780993397, "deleted": 0, "content": "接到陌生人电话让我去派出所一趟，也不明说有什么事情，一开始以为是诈骗，但是对方说本地话，感觉不像骗子。\r\n\r\n然后我就去了，民警说我们公司的网站涉黄，我一看，我说这个域名我们 2019 年就没有使用了，很多年不用了，不是我们的域名。\r\n\r\n但是，这个域名的备案信息之前是用我们公司备案的，所以找到了我。\r\n\r\n然后提交了一些证明，证明和我无关。公安给我下发几个通知书、整改书、网络安全知识等公文，然后喝了杯茶就回家了，茶还不错。\r\n\r\n提醒大家，不续费的域名记得取消备案，以免给自己带来麻烦。", "content_rendered": "<p>接到陌生人电话让我去派出所一趟，也不明说有什么事情，一开始以为是诈骗，但是对方说本地话，感觉不像骗子。</p>\n<p>然后我就去了，民警说我们公司的网站涉黄，我一看，我说这个域名我们 2019 年就没有使用了，很多年不用了，不是我们的域名。</p>\n<p>但是，这个域名的备案信息之前是用我们公司备案的，所以找到了我。</p>\n<p>然后提交了一些证明，证明和我无关。公安给我下发几个通知书、整改书、网络安全知识等公文，然后喝了杯茶就回家了，茶还不错。</p>\n<p>提醒大家，不续费的域名记得取消备案，以免给自己带来麻烦。</p>\n", "last_modified": 1780993485, "replies": 90, "id": 1219106}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239006, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4491, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 794327, "username": "Brightt", "url": "https://www.v2ex.com/u/Brightt", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/a0148972723b2742b36b0705d6082534?s=73&d=retro", "created": 1773653592, "last_modified": 1774187741, "pro": 0}, "last_reply_by": "sq955", "last_touched": 1781033012, "title": "回复 R 拒收短信真有效果吗？", "url": "https://www.v2ex.com/t/1218966", "created": 1780971502, "deleted": 0, "content": "这个农商银行每天给我发一条短信，让我贷款，今天试试回复 R 拒收看看有没有效果。\r\n\r\nhttps://i.v2ex.co/5E90Sva2l.png\r\n\r\n本来之前每天只发一条，今天仿佛是知道我拒收了，更来劲了，不到一小时又给我发一条一模一样的\r\n\r\nhttps://i.v2ex.co/5PLuyse2l.png\r\n\r\n这种怎么彻底屏蔽掉？", "content_rendered": "这个农商银行每天给我发一条短信，让我贷款，今天试试回复 R 拒收看看有没有效果。<br /><br /><a target=\"_blank\" href=\"/i/5E90Sva2l.png\" rel=\"nofollow noopener\" target=\"_blank\" title=\"在新窗口打开图片 5E90Sva2l.png\"><img src=\"//i.v2ex.co/5E90Sva2l.png\" class=\"embedded_image\"></a><br /><br />本来之前每天只发一条，今天仿佛是知道我拒收了，更来劲了，不到一小时又给我发一条一模一样的<br /><br /><a target=\"_blank\" href=\"/i/5PLuyse2l.png\" rel=\"nofollow noopener\" target=\"_blank\" title=\"在新窗口打开图片 5PLuyse2l.png\"><img src=\"//i.v2ex.co/5PLuyse2l.png\" class=\"embedded_image\"></a><br /><br />这种怎么彻底屏蔽掉？", "last_modified": 1780971502, "replies": 89, "id": 1218966}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https:/