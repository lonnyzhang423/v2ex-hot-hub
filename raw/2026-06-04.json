[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9f61/408e/56_large.png?m=1628212285", "name": "internet", "avatar_normal": "https://cdn.v2ex.com/navatar/9f61/408e/56_normal.png?m=1628212285", "title": "互联网", "url": "https://www.v2ex.com/go/internet", "topics": 4177, "footer": "", "header": "In Internet we trust", "title_alternative": "Internet", "avatar_mini": "https://cdn.v2ex.com/navatar/9f61/408e/56_mini.png?m=1628212285", "stars": 1197, "founder_id": 0, "aliases": [], "root": false, "id": 56, "parent_node_name": "computer"}, "member": {"id": 619857, "username": "wei417739", "url": "https://www.v2ex.com/u/wei417739", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/9406/46f3/619857_mini.png?m=1780540279", "avatar_normal": "https://cdn.v2ex.com/avatar/9406/46f3/619857_normal.png?m=1780540279", "avatar_large": "https://cdn.v2ex.com/avatar/9406/46f3/619857_large.png?m=1780540279", "avatar_xlarge": "https://cdn.v2ex.com/avatar/9406/46f3/619857_xlarge.png?m=1780540279", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/9406/46f3/619857_xxlarge.png?m=1780540279", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/9406/46f3/619857_xxxlarge.png?m=1780540279", "created": 1679285053, "last_modified": 1780540279, "pro": 0}, "last_reply_by": "Venlenter", "last_touched": 1780556607, "title": "L 站真有这么神？", "url": "https://www.v2ex.com/t/1217784", "created": 1780536605, "deleted": 0, "content": "最近在申請 linuxdo 社區，因為有些 AI 問題得到解決方案。是公開的帖子，然後我覺得社區裡未公開帖子會更有含金量一些，就想著去申請，昨天拿了三個邀請碼，申請了三次，一次沒過。\r\n我就想知道，真有必要一直卡著嗎？不理解\r\n還有就是想問下 L 站的大神，裡面貼文還有必要讓我繼續申請下去嗎？已經有點崩潰了", "content_rendered": "最近在申請 linuxdo 社區，因為有些 AI 問題得到解決方案。是公開的帖子，然後我覺得社區裡未公開帖子會更有含金量一些，就想著去申請，昨天拿了三個邀請碼，申請了三次，一次沒過。<br />我就想知道，真有必要一直卡著嗎？不理解<br />還有就是想問下 L 站的大神，裡面貼文還有必要讓我繼續申請下去嗎？已經有點崩潰了", "last_modified": 1780543459, "replies": 128, "id": 1217784}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10980, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2346, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 239115, "username": "kjmuamua", "url": "https://www.v2ex.com/u/kjmuamua", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/1ef8/6e4c/239115_mini.png?m=1517897561", "avatar_normal": "https://cdn.v2ex.com/avatar/1ef8/6e4c/239115_normal.png?m=1517897561", "avatar_large": "https://cdn.v2ex.com/avatar/1ef8/6e4c/239115_large.png?m=1517897561", "created": 1499391871, "last_modified": 1517897561, "pro": 0}, "last_reply_by": "xiapipi", "last_touched": 1780555607, "title": "年龄越来越大 找不到老婆怎么办", "url": "https://www.v2ex.com/t/1217656", "created": 1780478857, "deleted": 0, "content": "91 年的，现在虚岁已经 36 了，自大学谈了一个分了后，就没谈过恋爱。原来越觉得累，但是年龄大了，家里又是各种给压力，每次回家就要面对一次。好烦，怎么办，兄弟们有什么好办法吗？", "content_rendered": "<p>91 年的，现在虚岁已经 36 了，自大学谈了一个分了后，就没谈过恋爱。原来越觉得累，但是年龄大了，家里又是各种给压力，每次回家就要面对一次。好烦，怎么办，兄弟们有什么好办法吗？</p>\n", "last_modified": 1780530594, "replies": 109, "id": 1217656}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10980, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2346, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 565394, "username": "ShowYourPrompt", "url": "https://www.v2ex.com/u/ShowYourPrompt", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/ba8a4d5bd3366f39b95db974e914e2da?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/ba8a4d5bd3366f39b95db974e914e2da?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/ba8a4d5bd3366f39b95db974e914e2da?s=73&d=retro", "created": 1639451987, "last_modified": 1640598925, "pro": 0}, "last_reply_by": "ButcherHu", "last_touched": 1780555764, "title": "断掉牛奶后感觉免疫力变强了", "url": "https://www.v2ex.com/t/1217768", "created": 1780534227, "deleted": 0, "content": "个人非科学统计学吗？\r\n\r\n之前喝鲜奶，有时晚上喝，有时早上喝，200 ～ 300ml 不等\r\n\r\n但是基本上两三月一次口腔溃疡\r\n\r\n今年元旦后，就断掉了，改成吃茶叶蛋了，自己做的，每天早上两个\r\n\r\n然后直到现在，也没有口腔溃疡\r\n\r\n有科学依据吗？", "content_rendered": "个人非科学统计学吗？<br /><br />之前喝鲜奶，有时晚上喝，有时早上喝，200 ～ 300ml 不等<br /><br />但是基本上两三月一次口腔溃疡<br /><br />今年元旦后，就断掉了，改成吃茶叶蛋了，自己做的，每天早上两个<br /><br />然后直到现在，也没有口腔溃疡<br /><br />有科学依据吗？", "last_modified": 1780543452, "replies": 81, "id": 1217768}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71378, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9700, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 811316, "username": "Lcy0128", "url": "https://www.v2ex.com/u/Lcy0128", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f7e4/22ec/811316_mini.png?m=1778739851", "avatar_normal": "https://cdn.v2ex.com/avatar/f7e4/22ec/811316_normal.png?m=1778739851", "avatar_large": "https://cdn.v2ex.com/avatar/f7e4/22ec/811316_large.png?m=1778739851", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f7e4/22ec/811316_xlarge.png?m=1778739851", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f7e4/22ec/811316_xxlarge.png?m=1778739851", "created": 1778643039, "last_modified": 1778739851, "pro": 0}, "last_reply_by": "niubilewodev", "last_touched": 1780556795, "title": "大家现在个人服务器一般怎么管理比较合适？", "url": "https://www.v2ex.com/t/1217789", "created": 1780538003, "deleted": 0, "content": "我最近靠着 AI 辅助写了一些小项目，想部署到自己的服务器上跑起来。\r\n\r\n原本想着装个管理面板会省事很多，因为 ai 也这么推荐我操作来着，毕竟改 Nginx 配置、看日志、管理数据库、上传文件这些都有图形界面，对我这种新手运维可能比较友好。但后来翻了一些帖子，发现很多人对面板比较谨慎，原因大多是权限太高、暴露面变大，万一面板本身出问题，整台机器都可能受影响，而且我也害怕面板偷偷在背后把我服务器的东西传输出去。\r\n\r\n所以现在有点纠结了，对于像我这种新手运维来说，管理服务器是用面板还是用什么其他方法啊！", "content_rendered": "<p>我最近靠着 AI 辅助写了一些小项目，想部署到自己的服务器上跑起来。</p>\n<p>原本想着装个管理面板会省事很多，因为 ai 也这么推荐我操作来着，毕竟改 Nginx 配置、看日志、管理数据库、上传文件这些都有图形界面，对我这种新手运维可能比较友好。但后来翻了一些帖子，发现很多人对面板比较谨慎，原因大多是权限太高、暴露面变大，万一面板本身出问题，整台机器都可能受影响，而且我也害怕面板偷偷在背后把我服务器的东西传输出去。</p>\n<p>所以现在有点纠结了，对于像我这种新手运维来说，管理服务器是用面板还是用什么其他方法啊！</p>\n", "last_modified": 1780538003, "replies": 68, "id": 1217789}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10980, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2346, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 406045, "username": "0xnycth", "url": "https://www.v2ex.com/u/0xnycth", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/4ee2/21b4/406045_mini.png?m=1658197092", "avatar_normal": "https://cdn.v2ex.com/avatar/4ee2/21b4/406045_normal.png?m=1658197092", "avatar_large": "https://cdn.v2ex.com/avatar/4ee2/21b4/406045_large.png?m=1658197092", "created": 1556173529, "last_modified": 1658197092, "pro": 0}, "last_reply_by": "xFrye", "last_touched": 1780275895, "title": "网上聊了个总裁助理的相亲对象，刚聊了几句，问了个问题，她就毛了", "url": "https://www.v2ex.com/t/1217714", "created": 1780494076, "deleted": 0, "content": "内容前面无非就是寒暄，晚上好啥的。\r\n然后我看到她的资料写的总裁助理。\r\n\r\n我就说：你做总裁助理的啊，好厉害\r\n\r\n她回：有什么厉害的，也是搬砖\r\n\r\n我说：那不是离权力中心很近吗\r\n\r\n她回：没啥用\r\n\r\n我说：哈哈哈为啥啊，我也不太懂这个\r\n\r\n她回：没事，也没那么多为啥\r\n\r\n————这时候我看她好像不想聊工作，我就看他学历是 985/211\r\n\r\n我说：你学历好高啊，学霸来的\r\n\r\n她回：你在考虑什么\r\n\r\n我回：啊？就聊天啊，学历咋了吗\r\n\r\n——————\r\n\r\n然后就没有任何回复了。\r\n\r\n奇怪的人真多啊。", "content_rendered": "<p>内容前面无非就是寒暄，晚上好啥的。\n然后我看到她的资料写的总裁助理。</p>\n<p>我就说：你做总裁助理的啊，好厉害</p>\n<p>她回：有什么厉害的，也是搬砖</p>\n<p>我说：那不是离权力中心很近吗</p>\n<p>她回：没啥用</p>\n<p>我说：哈哈哈为啥啊，我也不太懂这个</p>\n<p>她回：没事，也没那么多为啥</p>\n<p>————这时候我看她好像不想聊工作，我就看他学历是 985/211</p>\n<p>我说：你学历好高啊，学霸来的</p>\n<p>她回：你在考虑什么</p>\n<p>我回：啊？就聊天啊，学历咋了吗</p>\n<p>——————</p>\n<p>然后就没有任何回复了。</p>\n<p>奇怪的人真多啊。</p>\n", "last_modified": 1780494076, "replies": 59, "id": 1217714}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a51f/b975/1298_large.png?m=1768486840", "name": "app", "avatar_normal": "https://cdn.v2ex.com/navatar/a51f/b975/1298_normal.png?m=1768486840", "title": "App推荐", "url": "https://www.v2ex.com/go/app", "topics": 16, "footer": "", "header": "别让好 App 埋没｜发你正在用的宝藏工具，顺便说清“为什么好用”", "title_alternative": "App推荐", "avatar_mini": "https://cdn.v2ex.com/navatar/a51f/b975/1298_mini.png?m=1768486840", "stars": 8, "founder_id": 6746, "aliases": [], "root": false, "id": 1298, "parent_node_name": null}, "member": {"id": 236252, "username": "JakeLaoyu", "url": "https://www.v2ex.com/u/JakeLaoyu", "website": "https://github.com/JakeLaoyu", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/12f817e9e305db9283ad4d21c2de825e?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/12f817e9e305db9283ad4d21c2de825e?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/12f817e9e305db9283ad4d21c2de825e?s=73&d=retro", "created": 1497883273, "last_modified": 1780507473, "pro": 0}, "last_reply_by": "BearCookie", "last_touched": 1780555364, "title": "[自荐] 做了个纯 SSH 的服务器管理 App —— Caret,iOS 已上线", "url": "https://www.v2ex.com/t/1217750", "created": 1780507529, "deleted": 0, "content": "分享个自己做的小工具 Caret:用手机或 Mac,纯标准 SSH 管 Linux 服务器,服务器端零安装。\r\n\r\n能干啥:\r\n\r\n完整 SSH 终端(xterm,能跑 vim/htop/tail -f,多标签、断线重连、命令片段)\r\n\r\n实时监控:CPU/内存/磁盘/网络/负载 曲线,多机聚合一屏\r\n\r\nDocker 管理、Pod 部署模板、SFTP 文件传输\r\n\r\n隐私(最想强调的): 纯客户端,没有我的服务器,流量直达你的机器、不上报遥测;凭据只进系统 \r\nKeychain/Keystore;同步可选,走你自己的 iCloud / Google Drive(Drive 上端到端加密)。\r\n\r\niOS 已上线 App Store,免费下载; Android / macOS 即将跟上。\r\n\r\nApp Store: https://apps.apple.com/app/id6775111587 **没有上架中国区**\r\n\r\n介绍页: https://zobubo.com/products/caret\r\n\r\n附上永久高级版兑换码，在 app store 中兑换，app 中没有兑换入口\r\n\r\nXPKJR8WH6NLXTKA6EK\r\n\r\n47TXLXFLFNW8P3F4K8\r\n\r\n7YEMA6YAP4MX64EEE7\r\n\r\nPXX3LW3M47K3KPJJK8\r\n\r\nXJKXYHYE64AJJ7N4FH\r\n\r\nMPNK8AYL3HYRH87AHA\r\n\r\nWN6KERWEA4E87KHAEE\r\n\r\n8TPPMXF47HM6N776RP\r\n\r\nMNJHKJR4RHA6XYRXK6\r\n\r\nR6LPNEEXWFY36KR4HF\r\n\r\n6L8M3K8J68Y7PR443K\r\n\r\nHTNP6JKNJPJ3P74JFY\r\n\r\nPEHAA86YHFYMFHEAFT\r\n\r\n6MPMEKW6N3PYHLXMWN\r\n\r\n88TWAFTJWPE7E4AYTH\r\n\r\n3AMHW3RFE8PMF86PKR\r\n\r\nF6NMEMW33KFATJ7XL6\r\n\r\n7EAMFELH4A8HY4W4T3\r\n\r\nNKWPN6RJNHNW6M7X8F\r\n\r\nRR678KRLXRYALKXEA6\r\n\r\n\r\n接受好评，也接受反馈", "content_rendered": "<p>分享个自己做的小工具 Caret:用手机或 Mac,纯标准 SSH 管 Linux 服务器,服务器端零安装。</p>\n<p>能干啥:</p>\n<p>完整 SSH 终端(xterm,能跑 vim/htop/tail -f,多标签、断线重连、命令片段)</p>\n<p>实时监控:CPU/内存/磁盘/网络/负载 曲线,多机聚合一屏</p>\n<p>Docker 管理、Pod 部署模板、SFTP 文件传输</p>\n<p>隐私(最想强调的): 纯客户端,没有我的服务器,流量直达你的机器、不上报遥测;凭据只进系统\nKeychain/Keystore;同步可选,走你自己的 iCloud / Google Drive(Drive 上端到端加密)。</p>\n<p>iOS 已上线 App Store,免费下载; Android / macOS 即将跟上。</p>\n<p>App Store: <a href=\"https://apps.apple.com/app/id6775111587\" rel=\"nofollow\">https://apps.apple.com/app/id6775111587</a> <strong>没有上架中国区</strong></p>\n<p>介绍页: <a href=\"https://zobubo.com/products/caret\" rel=\"nofollow\">https://zobubo.com/products/caret</a></p>\n<p>附上永久高级版兑换码，在 app store 中兑换，app 中没有兑换入口</p>\n<p>XPKJR8WH6NLXTKA6EK</p>\n<p>47TXLXFLFNW8P3F4K8</p>\n<p>7YEMA6YAP4MX64EEE7</p>\n<p>PXX3LW3M47K3KPJJK8</p>\n<p>XJKXYHYE64AJJ7N4FH</p>\n<p>MPNK8AYL3HYRH87AHA</p>\n<p>WN6KERWEA4E87KHAEE</p>\n<p>8TPPMXF47HM6N776RP</p>\n<p>MNJHKJR4RHA6XYRXK6</p>\n<p>R6LPNEEXWFY36KR4HF</p>\n<p>6L8M3K8J68Y7PR443K</p>\n<p>HTNP6JKNJPJ3P74JFY</p>\n<p>PEHAA86YHFYMFHEAFT</p>\n<p>6MPMEKW6N3PYHLXMWN</p>\n<p>88TWAFTJWPE7E4AYTH</p>\n<p>3AMHW3RFE8PMF86PKR</p>\n<p>F6NMEMW33KFATJ7XL6</p>\n<p>7EAMFELH4A8HY4W4T3</p>\n<p>NKWPN6RJNHNW6M7X8F</p>\n<p>RR678KRLXRYALKXEA6</p>\n<p>接受好评，也接受反馈</p>\n", "last_modified": 1780507710, "replies": 58, "id": 1217750}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 3980, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3118, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 630191, "username": "laoyutang", "url": "https://www.v2ex.com/u/laoyutang", "website": "https://blog.laoyutang.cn", "twitter": "", "psn": "", "github": "laoyutang", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/9e8d/da54/630191_mini.png?m=1750398486", "avatar_normal": "https://cdn.v2ex.com/avatar/9e8d/da54/630191_normal.png?m=1750398486", "avatar_large": "https://cdn.v2ex.com/avatar/9e8d/da54/630191_large.png?m=1750398486", "avatar_xlarge": "https://cdn.v2ex.com/avatar/9e8d/da54/630191_xlarge.png?m=1750398486", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/9e8d/da54/630191_xxlarge.png?m=1750398486", "created": 1684742772, "last_modified": 1750398486, "pro": 0}, "last_reply_by": "unusualcat", "last_touched": 1780556838, "title": "有重置了兄弟们", "url": "https://www.v2ex.com/t/1217762", "created": 1780533212, "deleted": 0, "content": "codex 周额度又又又重置了", "content_rendered": "<p>codex 周额度又又又重置了</p>\n", "last_modified": 1780533212, "replies": 54, "id": 1217762}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71378, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9700, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 434592, "username": "lynn1su", "url": "https://www.v2ex.com/u/lynn1su", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f59f/474b/434592_mini.png?m=1777788899", "avatar_normal": "https://cdn.v2ex.com/avatar/f59f/474b/434592_normal.png?m=1777788899", "avatar_large": "https://cdn.v2ex.com/avatar/f59f/474b/434592_large.png?m=1777788899", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f59f/474b/434592_xlarge.png?m=1777788899", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f59f/474b/434592_xxlarge.png?m=1777788899", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/f59f/474b/434592_xxxlarge.png?m=1777788899", "created": 1565250257, "last_modified": 1777788899, "pro": 0}, "last_reply_by": "QlanQ", "last_touched": 1780556675, "title": "兄弟们， 5 月总计用了多少 token？我用了 34 亿，做了 3 个项目，主用 deepseek v4 pro", "url": "https://www.v2ex.com/t/1217791", "created": 1780538165, "deleted": 0, "content": "https://i.imgur.com/EhbDnE2.png", "content_rendered": "<a target=\"_blank\" href=\"https://i.imgur.com/EhbDnE2.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/EhbDnE2.png\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1780538165, "replies": 54, "id": 1217791}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71378, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9700, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 582364, "username": "SeleiXi", "url": "https://www.v2ex.com/u/SeleiXi", "website": "www.seleixi.com", "twitter": "", "psn": "", "github": "SeleiXi", "btc": "", "location": "香港", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/b45c/e619/582364_mini.png?m=1774620203", "avatar_normal": "https://cdn.v2ex.com/avatar/b45c/e619/582364_normal.png?m=1774620203", "avatar_large": "https://cdn.v2ex.com/avatar/b45c/e619/582364_large.png?m=1774620203", "avatar_xlarge": "https://cdn.v2ex.com/avatar/b45c/e619/582364_xlarge.png?m=1774620203", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/b45c/e619/582364_xxlarge.png?m=1774620203", "created": 1653185546, "last_modified": 1774620203, "pro": 0}, "last_reply_by": "opeth", "last_touched": 1780553314, "title": "v 友们 windows 电脑用 codex/claude code 一般用什么终端？感觉系统原生终端/powershell 有点难用", "url": "https://www.v2ex.com/t/1217746", "created": 1780504359, "deleted": 0, "content": "因为在 windows 上有 codex/claude code 需求，但又没有一个类似 tmux 的，打算用 wezterm 试试，死活解决不了这个问题 wezterm 用 codex 的时候用中文输入法就闪退（ QQ 输入法，随便输入什么都闪退，系统输入法没问题，但我其中一个不想用系统原生终端的原因就是渲染不出来第三方中文输入法的习惯，但我的习惯数据都已经在第三方输入法里面了）\r\n\r\nbtw 想问下 v 友们 windows 开发一般用什么终端，我个人会有一些需求\r\n1. 重启会恢复原本我在开发的目录，最好的话是能恢复到那个进程（我原本开了多少个 tab 就恢复回来多少个 tab ）\r\n2. 对第三方中文输入法支持比较好\r\n3. 终端不要太重，不要太占内存（最好有一些比如闲置 tab 就 freeze 内存的管理之类的？）", "content_rendered": "因为在 windows 上有 codex/claude code 需求，但又没有一个类似 tmux 的，打算用 wezterm 试试，死活解决不了这个问题 wezterm 用 codex 的时候用中文输入法就闪退（ QQ 输入法，随便输入什么都闪退，系统输入法没问题，但我其中一个不想用系统原生终端的原因就是渲染不出来第三方中文输入法的习惯，但我的习惯数据都已经在第三方输入法里面了）<br /><br />btw 想问下 v 友们 windows 开发一般用什么终端，我个人会有一些需求<br />1. 重启会恢复原本我在开发的目录，最好的话是能恢复到那个进程（我原本开了多少个 tab 就恢复回来多少个 tab ）<br />2. 对第三方中文输入法支持比较好<br />3. 终端不要太重，不要太占内存（最好有一些比如闲置 tab 就 freeze 内存的管理之类的？）", "last_modified": 1780504359, "replies": 47, "id": 1217746}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9f61/408e/56_large.png?m=1628212285", "name": "internet", "avatar_normal": "https://cdn.v2ex.com/navatar/9f61/408e/56_normal.png?m=1628212285", "title": "互联网", "url": "https://www.v2ex.com/go/internet", "topics": 4177, "footer": "", "header": "In Internet we trust", "title_alternative": "Internet", "avatar_mini": "https://cdn.v2ex.com/navatar/9f61/408e/56_mini.png?m=1628212285", "stars": 1197, "founder_id": 0, "aliases": [], "root": false, "id": 56, "parent_node_name": "computer"}, "member": {"id": 747031, "username": "ljkgpxs", "url": "https://www.v2ex.com/u/ljkgpxs", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/5cae10775c40d63af69c352c9bfcbdeb?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/5cae10775c40d63af69c352c9bfcbdeb?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/5cae10775c40d63af69c352c9bfcbdeb?s=73&d=retro", "created": 1746580143, "last_modified": 1746580143, "pro": 0}, "last_reply_by": "xppgg", "last_touched": 1780522342, "title": "老罗思想还是太超前了", "url": "https://www.v2ex.com/t/1217612", "created": 1780470758, "deleted": 0, "content": "他的 TNT 产品真是生不逢时，一句“安静！吵到我用 TNT 了”成了一个经典的梗。最近 AI 用多了，天天写提示词，码字又累又慢，不如直接嘴说来的快，而且现在语音识别率是真的高，一句话解释不清，多说几句就好啦，TNT 产品搁到现在估计都成爆款了", "content_rendered": "<p>他的 TNT 产品真是生不逢时，一句“安静！吵到我用 TNT 了”成了一个经典的梗。最近 AI 用多了，天天写提示词，码字又累又慢，不如直接嘴说来的快，而且现在语音识别率是真的高，一句话解释不清，多说几句就好啦，TNT 产品搁到现在估计都成爆款了</p>\n", "last_modified": 1780470758, "replies": 45, "id": 1217612}]