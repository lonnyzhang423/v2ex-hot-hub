d": 12, "parent_node_name": "v2ex"}, "member": {"id": 541011, "username": "tactac", "url": "https://www.v2ex.com/u/tactac", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/d029e73ef44bb3ef7a036038367f0fd9?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/d029e73ef44bb3ef7a036038367f0fd9?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/d029e73ef44bb3ef7a036038367f0fd9?s=73&d=retro", "created": 1617494071, "last_modified": 1617494071, "pro": 0}, "last_reply_by": "zsqduke", "last_touched": 1774421225, "title": "token 的中文翻译，正式定为词元，如何？", "url": "https://www.v2ex.com/t/1200873", "created": 1774395084, "deleted": 0, "content": "个人认为很不错，语言的最小单元，和字节这个翻译类似。有没有人去注册一家词元跳动的公司？🤣", "content_rendered": "<p>个人认为很不错，语言的最小单元，和字节这个翻译类似。有没有人去注册一家词元跳动的公司？🤣</p>\n", "last_modified": 1774395084, "replies": 78, "id": 1200873}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/53fd/e96f/522_large.png?m=1747625689", "name": "bike", "avatar_normal": "https://cdn.v2ex.com/navatar/53fd/e96f/522_normal.png?m=1747625689", "title": "骑行", "url": "https://www.v2ex.com/go/bike", "topics": 241, "footer": "", "header": "", "title_alternative": "Bike", "avatar_mini": "https://cdn.v2ex.com/navatar/53fd/e96f/522_mini.png?m=1747625689", "stars": 355, "founder_id": 0, "aliases": [], "root": false, "id": 522, "parent_node_name": ""}, "member": {"id": 494760, "username": "lw10645", "url": "https://www.v2ex.com/u/lw10645", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/80e3/9f2e/494760_mini.png?m=1736993733", "avatar_normal": "https://cdn.v2ex.com/avatar/80e3/9f2e/494760_normal.png?m=1736993733", "avatar_large": "https://cdn.v2ex.com/avatar/80e3/9f2e/494760_large.png?m=1736993733", "created": 1592189459, "last_modified": 1736993733, "pro": 0}, "last_reply_by": "2ako", "last_touched": 1774420696, "title": "山地车 or 公路车？", "url": "https://www.v2ex.com/t/1200939", "created": 1774406520, "deleted": 0, "content": "天气暖和了，准备动起来\r\n\r\n70%时间用于通勤，通勤骑行距离单边 8 公里多点，骑青桔大概 26 分钟，现在通勤是坐公交 50 多分钟\r\n\r\n剩余时间就是偶尔长距离休闲骑行，以前是扫个车随便骑一下，每次骑二三十公里（一年 10 多次的频率，集中在春夏秋）\r\n\r\n如果只考虑通勤，都是城市道路，买公路车好一点\r\n\r\n但是考虑到平时会骑出去玩，可能有非铺装路面，是不是买山地车更兼容一点\r\n\r\n各位佬有推荐的车吗，预算 1000 左右，不超过 1500", "content_rendered": "<p>天气暖和了，准备动起来</p>\n<p>70%时间用于通勤，通勤骑行距离单边 8 公里多点，骑青桔大概 26 分钟，现在通勤是坐公交 50 多分钟</p>\n<p>剩余时间就是偶尔长距离休闲骑行，以前是扫个车随便骑一下，每次骑二三十公里（一年 10 多次的频率，集中在春夏秋）</p>\n<p>如果只考虑通勤，都是城市道路，买公路车好一点</p>\n<p>但是考虑到平时会骑出去玩，可能有非铺装路面，是不是买山地车更兼容一点</p>\n<p>各位佬有推荐的车吗，预算 1000 左右，不超过 1500</p>\n", "last_modified": 1774413514, "replies": 74, "id": 1200939}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 22785, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3635, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 759554, "username": "arihca", "url": "https://www.v2ex.com/u/arihca", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "achira账号的小号，于2020年注册。2025年7月使用SOL注册小号", "bio": "achira账号的小号，于2020年注册。2025年7月使用SOL注册小号", "avatar_mini": "https://cdn.v2ex.com/gravatar/5642838b65a32803ba9586a0db00a563?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/5642838b65a32803ba9586a0db00a563?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/5642838b65a32803ba9586a0db00a563?s=73&d=retro", "created": 1753502591, "last_modified": 1757912216, "pro": 1774421204}, "last_reply_by": "Chichele", "last_touched": 1774421336, "title": "我很佩服也很羡慕张雪峰", "url": "https://www.v2ex.com/t/1200970", "created": 1774410401, "deleted": 0, "content": "在 23 年就表达了希望死在工作台上，也的确践行了这一点\r\n无论如何也好，他做到了，虽然最后这两年的各方面状态很糟糕，但就值得敬佩\r\n但有些人的宿命和习惯就是燃尽，就像明日之丈里的矢吹丈一样拳击到最后一刻在拳击台上去世\r\n各类极限运动所追求的本质也是无惧坦然的面对自己的终结，与自身最后本能的反抗谈和，达到真正的和谐\r\n张雪峰既不是为了钱，也不是为了名誉，更不是为了死，而是为了真正活着，所以赴死。", "content_rendered": "在 23 年就表达了希望死在工作台上，也的确践行了这一点<br />无论如何也好，他做到了，虽然最后这两年的各方面状态很糟糕，但就值得敬佩<br />但有些人的宿命和习惯就是燃尽，就像明日之丈里的矢吹丈一样拳击到最后一刻在拳击台上去世<br />各类极限运动所追求的本质也是无惧坦然的面对自己的终结，与自身最后本能的反抗谈和，达到真正的和谐<br />张雪峰既不是为了钱，也不是为了名誉，更不是为了死，而是为了真正活着，所以赴死。", "last_modified": 1774410401, "replies": 69, "id": 1200970}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 70240, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9603, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 581861, "username": "xitler", "url": "https://www.v2ex.com/u/xitler", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/dee107f09d63f412201ef54fe8d5459c?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/dee107f09d63f412201ef54fe8d5459c?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/dee107f09d63f412201ef54fe8d5459c?s=73&d=retro", "created": 1652701896, "last_modified": 1655351986, "pro": 0}, "last_reply_by": "zhouxu", "last_touched": 1774420800, "title": "[纯吐槽]没想到 minimax 会这么难用", "url": "https://www.v2ex.com/t/1200857", "created": 1774367218, "deleted": 0, "content": "看了 ai benchmark 排名，显示说 m2.7 仅次于 gpt 5.4 。价格又很有诱惑力，差点没把持住买年卡。斥巨资 119 买了 max 套餐之后才发现实际上垃圾的要命，这是我用过最差劲的模型。别说国外模型了，比 kimi 都差一大截。\r\n真就跑分没输过，实战没赢过。", "content_rendered": "看了 ai benchmark 排名，显示说 m2.7 仅次于 gpt 5.4 。价格又很有诱惑力，差点没把持住买年卡。斥巨资 119 买了 max 套餐之后才发现实际上垃圾的要命，这是我用过最差劲的模型。别说国外模型了，比 kimi 都差一大截。<br />真就跑分没输过，实战没赢过。", "last_modified": 1774367218, "replies": 69, "id": 1200857}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a87f/f679/4_large.png?m=1625264761", "name": "music", "avatar_normal": "https://cdn.v2ex.com/navatar/a87f/f679/4_normal.png?m=1625264761", "title": "音乐", "url": "https://www.v2ex.com/go/music", "topics": 1812, "footer": "", "header": "Music is an art form whose medium is sound and silence.", "title_alternative": "Music", "avatar_mini": "https://cdn.v2ex.com/navatar/a87f/f679/4_mini.png?m=1625264761", "stars": 1575, "founder_id": 0, "aliases": [], "root": false, "id": 4, "parent_node_name": "life"}, "member": {"id": 572158, "username": "sevenyangcc", "url": "https://www.v2ex.com/u/sevenyangcc", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/8799/296c/572158_mini.png?m=1770692663", "avatar_normal": "https://cdn.v2ex.com/avatar/8799/296c/572158_normal.png?m=1770692663", "avatar_large": "https://cdn.v2ex.com/avatar/8799/296c/572158_large.png?m=1770692663", "avatar_xlarge": "https://cdn.v2ex.com/avatar/8799/296c/572158_xlarge.png?m=1770692663", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/8799/296c/572158_xxlarge.png?m=1770692663", "created": 1644316741, "last_modified": 1770692663, "pro": 0}, "last_reply_by": "Dylaan", "last_touched": 1774421042, "title": "周杰伦新专辑《太阳之子》发了，各位还听吗？", "url": "https://www.v2ex.com/t/1200944", "created": 1774406968, "deleted": 0, "content": "数专￥ 40 ，刚听主打歌就要劝退了，还是好好开演唱会吃老本吧。", "content_rendered": "<p>数专￥ 40 ，刚听主打歌就要劝退了，还是好好开演唱会吃老本吧。</p>\n", "last_modified": 1774406968, "replies": 60, "id": 1200944}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.