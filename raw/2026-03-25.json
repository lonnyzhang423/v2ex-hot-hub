[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_large.png?m=1643940920", "name": "ev", "avatar_normal": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_normal.png?m=1643940920", "title": "电动汽车", "url": "https://www.v2ex.com/go/ev", "topics": 422, "footer": "", "header": "", "title_alternative": "EV", "avatar_mini": "https://cdn.v2ex.com/navatar/bdb1/06a0/1034_mini.png?m=1643940920", "stars": 433, "founder_id": 0, "aliases": [], "root": false, "id": 1034, "parent_node_name": "tech"}, "member": {"id": 390917, "username": "gitsuck", "url": "https://www.v2ex.com/u/gitsuck", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/87b1/64f2/390917_mini.png?m=1770718716", "avatar_normal": "https://cdn.v2ex.com/avatar/87b1/64f2/390917_normal.png?m=1770718716", "avatar_large": "https://cdn.v2ex.com/avatar/87b1/64f2/390917_large.png?m=1770718716", "created": 1552190432, "last_modified": 1770718716, "pro": 0}, "last_reply_by": "wangj00756", "last_touched": 1774417437, "title": "极氪 7X / Model Y / MG4 怎么选？", "url": "https://www.v2ex.com/t/1200722", "created": 1774334328, "deleted": 0, "content": "▌基本情况\r\n我税前 28w 有存款 26w ，对象税前 12W ；\r\n未婚，近两年结婚，婚后 1-2 年要孩子，5 年后计划佛山购房，父母无支持。\r\n租房住，无私家充电桩。\r\n\r\n▌用车场景\r\n- 日常通勤：广州黄浦 ↔ 佛山桂城，往返日均 80km\r\n- 每月 1-2 次周边游（ 100km 内）\r\n- 每年回潮汕一次，单程 400km （刚需，确定要开）\r\n- 年度自驾游 1-2 次（可高铁+租车替代）\r\n\r\n▌三个方案\r\n\r\nMG4 智趣版｜落地约 5.5w ，月供 2,083 （ 2 年 0 息）\r\n实测续航约 350km ，无私家桩每周公充约 2 次，400km 潮汕单程偏紧张。名爵售后稀烂。\r\n\r\n极氪 7X ｜落地约 7.5w ，月供 7,800 （ 2 年 0 息）\r\n实测续航约 450km ，每周公充 1 次，舒适性好，含辅助驾驶，终身电池质保。\r\n\r\nModel Y ｜落地约 11.5w ，月供 3,060 （ 5 年 0 息）\r\n实测续航约 450km ，每周公充 1 次，空间最大，超充补能快，辅助驾驶另付费订阅。\r\n\r\n▌主要纠结点\r\n1. 婚育+购房压力大，父母无帮衬，MG4 省钱方案是否更稳妥？后期再换车。\r\n2. 无私家桩，MG4 每周 2 次公充的实际体验能接受吗？\r\n3. 极氪 7X 月供最高但含辅驾，非毛坯； Model Y 月供低但辅驾另付、首付多 4w 。哪个更值？\r\n4. 黄浦-桂城高速通勤，晚上必堵车，哪个体验更好？\r\n\r\n求 v 友指点，谢谢🙏", "content_rendered": "▌基本情况<br />我税前 28w 有存款 26w ，对象税前 12W ；<br />未婚，近两年结婚，婚后 1-2 年要孩子，5 年后计划佛山购房，父母无支持。<br />租房住，无私家充电桩。<br /><br />▌用车场景<br />- 日常通勤：广州黄浦 ↔ 佛山桂城，往返日均 80km<br />- 每月 1-2 次周边游（ 100km 内）<br />- 每年回潮汕一次，单程 400km （刚需，确定要开）<br />- 年度自驾游 1-2 次（可高铁+租车替代）<br /><br />▌三个方案<br /><br />MG4 智趣版｜落地约 5.5w ，月供 2,083 （ 2 年 0 息）<br />实测续航约 350km ，无私家桩每周公充约 2 次，400km 潮汕单程偏紧张。名爵售后稀烂。<br /><br />极氪 7X ｜落地约 7.5w ，月供 7,800 （ 2 年 0 息）<br />实测续航约 450km ，每周公充 1 次，舒适性好，含辅助驾驶，终身电池质保。<br /><br />Model Y ｜落地约 11.5w ，月供 3,060 （ 5 年 0 息）<br />实测续航约 450km ，每周公充 1 次，空间最大，超充补能快，辅助驾驶另付费订阅。<br /><br />▌主要纠结点<br />1. 婚育+购房压力大，父母无帮衬，MG4 省钱方案是否更稳妥？后期再换车。<br />2. 无私家桩，MG4 每周 2 次公充的实际体验能接受吗？<br />3. 极氪 7X 月供最高但含辅驾，非毛坯； Model Y 月供低但辅驾另付、首付多 4w 。哪个更值？<br />4. 黄浦-桂城高速通勤，晚上必堵车，哪个体验更好？<br /><br />求 v 友指点，谢谢🙏", "last_modified": 1774338512, "replies": 133, "id": 1200722}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 22785, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3635, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 422626, "username": "ellison13tj", "url": "https://www.v2ex.com/u/ellison13tj", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/bba21148fd71b8eebf6654e53ead0a02?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/bba21148fd71b8eebf6654e53ead0a02?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/bba21148fd71b8eebf6654e53ead0a02?s=73&d=retro", "created": 1560792408, "last_modified": 1774333474, "pro": 0}, "last_reply_by": "letwewell", "last_touched": 1774416762, "title": "大家都能 AI Coding 了，做软件还有什么意义？", "url": "