[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10632, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2279, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 803946, "username": "Lini1122", "url": "https://www.v2ex.com/u/Lini1122", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/cd12/514e/803946_mini.png?m=1776526132", "avatar_normal": "https://cdn.v2ex.com/avatar/cd12/514e/803946_normal.png?m=1776526132", "avatar_large": "https://cdn.v2ex.com/avatar/cd12/514e/803946_large.png?m=1776526132", "avatar_xlarge": "https://cdn.v2ex.com/avatar/cd12/514e/803946_xlarge.png?m=1776526132", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/cd12/514e/803946_xxlarge.png?m=1776526132", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/cd12/514e/803946_xxxlarge.png?m=1776526132", "created": 1776514165, "last_modified": 1776526132, "pro": 0}, "last_reply_by": "resist", "last_touched": 1776576073, "title": "我妈逼迫我 23 年深圳买房，导致 3 年房子降价 100 万，加上 30 年利息亏损 180 万", "url": "https://www.v2ex.com/t/1206894", "created": 1776521562, "deleted": 0, "content": "我的成长背景：\r\n\r\n我是男的。我家有爷爷奶奶，爸爸和妈妈，我弟（比我小 13 岁），叔叔，姥姥，大舅，小舅。\r\n\r\n我从小就是一个比较内向的人。从小我爸妈就把垃圾情绪发泄给我，导致我一直拉个脸，他们就会怒斥我，为什么老是拉个脸！！！！\r\n\r\n我爸从我小时就来到深圳，跟我大舅做吊车生意，算是给我大舅打工。我妈从我幼儿园到小学 5 年纪，之后就把我丢到我爷爷奶奶家了，她来深圳和我爸住一块了。我从此以后就寒暑假来深圳找我爸妈。\r\n\r\n到了深圳以后，就开始猛教训我，他们不是拉近和我的关系，而是一直让我做家务，一直训斥我，一直教育我，一直打压我说我是个废物。我很不明白，为什么对我态度这么差？好像我学习不好就对他们没用。", "content_rendered": "我的成长背景：<br /><br />我是男的。我家有爷爷奶奶，爸爸和妈妈，我弟（比我小 13 岁），叔叔，姥姥，大舅，小舅。<br /><br />我从小就是一个比较内向的人。从小我爸妈就把垃圾情绪发泄给我，导致我一直拉个脸，他们就会怒斥我，为什么老是拉个脸！！！！<br /><br />我爸从我小时就来到深圳，跟我大舅做吊车生意，算是给我大舅打工。我妈从我幼儿园到小学 5 年纪，之后就把我丢到我爷爷奶奶家了，她来深圳和我爸住一块了。我从此以后就寒暑假来深圳找我爸妈。<br /><br />到了深圳以后，就开始猛教训我，他们不是拉近和我的关系，而是一直让我做家务，一直训斥我，一直教育我，一直打压我说我是个废物。我很不明白，为什么对我态度这么差？好像我学习不好就对他们没用。", "last_modified": 1776521923, "replies": 111, "id": 1206894}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_large.png?m=1691642161", "name": "bb", "avatar_normal": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_normal.png?m=1691642161", "title": "宽带症候群", "url": "https://www.v2ex.com/go/bb", "topics": 18592, "footer": "", "header": "网速很重要。比快更快。", "title_alternative": "Broadband Symptom Complex", "avatar_mini": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_mini.png?m=1691642161", "stars": 8201, "founder_id": 0, "aliases": [], "root": false, "id": 108, "parent_node_name": "geek"}, "member": {"id": 663321, "username": "Achao1121", "url": "https://www.v2ex.com/u/Achao1121", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/47f6/f490/663321_mini.png?m=1704094324", "avatar_normal": "https://cdn.v2ex.com/avatar/47f6/f490/663321_normal.png?m=1704094324", "avatar_large": "https://cdn.v2ex.com/avatar/47f6/f490/663321_large.png?m=1704094324", "avatar_xlarge": "https://cdn.v2ex.com/avatar/47f6/f490/663321_xlarge.png?m=1704094324", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/47f6/f490/663321_xxlarge.png?m=1704094324", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/47f6/f490/663321_xxxlarge.png?m=1704094324", "created": 1700358716, "last_modified": 1704094324, "pro": 0}, "last_reply_by": "HUZHUANGZHUANG", "last_touched": 1776576119, "title": "刚刚自建的，目前自己在用，网速还不错", "url": "https://www.v2ex.com/t/1206847", "created": 1776501770, "deleted": 0, "content": "找到搬瓦工   全程跟着 Gemini 搭建起来   Mac 上建好了\r\n\r\n美国 - 洛杉矶 DC9 CN2GIA (USCA_9)     **49.99 美元/3 个月   Alipay\r\n\r\nUbuntu-22.04-x86_64    机房 USCA_9 (DC9)\r\n\r\n**20 GB SSD / 1 GB RAM / 1 TB 流量每月 / 2.5G 带宽\r\n\r\n各位评价一下怎么样", "content_rendered": "<p>找到搬瓦工   全程跟着 Gemini 搭建起来   Mac 上建好了</p>\n<p>美国 - 洛杉矶 DC9 CN2GIA (USCA_9)     **49.99 美元/3 个月   Alipay</p>\n<p>Ubuntu-22.04-x86_64    机房 USCA_9 (DC9)</p>\n<p>**20 GB SSD / 1 GB RAM / 1 TB 流量每月 / 2.5G 带宽</p>\n<p>各位评价一下怎么样</p>\n", "last_modified": 1776506311, "replies": 90, "id": 1206847}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10632, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2279, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 88150, "username": "wenJoy", "url": "https://www.v2ex.com/u/wenJoy", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/131b9138bcd1124ed6591c54f42773af?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/131b9138bcd1124ed6591c54f42773af?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/131b9138bcd1124ed6591c54f42773af?s=73&d=retro", "created": 1419385761, "last_modified": 1419385761, "pro": 0}, "last_reply_by": "hamsterbase", "last_touched": 1776579627, "title": "我感觉自己好像被困住了。似乎我经常陷入这种困境， 而这种困境更像是我给自己的限制太多", "url": "https://www.v2ex.com/t/1206941", "created": 1776565966, "deleted": 0, "content": "举个例子，我最近准备租房子，花了很多时间，看了 20 多套房子， 终于找到一套满意的房子。但是因为是新房，我担心甲醛的问题，所以请了有 cma 检测资质的人检测。 检测的时间是 4 月， 春天的时候， 温度 22 度左右， 密闭门窗时间还特意延长到 24 小时，尽管没有把所有的柜子门和抽屉打开。在检测报告出来之前我告诉自己，如果检测结果达标，我就放心，因为我密闭时间是超过标准要求的时间的，即使是刚刚合格， 比如 0.08 ， 我都接受。\r\n\r\n但是，检测结果是 0.086 。我本来觉得只超了 0.006 ，可以忽略不计， 但是接着我又考虑到即将到来的夏天， 温度会升高，我查了一些资料显示，高温高湿会让甲醛加速释放， 很有可能到夏天的时候， 室内甲醛的浓度，会达到 0.2 以上。于是我又陷入了困境。租得话， 我担心夏天高温导致的更高的风险；因为这个不租的话， 我又不甘心，不死心。\r\n\r\n以上例子中的困境，我感觉在我的人生中经常出现。有点心累， 是不是我的认知模式有啥问题？", "content_rendered": "<p>举个例子，我最近准备租房子，花了很多时间，看了 20 多套房子， 终于找到一套满意的房子。但是因为是新房，我担心甲醛的问题，所以请了有 cma 检测资质的人检测。 检测的时间是 4 月， 春天的时候， 温度 22 度左右， 密闭门窗时间还特意延长到 24 小时，尽管没有把所有的柜子门和抽屉打开。在检测报告出来之前我告诉自己，如果检测结果达标，我就放心，因为我密闭时间是超过标准要求的时间的，即使是刚刚合格， 比如 0.08 ， 我都接受。</p>\n<p>但是，检测结果是 0.086 。我本来觉得只超了 0.006 ，可以忽略不计， 但是接着我又考虑到即将到来的夏天， 温度会升高，我查了一些资料显示，高温高湿会让甲醛加速释放， 很有可能到夏天的时候， 室内甲醛的浓度，会达到 0.2 以上。于是我又陷入了困境。租得话， 我担心夏天高温导致的更高的风险；因为这个不租的话， 我又不甘心，不死心。</p>\n<p>以上例子中的困境，我感觉在我的人生中经常出现。有点心累， 是不是我的认知模式有啥问题？</p>\n", "last_modified": 1776566610, "replies": 41, "id": 1206941}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/f854/54e8/422_large.png?m=1605263518", "name": "browsers", "avatar_normal": "https://cdn.v2ex.com/navatar/f854/54e8/422_normal.png?m=1605263518", "title": "浏览器", "url": "https://www.v2ex.com/go/browsers", "topics": 855, "footer": "", "header": "", "title_alternative": "Browsers", "avatar_mini": "https://cdn.v2ex.com/navatar/f854/54e8/422_mini.png?m=1605263518", "stars": 497, "founder_id": 0, "aliases": [], "root": false, "id": 422, "parent_node_name": "software"}, "member": {"id": 362936, "username": "339", "url": "https://www.v2ex.com/u/339", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/e1c7/f147/362936_mini.png?m=1757636887", "avatar_normal": "https://cdn.v2ex.com/avatar/e1c7/f147/362936_normal.png?m=1757636887", "avatar_large": "https://cdn.v2ex.com/avatar/e1c7/f147/362936_large.png?m=1757636887", "avatar_xlarge": "https://cdn.v2ex.com/avatar/e1c7/f147/362936_xlarge.png?m=1757636887", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/e1c7/f147/362936_xxlarge.png?m=1757636887", "created": 1542120503, "last_modified": 1757636887, "pro": 0}, "last_reply_by": "MoRanjiang", "last_touched": 1776579401, "title": "你会愿意为浏览器付费吗？", "url": "https://www.v2ex.com/t/1206919", "created