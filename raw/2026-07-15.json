[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11243, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2395, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 622110, "username": "xiaowowo", "url": "https://www.v2ex.com/u/xiaowowo", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/9883/783b/622110_mini.png?m=1784013174", "avatar_normal": "https://cdn.v2ex.com/avatar/9883/783b/622110_normal.png?m=1784013174", "avatar_large": "https://cdn.v2ex.com/avatar/9883/783b/622110_large.png?m=1784013174", "avatar_xlarge": "https://cdn.v2ex.com/avatar/9883/783b/622110_xlarge.png?m=1784013174", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/9883/783b/622110_xxlarge.png?m=1784013174", "created": 1680440870, "last_modified": 1784013174, "pro": 0}, "last_reply_by": "eventlooped", "last_touched": 1784089915, "title": "中医税？", "url": "https://www.v2ex.com/t/1227206", "created": 1784013243, "deleted": 0, "content": "这两天感冒发烧，在确诊乙型流感前后，去了两家不同的公立医院。\r\n\r\n第一家医院（尚未确诊乙流）给我开了：\r\n\r\n* 布洛芬（退烧）约 40 元；\r\n* 一盒中成药，约 90 元。\r\n\r\n第二天症状加重，我去了另一家医院，用试纸确诊乙型流感。医生开的药是：\r\n\r\n* 布洛芬约 40 元；\r\n* 奥司他韦约 14 元（抗病毒治疗）；\r\n* 头孢约 6 元；\r\n* 一盒中成药约 48 元。\r\n\r\n整个过程里，我按医嘱服用了奥司他韦、布洛芬等药物，但两盒中成药一粒都没吃，现在已经痊愈。\r\n\r\n这让我想起以前去医院看病，好像无论是感冒、发烧还是其他一些常见疾病，处方里经常都会搭配一盒价格并不便宜的中成药。\r\n\r\n我并不是想讨论中医或中药本身，而是想讨论一种现象：**为什么中成药几乎成了很多处方里的“标配”？**\r\n\r\n更让我疑惑的是，两家医院开的中成药还完全不是同一种。如果它们都是必需的辅助治疗，为什么不同医院开的品种差别这么大？如果不是必需，为什么又几乎每次都会出现在处方里？\r\n\r\n想请教大家，这到底是医生个人的用药习惯、医院的诊疗要求，还是存在其他原因？大家有没有遇到过类似的情况？", "content_rendered": "<p>这两天感冒发烧，在确诊乙型流感前后，去了两家不同的公立医院。</p>\n<p>第一家医院（尚未确诊乙流）给我开了：</p>\n<ul>\n<li>布洛芬（退烧）约 40 元；</li>\n<li>一盒中成药，约 90 元。</li>\n</ul>\n<p>第二天症状加重，我去了另一家医院，用试纸确诊乙型流感。医生开的药是：</p>\n<ul>\n<li>布洛芬约 40 元；</li>\n<li>奥司他韦约 14 元（抗病毒治疗）；</li>\n<li>头孢约 6 元；</li>\n<li>一盒中成药约 48 元。</li>\n</ul>\n<p>整个过程里，我按医嘱服用了奥司他韦、布洛芬等药物，但两盒中成药一粒都没吃，现在已经痊愈。</p>\n<p>这让我想起以前去医院看病，好像无论是感冒、发烧还是其他一些常见疾病，处方里经常都会搭配一盒价格并不便宜的中成药。</p>\n<p>我并不是想讨论中医或中药本身，而是想讨论一种现象：<strong>为什么中成药几乎成了很多处方里的“标配”？</strong></p>\n<p>更让我疑惑的是，两家医院开的中成药还完全不是同一种。如果它们都是必需的辅助治疗，为什么不同医院开的品种差别这么大？如果不是必需，为什么又几乎每次都会出现在处方里？</p>\n<p>想请教大家，这到底是医生个人的用药习惯、医院的诊疗要求，还是存在其他原因？大家有没有遇到过类似的情况？</p>\n", "last_modified": 1784077182, "replies": 100, "id": 1227206}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 72048, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9728, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 580005, "username": "WorkerMatt", "url": "https://www.v2ex.com/u/WorkerMatt", "website": "castaly.ai", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/e82e/654e/580005_mini.png?m=1784006306", "avatar_normal": "https://cdn.v2ex.com/avatar/e82e/654e/580005_normal.png?m=1784006306", "avatar_large": "https://cdn.v2ex.com/avatar/e82e/654e/580005_large.png?m=1784006306", "avatar_xlarge": "https://cdn.v2ex.com/avatar/e82e/654e/580005_xlarge.png?m=1784006306", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/e82e/654e/580005_xxlarge.png?m=1784006306", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/e82e/654e/580005_xxxlarge.png?m=1784006306", "created": 1651678337, "last_modified": 1784006306, "pro": 0}, "last_reply_by": "xiaomushen", "last_touched": 1784088974, "title": "大家用中转站不怕被掺水么, 信息安全怎么保障", "url": "https://www.v2ex.com/t/1227175", "created": 1784006345, "deleted": 0, "content": "虽然我自己也有在用，但不知道大家是怎么想的", "content_rendered": "<p>虽然我自己也有在用，但不知道大家是怎么想的</p>\n", "last_modified": 1784006345, "replies": 78, "id": 1227175}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/ccb0/9896/755_large.png?m=1402729057", "name": "libido", "avatar_normal": "https://cdn.v2ex.com/navatar/ccb0/9896/755_normal.png?m=1402729057", "title": "情感问题", "url": "https://www.v2ex.com/go/libido", "topics": 1769, "footer": "", "header": "有些事情不必一直憋在心里，说出来让大家听听，然后一起想办法吧。", "title_alternative": "Libido", "avatar_mini": "https://cdn.v2ex.com/navatar/ccb0/9896/755_mini.png?m=1402729057", "stars": 932, "founder_id": 0, "aliases": [], "root": false, "id": 755, "parent_node_name": "life"}, "member": {"id": 781413, "username": "sorakaite", "url": "https://www.v2ex.com/u/sorakaite", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/84db/6105/781413_mini.png?m=1773978461", "avatar_normal": "https://cdn.v2ex.com/avatar/84db/6105/781413_normal.png?m=1773978461", "avatar_large": "https://cdn.v2ex.com/avatar/84db/6105/781413_large.png?m=1773978461", "avatar_xlarge": "https://cdn.v2ex.com/avatar/84db/6105/781413_xlarge.png?m=1773978461", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/84db/6105/781413_xxlarge.png?m=1773978461", "created": 1767063738, "last_modified": 1773978461, "pro": 0}, "last_reply_by": "missx", "last_touched": 1784090351, "title": "大佬们，想咨询一下两性生活持久性问题", "url": "https://www.v2ex.com/t/1227385", "created": 1784082114, "deleted": 0, "content": "感觉自己特别敏感，第一次进入抽动不到 5 分钟就有想射的感觉，后面想着不动通过亲吻之类的转移一下注意力，或者抽出来冷静一会儿会好些，但是发现还是不行，再次进入的时候感觉来的还是很快\r\n\r\n第二次的话，硬度比第一次稍差点，但是时间会久一些，差不多十几分钟\r\n想问下 V 友们这个情况正常吗以及有没有方法改变一下现状，之前看网上都是半小时起步，整的有点自卑了", "content_rendered": "<p>感觉自己特别敏感，第一次进入抽动不到 5 分钟就有想射的感觉，后面想着不动通过亲吻之类的转移一下注意力，或者抽出来冷静一会儿会好些，但是发现还是不行，再次进入的时候感觉来的还是很快</p>\n<p>第二次的话，硬度比第一次稍差点，但是时间会久一些，差不多十几分钟\n想问下 V 友们这个情况正常吗以及有没有方法改变一下现状，之前看网上都是半小时起步，整的有点自卑了</p>\n", "last_modified": 1784082460, "replies": 73, "id": 1227385}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239928, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4496, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 111002, "username": "Awes0me", "url": "https://www.v2ex.com/u/Awes0me", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_mini.png?m=1767670953", "avatar_normal": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_normal.png?m=1767670953", "avatar_large": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_large.png?m=1767670953", "avatar_xlarge": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_xlarge.png?m=1767670953", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_xxlarge.png?m=1767670953", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/9ad2/67ac/111002_xxxlarge.png?m=1767670953", "created": 1429013905, "last_modified": 1767670953, "pro": 0}, "last_reply_by": "cptike", "last_touched": 1784089460, "title": "有没有便宜点的宽带，一个月 139 真的受不了了", "url": "https://www.v2ex.com/t/1227367", "created": 1784079209, "deleted": 0, "content": "之前为了公网 ip 一直在花 139 用电信的宽带，都 10 年了，现在有更好的方案，没必要续费了，想换便宜点的，尝试跟线上客服要折扣，一点都不挽留我，直接就说好啊给你登记安排退网。。。\r\n\r\n坐标深圳", "content_rendered": "之前为了公网 ip 一直在花 139 用电信的宽带，都 10 年了，现在有更好的方案，没必要续费了，想换便宜点的，尝试跟线上客服要折扣，一点都不挽留我，直接就说好啊给你登记安排退网。。。<br /><br />坐标深圳", "last_modified": 1784079209, "replies": 64, "id": 1227367}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4288, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3220, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 243182, "username": "SilenceLL", "url": "https://www.v2ex.com/u/SilenceLL", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "想得太多，做的太少", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/4505/454a/243182_mini.png?m=1725416416", "avatar_normal": "https://cdn.v2ex.com/avatar/4505/454a/243182_normal.png?m=1725416416", "avatar_large": "https://cdn.v2ex.com/avatar/4505/454a/243182_large.png?m=1725416416", "avatar_xlarge": "https://cdn.v2ex.com/avatar/4505/454a/243182_xlarge.png?m=1725416416", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/4505/454a/243182_xxlarge.png?m=1725416416", "created": 1500541973, "last_modified": 1725416416, "pro": 0}, "last_reply_by": "LittleControl", "last_touched": 1783440117, "title": "土区续费这是长期 499 了吗", "url": "https://www.v2ex.com/t/1227346", "created": 1784075702, "deleted": 0, "content": "![]( https://i.imgur.com/utJVL3G.jpeg)  ![]( https://i.imgur.com/QRVjY6N.jpeg) \r\n \r\n 看续费价格还是 499 ，涨价后续费了两次了。", "content_rendered": "<p><img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/utJVL3G.jpeg\"/> <img alt=\"\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://i.imgur.com/QRVjY6N.jpeg\"/> </p>\n<p>看续费价格还是 499 ，涨价后续费了两次了。</p>\n", "last_modified": 1784075702, "replies": 59, "id": 1227346}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11243, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2395, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 72899, "username": "BruceXu", "url": "https://www.v2ex.com/u/BruceXu", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/8e46/807f/72899_mini.png?m=1750989185", "avatar_normal": "https://cdn.v2ex.com/avatar/8e46/807f/72899_normal.png?m=1750989185", "avatar_large": "https://cdn.v2ex.com/avatar/8e46/807f/72899_large.png?m=1750989185", "created": 1409804831, "last_modified": 1750989185, "pro": 0}, "last_reply_by": "OnceUponATime", "last_touched": 1784088441, "title": "关于去医院看病开中成药问题,大家是怎么解决的", "url": "https://www.v2ex.com/t/1227347", "created": 1784075916, "deleted": 0, "content": "回忆了下最近几次社区医院和三甲医院的经历,确实最后都会带一个中成药,价格还不便宜.\r\n因为都是很难喝的口服液之类,放着放着就过期扔掉了.\r\n\r\n看了论坛里相关的讨论主要有以下几种做法:\r\n\r\n1. ### 带上处方,全部在外面买.\r\n\r\n\r\n   优点:不会直面医生,适合社恐.价格可能更加便宜.\r\n   \r\n   缺点:美团买,不能用医保.线下药店买,又贵.\r\n\r\n2. ### 开药时跟医生说不要中成药.\r\n\r\n   优点:简单直接.\r\n   \r\n   缺点:可能医生不高兴?需要编理由?\r\n   \r\n3. ### 拿完药退掉中成药.\r\n    \r\n   优点:达成目的,还不用直面医生.\r\n   \r\n   缺点:有些医院可能不支持部分退.", "content_rendered": "<p>回忆了下最近几次社区医院和三甲医院的经历,确实最后都会带一个中成药,价格还不便宜.\n因为都是很难喝的口服液之类,放着放着就过期扔掉了.</p>\n<p>看了论坛里相关的讨论主要有以下几种做法:</p>\n<ol>\n<li>\n<h3>带上处方,全部在外面买.</h3>\n<p>优点:不会直面医生,适合社恐.价格可能更加便宜.</p>\n<p>缺点:美团买,不能用医保.线下药店买,又贵.</p>\n</li>\n<li>\n<h3>开药时跟医生说不要中成药.</h3>\n<p>优点:简单直接.</p>\n<p>缺点:可能医生不高兴?需要编理由?</p>\n</li>\n<li>\n<h3>拿完药退掉中成药.</h3>\n<p>优点:达成目的,还不用直面医生.</p>\n<p>缺点:有些医院可能不支持部分退.</p>\n</li>\n</ol>\n", "last_modified": 1784075916, "replies": 49, "id": 1227347}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_large.png?m=1751736785", "name": "openai", "avatar_normal": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_normal.png?m=1751736785", "title": "OpenAI", "url": "https://www.v2ex.com/go/openai", "topics": 4288, "footer": "", "header": "关于 OpenAI 旗下产品 GPT，DALL·E，和 ChatGPT 的讨论。请不要在 V2EX 的回复中粘贴复制来自 AI 生成的文本。", "title_alternative": "OpenAI", "avatar_mini": "https://cdn.v2ex.com/navatar/fd2c/5e46/1135_mini.png?m=1751736785", "stars": 3220, "founder_id": 0, "aliases": [], "root": false, "id": 1135, "parent_node_name": "geek"}, "member": {"id": 828618, "username": "GushAPI", "url": "https://www.v2ex.com/u/GushAPI", "website": "gush.cc", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "api.gush.cc", "avatar_mini": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_mini.png?m=1784007874", "avatar_normal": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_normal.png?m=1784007874", "avatar_large": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_large.png?m=1784007874", "avatar_xlarge": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_xlarge.png?m=1784007874", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_xxlarge.png?m=1784007874", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/23d2/ec0c/828618_xxxlarge.png?m=1784007874", "created": 1783905063, "last_modified": 1784007874, "pro": 0}, "last_reply_by": "mency89", "last_touched": 1784046892, "title": "GPT 今天是不是特别慢？和最近取消 5 小时限额有关吗？", "url": "https://www.v2ex.com/t/1227176", "created": 1784006835, "deleted": 0, "content": "今天用 GPT 感觉特别慢，经常要等很久才开始响应，生成过程中也会卡顿。\r\n\r\n一开始我还以为是自己的中转服务器出了问题，排查了一圈后感觉又不太像。最近看到有人说 OpenAI 取消了 5 小时限额，不知道是不是因此使用人数或请求量增加，导致这两天整体变慢了？这个消息是否准确我也不确定，想来问问大家。\r\n\r\n大家今天使用时有遇到类似情况吗？", "content_rendered": "<p>今天用 GPT 感觉特别慢，经常要等很久才开始响应，生成过程中也会卡顿。</p>\n<p>一开始我还以为是自己的中转服务器出了问题，排查了一圈后感觉又不太像。最近看到有人说 OpenAI 取消了 5 小时限额，不知道是不是因此使用人数或请求量增加，导致这两天整体变慢了？这个消息是否准确我也不确定，想来问问大家。</p>\n<p>大家今天使用时有遇到类似情况吗？</p>\n", "last_modified": 1784006835, "replies": 47, "id": 1227176}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23849, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3709, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 136189, "username": "andforce", "url": "https://www.v2ex.com/u/andforce", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_mini.png?m=1774924642", "avatar_normal": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_normal.png?m=1774924642", "avatar_large": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_large.png?m=1774924642", "avatar_xlarge": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_xlarge.png?m=1774924642", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_xxlarge.png?m=1774924642", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/5fd5/33c7/136189_xxxlarge.png?m=1774924642", "created": 1441017989, "last_modified": 1774924642, "pro": 0}, "last_reply_by": "crysislinux", "last_touched": 1784090284, "title": "同时干超过 3 个，有点吃力", "url": "https://www.v2ex.com/t/1227341", "created": 1784074256, "deleted": 0, "content": "现在主力工作场景是使用 Chatgpt 手机端，远程连接电脑，进行开发\n\n最多并行开发 5 个项目，其实 2 个项目比较舒服，3 个项目就点吃力，达到 5 个项目同时开发，有点手忙脚乱\n\n\n兄弟们同时干几个？", "content_rendered": "现在主力工作场景是使用 Chatgpt 手机端，远程连接电脑，进行开发<br /><br />最多并行开发 5 个项目，其实 2 个项目比较舒服，3 个项目就点吃力，达到 5 个项目同时开发，有点手忙脚乱<br /><br /><br />兄弟们同时干几个？", "last_modified": 1784075929, "replies": 46, "id": 1227341}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11243, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2395, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 634862, "username": "z1111h", "url": "https://www.v2ex.com/u/z1111h", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_mini.png?m=1784077896", "avatar_normal": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_normal.png?m=1784077896", "avatar_large": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_large.png?m=1784077896", "avatar_xlarge": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_xlarge.png?m=1784077896", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_xxlarge.png?m=1784077896", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/c0ab/3526/634862_xxxlarge.png?m=1784077896", "created": 1687232943, "last_modified": 1784077896, "pro": 0}, "last_reply_by": "BigShot404", "last_touched": 1784088872, "title": "蚌埠住了，国内痔疮药都 tm 是中成药，艹", "url": "https://www.v2ex.com/t/1227357", "created": 1784078072, "deleted": 0, "content": "最近疯狂加班，坐的时间太久，痔疮犯了\r\n菊花跳跃着疼\r\n一边疼还要一边处理工作的一堆事情\r\n心情十分烦躁\r\n\r\n火速购买痔疮药\r\n马应龙痔疮栓和痔疮膏用了三天了\r\n该疼还疼\r\n想换一种见效快的药顶过这几天\r\n搜了半天发现国内痔疮药都是中成药\r\n\r\n突然想到老外痔疮犯了总不用中成药\r\n问了一下豆包，国内外痔疮用药的区别\r\nhttps://www.doubao.com/thread/x6ebbbe06382b8a6eac135a09b5697716\r\n国外：纯西药 / 植物提取物，成分单一明确，机制清晰（麻醉、抗炎、收缩血管）。\r\n国内：中药复方为主、西药为辅；中药多含麝香、牛黄、冰片、地榆、槐花等，强调辨证施治、整体调理。\r\n\r\n艹！\r\n\r\n国内之前只有一款含利多卡因的太宁复方角菜酸酯栓停产了\r\n现在买痔疮药国内买要走全球购\r\n起码周日才能到了\r\n多囤几盒\r\n无语住了 \r\n唉\r\n再次艹", "content_rendered": "最近疯狂加班，坐的时间太久，痔疮犯了<br />菊花跳跃着疼<br />一边疼还要一边处理工作的一堆事情<br />心情十分烦躁<br /><br />火速购买痔疮药<br />马应龙痔疮栓和痔疮膏用了三天了<br />该疼还疼<br />想换一种见效快的药顶过这几天<br />搜了半天发现国内痔疮药都是中成药<br /><br />突然想到老外痔疮犯了总不用中成药<br />问了一下豆包，国内外痔疮用药的区别<br /><a target=\"_blank\" href=\"https://www.doubao.com/thread/x6ebbbe06382b8a6eac135a09b5697716\" rel=\"nofollow noopener\">https://www.doubao.com/thread/x6ebbbe06382b8a6eac135a09b5697716</a><br />国外：纯西药 / 植物提取物，成分单一明确，机制清晰（麻醉、抗炎、收缩血管）。<br />国内：中药复方为主、西药为辅；中药多含麝香、牛黄、冰片、地榆、槐花等，强调辨证施治、整体调理。<br /><br />艹！<br /><br />国内之前只有一款含利多卡因的太宁复方角菜酸酯栓停产了<br />现在买痔疮药国内买要走全球购<br />起码周日才能到了<br />多囤几盒<br />无语住了 <br />唉<br />再次艹", "last_modified": 1784078072, "replies": 46, "id": 1227357}]