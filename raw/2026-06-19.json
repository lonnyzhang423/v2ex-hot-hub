[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/eaae/339c/653_large.png?m=1678403810", "name": "vps", "avatar_normal": "https://cdn.v2ex.com/navatar/eaae/339c/653_normal.png?m=1678403810", "title": "VPS", "url": "https://www.v2ex.com/go/vps", "topics": 8175, "footer": "", "header": "关于 VPS 购买和使用的讨论。", "title_alternative": "VPS", "avatar_mini": "https://cdn.v2ex.com/navatar/eaae/339c/653_mini.png?m=1678403810", "stars": 3960, "founder_id": 0, "aliases": [], "root": false, "id": 653, "parent_node_name": "cloud"}, "member": {"id": 95308, "username": "wdv2ly", "url": "https://www.v2ex.com/u/wdv2ly", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/870d/a5a0/95308_mini.png?m=1541413811", "avatar_normal": "https://cdn.v2ex.com/avatar/870d/a5a0/95308_normal.png?m=1541413811", "avatar_large": "https://cdn.v2ex.com/avatar/870d/a5a0/95308_large.png?m=1541413811", "created": 1422855221, "last_modified": 1541413811, "pro": 0}, "last_reply_by": "Solix", "last_touched": 1781864389, "title": "端午节快乐！求推荐高质量 VPS 线路", "url": "https://www.v2ex.com/t/1221493", "created": 1781836932, "deleted": 0, "content": "楼主联通宽带，以前用过几年 dmit ，稳定性可以，速度感觉一般。后来蹬了一年 clawcloud ，速度起飞，稳定性拉胯到底，这个月底要跑路了，得赶紧换一家，不想折腾了，\n\n预算 3K 每年，如果特别好也可以酌情加一些。机器要稳定（速度，可访问性，ip 质量等各方面），位置最好是新加坡（现在 ip 所在地，怕突然换地区 cc 之类的被风控），次选香港日本等。\n\n可以接受推广链接，但希望对得起前面的标准，谢谢各位~", "content_rendered": "<p>楼主联通宽带，以前用过几年 dmit ，稳定性可以，速度感觉一般。后来蹬了一年 clawcloud ，速度起飞，稳定性拉胯到底，这个月底要跑路了，得赶紧换一家，不想折腾了，</p>\n<p>预算 3K 每年，如果特别好也可以酌情加一些。机器要稳定（速度，可访问性，ip 质量等各方面），位置最好是新加坡（现在 ip 所在地，怕突然换地区 cc 之类的被风控），次选香港日本等。</p>\n<p>可以接受推广链接，但希望对得起前面的标准，谢谢各位~</p>\n", "last_modified": 1781836932, "replies": 41, "id": 1221493}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/70ef/df2e/17_large.png?m=1660301119", "name": "create", "avatar_normal": "https://cdn.v2ex.com/navatar/70ef/df2e/17_normal.png?m=1660301119", "title": "分享创造", "url": "https://www.v2ex.com/go/create", "topics": 34004, "footer": "", "header": "欢迎你在这里发布自己的最新作品！", "title_alternative": "Create", "avatar_mini": "https://cdn.v2ex.com/navatar/70ef/df2e/17_mini.png?m=1660301119", "stars": 6084, "founder_id": 0, "aliases": [], "root": false, "id": 17, "parent_node_name": "geek"}, "member": {"id": 816989, "username": "k114413450", "url": "https://www.v2ex.com/u/k114413450", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/dc319d5d344f58dba219fbac4c38d839?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/dc319d5d344f58dba219fbac4c38d839?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/dc319d5d344f58dba219fbac4c38d839?s=73&d=retro", "created": 1779871235, "last_modified": 1779873814, "pro": 0}, "last_reply_by": "unused", "last_touched": 1781865919, "title": "写了个德扑单挑 GTO 机器人，感觉自己已经玩不过它了，求大佬来军训", "url": "https://www.v2ex.com/t/1221491", "created": 1781835834, "deleted": 0, "content": "最近闲着没事，自己动手训练了一个网页版的单挑德州扑克机器人（叫它 博弈姬 吧）。\r\n\r\n本来想写着自己练牌用的，结果现在调教得有点过头，我自己打了几手，目前已经送掉 120+ BB 了……😅\r\n\r\n今天摸鱼的时候突然想看看社区里隐藏的德扑大佬多不多，发出来给大家解解闷。免注册即玩，每手自动补满 100BB ，但累计盈亏会一直记着。\r\n\r\n有无聊或者手痒的兄弟去帮我“军训”一下它，看看它到底有没有漏洞？\r\n试玩地址： https://heads-up-poker-gto.onrender.com/", "content_rendered": "最近闲着没事，自己动手训练了一个网页版的单挑德州扑克机器人（叫它 博弈姬 吧）。<br /><br />本来想写着自己练牌用的，结果现在调教得有点过头，我自己打了几手，目前已经送掉 120+ BB 了……😅<br /><br />今天摸鱼的时候突然想看看社区里隐藏的德扑大佬多不多，发出来给大家解解闷。免注册即玩，每手自动补满 100BB ，但累计盈亏会一直记着。<br /><br />有无聊或者手痒的兄弟去帮我“军训”一下它，看看它到底有没有漏洞？<br />试玩地址： <a target=\"_blank\" href=\"https://heads-up-poker-gto.onrender.com/\" rel=\"nofollow noopener\">https://heads-up-poker-gto.onrender.com/</a>", "last_modified": 1781848604, "replies": 35, "id": 1221491}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23642, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3696, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 330317, "username": "qtxxm", "url": "https://www.v2ex.com/u/qtxxm", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/0ff395c144b1e701d19179c679d92494?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/0ff395c144b1e701d19179c679d92494?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/0ff395c144b1e701d19179c679d92494?s=73&d=retro", "created": 1532053818, "last_modified": 1739514251, "pro": 0}, "last_reply_by": "Cu635", "last_touched": 1781867211, "title": "年近 40，继续私企国企怎么选", "url": "https://www.v2ex.com/t/1221502", "created": 1781839217, "deleted": 0, "content": "80 尾的，现在在一个私企公司，目前 3w x 12 ，公司业务属于金融擦边性质，年初已经感觉到组织变化，已经没有什么上升空间了，被当做工具人使用，PUA 文化严重，价值观严重不一致，心累的一匹，一天工作强度在 10-11 小时。现在有个收入砍半的国企岗位，工作内容差不多算技术负责人，对接内部需求和外部服务商，朝九晚五，工作强度不大，业务相对稳定。各位怎么看？不想躺平，但是缺失了目标的感觉，近半年代码都是 ai 写，跑通了除需求之外的 方案设计、自动化单元测试、简单集成场景测试、自动化 cr 全流程。娃马上初中了，感觉整个小学阶段就没管过娃，有点愧疚", "content_rendered": "80 尾的，现在在一个私企公司，目前 3w x 12 ，公司业务属于金融擦边性质，年初已经感觉到组织变化，已经没有什么上升空间了，被当做工具人使用，PUA 文化严重，价值观严重不一致，心累的一匹，一天工作强度在 10-11 小时。现在有个收入砍半的国企岗位，工作内容差不多算技术负责人，对接内部需求和外部服务商，朝九晚五，工作强度不大，业务相对稳定。各位怎么看？不想躺平，但是缺失了目标的感觉，近半年代码都是 ai 写，跑通了除需求之外的 方案设计、自动化单元测试、简单集成场景测试、自动化 cr 全流程。娃马上初中了，感觉整个小学阶段就没管过娃，有点愧疚", "last_modified": 1781839217, "replies": 26, "id": 1221502}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3cef/96dc/949_large.png?m=1730363795", "name": "nas", "avatar_normal": "https://cdn.v2ex.com/navatar/3cef/96dc/949_normal.png?m=1730363795", "title": "NAS", "url": "https://www.v2ex.com/go/nas", "topics": 3240, "footer": "", "header": "关于网络存储设备的讨论", "title_alternative": "NAS", "avatar_mini": "https://cdn.v2ex.com/navatar/3cef/96dc/949_mini.png?m=1730363795", "stars": 3072, "founder_id": 0, "aliases": [], "root": false, "id": 949, "parent_node_name": "hardware"}, "member": {"id": 441003, "username": "ebushicao", "url": "https://www.v2ex.com/u/ebushicao", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/7bad/8a20/441003_mini.png?m=1716075803", "avatar_normal": "https://cdn.v2ex.com/avatar/7bad/8a20/441003_normal.png?m=1716075803", "avatar_large": "https://cdn.v2ex.com/avatar/7bad/8a20/441003_large.png?m=1716075803", "avatar_xlarge": "https://cdn.v2ex.com/avatar/7bad/8a20/441003_xlarge.png?m=1716075803", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/7bad/8a20/441003_xxlarge.png?m=1716075803", "created": 1568278099, "last_modified": 1716075803, "pro": 0}, "last_reply_by": "ebushicao", "last_touched": 1781141615, "title": "停电之后瞬间又来电我的 NAS 坏了 3 块硬盘，还能抢救吗", "url": "https://www.v2ex.com/t/1221483", "created": 1781832815, "deleted": 0, "content": "硬盘已经过保了，数据倒是不重要，因为插上那 3 块硬盘的任意一块都不能开机，所以我怀疑是硬盘短路了，这种情况还能抢救一下吗？\r\n\r\n现在硬盘价格涨的太多了，换硬盘小几千就没了。", "content_rendered": "硬盘已经过保了，数据倒是不重要，因为插上那 3 块硬盘的任意一块都不能开机，所以我怀疑是硬盘短路了，这种情况还能抢救一下吗？<br /><br />现在硬盘价格涨的太多了，换硬盘小几千就没了。", "last_modified": 1781832894, "replies": 25, "id": 1221483}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_large.png?m=1691642161", "name": "bb", "avatar_normal": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_normal.png?m=1691642161", "title": "宽带症候群", "url": "https://www.v2ex.com/go/bb", "topics": 18824, "footer": "", "header": "网速很重要。比快更快。", "title_alternative": "Broadband Symptom Complex", "avatar_mini": "https://cdn.v2ex.com/navatar/a3c6/5c29/108_mini.png?m=1691642161", "stars": 8263, "founder_id": 0, "aliases": [], "root": false, "id": 108, "parent_node_name": "geek"}, "member": {"id": 289068, "username": "desususula", "url": "https://w