[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1fc2/1400/864_large.png?m=1778522847", "name": "promotions", "avatar_normal": "https://cdn.v2ex.com/navatar/1fc2/1400/864_normal.png?m=1778522847", "title": "推广", "url": "https://www.v2ex.com/go/promotions", "topics": 12740, "footer": "", "header": "来自厂商的推广活动类主题，会被归类到这个节点。希望有情怀的产商们在发布推广内容时，主动选择发布到本节点下。点击 <a href=\"/help/node\">这里</a> 阅读 V2EX 的节点使用指南。", "title_alternative": "Promotions", "avatar_mini": "https://cdn.v2ex.com/navatar/1fc2/1400/864_mini.png?m=1778522847", "stars": 1375, "founder_id": 0, "aliases": [], "root": false, "id": 864, "parent_node_name": ""}, "member": {"id": 775347, "username": "duanyongcheng77", "url": "https://www.v2ex.com/u/duanyongcheng77", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/9d4d2488bc788860243dd8962f172c01?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/9d4d2488bc788860243dd8962f172c01?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/9d4d2488bc788860243dd8962f172c01?s=73&d=retro", "created": 1763709421, "last_modified": 1763709421, "pro": 0}, "last_reply_by": "Lisa9527", "last_touched": 1783494172, "title": "fcodex 小站开业，评论送 5 额度,倍率低至:0.07x;plus 0.11x;pro 号池倍率 0.25x", "url": "https://www.v2ex.com/t/1225627", "created": 1783415739, "deleted": 0, "content": "[focus codex]( https://fcodex.top)\r\n\r\n留下你的用户名，每个送 5 额度。", "content_rendered": "<p><a href=\"https://fcodex.top\" rel=\"nofollow\">focus codex</a></p>\n<p>留下你的用户名，每个送 5 额度。</p>\n", "last_modified": 1783415838, "replies": 131, "id": 1225627}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1777132346", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1777132346", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 239772, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1777132346", "stars": 4496, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 611298, "username": "owen800q", "url": "https://www.v2ex.com/u/owen800q", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/757883d1d6cab2375e6331cbe648a7a9?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/757883d1d6cab2375e6331cbe648a7a9?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/757883d1d6cab2375e6331cbe648a7a9?s=73&d=retro", "created": 1674799402, "last_modified": 1781702576, "pro": 0}, "last_reply_by": "Moishine", "last_touched": 1783495259, "title": "为什么中央政府不管控国人使用外国大模型？", "url": "https://www.v2ex.com/t/1225718", "created": 1783470647, "deleted": 0, "content": "像 gpt 5.5, claude, 为什么中央政府不管控， 这不是会提高国内大模型使用率吗\r\n而且国内代码全往国外势力送， 工信部不会看不见吧", "content_rendered": "像 gpt 5.5, claude, 为什么中央政府不管控， 这不是会提高国内大模型使用率吗<br />而且国内代码全往国外势力送， 工信部不会看不见吧", "last_modified": 1783474684, "replies": 121, "id": 1225718}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23791, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3706, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 221490, "username": "bush911", "url": "https://www.v2ex.com/u/bush911", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_mini.png?m=1783056570", "avatar_normal": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_normal.png?m=1783056570", "avatar_large": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_large.png?m=1783056570", "avatar_xlarge": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_xlarge.png?m=1783056570", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_xxlarge.png?m=1783056570", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/84d8/34e2/221490_xxxlarge.png?m=1783056570", "created": 1489720667, "last_modified": 1783056570, "pro": 0}, "last_reply_by": "TAKETODAY", "last_touched": 1783493804, "title": "华为天才少年吐槽 DeepSeek 面试不规范，程序员的你怎么看？", "url": "https://www.v2ex.com/t/1225610", "created": 1783412953, "deleted": 0, "content": "如题，OP 非程序员，无从点评。   来源[联合早报]( https://www.zaobao.com.sg/news/china/story20260707-9326742?ref=home-sidebar-china-realtime)\r\n\r\n> 有“华为天才少年”之称的李博杰公开批评中国人工智能公司深度求索（ DeepSeek ）面试流程，相关话题冲上微博热搜。\r\n\r\n>据澎湃新闻报道，李博杰星期一（ 7 月 6 日）称，在通过 DeepSeek 笔试后，半个月不安排面试，其他公司 offer 都已经下来了，经过反复催促才安排面试。去其他公司面试都不需要代码面，但 DeepSeek 仍然需要笔试，前两轮面试都是代码面试。\r\n\r\n>李博杰还说，在二面过程中，面试官评价自己的工作态度不好，甚至无端指控自己抄袭，“代码面试中我有两个屏幕，面试官说我不断在瞟左边的屏幕，说我在抄代码，让我停止抄代码，并说如果我不能证明我没有在抄代码，面试就无法继续下去了。我已经解释了我有两个屏幕，面试官仍然坚信我在抄代码，并用终止面试来威胁我。我感到被严重冒犯，立即决定终止面试。”\r\n\r\n>李博杰认为，从面试官的表现来看，跟自己想象中的 DeepSeek 完全不同，决定终止面试流程。\r\n\r\n>公开资料显示，李博杰 1992 年出生，中国科学技术大学计算机科学博士，中科大少年班、中科大和微软亚洲研究院联合培养的计算机博士。此外，李博杰还是华为第一批天才少年，入职定级 P20——副首席专家，技术专家 A 级，进 2012 实验室，在 2023 年创立 LogenicAI （后升级为 PineAI ），并担任联合创始人、首席科学家。\r\n\r\n>李博杰的贴文尚未得到 DeepSeek 回应。\r\n\r\n>DeepSeek6 月 25 日发布公告广招人才，称当今人类正处于通用人工智能（ AGI ）的前夜，加入 DeepSeek ，可亲历 AGI 的发展进程，坐在时代前排，见证一个新纪元的诞生，“随着技术演进，我们正努力将所有部门的规模扩大至少一倍。”", "content_rendered": "<p>如题，OP 非程序员，无从点评。   来源<a href=\"https://www.zaobao.com.sg/news/china/story20260707-9326742?ref=home-sidebar-china-realtime\" rel=\"nofollow\">联合早报</a></p>\n<blockquote>\n<p>有“华为天才少年”之称的李博杰公开批评中国人工智能公司深度求索（ DeepSeek ）面试流程，相关话题冲上微博热搜。</p>\n</blockquote>\n<blockquote>\n<p>据澎湃新闻报道，李博杰星期一（ 7 月 6 日）称，在通过 DeepSeek 笔试后，半个月不安排面试，其他公司 offer 都已经下来了，经过反复催促才安排面试。去其他公司面试都不需要代码面，但 DeepSeek 仍然需要笔试，前两轮面试都是代码面试。</p>\n</blockquote>\n<blockquote>\n<p>李博杰还说，在二面过程中，面试官评价自己的工作态度不好，甚至无端指控自己抄袭，“代码面试中我有两个屏幕，面试官说我不断在瞟左边的屏幕，说我在抄代码，让我停止抄代码，并说如果我不能证明我没有在抄代码，面试就无法继续下去了。我已经解释了我有两个屏幕，面试官仍然坚信我在抄代码，并用终止面试来威胁我。我感到被严重冒犯，立即决定终止面试。”</p>\n</blockquote>\n<blockquote>\n<p>李博杰认为，从面试官的表现来看，跟自己想象中的 DeepSeek 完全不同，决定终止面试流程。</p>\n</blockquote>\n<blockquote>\n<p>公开资料显示，李博杰 1992 年出生，中国科学技术大学计算机科学博士，中科大少年班、中科大和微软亚洲研究院联合培养的计算机博士。此外，李博杰还是华为第一批天才少年，入职定级 P20——副首席专家，技术专家 A 级，进 2012 实验室，在 2023 年创立 LogenicAI （后升级为 PineAI ），并担任联合创始人、首席科学家。</p>\n</blockquote>\n<blockquote>\n<p>李博杰的贴文尚未得到 DeepSeek 回应。</p>\n</blockquote>\n<blockquote>\n<p>DeepSeek6 月 25 日发布公告广招人才，称当今人类正处于通用人工智能（ AGI ）的前夜，加入 DeepSeek ，可亲历 AGI 的发展进程，坐在时代前排，见证一个新纪元的诞生，“随着技术演进，我们正努力将所有部门的规模扩大至少一倍。”</p>\n</blockquote>\n", "last_modified": 1783474703, "replies": 118, "id": 1225610}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_large.png?m=1650127314", "name": "beijing", "avatar_normal": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_normal.png?m=1650127314", "title": "北京", "url": "https://www.v2ex.com/go/beijing", "topics": 4470, "footer": "", "header": "", "title_alternative": "Beijing", "avatar_mini": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_mini.png?m=1650127314", "stars": 2396, "founder_id": 0, "aliases": [], "root": false, "id": 19, "parent_node_name": "cn"}, "member": {"id": 608993, "username": "apples01", "url": "https://www.v2ex.com/u/apples01", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/6b24e0306cf87bb52cc7ce78b0a9bb85?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/6b24e0306cf87bb52cc7ce78b0a9bb85?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/6b24e0306cf87bb52cc7ce78b0a9bb85?s=73&d=retro", "created": 1672735822, "last_modified": 1719560429, "pro": 0}, "last_reply_by": "euronx", "last_touched": 1783495025, "title": "好奇大家裤衩多久换？", "url": "https://www.v2ex.com/t/1225768", "created": 1783478463, "deleted": 0, "content": "看科普裤衩需要 3 个月换新的，我本人之前没有固定换新时间基本穿烂了换", "content_rendered": "看科普裤衩需要 3 个月换新的，我本人之前没有固定换新时间基本穿烂了换", "last_modified": 1783478463, "replies": 76, "id": 1225768}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 11200, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2388, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 393052, "username": "kksyy", "url": "https://www.v2ex.com/u/kksyy", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_mini.png?m=1690869925", "avatar_normal": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_normal.png?m=1690869925", "avatar_large": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_large.png?m=1690869925", "avatar_xlarge": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_xlarge.png?m=1690869925", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_xxlarge.png?m=1690869925", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/0b3e/262e/393052_xxxlarge.png?m=1690869925", "created": 1552876920, "last_modified": 1690869925, "pro": 0}, "last_reply_by": "pandoudousteve", "last_touched": 1783221553, "title": "人生真是给我开了个玩笑，父亲 59 岁突然查出来癌症晚期", "url": "https://www.v2ex.com/t/1225777", "created": 1783479989, "deleted": 0, "content": "我爸 41 年教龄教师，马上就要退休享福的年纪却突然遭此一劫，我和家人实在难以接受。\r\n\r\n开始只是以为肠胃不舒服，在县医院做了肠胃镜，说是肠胃炎，结果一个多月都没多少好转，我爸又是比较犟的，拖到最后实在腹胀的不舒服了才紧急转去市里的云南肿瘤医院去，直接去了急诊穿刺放腹水，腹水检测出癌细胞（ 6.19 日），6.22 做了加强 CT 腹膜、淋巴结转移，6.24 做了腹腔镜活检，手术中也拍了照片腹腔转移很多，最后病理和免疫组化出来，无法确定原发灶，倾向胃肠来源低分化腺癌。术后到现在，每天腹水都很多，进食很少，本来都决定先按胃肠来源开始化疗先看看效果（原发灶无法确定，得自费），我自己这边也拿着切片到华西来做病理会诊，结果 7.3 的时候肾功能检查肌酐过高，先安装了右侧输尿管支架，到了 7.6 的时候肌酐还是持续升高，重新做了超声，左侧也挤压，昨天 7.7 去装左侧输尿管支架直接装不上，只能做了肾瘘。这下等肾功能恢复，开启化疗的窗口都不知道要何时。医生都说肿瘤恶性程度超预期，发展太快，要家属有心理准备。\r\n\r\n我是独生子，在成都干了 7 前端，目前这家公司算是个小核心开发，爸妈都是事业单位编制在昆明下属县城，马上退休的年纪却要受到这种苦痛。现在行业这个情况，如果放弃工作再有一段空窗，几乎很难了。我很纠结，已经请假了 10 天回昆明陪伴了两周，本来打算是开始治疗后就每周五请假飞回去，周天回来。但我爸这个情况，我现在上班都像是带着一种愧疚感，唉～。现在我妈妈在医院附近租个名宿，每天照顾我爸，我表妹刚大学毕业正好没啥事中，她陪着我妈妈，在昆明也几乎天天都有亲戚来陪同看望。我现在很纠结要不要放弃工作来全陪伴。\r\n\r\n发点牢骚，最近压力实在好大～", "content_rendered": "我爸 41 年教龄教师，马上就要退休享福的年纪却突然遭此一劫，我和家人实在难以接受。<br /><br />开始只是以为肠胃不舒服，在县医院做了肠胃镜，说是肠胃炎，结果一个多月都没多少好转，我爸又是比较犟的，拖到最后实在腹胀的不舒服了才紧急转去市里的云南肿瘤医院去，直接去了急诊穿刺放腹水，腹水检测出癌细胞（ 6.19 日），6.22 做了加强 CT 腹膜、淋巴结转移，6.24 做了腹腔镜活检，手术中也拍了照片腹腔转移很多，最后病理和免疫组化出来，无法确定原发灶，倾向胃肠来源低分化腺癌。术后到现在，每天腹水都很多，进食很少，本来都决定先按胃肠来源开始化疗先看看效果（原发灶无法确定，得自费），我自己这边也拿着切片到华西来做病理会诊，结果 7.3 的时候肾功能检查肌酐过高，先安装了右侧输尿管支架，到了 7.6 的时候肌酐还是持续升高，重新做了超声，左侧也挤压，昨天 7.7 去装左侧输尿管支架直接装不上，只能做了肾瘘。这下等肾功能恢复，开启化疗的窗口都不知道要何时。医生都说肿瘤恶性程度超预期，发展太快，要家属有心理准备。<br /><br />我是独生子，在成都干了 7 前端，目前这家公司算是个小核心开发，爸妈都是事业单位编制在昆明下属县城，马上退休的年纪却要受到这种苦痛。现在行业这个情况，如果放弃工作再有一段空窗，几乎很难了。我很纠结，已经请假了 10 天回昆明陪伴了两周，本来打算是开始治疗后就每周五请假飞回去，周天回来。但我爸这个情况，我现在上班都像是带着一种愧疚感，唉～。现在我妈妈在医院附近租个名宿，每天照顾我爸，我表妹刚大学毕业正好没啥事中，她陪着我妈妈，在昆明也几乎天天都有亲戚来陪同看望。我现在很纠结要不要放弃工作来全陪伴。<br /><br />发点牢骚，最近压力实在好大～", "last_modified": 1783479989, "replies": 75, "id": 1225777}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c74d/97b0/16_large.png?m=1727584731", "name": "share", "avatar_normal": "https://cdn.v2ex.com/navatar/c74d/97b0/16_normal.png?m=1727584731", "title": "分享发现", "url": "https://www.v2ex.com/go/share", "topics": 46550, "footer": "", "header": "分享你看到的好玩的，有信息量的，欢迎从这里获取灵感。", "title_alternative": "Share", "avatar_mini": "https://cdn.v2ex.com/navatar/c74d/97b0/16_mini.png?m=1727584731", "stars": 6331, "founder_id": 0, "aliases": [], "root": false, "id": 16, "parent_node_name": "v2ex"}, "member": {"id": 608161, "username": "Bologna", "url": "https://www.v2ex.com/u/Bologna", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/302a/8be1/608161_mini.png?m=1782701942", "avatar_normal": "https://cdn.v2ex.com/avatar/302a/8be1/608161_normal.png?m=1782701942", "avatar_large": "https://cdn.v2ex.com/avatar/302a/8be1/608161_large.png?m=1782701942", "avatar_xlarge": "https://cdn.v2ex.com/avatar/302a/8be1/608161_xlarge.png?m=1782701942", "created": 1672197235, "last_modified": 1782701942, "pro": 0}, "last_reply_by": "fank99", "last_touched": 1783494360, "title": "如果有家族遗传脱发应尽早使用非那雄胺", "url": "https://www.v2ex.com/t/1225721", "created": 1783472061, "deleted": 0, "content": "我吃了一周，洗手池里基本已经没有头发了，副作用暂时还不明显", "content_rendered": "我吃了一周，洗手池里基本已经没有头发了，副作用暂时还不明显", "last_modified": 1783472061, "replies": 64, "id": 1225721}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23791, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3706, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 319660, "username": "052678", "url": "https://www.v2ex.com/u/052678", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_mini.png?m=1781659028", "avatar_normal": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_normal.png?m=1781659028", "avatar_large": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_large.png?m=1781659028", "avatar_xlarge": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_xlarge.png?m=1781659028", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_xxlarge.png?m=1781659028", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/3824/6f0d/319660_xxxlarge.png?m=1781659028", "created": 1527742385, "last_modified": 1781659028, "pro": 0}, "last_reply_by": "xxss0903", "last_touched": 1783414997, "title": "35 岁了， 一事无成，还没有对象，感到未来人生会继续平庸且孤单", "url": "https://www.v2ex.com/t/1225723", "created": 1783472597, "deleted": 0, "content": "干了几年程序员工作，前段时间被裁了。目前除了有点小存款，差不多 60 万和老家自建农民房一栋就没了。没买车、没买房，无贷款也没对象，几乎没啥朋友。，目前这个年龄和行情，工作真是不好找，所以暂时先躺平做独立开发了（还没做起来），现在这种环境下，不知道该何去何从。", "content_rendered": "<p>干了几年程序员工作，前段时间被裁了。目前除了有点小存款，差不多 60 万和老家自建农民房一栋就没了。没买车、没买房，无贷款也没对象，几乎没啥朋友。，目前这个年龄和行情，工作真是不好找，所以暂时先躺平做独立开发了（还没做起来），现在这种环境下，不知道该何去何从。</p>\n", "last_modified": 1783475074, "replies": 59, "id": 1225723}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_large.png?m=1650127314", "name": "beijing", "avatar_normal": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_normal.png?m=1650127314", "title": "北京", "url": "https://www.v2ex.com/go/beijing", "topics": 4470, "footer": "", "header": "", "title_alternative": "Beijing", "avatar_mini": "https://cdn.v2ex.com/navatar/1f0e/3dad/19_mini.png?m=1650127314", "stars": 2396, "founder_id": 0, "aliases": [], "root": false, "id": 19, "parent_node_name": "cn"}, "member": {"id": 719276, "username": "yuanyao", "url": "https://www.v2ex.com/u/yuanyao", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_mini.png?m=1751848954", "avatar_normal": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_normal.png?m=1751848954", "avatar_large": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_large.png?m=1751848954", "avatar_xlarge": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_xlarge.png?m=1751848954", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_xxlarge.png?m=1751848954", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/b5f6/534f/719276_xxxlarge.png?m=1751848954", "created": 1731139895, "last_modified": 1751848954, "pro": 0}, "last_reply_by": "prosgtsr", "last_touched": 1783495253, "title": "做梦都想买个单人沙发，但是租房😮‍💨", "url": "https://www.v2ex.com/t/1225739", "created": 1783474831, "deleted": 0, "content": "看电影玩游戏，有个单人沙发不知道多舒服，电动调节，带通风追腰。过一段时间就淘宝上找一圈，有几个中意的，但是一想到住的出租房，空间小，搬家不容易携带，顿时高兴不起来了，几次下单后又取消了，有个自己的房子还是很重要的。", "content_rendered": "看电影玩游戏，有个单人沙发不知道多舒服，电动调节，带通风追腰。过一段时间就淘宝上找一圈，有几个中意的，但是一想到住的出租房，空间小，搬家不容易携带，顿时高兴不起来了，几次下单后又取消了，有个自己的房子还是很重要的。", "last_modified": 1783474831, "replies": 53, "id": 1225739}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/3cef/96dc/949_large.png?m=1730363795", "name": "nas", "avatar_normal": "https://cdn.v2ex.com/navatar/3cef/96dc/949_normal.png?m=1730363795", "title": "NAS", "url": "https://www.v2ex.com/go/nas", "topics": 3251, "footer": "", "header": "关于网络存储设备的讨论", "title_alternative": "NAS", "avatar_mini": "https://cdn.v2ex.com/navatar/3cef/96dc/949_mini.png?m=1730363795", "stars": 3079, "founder_id": 0, "aliases": [], "root": false, "id": 949, "parent_node_name": "hardware"}, "member": {"id": 266243, "username": "zeex", "url": "https://www.v2ex.com/u/zeex", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "1", "avatar_mini": "https://cdn.v2ex.com/avatar/c9cb/2424/266243_mini.png?m=1774841026", "avatar_normal": "https://cdn.v2ex.com/avatar/c9cb/2424/266243_normal.png?m=1774841026", "avatar_large": "https://cdn.v2ex.com/avatar/c9cb/2424/266243_large.png?m=1774841026", "avatar_xlarge": "https://cdn.v2ex.com/avatar/c9cb/2424/266243_xlarge.png?m=1774841026", "created": 1510299733, "last_modified": 1774841026, "pro": 0}, "last_reply_by": "mrzx", "last_touched": 1783495034, "title": "硬盘要涨价到啥时候？怎么越涨越高了", "url": "https://www.v2ex.com/t/1225760", "created": 1783477257, "deleted": 0, "content": "想组一台容量大点的 NAS ，主要放家人照片等用\r\n\r\n前年下单了一个绿联的 NAS+两块西数紫盘 8T,750 一块。后面我觉得租房没地方放，给取消订单了\r\n\r\n目前手上只有 2 块酷狼 4T ，还是当时买威联通送的，两块 4T 酷狼+威联通 NAS 主机总共 1.9K 。\r\n\r\n就是感觉空间不太够用了，啥时候能回归正常价", "content_rendered": "<p>想组一台容量大点的 NAS ，主要放家人照片等用</p>\n<p>前年下单了一个绿联的 NAS+两块西数紫盘 8T,750 一块。后面我觉得租房没地方放，给取消订单了</p>\n<p>目前手上只有 2 块酷狼 4T ，还是当时买威联通送的，两块 4T 酷狼+威联通 NAS 主机总共 1.9K 。</p>\n<p>就是感觉空间不太够用了，啥时候能回归正常价</p>\n", "last_modified": 1783477257, "replies": 50, "id": 1225760}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/9232/fe81/953_large.png?m=1530638648", "name": "huawei", "avatar_normal": "https://cdn.v2ex.com/navatar/9232/fe81/953_normal.png?m=1530638648", "title": "华为", "url": "https://www.v2ex.com/go/huawei", "topics": 498, "footer": "", "header": "华为各种设备用户的讨论节点", "title_alternative": "Huawei", "avatar_mini": "https://cdn.v2ex.com/navatar/9232/fe81/953_mini.png?m=1530638648", "stars": 146, "founder_id": 0, "aliases": [], "root": false, "id": 953, "parent_node_name": "hardware"}, "member": {"id": 612740, "username": "gotorion", "url": "https://www.v2ex.com/u/gotorion", "website": "", "twitter": "_gotorion", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/17e3da6de7d84ecc425682183bf15bd5?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/17e3da6de7d84ecc425682183bf15bd5?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/17e3da6de7d84ecc425682183bf15bd5?s=73&d=retro", "created": 1675750957, "last_modified": 1777194503, "pro": 0}, "last_reply_by": "hoky", "last_touched": 1783495300, "title": "改正对部分华为产品的一些偏见", "url": "https://www.v2ex.com/t/1225643", "created": 1783418950, "deleted": 0, "content": "2400 下单了华为的 matepad mini ，体验下来居然非常不错，机身非常薄，鸿蒙也比较丝滑。\r\n我常用的微信读书适配的也可以，最喜欢的是屏幕有个电子书模式，可以调成黑白的。\r\n\r\n我之前使用华为产品大概是 Nova 2S -> 荣耀 V10 -> Mate30 Pro ，都是比较久的产品了。不过华为之前的爱国宣传导致我非常反感，再也没用过。\r\n\r\n现在买 mini 主要是国内其他同行做的太烂了，而且价格合适就入手了，如果经常通勤看书的话还是很推荐的。\r\n\r\n叠个甲：我对华为这个公司继续持保留态度，做的华为相关的项目挺坑的。", "content_rendered": "<p>2400 下单了华为的 matepad mini ，体验下来居然非常不错，机身非常薄，鸿蒙也比较丝滑。\n我常用的微信读书适配的也可以，最喜欢的是屏幕有个电子书模式，可以调成黑白的。</p>\n<p>我之前使用华为产品大概是 Nova 2S -&gt; 荣耀 V10 -&gt; Mate30 Pro ，都是比较久的产品了。不过华为之前的爱国宣传导致我非常反感，再也没用过。</p>\n<p>现在买 mini 主要是国内其他同行做的太烂了，而且价格合适就入手了，如果经常通勤看书的话还是很推荐的。</p>\n<p>叠个甲：我对华为这个公司继续持保留态度，做的华为相关的项目挺坑的。</p>\n", "last_modified": 1783418950, "replies": 49, "id": 1225643}]