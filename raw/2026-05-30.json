[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_large.png?m=1733731195", "name": "programmer", "avatar_normal": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_normal.png?m=1733731195", "title": "程序员", "url": "https://www.v2ex.com/go/programmer", "topics": 71298, "footer": "", "header": "While code monkeys are not eating bananas, they're coding.", "title_alternative": "Programmer", "avatar_mini": "https://cdn.v2ex.com/navatar/94f6/d7e0/300_mini.png?m=1733731195", "stars": 9694, "founder_id": 0, "aliases": [], "root": false, "id": 300, "parent_node_name": "computer"}, "member": {"id": 793169, "username": "liandro", "url": "https://www.v2ex.com/u/liandro", "website": "https://imagetovideoai.net", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "独立开发", "avatar_mini": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_mini.png?m=1776828776", "avatar_normal": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_normal.png?m=1776828776", "avatar_large": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_large.png?m=1776828776", "avatar_xlarge": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_xlarge.png?m=1776828776", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_xxlarge.png?m=1776828776", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/4ab4/ce65/793169_xxxlarge.png?m=1776828776", "created": 1773205837, "last_modified": 1776828776, "pro": 0}, "last_reply_by": "PerFectTime", "last_touched": 1780139148, "title": "AI 把我调教了，从 0 消费，到月消费 1200 元。", "url": "https://www.v2ex.com/t/1216578", "created": 1780065455, "deleted": 0, "content": "AI 把我调教了。\r\n\r\n一路走下来的订阅路程：\r\n\r\n- 最早用国产 Kimi\r\n- 订阅 minimax 2.5 （¥25 还是 ¥35 不记得了）\r\n- 用 opencode （内部跑的也是 minimax ）\r\n- 阿里百炼的订阅（¥20 、¥30 一个业务）\r\n- 咸鱼上买 antigravity 家庭组（¥157/月）+ codex pro （当时 ¥20/月）\r\n- 全面转 codex 20 倍，2 人拼车，相当于 10 倍（¥650/月）\r\n- 加上 claude Pro （¥85 左右一个人）\r\n- 现在：codex 20 倍拼车（¥650/月） + claude Pro 5 倍（¥575/月）\r\n\r\n从今年 3 月中到现在 5 月底，2 个半月，我已经被调教到没有 AI 活不了的地步了。\r\n\r\n看了下统计，近一个月用了 76 亿的 token 。\r\n\r\nAI 的费用越来越高，依赖也越来越高。不知道是好是坏。", "content_rendered": "<p>AI 把我调教了。</p>\n<p>一路走下来的订阅路程：</p>\n<ul>\n<li>最早用国产 Kimi</li>\n<li>订阅 minimax 2.5 （¥25 还是 ¥35 不记得了）</li>\n<li>用 opencode （内部跑的也是 minimax ）</li>\n<li>阿里百炼的订阅（¥20 、¥30 一个业务）</li>\n<li>咸鱼上买 antigravity 家庭组（¥157/月）+ codex pro （当时 ¥20/月）</li>\n<li>全面转 codex 20 倍，2 人拼车，相当于 10 倍（¥650/月）</li>\n<li>加上 claude Pro （¥85 左右一个人）</li>\n<li>现在：codex 20 倍拼车（¥650/月） + claude Pro 5 倍（¥575/月）</li>\n</ul>\n<p>从今年 3 月中到现在 5 月底，2 个半月，我已经被调教到没有 AI 活不了的地步了。</p>\n<p>看了下统计，近一个月用了 76 亿的 token 。</p>\n<p>AI 的费用越来越高，依赖也越来越高。不知道是好是坏。</p>\n", "last_modified": 1780065455, "replies": 46, "id": 1216578}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23470, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3684, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 404308, "username": "tenserG", "url": "https://www.v2ex.com/u/tenserG", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/73ce/5ad8/404308_mini.png?m=1736344573", "avatar_normal": "https://cdn.v2ex.com/avatar/73ce/5ad8/404308_normal.png?m=1736344573", "avatar_large": "https://cdn.v2ex.com/avatar/73ce/5ad8/404308_large.png?m=1736344573", "created": 1555944006, "last_modified": 1736344573, "pro": 0}, "last_reply_by": "Nzelites", "last_touched": 1780133913, "title": "跟北航的弟弟聊了下人生规划，聊完我 emo 了", "url": "https://www.v2ex.com/t/1216587", "created": 1780069121, "deleted": 0, "content": "起因是表弟找我有杭州有没有实习推荐\r\n\r\n我难为情的告诉他，今天是 5.30 ，我正式失业了，也在找工作\r\n\r\n然后反应过来，你才研一，这么早就找实习吗\r\n\r\n他扭扭捏捏，问半天才套出话\r\n\r\n原来他导师管的严，他想趁着导师外出交流，找个实习方便以后找工作\r\n\r\n我叹了口气，告诉他先别做急急国王\r\n\r\n首先，双 95,058400 ，这个背景找份实习不难\r\n\r\n其次，导师就是老板，她要学生发论文，校招也看论文，争取多发几篇\r\n\r\n最后，导师不放人，找实习也没用，如果有时间可以考个雅思，以后用得上\r\n\r\n聊完反而心里堵得慌，要是我有个 985 学历早就找到下家了\r\n\r\n当前 ai 冲击下，编程差距早就被抹平，学历事实上成了硬性区分条件\r\n\r\n大环境是差，但高学历确实不受影响", "content_rendered": "<p>起因是表弟找我有杭州有没有实习推荐</p>\n<p>我难为情的告诉他，今天是 5.30 ，我正式失业了，也在找工作</p>\n<p>然后反应过来，你才研一，这么早就找实习吗</p>\n<p>他扭扭捏捏，问半天才套出话</p>\n<p>原来他导师管的严，他想趁着导师外出交流，找个实习方便以后找工作</p>\n<p>我叹了口气，告诉他先别做急急国王</p>\n<p>首先，双 95,058400 ，这个背景找份实习不难</p>\n<p>其次，导师就是老板，她要学生发论文，校招也看论文，争取多发几篇</p>\n<p>最后，导师不放人，找实习也没用，如果有时间可以考个雅思，以后用得上</p>\n<p>聊完反而心里堵得慌，要是我有个 985 学历早就找到下家了</p>\n<p>当前 ai 冲击下，编程差距早就被抹平，学历事实上成了硬性区分条件</p>\n<p>大环境是差，但高学历确实不受影响</p>\n", "last_modified": 1780069121, "replies": 32, "id": 1216587}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 23470, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3684, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 375913, "username": "loverorser", "url": "https://www.v2ex.com/u/loverorser", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/33e18951a4320f97d537099a3ac14fc7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/33e18951a4320f97d537099a3ac14fc7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/33e18951a4320f97d537099a3ac14fc7?s=73&d=retro", "created": 1546878179, "last_modified": 1691135412, "pro": 0}, "last_reply_by": "ninjaJ", "last_touched": 1780110148, "title": "陪老大加班能否成为嫡系？", "url": "https://www.v2ex.