[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_large.png?m=1768280127", "name": "career", "avatar_normal": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_normal.png?m=1768280127", "title": "职场话题", "url": "https://www.v2ex.com/go/career", "topics": 22750, "footer": "", "header": "这里，我们聊聊那些工作中遇到的开心和不开心的事。", "title_alternative": "Career", "avatar_mini": "https://cdn.v2ex.com/navatar/4ea0/6fbc/770_mini.png?m=1768280127", "stars": 3634, "founder_id": 0, "aliases": [], "root": false, "id": 770, "parent_node_name": ""}, "member": {"id": 605604, "username": "mk3s", "url": "https://www.v2ex.com/u/mk3s", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/5ecfeef930996da63c2ee87ffcde03a7?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/5ecfeef930996da63c2ee87ffcde03a7?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/5ecfeef930996da63c2ee87ffcde03a7?s=73&d=retro", "created": 1670639308, "last_modified": 1766718099, "pro": 0}, "last_reply_by": "ming1455", "last_touched": 1774255145, "title": "死亡螺旋若隐若现", "url": "https://www.v2ex.com/t/1200248", "created": 1774228474, "deleted": 0, "content": "ai 替代人工效率提升->雇员减少公司成本降低->失业导致消费降低->产品买方减少->资本进一步压榨 ai->雇员继续减少->消费继续降低->产品更加卖不出去\r\n----------\r\n上一次 k12 猛砍一刀，教育行业遭重，这次行业波及范围更广，如果大范围失业，先不说社会稳定性，不知道银行能不能抗住大量断贷的情况，不止房贷，理论上包含所有贷。这下考验政府治理能力的时候到了，我们拭目以待（不知道今年暴力机关有没有扩招哦", "content_rendered": "<h2>ai 替代人工效率提升-&gt;雇员减少公司成本降低-&gt;失业导致消费降低-&gt;产品买方减少-&gt;资本进一步压榨 ai-&gt;雇员继续减少-&gt;消费继续降低-&gt;产品更加卖不出去</h2>\n<p>上一次 k12 猛砍一刀，教育行业遭重，这次行业波及范围更广，如果大范围失业，先不说社会稳定性，不知道银行能不能抗住大量断贷的情况，不止房贷，理论上包含所有贷。这下考验政府治理能力的时候到了，我们拭目以待（不知道今年暴力机关有没有扩招哦</p>\n", "last_modified": 1774232910, "replies": 130, "id": 1200248}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/70ef/df2e/17_large.png?m=1660301119", "name": "create", "avatar_normal": "https://cdn.v2ex.com/navatar/70ef/df2e/17_normal.png?m=1660301119"