[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1751718333", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1751718333", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 238191, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1751718333", "stars": 4481, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 638855, "username": "mode171", "url": "https://www.v2ex.com/u/mode171", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "深圳", "tagline": "生活是一部电影； 死亡是一张照片。", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_mini.png?m=1766369444", "avatar_normal": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_normal.png?m=1766369444", "avatar_large": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_large.png?m=1766369444", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xlarge.png?m=1766369444", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxlarge.png?m=1766369444", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxxlarge.png?m=1766369444", "created": 1689515364, "last_modified": 1766369444, "pro": 0}, "last_reply_by": "kemistep", "last_touched": 1776333795, "title": "有人说 [外包] 太难听了，很土，有没有什么别的、更好听的名称。", "url": "https://www.v2ex.com/t/1206278", "created": 1776308257, "deleted": 0, "content": "V 站外包大佬的数量，算是个人已知最多的站了。\r\n***\r\n外包这个名称有没有什么别的、更好听的名称。征求一下", "content_rendered": "<p>V 站外包大佬的数量，算是个人已知最多的站了。</p>\n<hr/>\n<p>外包这个名称有没有什么别的、更好听的名称。征求一下</p>\n", "last_modified": 1776308257, "replies": 198, "id": 1206278}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10615, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2277, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 673788, "username": "6866vpuu", "url": "https://www.v2ex.com/u/6866vpuu", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=73&d=retro", "created": 1706494270, "last_modified": 1758611434, "pro": 0}, "last_reply_by": "littleG", "last_touched": 1776333595, "title": "关于父母的托举", "url": "https://www.v2ex.com/t/1206165", "created": 1776252779, "deleted": 0, "content": "本人男 28 岁。已婚。有个 1 岁多的孩子。\r\n\r\n出身农村，15 年考了个大专。上大学后学费生活费都是自己赚 ，父母没提供过什么大的帮助。\r\n\r\n母亲在私人的陶瓷厂上班，计件工资 一个月大概 3000-4000 。\r\n\r\n父亲在私人的煤气罐厂上班，一个月 4000 多。\r\n\r\n家里还有一个美术专业的妹妹上大四。\r\n\r\n\r\n结婚时家里给拿了 8 万，我拿了 10 万首付了一套 2 居（媳妇对这个房子也很不满意）。后面贷款每月 3000 左右一直是我在还。结婚后装修、家电我父母也没出过一分钱。因为他们要还结婚时的外债！\r\n\r\n生娃后也是婆媳矛盾不断 ，最终我俩独自带娃。之后媳妇和孩子没有回过我家。奶奶也自从孩子满月后没见到过孩子。\r\n\r\n媳妇没工作在家带娃，一直埋怨我爸妈不出钱不出力。要让我爸妈来还这个贷款。\r\n\r\n我自由职业，月入 2w+生活在三线城市也绰绰有余。我的想法是完全没有必要让父母出这个钱，但是媳妇说他们老了你管不管他们，说他们不给还这个贷款就让他们村里的房子也不要住了。\r\n\r\n怎么解决这个矛盾。", "content_rendered": "<p>本人男 28 岁。已婚。有个 1 岁多的孩子。</p>\n<p>出身农村，15 年考了个大专。上大学后学费生活费都是自己赚 ，父母没提供过什么大的帮助。</p>\n<p>母亲在私人的陶瓷厂上班，计件工资 一个月大概 3000-4000 。</p>\n<p>父亲在私人的煤气罐厂上班，一个月 4000 多。</p>\n<p>家里还有一个美术专业的妹妹上大四。</p>\n<p>结婚时家里给拿了 8 万，我拿了 10 万首付了一套 2 居（媳妇对这个房子也很不满意）。后面贷款每月 3000 左右一直是我在还。结婚后装修、家电我父母也没出过一分钱。因为他们要还结婚时的外债！</p>\n<p>生娃后也是婆媳矛盾不断 ，最终我俩独自带娃。之后媳妇和孩子没有回过我家。奶奶也自从孩子满月后没见到过孩子。</p>\n<p>媳妇没工作在家带娃，一直埋怨我爸妈不出钱不出力。要让我爸妈来还这个贷款。</p>\n<p>我自由职业，月入 2w+生活在三线城市也绰绰有余。我的想法是完全没有必要让父母出这个钱，但是媳妇说他们老了你管不管他们，说他们不给还这个贷款就让他们村里的房子也不要住了。</p>\n<p>怎么解决这个矛盾。</p>\n", "last_modified": 1776252779, "replies": 122, "id": 1206165}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_large.png?m=1630576706", "name": "invest", "avatar_normal": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_normal.png?m=1630576706", "title": "投资", "url": "https://www.v2ex.com/go/invest", "topics": 3471, "footer": "", "header": "Can you make money with money?", "title_alternative": "Invest", "avatar_mini": "https://cdn.v2ex.com/navatar/a4a0/42cf/171_mini.png?m=1630576706", "stars": 4339, "founder_id": 0, "aliases": [], "root": false, "id": 171, "parent_node_name": "money"}, "member": {"id": 582348, "username": "kerwin1874", "url": "https://www.v2ex.com/u/kerwin1874", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_mini.png?m=1748504239", "avatar_normal": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_normal.png?m=1748504239", "avatar_large": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_large.png?m=1748504239", "avatar_xlarge": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_xlarge.png?m=1748504239", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_xxlarge.png?m=1748504239", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/2904/7d7d/582348_xxxlarge.png?m=1748504239", "created": 1653144232, "last_modified": 1748504239, "pro": 0}, "last_reply_by": "r6cb", "last_touched": 1776333588, "title": "万把块钱搞什么投资（投机？）好呢", "url": "https://www.v2ex.com/t/1206257", "created": 1776304991, "deleted": 0, "content": "应届牛马干了大半年，有点存款放着，有什么投资渠道？\r\n\r\n现在就定投纳指，但是每天限额 10 块钱，大半年现在才总额 2k 不到，要换个渠道继续投吗？\r\n\r\n在想着是大 A 开户还是炒虚拟币现货，虚拟币之前玩过，合约害人一千块被插针爆仓了，倒也有个好处让我从此以后任何赌博都不碰了。", "content_rendered": "应届牛马干了大半年，有点存款放着，有什么投资渠道？<br /><br />现在就定投纳指，但是每天限额 10 块钱，大半年现在才总额 2k 不到，要换个渠道继续投吗？<br /><br />在想着是大 A 开户还是炒虚拟币现货，虚拟币之前玩过，合约害人一千块被插针爆仓了，倒也有个好处让我从此以后任何赌博都不碰了。", "last_modified": 1776304991, "replies": 77, "id": 1206257}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_large.png?m=1649080598", "name": "macos", "avatar_normal": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_normal.png?m=1649080598", "title": "macOS", "url": "https://www.v2ex.com/go/macos", "topics": 23787, "footer": "<a href=\"/mbp\">MacBook Pro</a> 及 <a href=\"/go/imac\">iMac</a> 等 <a href=\"/go/apple\">Apple</a> 公司设计的计算机所运行的操作系统。<a href=\"/go/idev\">iOS</a> 的基础。", "header": "The world’s most advanced desktop operating system.", "title_alternative": "macOS", "avatar_mini": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_mini.png?m=1649080598", "stars": 5462, "founder_id": 0, "aliases": [], "root": false, "id": 22, "parent_node_name": "os"}, "member": {"id": 559302, "username": "Bodo", "url": "https://www.v2ex.com/u/Bodo", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/af4b/2674/559302_mini.png?m=1770015830", "avatar_normal": "https://cdn.v2ex.com/avatar/af4b/2674/559302_normal.png?m=1770015830", "avatar_large": "https://cdn.v2ex.com/avatar/af4b/2674/559302_large.png?m=1770015830", "avatar_xlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xlarge.png?m=1770015830", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xxlarge.png?m=1770015830", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xxxlarge.png?m=1770015830", "created": 1634868462, "last_modified": 1770015830, "pro": 0}, "last_reply_by": "500", "last_touched": 1776332605, "title": "Gemini app, now on Mac", "url": "https://www.v2ex.com/t/1206235", "created": 1776300507, "deleted": 0, "content": "https://gemini.google/mac/\r\n\r\nhttps://i.imgur.com/wSQqk5L.jpeg", "content_rendered": "<a target=\"_blank\" href=\"https://gemini.google/mac/\" rel=\"nofollow noopener\">https://gemini.google/mac/</a><br /><br /><a target=\"_blank\" href=\"https://i.imgur.com/wSQqk5L.jpeg\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/wSQqk5L.jpeg\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1776300507, "replies": 67, "id": 1206235}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6b18/0037/1013_large.png?m=1699513459", "name": "jd", "avatar_normal": "https://cdn.v2ex.com/navatar/6b18/0037/1013_normal.png?m=1699513459", "title": "京东", "url": "https://www.v2ex.com/go/jd", "topics": 1976, "footer": "", "header": "关于使用 jd.com 过程中遇到的问题的讨论", "title_alternative": "京东", "avatar_mini": "https://cdn.v2ex.com/navatar/6b18/0037/1013_mini.png?m=1699513459", "stars": 226, "founder_id": 0, "aliases": [], "root": false, "id": 1013, "parent_node_name": "mmm"}, "member": {"id": 564073, "username": "shervy", "url": "https://www.v2ex.com/u/shervy", "website": "", "twitter": "", "psn": "", "github": "", "btc": "", "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/fed1/379e/564073_mini.png?m=1733107621", "avatar_normal": "https://cdn.v2ex.com/avatar/fed1/379e/564073_normal.png?m=1733107621", "avatar_large": "https://cdn.v2ex.com/avatar/fed1/379e/564073_large.png?m=1733107621", "avatar_xlarge": "https://cdn.v2ex.com/avatar/fed1/379e/564073_xlarge.png?m=1733107621", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/fed1/379e/564073_xxlarge.png?m=1733107621", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/fed1/379e/564073_xxxlarge.png?m=1733107621", "created": 1638491434, "last_modified": 1733107621, "pro": 0}, "last_reply_by": "Panic", "last_touched": 1776329205, "title": "京东家政 2 小时预约火爆，为什么", "url": "https://www.v2ex.com/t/1206231", "created": 1776298937, "deleted": 0, "content": "### 买的京东 Plus 送的 12 积分，5 积分换了京东家政 2 小时\r\n约的时间是近四天内，无论选系统推荐的时间或是其它任何时间均是预约火爆，\r\n我不死心，约 4 月 30 日系统推荐的时间总不火爆吧，很遗憾，依然是销售火爆。\r\n问 Plus 客服说让我换时间约或约系统推荐时间除此无它。\r\n\r\n### 烦请有经验的前辈指点怎么才能约上。\r\n\r\n\r\n![img]( https://im.gurl.eu.org/file/AgACAgEAAxkDAAEBfwxp4CsRE0qd-ckod7sI3eWySxAqfwAC2AtrG7AOAUcmAAGCPykGxUYBAAMCAAN3AAM7BA.png)\r\n\r\n![img]( https://im.gurl.eu.org/file/AgACAgEAAxkDAAEBfw1p4CtWWRYJt74MRZ0h4hqxuFkAAaQAAtkLaxuwDgFHVRrVVUo62QMBAAMCAAN3AAM7BA.png)", "content_rendered": "<h3>买的京东 Plus 送的 12 积分，5 积分换了京东家政 2 小时</h3>\n<p>约的时间是近四天内，无论选系统推荐的时间或是其它任何时间均是预约火爆，\n我不死心，约 4 月 30 日系统推荐的时间总不火爆吧，很遗憾，依然是销售火爆。\n问 Plus 客服说让我换时间约或约系统推荐时间除此无它。</p>\n<h3>烦请有经验的前辈指点怎么才能约上。</h3>\n<p><img alt=\"img\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://im.gurl.eu.org/file/AgACAgEAAxkDAAEBfwxp4CsRE0qd-ckod7sI3eWySxAqfwAC2AtrG7AOAUcmAAGCPykGxUYBAAMCAAN3AAM7BA.png\"/></p>\n<p><img alt=\"img\" class=\"embedded_image\" loading=\"lazy\" referrerpolicy=\"no-referrer\" rel=\"noreferrer\" src=\"https://im.gurl.eu.org/file/AgACAgEAAxkDAAEBfw1p4CtWWRYJt74MRZ0h4hqxuFkAAaQAAtkLaxuwDgFHVRrVVUo62QMBAAMCAAN3AAM7BA.png\"/></p>\n", "last_modified": 1776299711, "replies": 61, "id": 1206231}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10615, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2277, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 673126, "username": "linmilu", "url": "https://www.v2ex.com/u/linmilu", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/8aa42069250e843189ac24f087b981e1?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/8aa42069250e843189ac24f087b981e1?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/8aa42069250e843189ac24f087b981e1?s=73&d=retro", "created": 1706146351, "last_modified": 1776325709, "pro": 0}, "last_reply_by": "LancerXu", "last_touched": 1776333360, "title": "公司裁员，目前没有工作。想试试摆摊，做一个移动鲜啤打酒车", "url": "https://www.v2ex.com/t/1206375", "created": 1776326473, "deleted": 0, "content": "已经失业两个月了，一直按照之前的方向投简历，但基本没有回应。目前虽然还在领取失业金，但心里难免有些焦虑。\r\n\r\n最近观察到一个情况：我们楼下有一条街，晚上非常热闹，两边有不少烧烤、炒饭、鸭货、水果等摊位。我也特地问过商贩关于城管的问题，大家普遍反馈管理相对宽松。这条街快到尽头的位置还有一家规模不小的固定烧烤店，而且这里也是附近居民取快递的必经之路——因为周边小区门口没有驿站，大多数人都要去隔壁小区门口取件。\r\n\r\n观察了一段时间后发现，这条街上没有专门卖啤酒的摊位。\r\n\r\n所以我在想，如果投入大概 2 万元，做一个打酒的三轮车，在这里摆摊卖啤酒，这个思路是否可行？不过我之前没有任何摆摊经验，也不太清楚实际操作中会遇到哪些问题。\r\n\r\n有没有有经验的朋友，可以给点建议或者提醒一些容易踩的坑？不胜感激。\r\n大家针对这个想法，有没有什么建议或意见，小弟非常感谢\r\n\r\n大致就是图片中的样子\r\nhttps://i.imgur.com/5esNv11.png\r\nhttps://i.imgur.com/XVoWtGl.png", "content_rendered": "已经失业两个月了，一直按照之前的方向投简历，但基本没有回应。目前虽然还在领取失业金，但心里难免有些焦虑。<br /><br />最近观察到一个情况：我们楼下有一条街，晚上非常热闹，两边有不少烧烤、炒饭、鸭货、水果等摊位。我也特地问过商贩关于城管的问题，大家普遍反馈管理相对宽松。这条街快到尽头的位置还有一家规模不小的固定烧烤店，而且这里也是附近居民取快递的必经之路——因为周边小区门口没有驿站，大多数人都要去隔壁小区门口取件。<br /><br />观察了一段时间后发现，这条街上没有专门卖啤酒的摊位。<br /><br />所以我在想，如果投入大概 2 万元，做一个打酒的三轮车，在这里摆摊卖啤酒，这个思路是否可行？不过我之前没有任何摆摊经验，也不太清楚实际操作中会遇到哪些问题。<br /><br />有没有有经验的朋友，可以给点建议或者提醒一些容易踩的坑？不胜感激。<br />大家针对这个想法，有没有什么建议或意见，小弟非常感谢<br /><br />大致就是图片中的样子<br /><a target=\"_blank\" href=\"https://i.imgur.com/5esNv11.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/5esNv11.png\" class=\"embedded_image\" rel=\"noreferrer\"></a><br /><a target=\"_blank\" href=\"https://i.imgur.com/XVoWtGl.png\" rel=\"nofollow noopener\" target=\"_blank\"><img src=\"https://i.imgur.com/XVoWtGl.png\" class=\"embedded_image\" rel=\"noreferrer\"></a>", "last_modified": 1776326473, "replies": 59, "id": 1206375}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c6bf/f625/1101_large.png?m=1751736810", "name": "copilot", "avatar_normal": "https://cdn.v2ex.com/navatar/c6bf/f625/1101_normal.png?m=1751736810", "title": "GitHub Copilot", "url": "https://www.v2ex.com/go/copilot", "topics": 324, "footer": "", "header": "来自 GitHub 的基于 AI 的结对编程工具 <a href=\"https://copilot.