[{"node": {"avatar_large": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_large.png?m=1751718333", "name": "qna", "avatar_normal": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_normal.png?m=1751718333", "title": "问与答", "url": "https://www.v2ex.com/go/qna", "topics": 238193, "footer": "", "header": "<!--\r\n一个更好的世界需要你持续地提出好问题。\r\n-->", "title_alternative": "Questions and Answers", "avatar_mini": "https://cdn.v2ex.com/navatar/c20a/d4d7/12_mini.png?m=1751718333", "stars": 4481, "founder_id": 0, "aliases": [], "root": false, "id": 12, "parent_node_name": "v2ex"}, "member": {"id": 638855, "username": "mode171", "url": "https://www.v2ex.com/u/mode171", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "深圳", "tagline": "生活是一部电影； 死亡是一张照片。", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_mini.png?m=1766369444", "avatar_normal": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_normal.png?m=1766369444", "avatar_large": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_large.png?m=1766369444", "avatar_xlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xlarge.png?m=1766369444", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxlarge.png?m=1766369444", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/6c0f/b032/638855_xxxlarge.png?m=1766369444", "created": 1689515364, "last_modified": 1766369444, "pro": 0}, "last_reply_by": "usauk1998", "last_touched": 1776327489, "title": "有人说 [外包] 太难听了，很土，有没有什么别的、更好听的名称。", "url": "https://www.v2ex.com/t/1206278", "created": 1776308257, "deleted": 0, "content": "V 站外包大佬的数量，算是个人已知最多的站了。\r\n***\r\n外包这个名称有没有什么别的、更好听的名称。征求一下", "content_rendered": "<p>V 站外包大佬的数量，算是个人已知最多的站了。</p>\n<hr/>\n<p>外包这个名称有没有什么别的、更好听的名称。征求一下</p>\n", "last_modified": 1776308257, "replies": 169, "id": 1206278}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10613, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2277, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 673788, "username": "6866vpuu", "url": "https://www.v2ex.com/u/6866vpuu", "website": null, "twitter": null, "psn": null, "github": null, "btc": null, "location": null, "tagline": null, "bio": null, "avatar_mini": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/96724ca2b1f84c955efc3a818120f01b?s=73&d=retro", "created": 1706494270, "last_modified": 1758611434, "pro": 0}, "last_reply_by": "colincat", "last_touched": 1776326636, "title": "关于父母的托举", "url": "https://www.v2ex.com/t/1206165", "created": 1776252779, "deleted": 0, "content": "本人男 28 岁。已婚。有个 1 岁多的孩子。\r\n\r\n出身农村，15 年考了个大专。上大学后学费生活费都是自己赚 ，父母没提供过什么大的帮助。\r\n\r\n母亲在私人的陶瓷厂上班，计件工资 一个月大概 3000-4000 。\r\n\r\n父亲在私人的煤气罐厂上班，一个月 4000 多。\r\n\r\n家里还有一个美术专业的妹妹上大四。\r\n\r\n\r\n结婚时家里给拿了 8 万，我拿了 10 万首付了一套 2 居（媳妇对这个房子也很不满意）。后面贷款每月 3000 左右一直是我在还。结婚后装修、家电我父母也没出过一分钱。因为他们要还结婚时的外债！\r\n\r\n生娃后也是婆媳矛盾不断 ，最终我俩独自带娃。之后媳妇和孩子没有回过我家。奶奶也自从孩子满月后没见到过孩子。\r\n\r\n媳妇没工作在家带娃，一直埋怨我爸妈不出钱不出力。要让我爸妈来还这个贷款。\r\n\r\n我自由职业，月入 2w+生活在三线城市也绰绰有余。我的想法是完全没有必要让父母出这个钱，但是媳妇说他们老了你管不管他们，说他们不给还这个贷款就让他们村里的房子也不要住了。\r\n\r\n怎么解决这个矛盾。", "content_rendered": "<p>本人男 28 岁。已婚。有个 1 岁多的孩子。</p>\n<p>出身农村，15 年考了个大专。上大学后学费生活费都是自己赚 ，父母没提供过什么大的帮助。</p>\n<p>母亲在私人的陶瓷厂上班，计件工资 一个月大概 3000-4000 。</p>\n<p>父亲在私人的煤气罐厂上班，一个月 4000 多。</p>\n<p>家里还有一个美术专业的妹妹上大四。</p>\n<p>结婚时家里给拿了 8 万，我拿了 10 万首付了一套 2 居（媳妇对这个房子也很不满意）。后面贷款每月 3000 左右一直是我在还。结婚后装修、家电我父母也没出过一分钱。因为他们要还结婚时的外债！</p>\n<p>生娃后也是婆媳矛盾不断 ，最终我俩独自带娃。之后媳妇和孩子没有回过我家。奶奶也自从孩子满月后没见到过孩子。</p>\n<p>媳妇没工作在家带娃，一直埋怨我爸妈不出钱不出力。要让我爸妈来还这个贷款。</p>\n<p>我自由职业，月入 2w+生活在三线城市也绰绰有余。我的想法是完全没有必要让父母出这个钱，但是媳妇说他们老了你管不管他们，说他们不给还这个贷款就让他们村里的房子也不要住了。</p>\n<p>怎么解决这个矛盾。</p>\n", "last_modified": 1776252779, "replies": 114, "id": 1206165}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_large.png?m=1649080598", "name": "macos", "avatar_normal": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_normal.png?m=1649080598", "title": "macOS", "url": "https://www.v2ex.com/go/macos", "topics": 23787, "footer": "<a href=\"/mbp\">MacBook Pro</a> 及 <a href=\"/go/imac\">iMac</a> 等 <a href=\"/go/apple\">Apple</a> 公司设计的计算机所运行的操作系统。<a href=\"/go/idev\">iOS</a> 的基础。", "header": "The world’s most advanced desktop operating system.", "title_alternative": "macOS", "avatar_mini": "https://cdn.v2ex.com/navatar/b6d7/67d2/22_mini.png?m=1649080598", "stars": 5462, "founder_id": 0, "aliases": [], "root": false, "id": 22, "parent_node_name": "os"}, "member": {"id": 559302, "username": "Bodo", "url": "https://www.v2ex.com/u/Bodo", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/af4b/2674/559302_mini.png?m=1770015830", "avatar_normal": "https://cdn.v2ex.com/avatar/af4b/2674/559302_normal.png?m=1770015830", "avatar_large": "https://cdn.v2ex.com/avatar/af4b/2674/559302_large.png?m=1770015830", "avatar_xlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xlarge.png?m=1770015830", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xxlarge.png?m=1770015830", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/af4b/2674/559302_xxxlarge.png?m=1770015830", "created": 1634868462, "last_modified": 1770015830, "pro": 0}, "last_reply_by": "IM1T", "last_touched": 1776325634, "title": "Gemini app, now on Mac", "url": "https://www.v2ex.com/t/1206235", "created": 1776300507, "deleted": 0, "content": "https://gemini.google/mac/\r\n\r\nhttps://i.imgur.com/wSQqk5L.jpeg", "content_rendered": "<a target=\"_blank\" href=\"https://gemini.google/mac/\" rel=\"nofollow noopener\">http