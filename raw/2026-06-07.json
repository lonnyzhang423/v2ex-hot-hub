 "id": 1306, "parent_node_name": null}, "member": {"id": 620774, "username": "beasnail", "url": "https://www.v2ex.com/u/beasnail", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=73&d=retro", "created": 1679729308, "last_modified": 1679729308, "pro": 0}, "last_reply_by": "Tink", "last_touched": 1780799360, "title": "不相信灵魂转世", "url": "https://www.v2ex.com/t/1218447", "created": 1780743303, "deleted": 0, "content": "地球上累计已经死亡 1000 多亿人了，活人才是少数。如果真有灵魂，早就有数不清的案例了，事实上就是没有\r\n\r\n所以大概率不存在灵魂，死了就是没了\r\n\r\n如果你用佛学的观点解释，那么当代佛学大部分内容都是后人加的，原始佛教没那么多东西，可以去了解一下", "content_rendered": "<p>地球上累计已经死亡 1000 多亿人了，活人才是少数。如果真有灵魂，早就有数不清的案例了，事实上就是没有</p>\n<p>所以大概率不存在灵魂，死了就是没了</p>\n<p>如果你用佛学的观点解释，那么当代佛学大部分内容都是后人加的，原始佛教没那么多东西，可以去了解一下</p>\n", "last_modified": 1780750164, "replies": 46, "id": 1218447}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10994, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2346, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 243325, "username": "intoext", "url": "https://www.v2ex.com/u/intoext", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/16dc/e148/243325_mini.png?m=1688862810", "avatar_normal": "https://cdn.v2ex.com/avatar/16dc/e148/243325_normal.png