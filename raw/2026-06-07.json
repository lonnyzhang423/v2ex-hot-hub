[{"node": {"avatar_large": "/static/img/node_default_large.png", "name": "mysticism", "avatar_normal": "/static/img/node_default_normal.png", "title": "玄学", "url": "https://www.v2ex.com/go/mysticism", "topics": 6, "footer": "", "header": "", "title_alternative": "玄学", "avatar_mini": "/static/img/node_default_mini.png", "stars": 10, "founder_id": 148455, "aliases": [], "root": false, "id": 1306, "parent_node_name": null}, "member": {"id": 620774, "username": "beasnail", "url": "https://www.v2ex.com/u/beasnail", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=24&d=retro", "avatar_normal": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=48&d=retro", "avatar_large": "https://cdn.v2ex.com/gravatar/46a2efefcbeb6961a47dcf97d637e666?s=73&d=retro", "created": 1679729308, "last_modified": 1679729308, "pro": 0}, "last_reply_by": "Julaoshi", "last_touched": 1780815256, "title": "不相信灵魂转世", "url": "https://www.v2ex.com/t/1218447", "created": 1780743303, "deleted": 0, "content": "地球上累计已经死亡 1000 多亿人了，活人才是少数。如果真有灵魂，早就有数不清的案例了，事实上就是没有\r\n\r\n所以大概率不存在灵魂，死了就是没了\r\n\r\n如果你用佛学的观点解释，那么当代佛学大部分内容都是后人加的，原始佛教没那么多东西，可以去了解一下", "content_rendered": "<p>地球上累计已经死亡 1000 多亿人了，活人才是少数。如果真有灵魂，早就有数不清的案例了，事实上就是没有</p>\n<p>所以大概率不存在灵魂，死了就是没了</p>\n<p>如果你用佛学的观点解释，那么当代佛学大部分内容都是后人加的，原始佛教没那么多东西，可以去了解一下</p>\n", "last_modified": 1780750164, "replies": 61, "id": 1218447}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_large.png?m=1630643913", "name": "apple", "avatar_normal": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_normal.png?m=1630643913", "title": "Apple", "url": "https://www.v2ex.com/go/apple", "topics": 30677, "footer": "", "header": "设计了 <a href=\"/go/watch\">Apple Watch</a>，<a href=\"/go/ipad\">iPad</a>，<a href=\"/go/iphone\">iPhone</a>，<a href=\"/go/imac\">iMac</a> 及 <a href=\"/go/mbp\">MacBook Pro</a> 等电子产品的美国公司。", "title_alternative": "Apple", "avatar_mini": "https://cdn.v2ex.com/navatar/6cdd/60ea/184_mini.png?m=1630643913", "stars": 3317, "founder_id": 0, "aliases": [], "root": false, "id": 184, "parent_node_name": "hardware"}, "member": {"id": 567497, "username": "wweerrgtc", "url": "https://www.v2ex.com/u/wweerrgtc", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "location": "", "tagline": "", "bio": "", "avatar_mini": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_mini.png?m=1743038632", "avatar_normal": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_normal.png?m=1743038632", "avatar_large": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_large.png?m=1743038632", "avatar_xlarge": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_xlarge.png?m=1743038632", "avatar_xxlarge": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_xxlarge.png?m=1743038632", "avatar_xxxlarge": "https://cdn.v2ex.com/avatar/f6f1/a31e/567497_xxxlarge.png?m=1743038632", "created": 1640937593, "last_modified": 1743038632, "pro": 0}, "last_reply_by": "RyougiShiki", "last_touched": 1780814687, "title": "iPhone air 和 iPhone17 同价，都是 5000 元，你会选哪一个", "url": "https://www.v2ex.com/t/1218442", "created": 1780740991, "deleted": 0, "content": "", "content_rendered": "", "last_modified": 1780740991, "replies": 42, "id": 1218442}, {"node": {"avatar_large": "https://cdn.v2ex.com/navatar/6e27/13a6/557_large.png?m=1747623425", "name": "life", "avatar_normal": "https://cdn.v2ex.com/navatar/6e27/13a6/557_normal.png?m=1747623425", "title": "生活", "url": "https://www.v2ex.com/go/life", "topics": 10994, "footer": "", "header": "生活中的技术讨论", "title_alternative": "Life", "avatar_mini": "https://cdn.v2ex.com/navatar/6e27/13a6/557_mini.png?m=1747623425", "stars": 2346, "founder_id": 0, "aliases": [], "root": false, "id": 557, "parent_node_name": ""}, "member": {"id": 243325, "username": "intoext", "url": "https://www.v2ex.com/u/intoext", "website": "", "twitter": null, "psn": null, "github": null, "btc": null, "locatio